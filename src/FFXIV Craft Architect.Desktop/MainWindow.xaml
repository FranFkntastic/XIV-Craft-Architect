            BorderThickness="1"
            Visibility="{Binding ActivityDrawerVisibility}">
            <Grid RowSpacing="9">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Activity History" Foreground="{StaticResource DesktopGoldBrush}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding LatestActivitySummaryText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                    </StackPanel>
                    <Button AutomationProperties.AutomationId="ActivityDrawerCloseButton" Grid.Column="1" Padding="8,5" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding ToggleActivityDrawerCommand}">
                        <TextBlock Text="Close" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" />
                    </Button>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button AutomationProperties.AutomationId="ActivityFilterAllButton" Padding="8,4" CornerRadius="7" Background="{Binding ActivityAllFilterBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetActivityFilterCommand}" CommandParameter="All">
                            <TextBlock Text="All" Foreground="{StaticResource DesktopTextBrush}" FontSize="11" />
                        </Button>
                        <Button AutomationProperties.AutomationId="ActivityFilterSessionButton" Padding="8,4" CornerRadius="7" Background="{Binding ActivitySessionFilterBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetActivityFilterCommand}" CommandParameter="Session">
                            <TextBlock Text="Session" Foreground="{StaticResource DesktopTextBrush}" FontSize="11" />
                        </Button>
                        <Button AutomationProperties.AutomationId="ActivityFilterJobButton" Padding="8,4" CornerRadius="7" Background="{Binding ActivityJobFilterBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetActivityFilterCommand}" CommandParameter="Job">
                            <TextBlock Text="Jobs" Foreground="{StaticResource DesktopTextBrush}" FontSize="11" />
                        </Button>
                        <Button AutomationProperties.AutomationId="ActivityFilterCacheButton" Padding="8,4" CornerRadius="7" Background="{Binding ActivityCacheFilterBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetActivityFilterCommand}" CommandParameter="Cache">
                            <TextBlock Text="Cache" Foreground="{StaticResource DesktopTextBrush}" FontSize="11" />
                        </Button>
                        <Button AutomationProperties.AutomationId="ActivityFilterDesktopButton" Padding="8,4" CornerRadius="7" Background="{Binding ActivityDesktopFilterBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetActivityFilterCommand}" CommandParameter="Desktop">
                            <TextBlock Text="Desktop" Foreground="{StaticResource DesktopTextBrush}" FontSize="11" />
                        </Button>
                    </StackPanel>

                    <TextBlock AutomationProperties.AutomationId="ActivityFilterSummaryText" AutomationProperties.Name="{Binding ActivityFilterSummaryText}" Grid.Column="1" Text="{Binding ActivityFilterSummaryText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" VerticalAlignment="Center" />
                </Grid>

                <ListView
                    Grid.Row="2"
                    MaxHeight="138"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding FilteredActivityLog}"
                    SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" MinHeight="28" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="76" />
                                    <ColumnDefinition Width="78" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Kind}" Foreground="{StaticResource DesktopBlueBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding Message}" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid
            Grid.Row="4"
            Padding="12,0"
            BorderBrush="{StaticResource DesktopLineBrush}"
            BorderThickness="0,1,0,0"
            Background="{StaticResource DesktopBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock AutomationProperties.AutomationId="OperationStatusText" AutomationProperties.Name="{Binding OperationStatusText}" Text="{Binding OperationStatusText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" VerticalAlignment="Center" />

            <ProgressBar Grid.Column="1" Width="180" Height="7" Value="{Binding OperationProgressPercent}" Maximum="100" VerticalAlignment="Center" />

            <Button AutomationProperties.AutomationId="ActivityDrawerToggleButton" Grid.Column="2" Padding="10,4" Margin="14,0,0,0" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding ToggleActivityDrawerCommand}" VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="{Binding ActivityDrawerButtonText}" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" />
                    <TextBlock Text="{Binding LatestActivitySummaryText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" MaxWidth="280" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Window>
