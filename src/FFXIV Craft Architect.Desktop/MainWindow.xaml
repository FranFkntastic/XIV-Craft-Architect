<Window
    x:Class="FFXIV_Craft_Architect.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid
        x:Name="Root"
        MinWidth="1180"
        MinHeight="760"
        Background="{StaticResource DesktopBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="44" />
            <RowDefinition Height="46" />
            <RowDefinition Height="42" />
            <RowDefinition Height="*" />
            <RowDefinition Height="34" />
        </Grid.RowDefinitions>

        <Grid
            Grid.Row="0"
            Padding="14,0"
            BorderBrush="{StaticResource DesktopLineBrush}"
            BorderThickness="0,0,0,1"
            Background="{StaticResource DesktopBackgroundBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border
                    Width="24"
                    Height="24"
                    CornerRadius="7"
                    BorderBrush="{StaticResource DesktopGoldBrush}"
                    BorderThickness="1"
                    Background="#24211A">
                    <TextBlock
                        Text="CA"
                        Foreground="#E5C15D"
                        FontSize="11"
                        FontWeight="SemiBold"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center" />
                </Border>
                <TextBlock
                    Text="FFXIV Craft Architect Desktop"
                    Foreground="{StaticResource DesktopTextBrush}"
                    FontSize="15"
                    FontWeight="SemiBold"
                    VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="14" VerticalAlignment="Center">
                <TextBlock Text="{Binding PersistenceStatusText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding LocalSnapshotSummaryText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" VerticalAlignment="Center" />
                <Button AutomationProperties.AutomationId="SaveSnapshotButton" Padding="10,5" CornerRadius="7" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding SaveSnapshotCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="S" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <TextBlock Text="Save Snapshot" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" />
                </Button>
                <Button AutomationProperties.AutomationId="LoadLatestSnapshotButton" Padding="10,5" CornerRadius="7" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding LoadLatestSnapshotCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="O" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <TextBlock Text="Load Latest" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" />
                </Button>
                <Button AutomationProperties.AutomationId="SettingsButton" Padding="0" Background="Transparent" BorderThickness="0" Command="{Binding ShowSettingsCommand}">
                    <TextBlock Text="Settings" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />
                </Button>
                <Button AutomationProperties.AutomationId="DiagnosticsButton" Padding="0" Background="Transparent" BorderThickness="0" Command="{Binding ShowDiagnosticsCommand}">
                    <TextBlock Text="Diagnostics" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="1"
            Padding="14,0"
            BorderBrush="{StaticResource DesktopLineBrush}"
            BorderThickness="0,0,0,1"
            Background="{StaticResource DesktopBackgroundBrush}">
            <Grid.Resources>
                <SolidColorBrush x:Key="ButtonBackground" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBackgroundDisabled" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBorderBrush" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBorderBrushPressed" Color="Transparent" />
                <SolidColorBrush x:Key="ButtonBorderBrushDisabled" Color="Transparent" />
            </Grid.Resources>

            <StackPanel Orientation="Horizontal" Spacing="0" VerticalAlignment="Stretch">
                <Button AutomationProperties.AutomationId="RecipePlannerTabButton" Padding="0" Background="Transparent" BorderThickness="0" Command="{Binding ShowRecipePlannerCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Number1" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <Grid Width="160" Padding="8,0" Background="{Binding RecipePlannerTabBackground}">
                        <TextBlock Text="Recipe Planner" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="MarketAnalysisTabButton" Padding="0" Background="Transparent" BorderThickness="0" Command="{Binding ShowMarketAnalysisCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Number2" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <Grid Width="168" Padding="8,0" Background="{Binding MarketAnalysisTabBackground}">
                        <TextBlock Text="Market Analysis" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="AcquisitionEvaluationTabButton" Padding="0" Background="Transparent" BorderThickness="0" Command="{Binding ShowAcquisitionEvaluationCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Number3" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <Grid Width="196" Padding="8,0" Background="{Binding AcquisitionEvaluationTabBackground}">
                        <TextBlock Text="Acquisition Evaluation" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </Button>
                <Button AutomationProperties.AutomationId="ProcurementPlanTabButton" Padding="0" Background="Transparent" BorderThickness="0" Command="{Binding ShowProcurementPlanCommand}">
                    <Button.KeyboardAccelerators>
                        <KeyboardAccelerator Key="Number4" Modifiers="Control" />
                    </Button.KeyboardAccelerators>
                    <Grid Width="176" Padding="8,0" Background="{Binding ProcurementPlanTabBackground}">
                        <TextBlock Text="Procurement Plan" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </Grid>
                </Button>
            </StackPanel>
        </Grid>

        <Grid
            Grid.Row="2"
            Padding="14,0"
            BorderBrush="{StaticResource DesktopLineSoftBrush}"
            BorderThickness="0,0,0,1"
            Background="#202020">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="Plan" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" VerticalAlignment="Center" />
                <TextBlock Text="{Binding PlanName}" Foreground="{StaticResource DesktopTextBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SelectedDataCenter}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" VerticalAlignment="Center" />
                <TextBlock Text="{Binding SelectedWorld}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" VerticalAlignment="Center" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="{Binding MarketStatusText}" Foreground="#90EE90" FontSize="12" />
                <TextBlock Text="{Binding LocalIntegrationStatusText}" Foreground="#D7E8F8" FontSize="12" />
                <TextBlock Text="{Binding JobsStatusText}" Foreground="#E5C15D" FontSize="12" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="3" ColumnSpacing="1" Background="{StaticResource DesktopLineBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="{Binding LeftPaneWidth}" MinWidth="{Binding LeftPaneMinWidth}" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="{Binding RightPaneWidth}" MinWidth="{Binding RightPaneMinWidth}" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="{StaticResource DesktopPanelBrush}" Visibility="{Binding LeftPaneVisibility}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="58" />
                    <RowDefinition Height="260" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Padding="14,10" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="Project Items" Foreground="{StaticResource DesktopTextBrush}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding PlanGraphSummary}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" Margin="0,2,0,0" />
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1" Padding="14,10" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="0,0,0,1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <TextBlock Text="Plan Builder" Foreground="{StaticResource DesktopGoldBrush}" FontSize="13" FontWeight="SemiBold" />

                    <AutoSuggestBox
                        Grid.Row="1"
                        x:Name="TargetSearchBox"
                        AutomationProperties.AutomationId="TargetSearchBox"
                        Text="{Binding NewItemName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        ItemsSource="{Binding SearchResults}"
                        PlaceholderText="Item name"
                        MinWidth="0"
                        HorizontalAlignment="Stretch"
                        Margin="0,11,0,0"
                        RequestedTheme="Dark"
                        Background="{StaticResource DesktopBackgroundBrush}"
                        Foreground="{StaticResource DesktopTextBrush}"
                        BorderBrush="{StaticResource DesktopLineSoftBrush}"
                        QuerySubmitted="TargetSearchBox_QuerySubmitted"
                        SuggestionChosen="TargetSearchBox_SuggestionChosen">
                        <AutoSuggestBox.Resources>
                            <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBackground" Color="{StaticResource DesktopPanelRaisedColor}" />
                            <SolidColorBrush x:Key="AutoSuggestBoxSuggestionsListBorderBrush" Color="{StaticResource DesktopGoldColor}" />
                            <SolidColorBrush x:Key="TextControlBackground" Color="{StaticResource DesktopBackgroundColor}" />
                            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{StaticResource DesktopPanelRaisedColor}" />
                            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{StaticResource DesktopBackgroundColor}" />
                            <SolidColorBrush x:Key="TextControlForeground" Color="{StaticResource DesktopTextColor}" />
                            <SolidColorBrush x:Key="TextControlForegroundPointerOver" Color="{StaticResource DesktopTextColor}" />
                            <SolidColorBrush x:Key="TextControlForegroundFocused" Color="{StaticResource DesktopTextColor}" />
                            <SolidColorBrush x:Key="TextControlPlaceholderForeground" Color="{StaticResource DesktopTextDimColor}" />
                            <SolidColorBrush x:Key="TextControlBorderBrush" Color="{StaticResource DesktopLineSoftColor}" />
                            <SolidColorBrush x:Key="TextControlBorderBrushPointerOver" Color="{StaticResource DesktopGoldColor}" />
                            <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="{StaticResource DesktopGoldColor}" />
                            <SolidColorBrush x:Key="ListViewItemBackground" Color="Transparent" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundPointerOver" Color="{StaticResource DesktopAmberDarkColor}" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelected" Color="{StaticResource DesktopAmberDarkColor}" />
                            <SolidColorBrush x:Key="ListViewItemBackgroundSelectedPointerOver" Color="{StaticResource DesktopPanelSoftColor}" />
                            <SolidColorBrush x:Key="ListViewItemForeground" Color="{StaticResource DesktopTextColor}" />
                            <SolidColorBrush x:Key="ListViewItemForegroundPointerOver" Color="{StaticResource DesktopTextColor}" />
                            <SolidColorBrush x:Key="ListViewItemForegroundSelected" Color="{StaticResource DesktopTextColor}" />
                            <SolidColorBrush x:Key="ListViewItemForegroundSelectedPointerOver" Color="{StaticResource DesktopTextColor}" />
                        </AutoSuggestBox.Resources>
                        <AutoSuggestBox.ItemTemplate>
                            <DataTemplate>
                                <Grid RowSpacing="2" MinHeight="40" Padding="4,3">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" />
                                    <TextBlock Grid.Row="1" Text="{Binding MetadataText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                                </Grid>
                            </DataTemplate>
                        </AutoSuggestBox.ItemTemplate>
                    </AutoSuggestBox>

                    <Grid Grid.Row="2" ColumnSpacing="6" Margin="0,7,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="78" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBox
                            Grid.Column="0"
                            Text="{Binding NewItemQuantityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            PlaceholderText="Qty"
                            Background="{StaticResource DesktopBackgroundBrush}"
                            Foreground="{StaticResource DesktopTextBrush}"
                            BorderBrush="{StaticResource DesktopLineSoftBrush}" />
                        <CheckBox
                            Grid.Column="1"
                            Content="HQ"
                            MinWidth="0"
                            Padding="0"
                            Margin="2,0"
                            VerticalAlignment="Center"
                            IsChecked="{Binding NewItemMustBeHq, Mode=TwoWay}"
                            Foreground="{StaticResource DesktopTextMutedBrush}" />
                        <Button AutomationProperties.AutomationId="SearchProjectItemsButton" Grid.Column="2" HorizontalAlignment="Stretch" Padding="10,7" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SearchProjectItemsCommand}">
                            <TextBlock Text="Search" Foreground="{StaticResource DesktopTextBrush}" />
                        </Button>
                    </Grid>

                    <TextBlock
                        AutomationProperties.AutomationId="TargetSearchStatusText"
                        AutomationProperties.Name="{Binding TargetSearchStatusText}"
                        Grid.Row="3"
                        Text="{Binding TargetSearchStatusText}"
                        Visibility="{Binding TargetSearchStatusVisibility}"
                        Foreground="{StaticResource DesktopTextDimBrush}"
                        FontSize="11"
                        TextWrapping="Wrap"
                        Margin="0,7,0,0" />

                    <Grid Grid.Row="4" ColumnSpacing="6" Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button AutomationProperties.AutomationId="AddTargetButton" HorizontalAlignment="Stretch" Padding="10,7" CornerRadius="7" Background="{StaticResource DesktopGoldBrush}" Command="{Binding AddTargetItemCommand}">
                            <TextBlock Text="Add Target" Foreground="#181612" FontWeight="SemiBold" />
                        </Button>
                    </Grid>
                </Grid>

                <ListView
                    Grid.Row="2"
                    Padding="10"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding TargetItems}"
                    SelectedItem="{Binding SelectedPlanItem, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="8" MinHeight="42" Margin="0,2" Padding="2,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}" Foreground="{StaticResource DesktopTextBrush}" FontSize="13" />
                                    <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,2,0,0">
                                        <TextBlock Text="{Binding Role}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" />
                                        <TextBlock Text="{Binding SourceText}" Foreground="{StaticResource DesktopBlueBrush}" FontSize="11" />
                                    </StackPanel>
                                </StackPanel>
                                <TextBlock Grid.Column="1" Text="{Binding CostText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,1,8,0" />
                                <TextBlock Grid.Column="2" Text="{Binding QuantityText}" Foreground="{StaticResource DesktopGoldBrush}" FontSize="13" HorizontalAlignment="Right" VerticalAlignment="Top" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" Padding="16,12" Background="#1F1F1F">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock AutomationProperties.AutomationId="WorkbenchTitleText" AutomationProperties.Name="{Binding WorkbenchTitle}" Text="{Binding WorkbenchTitle}" Foreground="{StaticResource DesktopTextBrush}" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WorkbenchSummary}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" Margin="0,3,0,0" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                        <Button AutomationProperties.AutomationId="DecreaseSelectedQuantityButton" Padding="9,6" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding DecreaseSelectedQuantityCommand}" Visibility="{Binding PlanEditActionVisibility}">
                            <TextBlock Text="-100" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" />
                        </Button>
                        <Button AutomationProperties.AutomationId="IncreaseSelectedQuantityButton" Padding="9,6" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding IncreaseSelectedQuantityCommand}" Visibility="{Binding PlanEditActionVisibility}">
                            <TextBlock Text="+100" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" />
                        </Button>
                        <Button AutomationProperties.AutomationId="ToggleSelectedHqButton" Padding="9,6" CornerRadius="7" Background="{StaticResource DesktopAmberDarkBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding ToggleSelectedHqCommand}" Visibility="{Binding PlanEditActionVisibility}">
                            <TextBlock Text="HQ" Foreground="{StaticResource DesktopGoldBrush}" FontSize="12" FontWeight="SemiBold" />
                        </Button>
                        <Button AutomationProperties.AutomationId="RemoveSelectedTargetButton" Padding="9,6" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding RemoveSelectedTargetCommand}" Visibility="{Binding PlanEditActionVisibility}">
                            <TextBlock Text="Remove" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" />
                        </Button>
                        <Button AutomationProperties.AutomationId="PrimaryActionButton" Padding="12,7" CornerRadius="7" Background="{StaticResource DesktopGoldBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding RunPrimaryActionCommand}">
                            <Button.KeyboardAccelerators>
                                <KeyboardAccelerator Key="Enter" Modifiers="Control" />
                            </Button.KeyboardAccelerators>
                            <TextBlock Text="{Binding PrimaryActionText}" Foreground="#181612" FontSize="12" FontWeight="SemiBold" />
                        </Button>
                    </StackPanel>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid Visibility="{Binding RecipePlannerPanelVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Recipe Plan" Foreground="{StaticResource DesktopGoldBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />

                        <ListView
                            Grid.Row="1"
                            Background="Transparent"
                            BorderThickness="0"
                            ItemsSource="{Binding PlanItems}"
                            SelectedItem="{Binding SelectedPlanItem, Mode=TwoWay}"
                            SelectionMode="Single"
                            Visibility="{Binding RecipePlanRowsVisibility}">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" MinHeight="34" Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="2*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding DisplayName}" Foreground="{StaticResource DesktopTextBrush}" FontSize="13" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{Binding Role}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{Binding SourceText}" Foreground="{StaticResource DesktopBlueBrush}" FontSize="12" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{Binding CostText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,10,0" />
                                        <TextBlock Grid.Column="4" Text="{Binding QuantityText}" Foreground="{StaticResource DesktopGoldBrush}" FontSize="13" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <Grid Grid.Row="1" Visibility="{Binding RecipePlanEmptyVisibility}">
                            <TextBlock
                                Text="{Binding RecipePlanEmptyText}"
                                Foreground="{StaticResource DesktopTextDimBrush}"
                                FontSize="13"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                TextWrapping="Wrap" />
                        </Grid>

                        <Grid Grid.Row="2" Padding="0,12,0,0" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="0,1,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding PlanGraphSummary}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="12" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Padding="10,6" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding SaveSnapshotCommand}">
                                <TextBlock Text="Save Plan Snapshot" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" />
                            </Button>
                        </Grid>
                    </Grid>

                    <Grid Visibility="{Binding MarketAnalysisPanelVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0">
                            <TextBlock Text="Market Evidence" Foreground="{StaticResource DesktopGoldBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </Grid>

                        <Grid Grid.Row="1" Padding="0,8,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Item" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />
                            <TextBlock Grid.Row="0" Grid.Column="1" Text="Need" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />
                            <TextBlock Grid.Row="0" Grid.Column="2" Text="Source" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />
                            <TextBlock Grid.Row="0" Grid.Column="3" Text="Estimate" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />
                            <TextBlock Grid.Row="0" Grid.Column="4" Text="Trust" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" />

                            <ListView
                                Grid.Row="1"
                                Grid.ColumnSpan="5"
                                Background="Transparent"
                                BorderThickness="0"
                                ItemsSource="{Binding MarketQueue}"
                                SelectedItem="{Binding SelectedMarketQueueItem, Mode=TwoWay}"
                                SelectionMode="Single">
                                <ListView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnSpacing="8" MinHeight="28" Margin="0,3">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding ItemName}" Foreground="{StaticResource DesktopTextBrush}" FontSize="13" />
                                            <TextBlock Grid.Column="1" Text="{Binding NeedText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="13" />
                                            <TextBlock Grid.Column="2" Text="{Binding SourceText}" Foreground="#D7E8F8" FontSize="13" />
                                            <TextBlock Grid.Column="3" Text="{Binding CostText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="13" />
                                            <TextBlock Grid.Column="4" Text="{Binding TrustText}" Foreground="{StaticResource DesktopGoldBrush}" FontSize="13" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>

                    <Grid Visibility="{Binding AcquisitionEvaluationPanelVisibility}">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="34" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Acquisition Evaluation" Foreground="{StaticResource DesktopGoldBrush}" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
                        <TextBlock Grid.Row="1" Text="{Binding InspectorItemName}" Foreground="{StaticResource DesktopTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                        <TextBlock Grid.Row="2" Text="{Binding InspectorItemDetail}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="13" Margin="0,4,0,12" />
                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Padding="11,7" CornerRadius="7" Background="{Binding CraftSourceOptionBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetSelectedSourceToCraftCommand}" Visibility="{Binding CraftSourceOptionVisibility}">
                                    <TextBlock Text="Craft" Foreground="{StaticResource DesktopTextBrush}" FontWeight="SemiBold" />
                                </Button>
                                <Button Padding="11,7" CornerRadius="7" Background="{Binding MarketNqSourceOptionBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetSelectedSourceToMarketNqCommand}" Visibility="{Binding MarketNqSourceOptionVisibility}">
                                    <TextBlock Text="Buy NQ" Foreground="{StaticResource DesktopTextBrush}" FontWeight="SemiBold" />
                                </Button>
                                <Button Padding="11,7" CornerRadius="7" Background="{Binding MarketHqSourceOptionBackground}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1" Command="{Binding SetSelectedSourceToMarketHqCommand}" Visibility="{Binding MarketHqSourceOptionVisibility}">
