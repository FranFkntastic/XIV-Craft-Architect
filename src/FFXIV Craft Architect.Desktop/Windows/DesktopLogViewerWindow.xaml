<Window
    x:Class="FFXIV_Craft_Architect.Desktop.Windows.DesktopLogViewerWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid
        x:Name="Root"
        Background="{StaticResource DesktopBackgroundBrush}"
        RowSpacing="1">
        <Grid.RowDefinitions>
            <RowDefinition Height="52" />
            <RowDefinition Height="*" />
            <RowDefinition Height="30" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Padding="14,9" Background="{StaticResource DesktopPanelBrush}" BorderBrush="{StaticResource DesktopLineBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Border Width="26" Height="26" CornerRadius="6" Background="{StaticResource DesktopAmberDarkBrush}" BorderBrush="{StaticResource DesktopGoldBrush}" BorderThickness="1">
                    <TextBlock Text="LOG" Foreground="{StaticResource DesktopGoldBrush}" FontSize="9" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="Diagnostic Log Viewer" Foreground="{StaticResource DesktopTextBrush}" FontSize="15" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding EntryCountText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="11" />
                </StackPanel>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button AutomationProperties.AutomationId="LogViewerOpenDifferentLogButton" Padding="10,7" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding OpenDifferentLogCommand}">
                    <TextBlock Text="Open Log..." Foreground="{StaticResource DesktopTextBrush}" />
                </Button>
                <Button AutomationProperties.AutomationId="LogViewerRefreshButton" Padding="10,7" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding RefreshLogFilesCommand}">
                    <TextBlock Text="Refresh" Foreground="{StaticResource DesktopTextBrush}" />
                </Button>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="1" Background="{StaticResource DesktopLineBrush}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="320" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Padding="14,12" Background="{StaticResource DesktopPanelBrush}" RowSpacing="9">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Text="Log Files" Foreground="{StaticResource DesktopGoldBrush}" FontSize="13" FontWeight="SemiBold" />
                <TextBlock
                    Grid.Row="1"
                    Text="{Binding SelectedFilePathText}"
                    Foreground="{StaticResource DesktopTextDimBrush}"
                    FontSize="11"
                    TextWrapping="WrapWholeWords">
                    <TextBlock.ContextFlyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="Open" Command="{Binding OpenSelectedLogFileCommand}" />
                            <MenuFlyoutItem Text="Open With..." Command="{Binding OpenSelectedLogFileWithCommand}" />
                            <MenuFlyoutItem Text="Reveal In Explorer" Command="{Binding RevealSelectedLogFileCommand}" />
                        </MenuFlyout>
                    </TextBlock.ContextFlyout>
                </TextBlock>

                <ListView
                    Grid.Row="2"
                    AutomationProperties.AutomationId="LogViewerFileList"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding LogFiles}"
                    SelectedItem="{Binding SelectedLogFile, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid MinHeight="46" RowSpacing="3">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="{Binding FileName}" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                <TextBlock Grid.Row="1" Text="{Binding MetadataText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="10" TextTrimming="CharacterEllipsis" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>

            <Grid Grid.Column="1" Padding="14,12" Background="{StaticResource DesktopBackgroundBrush}" RowSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="190" />
                </Grid.RowDefinitions>

                <Grid ColumnSpacing="9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="260" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <TextBox
                        AutomationProperties.AutomationId="LogViewerSearchTextBox"
                        Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                        PlaceholderText="Search logs..."
                        Background="{StaticResource DesktopPanelBrush}"
                        Foreground="{StaticResource DesktopTextBrush}"
                        BorderBrush="{StaticResource DesktopLineSoftBrush}" />

                    <ComboBox
                        Grid.Column="1"
                        AutomationProperties.AutomationId="LogViewerLevelFilter"
                        ItemsSource="{Binding LevelFilters}"
                        SelectedItem="{Binding SelectedLevelFilter, Mode=TwoWay}"
                        Background="{StaticResource DesktopPanelBrush}"
                        Foreground="{StaticResource DesktopTextBrush}"
                        BorderBrush="{StaticResource DesktopLineSoftBrush}" />

                    <ComboBox
                        Grid.Column="2"
                        AutomationProperties.AutomationId="LogViewerCategoryFilter"
                        ItemsSource="{Binding CategoryFilters}"
                        SelectedItem="{Binding SelectedCategoryFilter, Mode=TwoWay}"
                        Background="{StaticResource DesktopPanelBrush}"
                        Foreground="{StaticResource DesktopTextBrush}"
                        BorderBrush="{StaticResource DesktopLineSoftBrush}" />

                    <Button Grid.Column="3" Padding="10,7" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding ClearFiltersCommand}">
                        <TextBlock Text="Clear" Foreground="{StaticResource DesktopTextBrush}" />
                    </Button>

                    <Button Grid.Column="4" Padding="10,7" CornerRadius="7" Background="{StaticResource DesktopPanelSoftBrush}" Command="{Binding CopySelectedLogEntryCommand}">
                        <TextBlock Text="Copy Entry" Foreground="{StaticResource DesktopTextBrush}" />
                    </Button>
                </Grid>

                <ListView
                    Grid.Row="1"
                    AutomationProperties.AutomationId="LogViewerEntriesList"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemsSource="{Binding FilteredEntries}"
                    SelectedItem="{Binding SelectedLogEntry, Mode=TwoWay}"
                    SelectionMode="Single">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid ColumnSpacing="10" MinHeight="34" Margin="0,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="82" />
                                    <ColumnDefinition Width="84" />
                                    <ColumnDefinition Width="210" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{Binding TimeText}" Foreground="{StaticResource DesktopTextMutedBrush}" FontSize="11" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="1" Text="{Binding Level}" Foreground="{StaticResource DesktopGoldBrush}" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="2" Text="{Binding CategoryText}" Foreground="{StaticResource DesktopBlueBrush}" FontSize="11" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="3" Text="{Binding SummaryText}" Foreground="{StaticResource DesktopTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <Border Grid.Row="2" Padding="12,10" CornerRadius="8" Background="{StaticResource DesktopPanelBrush}" BorderBrush="{StaticResource DesktopLineSoftBrush}" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                        <TextBlock
                            Text="{Binding SelectedLogEntry.CopyText}"
                            Foreground="{StaticResource DesktopTextMutedBrush}"
                            FontFamily="Consolas"
                            FontSize="12"
                            TextWrapping="NoWrap" />
                    </ScrollViewer>
                </Border>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Padding="12,0" Background="{StaticResource DesktopPanelBrush}" BorderBrush="{StaticResource DesktopLineBrush}" BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding ViewerStatusText}" Foreground="{StaticResource DesktopTextDimBrush}" FontSize="12" VerticalAlignment="Center" TextTrimming="CharacterEllipsis" />
        </Grid>
    </Grid>
</Window>
