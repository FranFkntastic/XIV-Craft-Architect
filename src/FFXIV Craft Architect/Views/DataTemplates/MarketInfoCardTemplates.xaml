<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:vm="clr-namespace:FFXIV_Craft_Architect.ViewModels">

    <DataTemplate DataType="{x:Type vm:MarketInfoCardViewModel}">
        <Border CornerRadius="4"
                Padding="12"
                Margin="0,0,0,8"
                BorderThickness="1">
            <Border.Style>
                <Style TargetType="Border">
                    <Setter Property="Background" Value="{StaticResource Brush.Surface.Card}"/>
                    <Setter Property="BorderBrush" Value="{StaticResource Brush.Border.Default}"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:MarketInfoCardKind.Vendor}">
                            <Setter Property="Background" Value="{StaticResource Brush.Surface.Card.Vendor}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:MarketInfoCardKind.Cached}">
                            <Setter Property="Background" Value="{StaticResource Brush.Surface.Card.Placeholder}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:MarketInfoCardKind.Untradeable}">
                            <Setter Property="Background" Value="{StaticResource Brush.Surface.Card.Untradeable}"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Kind}" Value="{x:Static vm:MarketInfoCardKind.Error}">
                            <Setter Property="Background" Value="{StaticResource Brush.Surface.Card.Error}"/>
                            <Setter Property="BorderBrush" Value="{StaticResource Brush.Status.Error}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <StackPanel>
                <TextBlock Text="{Binding Title}"
                           FontWeight="SemiBold"
                           FontSize="14"
                           Foreground="{StaticResource Brush.Text.Primary}"/>
                <TextBlock Text="{Binding Content}"
                           Margin="0,8,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource Brush.Text.Secondary}"/>
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
