<Window x:Class="FFXIV_Craft_Architect.Views.ArtisanImportWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="Import from Artisan"
        Width="550"
        Height="500"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource WindowBackgroundBrush}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <TextBlock Grid.Row="0"
                   Text="Import from Artisan"
                   FontSize="20"
                   FontWeight="Bold"
                   Margin="0,0,0,8"/>
        
        <TextBlock Grid.Row="1"
                   Text="Paste your Artisan JSON export below. In Artisan, use 'Export List' then paste here."
                   Foreground="Gray"
                   Margin="0,0,0,16"
                   TextWrapping="Wrap"/>

        <!-- JSON Input -->
        <Border Grid.Row="2"
                Background="{StaticResource CardBackgroundBrush}"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                
                <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="Artisan JSON"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text=" (paste from clipboard)"
                               Foreground="Gray"
                               FontSize="11"
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <TextBox Grid.Row="1"
                         x:Name="JsonTextBox"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Background="Transparent"
                         BorderThickness="1"
                         Padding="8"
                         FontFamily="Consolas"
                         FontSize="11"/>
            </Grid>
        </Border>

        <!-- Detected Items Preview -->
        <Border Grid.Row="3"
                Background="{StaticResource PanelBackgroundBrush}"
                CornerRadius="4"
                Padding="8"
                Margin="0,0,0,8"
                x:Name="PreviewPanel"
                Visibility="Collapsed">
            <StackPanel>
                <TextBlock Text="Detected Items:"
                           FontWeight="SemiBold"
                           FontSize="11"
                           Foreground="Gray"
                           Margin="0,0,0,4"/>
                <TextBlock x:Name="PreviewText"
                           FontSize="11"
                           Foreground="{StaticResource LightGreenBrush}"
                           TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="4" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <ui:Button Grid.Column="0"
                       Content="Paste from Clipboard"
                       Appearance="Secondary"
                       Click="OnPasteFromClipboard"
                       Margin="0,0,8,0"/>
            
            <TextBlock Grid.Column="1"
                       x:Name="StatusText"
                       Text=""
                       Foreground="Gray"
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"/>
            
            <ui:Button Grid.Column="2"
                       Content="Cancel"
                       Appearance="Secondary"
                       Click="OnCancel"/>
            
            <ui:Button Grid.Column="4"
                       Content="Import"
                       Appearance="Primary"
                       Click="OnImport"
                       x:Name="ImportButton"/>
        </Grid>
    </Grid>
</Window>
