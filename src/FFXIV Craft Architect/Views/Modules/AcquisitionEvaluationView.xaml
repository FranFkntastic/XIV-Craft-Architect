<UserControl x:Class="FFXIV_Craft_Architect.Views.Modules.AcquisitionEvaluationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border x:Name="AcquisitionEvaluationContent"
            Background="Transparent"
            Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Acquisition Evaluation"
                       FontSize="20"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,12"/>

            <Border Grid.Row="1"
                    Background="{StaticResource PanelBackgroundBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="280"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Decision Ledger"
                               FontSize="14"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentGoldBrush}"
                               Margin="0,0,0,12"/>

                    <ListView Grid.Row="1"
                              Grid.Column="0"
                              x:Name="AcquisitionRowsList"
                              ItemsSource="{Binding DataContext.AcquisitionEvaluation.Rows, RelativeSource={RelativeSource AncestorType=Window}}"
                              SelectedItem="{Binding DataContext.AcquisitionEvaluation.SelectedRow, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                              Background="Transparent"
                              BorderThickness="0">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Item"
                                                Width="220"
                                                DisplayMemberBinding="{Binding ItemName}"/>
                                <GridViewColumn Header="Source"
                                                Width="180">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <ComboBox ItemsSource="{Binding SourceOptions}"
                                                      DisplayMemberPath="DisplayName"
                                                      SelectedValuePath="Source"
                                                      SelectedValue="{Binding SelectedSource, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding CanChangeSource}"
                                                      MinWidth="150"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="HQ"
                                                Width="56">
                                    <GridViewColumn.CellTemplate>
                                        <DataTemplate>
                                            <CheckBox IsChecked="{Binding IsMarketHq, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                      IsEnabled="{Binding CanChangeMarketHq}"
                                                      HorizontalAlignment="Center"/>
                                        </DataTemplate>
                                    </GridViewColumn.CellTemplate>
                                </GridViewColumn>
                                <GridViewColumn Header="Need"
                                                Width="120"
                                                DisplayMemberBinding="{Binding QuantityDisplay}"/>
                                <GridViewColumn Header="Market"
                                                Width="180"
                                                DisplayMemberBinding="{Binding MarketEvidence}"/>
                                <GridViewColumn Header="Estimate"
                                                Width="120"
                                                DisplayMemberBinding="{Binding EstimatedCost}"/>
                                <GridViewColumn Header="Status"
                                                Width="140"
                                                DisplayMemberBinding="{Binding Status}"/>
                            </GridView>
                        </ListView.View>
                    </ListView>

                    <Border Grid.Row="1"
                            Grid.Column="1"
                            Margin="16,0,0,0"
                            Padding="12"
                            Background="{StaticResource SurfaceBrush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="6">
                        <StackPanel DataContext="{Binding DataContext.AcquisitionEvaluation.SelectedRow, RelativeSource={RelativeSource AncestorType=Window}}">
                            <TextBlock Text="Acquisition Details"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGoldBrush}"
                                       Margin="0,0,0,10"/>
                            <TextBlock Text="{Binding ItemName, TargetNullValue=Select an item}"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextWrapping="Wrap"/>
                            <TextBlock Text="{Binding QuantityDisplay}"
                                       FontSize="11"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,10"/>
                            <TextBlock Text="{Binding SourceDisplay}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,12"/>
                            <TextBlock Text="Acquisition Options"
                                       FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ItemsControl ItemsSource="{Binding OptionRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderThickness="0,0,0,1"
                                                Padding="0,6">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsProjectedUnsupported}" Value="True">
                                                            <Setter Property="Background" Value="#2b1717"/>
                                                            <Setter Property="BorderBrush" Value="#8a4038"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="12"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Detail}"
                                                               FontSize="11"
                                                               Foreground="{StaticResource TextSecondaryBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding CostText}"
                                                           FontSize="12"
                                                           Margin="10,0,0,0"
                                                           VerticalAlignment="Top">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentGoldBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsProjectedUnsupported}" Value="True">
                                                                    <Setter Property="Foreground" Value="#ff6b6b"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
