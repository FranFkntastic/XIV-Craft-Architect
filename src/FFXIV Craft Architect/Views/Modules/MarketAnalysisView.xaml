<UserControl x:Class="FFXIV_Craft_Architect.Views.Modules.MarketAnalysisView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Border x:Name="MarketAnalysisContent"
            Background="Transparent"
            Padding="8"
            Visibility="Collapsed">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0"
                        Orientation="Horizontal"
                        Margin="0,0,0,8">
                <TextBlock Text="Market Analysis"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource Brush.Accent.Primary}"
                           VerticalAlignment="Center"/>
            </StackPanel>

            <Border Grid.Row="1"
                    Background="{StaticResource Brush.Surface.Card}"
                    CornerRadius="4"
                    Padding="8">
                <Grid x:Name="SplitPaneMarketView">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="{Binding DataContext.MarketAnalysis.TopPaneHeight, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Top Pane Container -->
                    <Border Grid.Row="0"
                            x:Name="TopPaneContainer"
                            Background="{StaticResource PanelBackgroundBrush}"
                            CornerRadius="4"
                            ClipToBounds="True">
                        <Grid>
                            <!-- Strip Mode (shown when no selection) -->
                            <Border Height="34"
                                    Background="{StaticResource CardBackgroundAltBrush}"
                                    BorderBrush="{StaticResource Brush.Border.Default}"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="10,6">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.MarketAnalysis.IsStripMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <DockPanel LastChildFill="True">
                                    <TextBlock DockPanel.Dock="Left"
                                               Text="Summary"
                                               FontSize="11"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Select a market card below to expand details"
                                               FontSize="10"
                                               Foreground="{StaticResource GrayBrush}"
                                               VerticalAlignment="Center"
                                               Margin="12,0,0,0"/>
                                </DockPanel>
                            </Border>

                            <!-- Expanded Mode (shown when selection exists) -->
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <ScrollViewer.Style>
                                    <Style TargetType="ScrollViewer">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding DataContext.MarketAnalysis.IsExpandedMode, RelativeSource={RelativeSource AncestorType=Window}}" Value="True">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ScrollViewer.Style>
                                <ContentControl Content="{Binding DataContext.MarketAnalysis.SelectedExpandedPanel, RelativeSource={RelativeSource AncestorType=Window}, FallbackValue={x:Null}}"
                                                HorizontalContentAlignment="Stretch"
                                                VerticalContentAlignment="Stretch"
                                                Padding="12"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Cards Pane (always fills remaining space) -->
                    <ScrollViewer Grid.Row="1"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="0,8,0,0">
                        <StackPanel x:Name="SplitPaneCardsGrid"
                                    Orientation="Vertical"
                                    HorizontalAlignment="Stretch">
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Border>
</UserControl>
