@using FFXIV_Craft_Architect.Core.Models

<div class="ma-ladder-shell">
    <table class="ma-ladder-table">
        <thead>
            <tr>
                <th>Qty</th>
                <th>Unit</th>
                <th>Total</th>
                <th>Retainer</th>
                <th>HQ/NQ</th>
                <th>Reviewed</th>
                <th>Flags</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var listing in World.Listings.OrderBy(listing => listing.SortIndex))
            {
                foreach (var divider in MarketAnalysisGridViewService.GetListingDividersBefore(World, listing))
                {
                    <tr class="ma-ladder-break-row">
                        <td colspan="7">@divider.Label</td>
                    </tr>
                }

                <tr class="@MarketAnalysisGridViewService.GetListingRowClass(World, listing, EvidenceOverlay)"
                    title="@MarketAnalysisGridViewService.GetListingPriceBandTooltip(World, listing, EvidenceOverlay)">
                    <td>@listing.Quantity.ToString("N0")</td>
                    <td>@listing.PricePerUnit.ToString("N0")g</td>
                    <td>@((listing.Quantity * listing.PricePerUnit).ToString("N0"))g</td>
                    <td class="ma-ladder-retainer">@listing.RetainerName</td>
                    <td>@(listing.IsHq ? "HQ" : "NQ")</td>
                    <td title="@FormatReviewTooltip(listing)">@FormatReviewAge(listing)</td>
                    <td>
                        @if (listing.PriceSanity == MarketListingPriceSanity.Insane)
                        {
                            <span class="ma-ladder-flag is-insane">insane</span>
                        }
                        else if (listing.PriceSanity == MarketListingPriceSanity.Outlier)
                        {
                            <span class="ma-ladder-flag is-outlier">outlier</span>
                        }
                        else if (listing.PriceSanity == MarketListingPriceSanity.LowOutlier)
                        {
                            <span class="ma-ladder-flag is-low-outlier">low outlier</span>
                        }
                        else if (MarketAnalysisGridViewService.IsUncompetitiveListing(listing))
                        {
                            <span class="ma-ladder-flag is-uncompetitive">uncompetitive</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public WorldMarketAnalysis World { get; set; } = default!;
    [Parameter] public MarketAnalysisEvidenceOverlay EvidenceOverlay { get; set; } = MarketAnalysisEvidenceOverlay.CompetitivenessOverlay;

    private static string FormatReviewAge(AnalyzedMarketListing listing)
    {
        if (!listing.LastReviewTimeUtc.HasValue)
        {
            return "-";
        }

        var age = DateTime.UtcNow - listing.LastReviewTimeUtc.Value;
        if (age < TimeSpan.Zero)
        {
            age = TimeSpan.Zero;
        }

        if (age < TimeSpan.FromMinutes(1))
        {
            return "<1m";
        }

        if (age < TimeSpan.FromHours(1))
        {
            return $"{Math.Floor(age.TotalMinutes):N0}m";
        }

        return age < TimeSpan.FromDays(1)
            ? $"{Math.Floor(age.TotalHours):N0}h"
            : $"{Math.Floor(age.TotalDays):N0}d";
    }

    private static string FormatReviewTooltip(AnalyzedMarketListing listing)
    {
        return listing.LastReviewTimeUtc.HasValue
            ? $"Reviewed: {listing.LastReviewTimeUtc.Value.ToLocalTime():g}"
            : "Review time unavailable";
    }
}
