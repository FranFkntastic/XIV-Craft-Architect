@using FFXIV_Craft_Architect.Core.Models

<div class="ma-world-grid-shell">
    @if (!string.IsNullOrWhiteSpace(Analysis.Warning))
    {
        <div class="ma-world-warning">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
            <span>@Analysis.Warning</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(ScopePriceSummary))
    {
        <div class="ma-scope-price-context">
            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Size="Size.Small" />
            <span>@ScopePriceSummary</span>
        </div>
    }

    <table class="ma-world-grid-table">
        <thead>
            <tr>
                <th>@SortHeader("World", MarketAnalysisWorldGridSortColumn.World)</th>
                <th>@SortHeader("Stock Depth", MarketAnalysisWorldGridSortColumn.StockDepth)</th>
                <th>@SortHeader("Coverage", MarketAnalysisWorldGridSortColumn.Coverage)</th>
                <th>@SortHeader("Price / Value", MarketAnalysisWorldGridSortColumn.PriceValue)</th>
                <th>@SortHeader("% Diff", MarketAnalysisWorldGridSortColumn.Value)</th>
                <th>@SortHeader("Data", MarketAnalysisWorldGridSortColumn.Data)</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var world in MarketAnalysisGridViewService.GetOrderedWorlds(Analysis, Lens, SortColumn, SortDescending))
            {
                var key = GetWorldKey(world);
                var scoreBucket = MarketAnalysisGridViewService.GetDisplayScoreBucket(world, Lens);
                var coverageBucket = MarketAnalysisGridViewService.GetDisplayCoverageBucket(world);
                var stockDetail = MarketAnalysisGridViewService.FormatCompetitiveStockDetail(world);
                <tr class="@MarketAnalysisGridViewService.GetWorldRowClass(world, Lens)">
                    <td>
                        <button type="button" class="ma-world-toggle" @onclick="() => ToggleWorld(key)">
                            <MudIcon Icon="@(IsExpanded(key) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight)" Size="Size.Small" />
                            <span>@world.WorldName</span>
                            @if (!string.IsNullOrWhiteSpace(world.DataCenter))
                            {
                                <span class="ma-world-dc">@world.DataCenter</span>
                            }
                        </button>
                    </td>
                    <td>
                        <span>@($"{MarketAnalysisGridViewService.GetCompetitiveQuantity(world):N0} competitive")</span>
                        @if (!string.IsNullOrWhiteSpace(stockDetail))
                        {
                            <span class="ma-world-muted">@stockDetail</span>
                        }
                    </td>
                    <td>
                        <span>@MarketAnalysisGridViewService.FormatCoverage(world)</span>
                        <span class="ma-world-muted">@MarketAnalysisGridViewService.FormatCoverageBucket(coverageBucket)</span>
                    </td>
                    <td>
                        <span class="ma-world-score @MarketAnalysisGridViewService.GetScoreClass(scoreBucket)">@MarketAnalysisGridViewService.FormatScoreBucket(scoreBucket)</span>
                        <span class="ma-world-muted">@MarketAnalysisGridViewService.FormatWorldPriceSummary(world, Lens)</span>
                    </td>
                    <td title="@MarketAnalysisGridViewService.FormatCompetitiveValueTooltip(world)">@MarketAnalysisGridViewService.FormatCompetitiveValue(world)</td>
                    <td title="@FormatDataTooltip(world)">
                        <span>@FormatDataAge(world)</span>
                        <span class="ma-world-muted">@FormatDataQuality(world)</span>
                    </td>
                </tr>

                @if (IsExpanded(key))
                {
                    <tr class="ma-world-expanded-row">
                        <td colspan="6">
                            <MarketAnalysisListingLadder World="world" />
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public MarketItemAnalysis Analysis { get; set; } = default!;
    [Parameter] public MarketAcquisitionLens Lens { get; set; }
    [Parameter] public int ItemId { get; set; }
    [Parameter] public MarketAnalysisWorldGridSortColumn? SortColumn { get; set; }
    [Parameter] public bool SortDescending { get; set; }
    [Parameter] public IReadOnlySet<MarketAnalysisExpandedWorldKey> ExpandedWorldKeys { get; set; } = new HashSet<MarketAnalysisExpandedWorldKey>();
    [Parameter] public EventCallback<MarketAnalysisExpandedWorldKey> OnWorldExpansionToggled { get; set; }
    [Parameter] public EventCallback<MarketAnalysisWorldGridSortState> OnSortChanged { get; set; }

    private string ScopePriceSummary => MarketAnalysisGridViewService.FormatAnalysisScopePriceSummary(Analysis);

    private async Task ToggleWorld(MarketAnalysisExpandedWorldKey key)
    {
        await OnWorldExpansionToggled.InvokeAsync(key);
    }

    private RenderFragment SortHeader(string label, MarketAnalysisWorldGridSortColumn column) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", GetSortHeaderClass(column));
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => ToggleSort(column)));
        builder.AddContent(sequence++, label);
        if (SortColumn == column)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "ma-world-sort-direction");
            builder.AddContent(sequence++, SortDescending ? "↓" : "↑");
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private string GetSortHeaderClass(MarketAnalysisWorldGridSortColumn column)
    {
        return SortColumn == column
            ? "ma-world-sort-header is-active"
            : "ma-world-sort-header";
    }

    private async Task ToggleSort(MarketAnalysisWorldGridSortColumn column)
    {
        var next = MarketAnalysisGridViewService.ToggleWorldSort(SortColumn, SortDescending, column);
        await OnSortChanged.InvokeAsync(next);
    }

    private MarketAnalysisExpandedWorldKey GetWorldKey(WorldMarketAnalysis world)
    {
        return new MarketAnalysisExpandedWorldKey(ItemId, world.DataCenter.Trim(), world.WorldName.Trim());
    }

    private bool IsExpanded(MarketAnalysisExpandedWorldKey key)
    {
        return ExpandedWorldKeys.Contains(key);
    }

    private static string FormatDataAge(WorldMarketAnalysis world)
    {
        if (!world.DataAge.HasValue)
        {
            return "Missing";
        }

        var prefix = world.DataAgeSource switch
        {
            MarketDataAgeSource.UniversalisWorldUpload => "MB ",
            MarketDataAgeSource.UniversalisResponseUpload => "API ",
            MarketDataAgeSource.LocalFetchFallback => "Cache ",
            _ => string.Empty
        };
        var age = world.DataAge.Value;
        if (age < TimeSpan.FromMinutes(1))
        {
            return $"{prefix}<1m";
        }

        if (age < TimeSpan.FromHours(1))
        {
            return $"{prefix}{Math.Floor(age.TotalMinutes):N0}m";
        }

        return age < TimeSpan.FromDays(1)
            ? $"{prefix}{Math.Floor(age.TotalHours):N0}h"
            : $"{prefix}{Math.Floor(age.TotalDays):N0}d";
    }

    private static string FormatDataQuality(WorldMarketAnalysis world)
    {
        var quality = world.DataQualityBucket switch
        {
            MarketDataQualityBucket.Current => "current",
            MarketDataQualityBucket.Aging => "aging",
            MarketDataQualityBucket.Old => "old",
            MarketDataQualityBucket.VeryOld => "very old",
            _ => "missing"
        };

        return world.DataAgeSource == MarketDataAgeSource.LocalFetchFallback && world.DataQualityBucket != MarketDataQualityBucket.Missing
            ? "cache fallback"
            : quality;
    }

    private static string FormatDataTooltip(WorldMarketAnalysis world)
    {
        return world.DataAgeSource switch
        {
            MarketDataAgeSource.UniversalisWorldUpload => $"World upload: {FormatTimestamp(world.MarketUploadedAtUtc)}; local fetch: {FormatTimestamp(world.FetchedAtUtc)}",
            MarketDataAgeSource.UniversalisResponseUpload => $"API response upload: {FormatTimestamp(world.MarketUploadedAtUtc)}; local fetch: {FormatTimestamp(world.FetchedAtUtc)}",
            MarketDataAgeSource.LocalFetchFallback => $"Universalis upload time unavailable; using local cache fetch time: {FormatTimestamp(world.FetchedAtUtc)}",
            _ => "Market data missing"
        };
    }

    private static string FormatTimestamp(DateTime? timestampUtc)
    {
        return timestampUtc.HasValue
            ? $"{timestampUtc.Value.ToLocalTime():g}"
            : "unknown";
    }
}
