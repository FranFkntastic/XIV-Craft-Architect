@using FFXIV_Craft_Architect.Core.Models

<div class="ma-world-grid-shell">
    @if (!string.IsNullOrWhiteSpace(Analysis.Warning))
    {
        <div class="ma-world-warning">
            <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
            <span>@Analysis.Warning</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(ScopePriceSummary))
    {
        <div class="ma-scope-price-context">
            <MudIcon Icon="@Icons.Material.Filled.QueryStats" Size="Size.Small" />
            <span>@ScopePriceSummary</span>
        </div>
    }

    <WebDataTable TItem="WorldMarketAnalysis"
                  TColumnId="MarketAnalysisWorldGridSortColumn"
                  CssClass="ma-world-grid-table"
                  Items="@MarketAnalysisGridViewService.GetOrderedWorlds(Analysis, Lens, SortColumn, SortDescending)"
                  Columns="@GetWorldColumns()"
                  GetRowKey="world => GetWorldKey(world).ToString()"
                  GetRowClass="world => MarketAnalysisGridViewService.GetWorldRowClass(world, Lens)"
                  IsRowExpanded="world => IsExpanded(GetWorldKey(world))"
                  ExpandedContent="RenderExpandedWorld"
                  SortState="@GetSortState()"
                  SortChanged="OnTableSortChanged" />
</div>

@code {
    [Parameter, EditorRequired] public MarketItemAnalysis Analysis { get; set; } = default!;
    [Parameter] public MarketAcquisitionLens Lens { get; set; }
    [Parameter] public int ItemId { get; set; }
    [Parameter] public Guid? PublicationId { get; set; }
    [Parameter] public MarketAnalysisWorldGridSortColumn? SortColumn { get; set; }
    [Parameter] public bool SortDescending { get; set; }
    [Parameter] public IReadOnlySet<MarketAnalysisExpandedWorldKey> ExpandedWorldKeys { get; set; } = new HashSet<MarketAnalysisExpandedWorldKey>();
    [Parameter] public EventCallback<MarketAnalysisExpandedWorldKey> OnWorldExpansionToggled { get; set; }
    [Parameter] public EventCallback<MarketAnalysisWorldGridSortState> OnSortChanged { get; set; }

    private string ScopePriceSummary => MarketAnalysisGridViewService.FormatAnalysisScopePriceSummary(Analysis);

    private async Task ToggleWorld(MarketAnalysisExpandedWorldKey key)
    {
        await OnWorldExpansionToggled.InvokeAsync(key);
    }

    private IReadOnlyList<WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>> GetWorldColumns()
    {
        return
        [
            new WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>
            {
                Id = MarketAnalysisWorldGridSortColumn.World,
                Header = "World",
                Size = WebTableColumnSize.Percent(22m),
                HeaderCssClass = "ma-world-column",
                CellCssClass = "ma-world-cell",
                CellTemplate = RenderWorldCell
            },
            new WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>
            {
                Id = MarketAnalysisWorldGridSortColumn.StockDepth,
                Header = "Stock Depth",
                Size = WebTableColumnSize.Percent(15m),
                HeaderCssClass = "ma-world-column",
                CellCssClass = "ma-world-cell",
                CellTemplate = RenderStockDepthCell
            },
            new WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>
            {
                Id = MarketAnalysisWorldGridSortColumn.Coverage,
                Header = "Coverage",
                Size = WebTableColumnSize.Percent(14m),
                HeaderCssClass = "ma-world-column",
                CellCssClass = "ma-world-cell",
                CellTemplate = RenderCoverageCell
            },
            new WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>
            {
                Id = MarketAnalysisWorldGridSortColumn.PriceValue,
                Header = "Price / Value",
                Size = WebTableColumnSize.Percent(24m),
                HeaderCssClass = "ma-world-column",
                CellCssClass = "ma-world-cell",
                CellTemplate = RenderPriceValueCell
            },
            new WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>
            {
                Id = MarketAnalysisWorldGridSortColumn.Value,
                Header = "% Diff",
                Size = WebTableColumnSize.Percent(10m),
                HeaderCssClass = "ma-world-column ma-world-value-column",
                CellCssClass = "ma-world-cell ma-world-value-column",
                CellTitleSelector = MarketAnalysisGridViewService.FormatCompetitiveValueTooltip,
                CellTemplate = RenderCompetitiveValueCell
            },
            new WebTableColumn<WorldMarketAnalysis, MarketAnalysisWorldGridSortColumn>
            {
                Id = MarketAnalysisWorldGridSortColumn.Data,
                Header = "Data",
                Size = WebTableColumnSize.Percent(15m),
                HeaderCssClass = "ma-world-column ma-world-data-column",
                CellCssClass = "ma-world-cell ma-world-data-column",
                CellTitleSelector = FormatDataTooltip,
                CellTemplate = RenderDataCell
            }
        ];
    }

    private WebTableSortState<MarketAnalysisWorldGridSortColumn> GetSortState()
    {
        return SortColumn.HasValue
            ? new WebTableSortState<MarketAnalysisWorldGridSortColumn>(SortColumn.Value, SortDescending)
            : WebTableSortState<MarketAnalysisWorldGridSortColumn>.Unsorted;
    }

    private async Task OnTableSortChanged(WebTableSortState<MarketAnalysisWorldGridSortColumn> state)
    {
        if (state.Column.HasValue)
        {
            await OnSortChanged.InvokeAsync(new MarketAnalysisWorldGridSortState(state.Column.Value, state.Descending));
        }
    }

    private RenderFragment<WorldMarketAnalysis> RenderWorldCell => world => builder =>
    {
        var key = GetWorldKey(world);
        var sequence = 0;
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", "ma-world-toggle");
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => ToggleWorld(key)));
        builder.OpenComponent<MudIcon>(sequence++);
        builder.AddAttribute(sequence++, "Icon", IsExpanded(key) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight);
        builder.AddAttribute(sequence++, "Size", Size.Small);
        builder.CloseComponent();
        builder.OpenElement(sequence++, "span");
        builder.AddContent(sequence++, world.WorldName);
        builder.CloseElement();
        if (!string.IsNullOrWhiteSpace(world.DataCenter))
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "ma-world-dc");
            builder.AddContent(sequence++, world.DataCenter);
            builder.CloseElement();
        }

        builder.CloseElement();
    };

    private RenderFragment<WorldMarketAnalysis> RenderStockDepthCell => world => builder =>
    {
        var stockDetail = MarketAnalysisGridViewService.FormatCompetitiveStockDetail(world);
        builder.OpenElement(0, "span");
        builder.AddContent(1, $"{MarketAnalysisGridViewService.GetCompetitiveQuantity(world):N0} competitive");
        builder.CloseElement();
        if (!string.IsNullOrWhiteSpace(stockDetail))
        {
            builder.OpenElement(2, "span");
            builder.AddAttribute(3, "class", "ma-world-muted");
            builder.AddContent(4, stockDetail);
            builder.CloseElement();
        }
    };

    private RenderFragment<WorldMarketAnalysis> RenderCoverageCell => world => builder =>
    {
        var coverageBucket = MarketAnalysisGridViewService.GetDisplayCoverageBucket(world);
        builder.OpenElement(0, "span");
        builder.AddContent(1, MarketAnalysisGridViewService.FormatCoverage(world));
        builder.CloseElement();
        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "ma-world-muted");
        builder.AddContent(4, MarketAnalysisGridViewService.FormatCoverageBucket(coverageBucket));
        builder.CloseElement();
    };

    private RenderFragment<WorldMarketAnalysis> RenderPriceValueCell => world => builder =>
    {
        var scoreBucket = MarketAnalysisGridViewService.GetDisplayScoreBucket(world, Lens);
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", $"ma-world-score {MarketAnalysisGridViewService.GetScoreClass(scoreBucket)}");
        builder.AddContent(2, MarketAnalysisGridViewService.FormatScoreBucket(scoreBucket));
        builder.CloseElement();
        builder.OpenElement(3, "span");
        builder.AddAttribute(4, "class", "ma-world-muted");
        builder.AddContent(5, MarketAnalysisGridViewService.FormatWorldPriceSummary(world, Lens));
        builder.CloseElement();
    };

    private RenderFragment<WorldMarketAnalysis> RenderCompetitiveValueCell => world => builder =>
    {
        builder.AddContent(0, MarketAnalysisGridViewService.FormatCompetitiveValue(world));
    };

    private RenderFragment<WorldMarketAnalysis> RenderDataCell => world => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddContent(1, FormatDataAge(world));
        builder.CloseElement();
        builder.OpenElement(2, "span");
        builder.AddAttribute(3, "class", "ma-world-muted");
        builder.AddContent(4, FormatDataQuality(world));
        builder.CloseElement();
    };

    private RenderFragment<WorldMarketAnalysis> RenderExpandedWorld => world => builder =>
    {
        builder.OpenComponent<MarketAnalysisListingLadder>(0);
        builder.AddAttribute(1, "World", world);
        builder.AddAttribute(2, "ItemId", ItemId);
        builder.AddAttribute(3, "PublicationId", PublicationId);
        builder.CloseComponent();
    };

    private MarketAnalysisExpandedWorldKey GetWorldKey(WorldMarketAnalysis world)
    {
        return new MarketAnalysisExpandedWorldKey(ItemId, world.DataCenter.Trim(), world.WorldName.Trim());
    }

    private bool IsExpanded(MarketAnalysisExpandedWorldKey key)
    {
        return ExpandedWorldKeys.Contains(key);
    }

    private static string FormatDataAge(WorldMarketAnalysis world)
    {
        if (!world.DataAge.HasValue)
        {
            return "Missing";
        }

        var prefix = world.DataAgeSource switch
        {
            MarketDataAgeSource.UniversalisWorldUpload => "MB ",
            MarketDataAgeSource.UniversalisResponseUpload => "API ",
            MarketDataAgeSource.LocalFetchFallback => "Cache ",
            _ => string.Empty
        };
        var age = world.DataAge.Value;
        if (age < TimeSpan.FromMinutes(1))
        {
            return $"{prefix}<1m";
        }

        if (age < TimeSpan.FromHours(1))
        {
            return $"{prefix}{Math.Floor(age.TotalMinutes):N0}m";
        }

        return age < TimeSpan.FromDays(1)
            ? $"{prefix}{Math.Floor(age.TotalHours):N0}h"
            : $"{prefix}{Math.Floor(age.TotalDays):N0}d";
    }

    private static string FormatDataQuality(WorldMarketAnalysis world)
    {
        var quality = world.DataQualityBucket switch
        {
            MarketDataQualityBucket.Current => "current",
            MarketDataQualityBucket.Aging => "aging",
            MarketDataQualityBucket.Old => "old",
            MarketDataQualityBucket.VeryOld => "very old",
            _ => "missing"
        };

        return world.DataAgeSource == MarketDataAgeSource.LocalFetchFallback && world.DataQualityBucket != MarketDataQualityBucket.Missing
            ? "cache fallback"
            : quality;
    }

    private static string FormatDataTooltip(WorldMarketAnalysis world)
    {
        return world.DataAgeSource switch
        {
            MarketDataAgeSource.UniversalisWorldUpload => $"World upload: {FormatTimestamp(world.MarketUploadedAtUtc)}; local fetch: {FormatTimestamp(world.FetchedAtUtc)}",
            MarketDataAgeSource.UniversalisResponseUpload => $"API response upload: {FormatTimestamp(world.MarketUploadedAtUtc)}; local fetch: {FormatTimestamp(world.FetchedAtUtc)}",
            MarketDataAgeSource.LocalFetchFallback => $"Universalis upload time unavailable; using local cache fetch time: {FormatTimestamp(world.FetchedAtUtc)}",
            _ => "Market data missing"
        };
    }

    private static string FormatTimestamp(DateTime? timestampUtc)
    {
        return timestampUtc.HasValue
            ? $"{timestampUtc.Value.ToLocalTime():g}"
            : "unknown";
    }
}
