@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Services
@inject ISettingsService Settings

<aside class="pp-controls-column" aria-labelledby="procurement-page-title">
    <h1 id="procurement-page-title" class="pp-page-title">Procurement Plan</h1>

    <section class="pp-settings" aria-labelledby="procurement-settings-title">
        <h2 id="procurement-settings-title" class="pp-section-title">Route settings</h2>

        <div class="pp-setting-grid">
            <div class="pp-field-block">
                <MudCheckBox T="bool"
                             Value="AppState.ProcurementSearchEntireRegion"
                             ValueChanged="OnProcurementSearchEntireRegionChanged"
                             Dense="true"
                             Color="Color.Primary">
                    <span>Search the whole region</span>
                </MudCheckBox>
                <p>Uses listings from every data center in @AppState.SelectedRegion, which can lower cost but add transfers.</p>
            </div>

            <div class="pp-field-block pp-travel-field">
                <ProcurementTravelTradeoff TravelTolerance="AppState.ProcurementTravelTolerance"
                                            RouteDecision="AppState.ProcurementRouteDecision"
                                            RouteValidity="AppState.ProcurementRouteValidity"
                                            IsReconciling="AppState.IsProcurementRouteReconciling"
                                            RouteFailure="AppState.ProcurementRouteFailure"
                                            TravelPriority="AppState.ProcurementTravelPriority"
                                            TravelToleranceChanged="OnProcurementTravelToleranceChanged" />
                <p id="procurement-travel-help">@GetTravelPreferenceHelp()</p>
                <div class="pp-route-policies" aria-label="Route policies">
                    <p class="pp-route-policy-note">
                        <MudIcon Icon="@(AppState.ProcurementEnableSplitWorldPurchases ? Icons.Material.Filled.CallSplit : Icons.Material.Filled.HorizontalRule)" Size="Size.Small" />
                        <span>@(AppState.ProcurementEnableSplitWorldPurchases ? "Split purchases allowed" : "Single-world purchases only")</span>
                        <small>Set in Options</small>
                    </p>
                    <p class="pp-route-policy-note">
                        <MudIcon Icon="@Icons.Material.Filled.Sort" Size="Size.Small" />
                        <span>@GetTravelPriorityLabel()</span>
                        <small>Set in Options</small>
                    </p>
                    @if (AppState.ProcurementSearchEntireRegion && AppState.ProcurementStartFromHomeDataCenter)
                    {
                        <p class="pp-origin-note"><MudIcon Icon="@Icons.Material.Filled.Home" Size="Size.Small" /> <span>Starts from @AppState.SelectedDataCenter</span></p>
                    }
                </div>
            </div>

            <div class="pp-field-block pp-duration-field">
                <CompactSelectField Id="procurement-world-exclusion-duration"
                                    Label="World exclusion duration"
                                    Value="@AppState.TemporaryWorldBlacklistDurationMinutes.ToString()"
                                    ValueChanged="OnTemporaryWorldBlacklistDurationValueChanged"
                                    Options="WorldExclusionDurationOptions"
                                    Class="pp-full-width" />
            </div>
        </div>
    </section>

    @if (AppState.ActiveTemporaryExclusionCount > 0)
    {
        <div class="pp-exclusion-summary" role="status">
            <span>@FormatExclusionCount()</span>
            <MudButton OnClick="OnClearExclusionsRequested"
                       Color="Color.Warning"
                       Variant="Variant.Text"
                       Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Clear">
                Clear
            </MudButton>
        </div>
    }

    <MudButton OnClick="OnRunAnalysisRequested"
               Disabled="@(!CanAnalyze || IsAnalyzing)"
               Color="Color.Primary"
               Variant="Variant.Filled"
               FullWidth="true"
               Class="pp-primary-action"
               StartIcon="@(IsAnalyzing ? string.Empty : Icons.Material.Filled.Route)">
        @if (IsAnalyzing)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Generating route…</span>
        }
        else
        {
            <span>@PrimaryActionLabel</span>
        }
    </MudButton>

    @if (ShowNotice)
    {
        <MudAlert Severity="NoticeSeverity" Class="pp-notice" Dense="true">
            @NoticeMessage
        </MudAlert>
    }

    <nav class="pp-secondary-actions" aria-label="Procurement navigation">
        <MudButton OnClick="OnGoToMarketAnalysisRequested"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.Analytics">
            Market Analysis
        </MudButton>
        <MudButton OnClick="OnExportCraftQuoteRequested"
                   Disabled="@(!CanExportCraftQuote)"
                   Variant="Variant.Text"
                   StartIcon="@Icons.Material.Filled.FileDownload">
            Export Quote
        </MudButton>
    </nav>
</aside>

@code {
    [Parameter, EditorRequired] public AppState AppState { get; set; } = default!;
    [Parameter] public bool IsAnalyzing { get; set; }
    [Parameter] public bool CanAnalyze { get; set; }
    [Parameter] public string PrimaryActionLabel { get; set; } = "Generate Route";
    [Parameter] public bool ShowNotice { get; set; } = true;
    [Parameter] public Severity NoticeSeverity { get; set; } = Severity.Info;
    [Parameter] public string NoticeMessage { get; set; } = string.Empty;
    [Parameter] public EventCallback OnRunAnalysisRequested { get; set; }
    [Parameter] public EventCallback OnClearExclusionsRequested { get; set; }
    [Parameter] public bool CanExportCraftQuote { get; set; }
    [Parameter] public EventCallback OnExportCraftQuoteRequested { get; set; }
    [Parameter] public EventCallback OnGoToMarketAnalysisRequested { get; set; }
    private static readonly IReadOnlyList<CompactSelectOption> WorldExclusionDurationOptions =
    [
        new("15", "15 minutes"),
        new("60", "1 hour"),
        new("240", "4 hours"),
        new("1440", "1 day")
    ];

    private string FormatExclusionCount()
    {
        var count = AppState.ActiveTemporaryExclusionCount;
        return $"{count} temporary exclusion{(count == 1 ? string.Empty : "s")} active";
    }

    private Task OnProcurementSearchEntireRegionChanged(bool value) =>
        ApplyProcurementSettingsAsync(searchEntireRegion: value);

    private Task OnProcurementTravelToleranceChanged(int value) =>
        ApplyProcurementSettingsAsync(travelTolerance: value);

    private string GetTravelPreferenceHelp()
    {
        var tolerance = AppState.ProcurementTravelTolerance;
        var premium = MarketRouteScoring.GetMaximumPremiumRate(tolerance);
        return tolerance switch
        {
            0 => $"Position 0 of 11. No gil ceiling; {GetTravelPriorityAction()}.",
            11 => "Position 11 of 11. No extra gil; choose the cheapest eligible route.",
            _ => $"Position {tolerance} of 11. Routes may cost up to {premium!.Value:P0} more gil than the cheapest eligible route."
        };
    }

    private string GetTravelPriorityAction() => AppState.ProcurementTravelPriority switch
    {
        MarketTravelPriority.WorldVisitsFirst => "minimize world visits, then data-center transfers",
        _ => "minimize data-center transfers, then world visits"
    };

    private string GetTravelPriorityLabel() => AppState.ProcurementTravelPriority switch
    {
        MarketTravelPriority.WorldVisitsFirst => "World visits ranked before transfers",
        _ => "Data-center transfers ranked before world visits"
    };

    private Task OnTemporaryWorldBlacklistDurationValueChanged(string value) =>
        int.TryParse(value, out var minutes)
            ? ApplyProcurementSettingsAsync(temporaryWorldBlacklistDurationMinutes: minutes)
            : Task.CompletedTask;

    private async Task ApplyProcurementSettingsAsync(
        bool? searchEntireRegion = null,
        bool? enableSplitWorldPurchases = null,
        int? travelTolerance = null,
        int? temporaryWorldBlacklistDurationMinutes = null)
    {
        AppState.SetProcurementSettings(
            searchEntireRegion ?? AppState.ProcurementSearchEntireRegion,
            enableSplitWorldPurchases ?? AppState.ProcurementEnableSplitWorldPurchases,
            travelTolerance ?? AppState.ProcurementTravelTolerance,
            temporaryWorldBlacklistDurationMinutes ?? AppState.TemporaryWorldBlacklistDurationMinutes);

        await Settings.SetAsync("procurement.search_entire_region", AppState.ProcurementSearchEntireRegion);
        await Settings.SetAsync("procurement.enable_split_world_purchases", AppState.ProcurementEnableSplitWorldPurchases);
        await Settings.SetAsync("procurement.travel_tolerance", AppState.ProcurementTravelTolerance);
        await Settings.SetAsync("procurement.world_exclusion_duration_minutes", AppState.TemporaryWorldBlacklistDurationMinutes);
    }
}
