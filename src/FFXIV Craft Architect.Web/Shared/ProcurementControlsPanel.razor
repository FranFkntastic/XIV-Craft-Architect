@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services

<div class="pp-controls-column">
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Procurement Plan</MudText>

    <div class="pp-field-block">
        <div class="pp-field-label">Mode</div>
        <MudSelect T="RecommendationMode"
                   @bind-Value="AppState.ProcurementRecommendationMode"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Class="pp-full-width">
            <MudSelectItem Value="@RecommendationMode.MinimizeTotalCost">Minimize Total Cost</MudSelectItem>
            <MudSelectItem Value="@RecommendationMode.MaximizeValue">Maximize Value</MudSelectItem>
            <MudSelectItem Value="@RecommendationMode.BestUnitPrice">Best Unit Price</MudSelectItem>
        </MudSelect>
    </div>

    <MudText Typo="Typo.subtitle2" Class="pp-section-title">Procurement Route Settings</MudText>

    <div class="pp-field-block">
        <MudCheckBox T="bool"
                     @bind-Value="AppState.ProcurementSearchEntireRegion"
                     Dense="true"
                     Color="Color.Primary">
            <MudText Typo="Typo.body2">Use region-wide market evidence</MudText>
        </MudCheckBox>
    </div>

    <div class="pp-field-block">
        <MudCheckBox T="bool"
                     @bind-Value="AppState.ProcurementEnableSplitWorldPurchases"
                     Dense="true"
                     Color="Color.Secondary">
            <MudText Typo="Typo.body2">Allow split-world purchases</MudText>
        </MudCheckBox>
    </div>

    <div class="pp-field-block">
        <div class="pp-field-label">Travel tolerance: @GetTravelToleranceLabel()</div>
        <MudSlider T="int"
                   @bind-Value="AppState.ProcurementTravelTolerance"
                   Min="0"
                   Max="11"
                   Step="1"
                   Color="Color.Primary"
                   Class="pp-full-width" />
        <MudStack Row="true" Justify="Justify.SpaceBetween" Class="pp-slider-endpoints">
            <MudText Typo="Typo.caption">Shortest route</MudText>
            <MudText Typo="Typo.caption">Cheapest</MudText>
        </MudStack>
    </div>

    <div class="pp-field-block">
        <div class="pp-field-label">World exclusion duration</div>
        <MudSelect T="int"
                   @bind-Value="AppState.TemporaryWorldBlacklistDurationMinutes"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Class="pp-full-width">
            <MudSelectItem Value="15">15 minutes</MudSelectItem>
            <MudSelectItem Value="60">1 hour</MudSelectItem>
            <MudSelectItem Value="240">4 hours</MudSelectItem>
            <MudSelectItem Value="1440">1 day</MudSelectItem>
        </MudSelect>
    </div>

    @if (AppState.ActiveTemporaryExclusionCount > 0)
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            <MudText Typo="Typo.caption">
                Excluding @AppState.ActiveTemporaryExclusionCount world/item rule(s) from procurement recommendations.
            </MudText>
        </MudAlert>
        <MudButton OnClick="ClearWorldExclusions"
                   Color="Color.Warning"
                   Variant="Variant.Outlined"
                   FullWidth="true"
                   Class="mb-4"
                   StartIcon="@Icons.Material.Filled.Clear">
            Clear World Exclusions
        </MudButton>
    }

    <MudButton OnClick="OnRunAnalysisRequested"
               Disabled="@(!CanAnalyze || IsAnalyzing)"
               Color="Color.Primary"
               Variant="Variant.Filled"
               FullWidth="true"
               Class="mb-4"
               StartIcon="@(IsAnalyzing ? "" : Icons.Material.Filled.Assignment)">
        @if (IsAnalyzing)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Analyzing...</span>
        }
        else
        {
            <span>Generate Plan</span>
        }
    </MudButton>

    <MudDivider Class="my-4" />

    <MudAlert Severity="NoticeSeverity" Class="mb-4" Dense="true">
        <MudText Typo="Typo.caption">@NoticeMessage</MudText>
    </MudAlert>

    <MudButton OnClick="OnGoToPlannerRequested"
               Color="Color.Info"
               Variant="Variant.Outlined"
               FullWidth="true"
               Class="mb-2"
               StartIcon="@Icons.Material.Filled.ArrowBack">
        Back to Planner
    </MudButton>

    <MudButton OnClick="OnGoToMarketAnalysisRequested"
               Color="Color.Warning"
               Variant="Variant.Outlined"
               FullWidth="true"
               StartIcon="@Icons.Material.Filled.Analytics">
        Market Analysis
    </MudButton>

    @if (ShoppingPlans.Any())
    {
        <MudDivider Class="my-4" />

        <MudPaper Elevation="2" Class="pa-3 pp-summary-paper">
            <MudText Typo="Typo.caption" Class="pp-summary-label">Total Market Cost</MudText>
            <MudText Typo="Typo.h6" Class="pp-summary-value">
                @(ShoppingPlans.Sum(GetPlanCost).ToString("N0"))g
            </MudText>

            <div class="pp-summary-stat-row">
                <div class="pp-summary-stat">
                    <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" Class="pp-summary-stat-icon" />
                    <MudText Typo="Typo.caption" Class="pp-summary-stat-text">
                        @EvidenceSummary.ActiveProcurementItemCount active
                    </MudText>
                </div>
            </div>
        </MudPaper>
    }
</div>

@code {
    [Parameter, EditorRequired] public AppState AppState { get; set; } = default!;
    [Parameter] public List<DetailedShoppingPlan> ShoppingPlans { get; set; } = new();
    [Parameter] public ProcurementEvidenceSummary EvidenceSummary { get; set; } = new(0, 0, 0, 0, 0);
    [Parameter] public bool IsAnalyzing { get; set; }
    [Parameter] public bool CanAnalyze { get; set; }
    [Parameter] public Severity NoticeSeverity { get; set; } = Severity.Info;
    [Parameter] public string NoticeMessage { get; set; } = string.Empty;

    [Parameter] public EventCallback OnRunAnalysisRequested { get; set; }
    [Parameter] public EventCallback OnGoToPlannerRequested { get; set; }
    [Parameter] public EventCallback OnGoToMarketAnalysisRequested { get; set; }

    private static long GetPlanCost(DetailedShoppingPlan plan)
    {
        return PurchaseRecommendationCost.GetRecommendedCost(plan);
    }

    private string GetTravelToleranceLabel()
    {
        return AppState.ProcurementTravelTolerance switch
        {
            0 => "shortest route",
            11 => "cheapest",
            _ => $"balanced {AppState.ProcurementTravelTolerance}/11"
        };
    }

    private void ClearWorldExclusions()
    {
        AppState.ClearTemporaryMarketWorldBlacklists();
    }
}
