@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<section class="pp-route-shell" aria-labelledby="procurement-route-title">
    <header class="pp-route-summary">
        <div class="pp-route-title-block">
            <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Success" Size="Size.Small" />
            <div>
                <h2 id="procurement-route-title" class="pp-route-title">Procurement Route</h2>
                @if (_routeCards.Count > 0)
                {
                    <p class="pp-route-subtitle">@FormatCount(_routeCards.Count, "world stop") · @FormatCount(ShoppingPlans.Count, "item")</p>
                }
            </div>
        </div>
        @if (ShoppingPlans.Count > 0)
        {
            <div class="pp-route-total">
                <span>@GetTotalCost().ToString("N0")g</span>
                <small>selected total</small>
            </div>
        }
    </header>

    @if (RouteDecision != null)
    {
        <div class="pp-decision" aria-label="Why this route was selected">
            <div class="pp-decision-copy">
                <strong>@MarketRouteScoring.GetToleranceLabel(RouteDecision.TravelTolerance)</strong>
                <span>@GetDecisionExplanation(RouteDecision)</span>
            </div>
            <div class="pp-decision-metrics">
                <span><strong>@RouteDecision.SelectedWorldStops</strong> @Pluralize(RouteDecision.SelectedWorldStops, "world", "worlds")</span>
                <span><strong>@RouteDecision.SelectedDataCenterTransfers</strong> DC @Pluralize(RouteDecision.SelectedDataCenterTransfers, "transfer", "transfers")</span>
            </div>
        </div>
        @if (RouteDecision.PremiumRate >= 1m)
        {
            <div class="pp-decision-warning" role="status">
                <MudIcon Icon="@Icons.Material.Filled.PriceChange" Size="Size.Small" />
                <span>Minimizing travel more than doubles the route cost: +@RouteDecision.PremiumGil.ToString("N0")g over the cheapest eligible route.</span>
            </div>
        }
    }

    <div class="pp-route-content">
        @if (ShoppingPlans.Count == 0)
        {
            <div class="pp-route-empty">
                <MudIcon Icon="@Icons.Material.Filled.Map" Size="Size.Large" />
                <strong>@EmptyTitle</strong>
                <span>@EmptyMessage</span>
            </div>
        }
        else
        {
            var dcGroups = _routeCards
                .Where(card => !card.IsVendor)
                .GroupBy(card => card.DataCenter)
                .OrderBy(group => group.Key)
                .ToList();
            var vendorCard = _routeCards.FirstOrDefault(card => card.IsVendor);
            var errorItems = ShoppingPlans.Where(plan => !string.IsNullOrEmpty(plan.Error)).ToList();
            var warningItems = ShoppingPlans
                .Where(plan => string.IsNullOrEmpty(plan.Error) && !string.IsNullOrEmpty(plan.MarketDataWarning))
                .ToList();

            <div class="pp-route-tree">
                @foreach (var dcGroup in dcGroups)
                {
                    var worlds = dcGroup.ToList();
                    <section class="pp-dc-group" aria-label="@dcGroup.Key data center">
                        <div class="pp-dc-header">
                            <strong>@dcGroup.Key</strong>
                            <small>@FormatCount(worlds.Count, "world") · @worlds.Sum(world => world.TotalCost).ToString("N0")g</small>
                            <MudIconButton Icon="@(IsGroupFullyExpanded(worlds) ? Icons.Material.Filled.UnfoldLess : Icons.Material.Filled.UnfoldMore)"
                                           Size="Size.Small"
                                           Class="pp-dc-toggle"
                                           Title="@(IsGroupFullyExpanded(worlds) ? $"Collapse {dcGroup.Key} worlds" : $"Expand {dcGroup.Key} worlds")"
                                           OnClick="() => ToggleDataCenter(worlds)" />
                        </div>

                        @foreach (var world in worlds)
                        {
                            @RenderWorldNode(world)
                        }
                    </section>
                }

                @if (vendorCard != null)
                {
                    <section class="pp-dc-group" aria-label="Vendor purchases">
                        <div class="pp-dc-header is-vendor">
                            <strong>Vendors</strong>
                            <small>@FormatCount(vendorCard.ItemCount, "item") · @vendorCard.TotalCost.ToString("N0")g</small>
                        </div>
                        @RenderWorldNode(vendorCard)
                    </section>
                }

                @if (errorItems.Count > 0)
                {
                    <section class="pp-error-group" aria-labelledby="procurement-errors-title">
                        <div class="pp-dc-header is-error">
                            <strong id="procurement-errors-title">Needs attention</strong>
                            <small>@FormatCount(errorItems.Count, "item")</small>
                        </div>
                        @foreach (var plan in errorItems)
                        {
                            <div class="pp-error-row"><strong>@plan.Name</strong><span>@plan.Error</span></div>
                        }
                    </section>
                }

                @if (warningItems.Count > 0)
                {
                    <section class="pp-error-group" aria-labelledby="procurement-warnings-title">
                        <div class="pp-dc-header">
                            <strong id="procurement-warnings-title">Evidence warnings</strong>
                            <small>@FormatCount(warningItems.Count, "item")</small>
                        </div>
                        @foreach (var plan in warningItems)
                        {
                            <div class="pp-error-row"><strong>@plan.Name</strong><span>@plan.MarketDataWarning</span></div>
                        }
                    </section>
                }
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public IReadOnlyList<DetailedShoppingPlan> ShoppingPlans { get; set; } = Array.Empty<DetailedShoppingPlan>();
    [Parameter] public MarketRouteDecision? RouteDecision { get; set; }
    [Parameter] public string EmptyTitle { get; set; } = "Route ready to generate";
    [Parameter] public string EmptyMessage { get; set; } = "Choose route settings and generate a route.";
    [Parameter] public MarketItemWorldKey? ReconcilingItemWorld { get; set; }
    [Parameter] public EventCallback<WorldProcurementCardModel> OnReanalyzeWithoutWorldRequested { get; set; }
    [Parameter] public EventCallback<WorldItemProcurementAction> OnExcludeWorldForItemRequested { get; set; }
    [Parameter] public EventCallback<WorldItemProcurementAction> OnRefreshItemRequested { get; set; }

    private readonly HashSet<string> _expandedWorlds = new(StringComparer.OrdinalIgnoreCase);
    private IReadOnlyList<WorldProcurementCardModel> _routeCards = Array.Empty<WorldProcurementCardModel>();
    private bool _hasInitializedExpansion;

    protected override void OnParametersSet()
    {
        _routeCards = ShoppingPlans.Count == 0
            ? Array.Empty<WorldProcurementCardModel>()
            : ProcurementWorldCardBuilder.BuildWorldCards(ShoppingPlans, AppState.SelectedDataCenter);

        var activeKeys = _routeCards.Select(GetWorldKey).ToHashSet(StringComparer.OrdinalIgnoreCase);
        _expandedWorlds.RemoveWhere(key => !activeKeys.Contains(key));
        if (!_hasInitializedExpansion && _routeCards.Count > 0)
        {
            foreach (var world in _routeCards.Take(2))
            {
                _expandedWorlds.Add(GetWorldKey(world));
            }

            _hasInitializedExpansion = true;
        }
    }

    private RenderFragment RenderWorldNode(WorldProcurementCardModel world) => @<article class="pp-world-node @(world.IsVendor ? "is-vendor" : null) @(world.IsCongested ? "is-congested" : null)">
        <div class="pp-world-row-wrap">
            <button class="pp-world-row" type="button" aria-expanded="@_expandedWorlds.Contains(GetWorldKey(world))" @onclick="() => ToggleWorld(world)">
                <span class="pp-world-main">
                    <MudIcon Icon="@(world.IsVendor ? Icons.Material.Filled.Store : Icons.Material.Filled.Public)" Size="Size.Small" />
                    <strong class="pp-world-name">@world.WorldName</strong>
                    @if (world.HasSplitPurchases)
                    {
                        <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Class="pp-split-icon" />
                    }
                    @if (world.IsCongested)
                    {
                        <span class="pp-congested-label">Congested</span>
                    }
                </span>
                <span class="pp-world-meta">@FormatCount(world.ItemCount, "item")</span>
                <span class="pp-world-meta">@world.TotalQuantity.ToString("N0") qty</span>
                <span class="pp-world-cost">@world.TotalCost.ToString("N0")g</span>
                <MudIcon Icon="@(_expandedWorlds.Contains(GetWorldKey(world)) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
            </button>
            @if (!world.IsVendor)
            {
                <MudIconButton Icon="@Icons.Material.Filled.WrongLocation"
                               Size="Size.Small"
                               Class="pp-world-action"
                               Title="@GetExcludeWorldTitle(world)"
                               OnClick="() => ReanalyzeWithoutWorld(world)" />
            }
        </div>

        @if (_expandedWorlds.Contains(GetWorldKey(world)))
        {
            <div class="pp-item-table-wrap">
                <table class="pp-item-table">
                    <thead>
                        <tr>
                            <th scope="col">Item</th>
                            <th scope="col">Quantity</th>
                            <th scope="col">Unit price</th>
                            <th scope="col">Total</th>
                            <th scope="col"><span class="sr-only">Actions</span></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in world.Items.OrderBy(item => item.ItemName))
                        {
                            var itemDecision = GetItemDecision(item);
                            var itemWorldKey = new MarketItemWorldKey(
                                item.ItemId,
                                new MarketWorldKey(world.DataCenter, world.WorldName));
                            var isReconciling = ReconcilingItemWorld == itemWorldKey;
                            <tr>
                                <th scope="row" data-label="Item">
                                    <div class="pp-item-main">
                                        @if (item.IsSplitPurchase)
                                        {
                                            <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Class="pp-split-icon" />
                                        }
                                        <button class="pp-item-link" type="button" @onclick="() => GoToMarketAnalysis(item)">@item.ItemName</button>
                                        @if (item.TravelContext == TravelContextConstants.Primary && itemDecision?.ConsolidationPremiumGil > 0)
                                        {
                                            <small class="pp-item-premium">Route consolidation: +@itemDecision.ConsolidationPremiumGil.ToString("N0")g vs cheapest eligible</small>
                                        }
                                        @if (world.IsVendor && item.Vendor != null)
                                        {
                                            <small>@item.Vendor.Name · @item.Vendor.Location</small>
                                        }
                                    </div>
                                </th>
                                <td data-label="Quantity">@(world.IsVendor || !item.IsSplitPurchase ? item.SimpleQuantityDisplay : item.QuantityDisplay)</td>
                                <td data-label="Unit price">@item.PriceDisplay</td>
                                <td data-label="Total" class="pp-item-total">@item.TotalCost.ToString("N0")g</td>
                                <td data-label="Actions">
                                    <span class="pp-item-actions">
                                        @if (!world.IsVendor)
                                        {
                                            <button class="pp-recheck-action"
                                                    type="button"
                                                    disabled="@isReconciling"
                                                    aria-label="@(isReconciling
                                                        ? $"Checking {item.ItemName} on {world.WorldName}"
                                                        : GetRefreshItemTitle(world, item))"
                                                    title="@GetRefreshItemTitle(world, item)"
                                                    @onclick="() => RefreshItem(world, item)">
                                                @if (isReconciling)
                                                {
                                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                                                    <span>Checking</span>
                                                }
                                                else
                                                {
                                                    <MudIcon Icon="@Icons.Material.Filled.Refresh" Size="Size.Small" />
                                                    <span>Recheck</span>
                                                }
                                            </button>
                                            <MudIconButton Icon="@Icons.Material.Filled.Block"
                                                           Size="Size.Small"
                                                           Title="@GetExcludeItemTitle(world, item)"
                                                           OnClick="() => ExcludeWorldForItem(world, item)" />
                                        }
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Size="Size.Small"
                                                       Title="@GetCopyItemTitle(item)"
                                                       OnClick="() => CopyItemName(item.ItemName)" />
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </article>;

    private void ToggleWorld(WorldProcurementCardModel world)
    {
        var key = GetWorldKey(world);
        if (!_expandedWorlds.Add(key))
        {
            _expandedWorlds.Remove(key);
        }
    }

    private bool IsGroupFullyExpanded(IEnumerable<WorldProcurementCardModel> worlds)
    {
        var worldList = worlds.ToList();
        return worldList.Count > 0 && worldList.All(world => _expandedWorlds.Contains(GetWorldKey(world)));
    }

    private void ToggleDataCenter(IEnumerable<WorldProcurementCardModel> worlds)
    {
        var worldList = worlds.ToList();
        var collapse = IsGroupFullyExpanded(worldList);
        foreach (var world in worldList)
        {
            if (collapse)
            {
                _expandedWorlds.Remove(GetWorldKey(world));
            }
            else
            {
                _expandedWorlds.Add(GetWorldKey(world));
            }
        }
    }

    private Task ReanalyzeWithoutWorld(WorldProcurementCardModel world) =>
        OnReanalyzeWithoutWorldRequested.InvokeAsync(world);

    private Task ExcludeWorldForItem(WorldProcurementCardModel world, WorldItemPurchase item) =>
        OnExcludeWorldForItemRequested.InvokeAsync(new WorldItemProcurementAction { World = world, Item = item });

    private Task RefreshItem(WorldProcurementCardModel world, WorldItemPurchase item) =>
        OnRefreshItemRequested.InvokeAsync(new WorldItemProcurementAction { World = world, Item = item });

    private Task CopyItemName(string itemName) =>
        JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", itemName).AsTask();

    private void GoToMarketAnalysis(WorldItemPurchase item)
    {
        AppState.RequestMarketItemAutoExpand(item.ItemId);
        NavigationManager.NavigateTo("market");
    }

    private decimal GetTotalCost() => ShoppingPlans.Sum(PurchaseRecommendationCost.GetRecommendedCost);

    private static string GetDecisionExplanation(MarketRouteDecision decision)
    {
        var origin = decision.StartsFromHomeDataCenter && !string.IsNullOrWhiteSpace(decision.HomeDataCenter)
            ? $" Travel starts from {decision.HomeDataCenter}."
            : string.Empty;
        if (decision.PremiumGil == 0)
        {
            return $"This route matches the cheapest eligible route at {decision.SelectedGilCost:N0}g.{origin}";
        }

        var avoided = new List<string>();
        if (decision.WorldStopsAvoided > 0)
        {
            avoided.Add(FormatCount(decision.WorldStopsAvoided, "world stop"));
        }
        if (decision.DataCenterTransfersAvoided > 0)
        {
            avoided.Add(FormatCount(decision.DataCenterTransfersAvoided, "data-center transfer"));
        }

        var benefit = avoided.Count > 0 ? $" and avoids {string.Join(" and ", avoided)}" : string.Empty;
        return $"This route costs {decision.PremiumGil:N0}g ({decision.PremiumRate:P1}) more than the cheapest route{benefit}.{origin}";
    }

    private MarketRouteItemDecision? GetItemDecision(WorldItemPurchase item) =>
        RouteDecision?.ItemPremiums.FirstOrDefault(decision => decision.ItemId == item.ItemId);

    private static string FormatCount(int count, string noun) => $"{count:N0} {noun}{(count == 1 ? string.Empty : "s")}";

    private static string Pluralize(int count, string singular, string plural) => count == 1 ? singular : plural;

    private static string GetExcludeWorldTitle(WorldProcurementCardModel world) =>
        $"Temporarily skip travel to {world.WorldName}";

    private static string GetExcludeItemTitle(WorldProcurementCardModel world, WorldItemPurchase item) =>
        $"Exclude {world.WorldName} listings for {item.ItemName}";

    private static string GetRefreshItemTitle(WorldProcurementCardModel world, WorldItemPurchase item) =>
        $"Recheck {item.ItemName} on {world.WorldName} and update the route";

    private static string GetCopyItemTitle(WorldItemPurchase item) => $"Copy {item.ItemName}";

    private static string GetWorldKey(WorldProcurementCardModel world) => ProcurementWorldCardBuilder.GetWorldKey(world);
}
