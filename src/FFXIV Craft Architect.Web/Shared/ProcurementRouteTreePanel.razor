@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<div class="pp-route-shell">
    <div class="pp-route-summary">
        <div class="pp-route-title-block">
            <MudIcon Icon="@Icons.Material.Filled.Route" Color="Color.Success" Size="Size.Small" />
            <div>
                <MudText Typo="Typo.subtitle1" Class="pp-route-title">Procurement Route</MudText>
                @if (ShoppingPlans.Any())
                {
                    <MudText Typo="Typo.caption" Class="pp-route-subtitle">
                        @GetRouteCards().Count world stops · @ShoppingPlans.Count analyzed items
                    </MudText>
                }
            </div>
        </div>
        @if (ShoppingPlans.Any())
        {
            <div class="pp-route-total">
                <span>@GetTotalCost().ToString("N0")g</span>
                <small>total</small>
            </div>
        }
    </div>

    <div class="pp-route-content">
        @if (!ShoppingPlans.Any())
        {
            <div class="pp-route-empty">
                <MudIcon Icon="@Icons.Material.Filled.Assignment" Size="Size.Large" />
                <MudText Typo="Typo.body1">No shopping plans available</MudText>
                <MudText Typo="Typo.caption">Run market analysis to generate a procurement route.</MudText>
            </div>
        }
        else
        {
            var routeCards = GetRouteCards();
            var dcGroups = routeCards
                .Where(c => !c.IsVendor)
                .GroupBy(c => c.DataCenter)
                .OrderBy(g => g.Key)
                .ToList();
            var vendorCard = routeCards.FirstOrDefault(c => c.IsVendor);
            var errorItems = GetItemsWithErrors().ToList();
            var warningItems = GetItemsWithWarnings().ToList();

            <div class="pp-route-tree">
                @foreach (var dcGroup in dcGroups)
                {
                    var worlds = dcGroup.ToList();
                    <section class="pp-dc-group">
                        <div class="pp-dc-header">
                            <span>@dcGroup.Key</span>
                            <MudIconButton Icon="@(IsGroupFullyExpanded(worlds) ? Icons.Material.Filled.UnfoldLess : Icons.Material.Filled.UnfoldMore)"
                                           Size="Size.Small"
                                           Class="pp-dc-toggle"
                                           Title="@(IsGroupFullyExpanded(worlds) ? "Collapse worlds" : "Expand worlds")"
                                           OnClick="() => ToggleDataCenter(worlds)" />
                            <small>@dcGroup.Count() worlds · @dcGroup.Sum(w => w.TotalCost).ToString("N0")g</small>
                        </div>

                        @foreach (var world in worlds)
                        {
                            @RenderWorldNode(world)
                        }
                    </section>
                }

                @if (vendorCard != null)
                {
                    <section class="pp-dc-group">
                        <div class="pp-dc-header is-vendor">
                            <span>Vendor</span>
                            <MudIconButton Icon="@(_expandedWorlds.Contains(GetWorldKey(vendorCard)) ? Icons.Material.Filled.UnfoldLess : Icons.Material.Filled.UnfoldMore)"
                                           Size="Size.Small"
                                           Class="pp-dc-toggle"
                                           Title="@(_expandedWorlds.Contains(GetWorldKey(vendorCard)) ? "Collapse vendor" : "Expand vendor")"
                                           OnClick="() => ToggleWorld(vendorCard)" />
                            <small>@vendorCard.ItemCount items · @vendorCard.TotalCost.ToString("N0")g</small>
                        </div>
                        @RenderWorldNode(vendorCard)
                    </section>
                }

                @if (errorItems.Any())
                {
                    <section class="pp-error-group">
                        <div class="pp-dc-header is-error">
                            <span>Needs Attention</span>
                            <small>@errorItems.Count items</small>
                        </div>
                        @foreach (var plan in errorItems)
                        {
                            <div class="pp-error-row">
                                <span>@plan.Name</span>
                                <span>@plan.Error</span>
                            </div>
                        }
                    </section>
                }

                @if (warningItems.Any())
                {
                    <section class="pp-error-group">
                        <div class="pp-dc-header">
                            <span>Warnings</span>
                            <small>@warningItems.Count items</small>
                        </div>
                        @foreach (var plan in warningItems)
                        {
                            <div class="pp-error-row">
                                <span>@plan.Name</span>
                                <span>@plan.MarketDataWarning</span>
                            </div>
                        }
                    </section>
                }
            </div>
        }
    </div>
</div>

@code {
    [Parameter] public List<DetailedShoppingPlan> ShoppingPlans { get; set; } = new();
    [Parameter] public EventCallback<WorldProcurementCardModel> OnReanalyzeWithoutWorldRequested { get; set; }
    [Parameter] public EventCallback<WorldItemProcurementAction> OnExcludeWorldForItemRequested { get; set; }
    [Parameter] public EventCallback<WorldItemProcurementAction> OnRefreshItemRequested { get; set; }

    private readonly HashSet<string> _expandedWorlds = new(StringComparer.OrdinalIgnoreCase);

    protected override void OnParametersSet()
    {
        ShoppingPlans ??= new List<DetailedShoppingPlan>();

        if (_expandedWorlds.Count == 0)
        {
            foreach (var world in GetRouteCards().Take(3))
            {
                _expandedWorlds.Add(GetWorldKey(world));
            }
        }
    }

    private RenderFragment RenderWorldNode(WorldProcurementCardModel world) => @<div class="pp-world-node @(world.IsVendor ? "is-vendor" : null) @(world.IsCongested ? "is-congested" : null)">
        <button class="pp-world-row" type="button" @onclick="() => ToggleWorld(world)">
            <span class="pp-world-main">
                <MudIcon Icon="@(world.IsVendor ? Icons.Material.Filled.Store : Icons.Material.Filled.Public)" Size="Size.Small" />
                <span class="pp-world-name">@world.WorldName</span>
                @if (world.HasSplitPurchases)
                {
                    <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Class="pp-split-icon" />
                }
                @if (world.IsCongested)
                {
                    <span class="pp-congested-label">Congested</span>
                }
            </span>
            <span class="pp-world-meta">@world.ItemCount items</span>
            <span class="pp-world-meta">@world.TotalQuantity qty</span>
            <span class="pp-world-cost">@world.TotalCost.ToString("N0")g</span>
            <MudIcon Icon="@(_expandedWorlds.Contains(GetWorldKey(world)) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
        </button>

        @if (_expandedWorlds.Contains(GetWorldKey(world)))
        {
            <div class="pp-item-table">
                <div class="pp-item-header">
                    <span>Item</span>
                    <span>Qty</span>
                    <span>Unit</span>
                    <span>Total</span>
                    <span></span>
                </div>

                @foreach (var item in world.Items.OrderBy(i => i.ItemName))
                {
                    <div class="pp-item-row">
                        <span class="pp-item-main">
                            @if (item.IsSplitPurchase)
                            {
                                <MudIcon Icon="@Icons.Material.Filled.CallSplit" Size="Size.Small" Class="pp-split-icon" />
                            }
                            <button class="pp-item-link" type="button" @onclick="() => GoToMarketAnalysis(item)">
                                @item.ItemName
                            </button>
                            @if (world.IsVendor && item.Vendor != null)
                            {
                                <small>@item.Vendor.Name - @item.Vendor.Location</small>
                            }
                        </span>
                        <span>@(world.IsVendor || !item.IsSplitPurchase ? item.SimpleQuantityDisplay : item.QuantityDisplay)</span>
                        <span>@item.PriceDisplay</span>
                        <span class="pp-item-total">@item.TotalCost.ToString("N0")g</span>
                        <span class="pp-item-actions">
                            @if (!world.IsVendor)
                            {
                                <MudIconButton Icon="@Icons.Material.Filled.Block"
                                               Size="Size.Small"
                                               Class="pp-copy-button"
                                               Title="Exclude this world's listings for this item"
                                               OnClick="() => ExcludeWorldForItem(world, item)" />
                                <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                               Size="Size.Small"
                                               Class="pp-copy-button"
                                               Title="Refresh market data for this item"
                                               OnClick="() => RefreshItem(world, item)" />
                            }
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Size="Size.Small"
                                           Class="pp-copy-button"
                                           Title="Copy item name"
                                           OnClick="() => CopyItemName(item.ItemName)" />
                        </span>
                    </div>
                }

                @if (!world.IsVendor)
                {
                    <div class="pp-world-warning">
                        <span>@(world.IsCongested ? "Cannot travel to congested worlds." : "World unavailable or listings stale?")</span>
                        <MudButton Size="Size.Small"
                                   Variant="Variant.Outlined"
                                   Color="Color.Warning"
                                   OnClick="() => ReanalyzeWithoutWorld(world)">
                            Exclude @world.WorldName
                        </MudButton>
                    </div>
                }
            </div>
        }
    </div>;

    private void ToggleWorld(WorldProcurementCardModel world)
    {
        var key = GetWorldKey(world);
        if (!_expandedWorlds.Add(key))
        {
            _expandedWorlds.Remove(key);
        }
    }

    private bool IsGroupFullyExpanded(IEnumerable<WorldProcurementCardModel> worlds)
    {
        var worldList = worlds.ToList();
        return worldList.Any() && worldList.All(world => _expandedWorlds.Contains(GetWorldKey(world)));
    }

    private void ToggleDataCenter(IEnumerable<WorldProcurementCardModel> worlds)
    {
        var worldList = worlds.ToList();
        if (IsGroupFullyExpanded(worldList))
        {
            foreach (var world in worldList)
            {
                _expandedWorlds.Remove(GetWorldKey(world));
            }

            return;
        }

        foreach (var world in worldList)
        {
            _expandedWorlds.Add(GetWorldKey(world));
        }
    }

    private async Task ReanalyzeWithoutWorld(WorldProcurementCardModel world)
    {
        await OnReanalyzeWithoutWorldRequested.InvokeAsync(world);
    }

    private async Task ExcludeWorldForItem(WorldProcurementCardModel world, WorldItemPurchase item)
    {
        await OnExcludeWorldForItemRequested.InvokeAsync(new WorldItemProcurementAction
        {
            World = world,
            Item = item
        });
    }

    private async Task RefreshItem(WorldProcurementCardModel world, WorldItemPurchase item)
    {
        await OnRefreshItemRequested.InvokeAsync(new WorldItemProcurementAction
        {
            World = world,
            Item = item
        });
    }

    private async Task CopyItemName(string itemName)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", itemName);
    }

    private void GoToMarketAnalysis(WorldItemPurchase item)
    {
        AppState.AutoExpandItemId = item.ItemId;
        NavigationManager.NavigateTo("market");
    }

    private decimal GetTotalCost()
    {
        return ShoppingPlans.Sum(PurchaseRecommendationCost.GetRecommendedCost);
    }

    private IEnumerable<DetailedShoppingPlan> GetItemsWithErrors()
    {
        return ShoppingPlans.Where(p => !string.IsNullOrEmpty(p.Error));
    }

    private IEnumerable<DetailedShoppingPlan> GetItemsWithWarnings()
    {
        return ShoppingPlans.Where(p => string.IsNullOrEmpty(p.Error) && !string.IsNullOrEmpty(p.MarketDataWarning));
    }

    private List<WorldProcurementCardModel> GetRouteCards()
    {
        if (!ShoppingPlans.Any())
            return new List<WorldProcurementCardModel>();

        return ProcurementWorldCardBuilder.BuildWorldCards(ShoppingPlans, AppState.SelectedDataCenter);
    }

    private static string GetWorldKey(WorldProcurementCardModel world)
    {
        return ProcurementWorldCardBuilder.GetWorldKey(world);
    }
}
