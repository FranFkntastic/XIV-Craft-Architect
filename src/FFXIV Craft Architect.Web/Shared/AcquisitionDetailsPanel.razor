@using FFXIV_Craft_Architect.Core.Helpers
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject NavigationManager NavigationManager

<div class="rp-column">
    @if (Node == null && Row == null)
    {
        <div class="rp-empty-state">
            <div class="rp-empty-title">Acquisition Details</div>
            <div class="rp-empty-subtitle">Select a recipe node to review acquisition options.</div>
        </div>
    }
    else
    {
        <div class="rp-panel">
            <div class="rp-panel-header">
                <div class="rp-header-title">Acquisition Details</div>
                @if (CanOpenMarketAnalysis)
                {
                    <button type="button"
                            class="rp-header-action"
                            title="Open this item in Market Analysis"
                            @onclick="GoToMarketAnalysis">
                        Market
                    </button>
                }
            </div>
            <div class="rp-details-wrap">
                <div class="rp-item-name">@ItemName</div>
                <div class="rp-item-meta">Quantity: @DisplayQuantity</div>

                <div class="rp-detail-row">
                    <span class="rp-detail-label">Current source</span>
                    <span class="rp-detail-value" style="color: @RecipePlanDisplayHelpers.GetSourceHexColor(CurrentSource)">
                        @RecipePlanDisplayHelpers.GetSourceDisplayName(CurrentSource)
                    </span>
                </div>
            </div>
        </div>

        @if (IsMarketUnavailable)
        {
            <div class="rp-warning-block">
                <div class="rp-warning-title">Market data unavailable</div>
                <div>This item was not included in market pricing.</div>
            </div>
        }

        <div class="rp-panel">
            <div class="rp-panel-header">
                <div class="rp-header-title">Acquisition Options</div>
            </div>
            <div class="rp-details-wrap">
                <div class="rp-method-list">
                    @foreach (var option in GetOptions())
                    {
                        <button class="@GetOptionClass(option)"
                                title="@(option.IsProjectedUnsupported ? ProjectedUnsupportedOptionTooltip : null)"
                                disabled="@(!option.IsAvailable)"
                                @onclick="() => SelectSource(option.Source)">
                            <span class="rp-method-main">
                                <span class="rp-method-name">@option.Name</span>
                                <span class="rp-method-detail">@option.Detail</span>
                            </span>
                            <span class="rp-method-cost @(option.IsProjectedUnsupported ? "projected-unsupported" : null)">@option.CostText</span>
                        </button>
                    }
                </div>
            </div>
        </div>

        <ShoppingListPanel
            CurrentPlan="@CurrentPlan"
            Materials="@ActiveProcurementItems"
            UnavailableMarketItems="@UnavailableMarketItems" />
    }
</div>

@code {
    [Parameter] public PlanNode? Node { get; set; }
    [Parameter] public DecisionRow? Row { get; set; }
    [Parameter] public CraftingPlan? CurrentPlan { get; set; }
    [Parameter] public DetailedShoppingPlan? MarketPlan { get; set; }
    [Parameter] public IReadOnlyList<DetailedShoppingPlan> MarketPlans { get; set; } = Array.Empty<DetailedShoppingPlan>();
    [Parameter] public AcquisitionCostContext CostContext { get; set; } =
        AcquisitionPlanningService.CreateCostContext(Array.Empty<DetailedShoppingPlan>());
    [Parameter] public IReadOnlyList<MaterialAggregate>? ActiveProcurementItems { get; set; }
    [Parameter] public IReadOnlyList<CoreMarketDataUnavailableItem> UnavailableMarketItems { get; set; } = Array.Empty<CoreMarketDataUnavailableItem>();
    [Parameter] public EventCallback<AcquisitionSourceChangeRequest> OnSourceChanged { get; set; }

    private int ItemId => Row?.ItemId ?? Node?.ItemId ?? 0;
    private string ItemName => Row?.ItemName ?? Node?.Name ?? string.Empty;
    private int DisplayQuantity => Row == null ? Node?.Quantity ?? 0 : AcquisitionEvaluationCostCalculator.GetCostQuantity(Row);
    private AcquisitionSource CurrentSource => Row?.Source ?? Node?.Source ?? AcquisitionSource.UnknownSource;
    private bool CanCraft => Row?.CanCraft ?? Node?.CanCraft ?? false;
    private bool HasChildren => Row?.HasChildren ?? Node?.Children.Any() ?? false;
    private bool CanBuyFromMarket => Row?.CanBuyFromMarket ?? Node?.CanBuyFromMarket ?? false;
    private bool MustBeHq => Row?.MustBeHq ?? Node?.MustBeHq ?? false;
    private bool CanBeHq => Row?.CanBeHq ?? Node?.CanBeHq ?? false;
    private bool CanBuyFromVendor => Row?.CanBuyFromVendor ?? Node?.CanBuyFromVendor ?? false;
    private decimal HqUnitPrice => Row?.HqUnitPrice ?? Node?.HqMarketPrice ?? 0;
    private decimal UnitPrice => Row?.UnitPrice ?? Node?.MarketPrice ?? 0;
    private IReadOnlyList<RecipeDemandVendorOption> VendorOptions => Row?.VendorOptions ?? GetNodeVendorOptions();
    private bool IsMarketUnavailable => ItemId != 0 && UnavailableMarketItems.Any(i => i.ItemId == ItemId);
    private bool CanOpenMarketAnalysis => ItemId != 0 && MarketPlans.Any(plan => plan.ItemId == ItemId);
    private const string ProjectedUnsupportedOptionTooltip = "This is a projected cost. The current search scope cannot support this purchase.";

    private async Task SelectSource(AcquisitionSource source)
    {
        if (Node == null)
        {
            return;
        }

        await OnSourceChanged.InvokeAsync(new AcquisitionSourceChangeRequest(Node, source));
    }

    private void GoToMarketAnalysis()
    {
        if (ItemId == 0)
        {
            return;
        }

        AppState.RequestMarketItemAutoExpand(ItemId);
        NavigationManager.NavigateTo("market");
    }

    private List<AcquisitionOptionView> GetOptions()
    {
        var options = new List<AcquisitionOptionView>();
        if (Node == null)
        {
            return options;
        }

        if (HasChildren && CanCraft)
        {
            var hasCraftCost = TryGetOptionCost(AcquisitionSource.Craft, out var craftCost);
            options.Add(new AcquisitionOptionView(
                AcquisitionSource.Craft,
                "Craft",
                MarketPlans.Any()
                    ? "Uses the recipe tree with market evidence for child purchases."
                    : "Uses the recipe tree below this item.",
                hasCraftCost ? $"{craftCost:N0}g" : "-",
                true,
                IsProjectedUnsupported: false));
        }

        if (CanBuyFromMarket)
        {
            if (!MustBeHq)
            {
                var hasNqMarketCost = TryGetOptionCost(AcquisitionSource.MarketBuyNq, out var nqMarketCost);
                var isProjectedUnsupported = IsProjectedUnsupportedOption(AcquisitionSource.MarketBuyNq);
                options.Add(new AcquisitionOptionView(
                    AcquisitionSource.MarketBuyNq,
                    "Buy NQ",
                    GetMarketPlanDetail("NQ"),
                    hasNqMarketCost ? $"{nqMarketCost:N0}g" : "-",
                    hasNqMarketCost && !isProjectedUnsupported,
                    isProjectedUnsupported));
            }

            if (CanBeHq)
            {
                var hasHqMarketCost = TryGetOptionCost(AcquisitionSource.MarketBuyHq, out var hqMarketCost);
                var isProjectedUnsupported = IsProjectedUnsupportedOption(AcquisitionSource.MarketBuyHq);
                options.Add(new AcquisitionOptionView(
                    AcquisitionSource.MarketBuyHq,
                    "Buy HQ",
                    GetMarketPlanDetail("HQ"),
                    hasHqMarketCost ? $"{hqMarketCost:N0}g" : "-",
                    hasHqMarketCost && !isProjectedUnsupported,
                    isProjectedUnsupported));
            }
        }

        if (CanBuyFromVendor)
        {
            var hasVendorCost = TryGetOptionCost(AcquisitionSource.VendorBuy, out var vendorCost);
            options.Add(new AcquisitionOptionView(
                AcquisitionSource.VendorBuy,
                "Vendor",
                GetVendorDetail(),
                hasVendorCost ? $"{vendorCost:N0}g" : "-",
                hasVendorCost,
                IsProjectedUnsupported: false));
        }

        if (!CanBuyFromMarket && !CanBuyFromVendor && !HasChildren)
        {
            options.Add(new AcquisitionOptionView(
                AcquisitionSource.UnknownSource,
                "Figure it out",
                "No supported craft, market, or vendor source is known.",
                "-",
                true,
                IsProjectedUnsupported: false));
        }

        return options;
    }

    private string GetOptionClass(AcquisitionOptionView option)
    {
        var classes = new List<string> { "rp-method-row" };
        if (CurrentSource == option.Source)
        {
            classes.Add("selected");
        }

        if (option.IsProjectedUnsupported)
        {
            classes.Add("projected-unsupported");
        }

        return string.Join(" ", classes);
    }

    private string GetMarketPlanDetail(string quality)
    {
        var marketPlan = MarketPlan;
        if (marketPlan == null && ItemId != 0)
        {
            CostContext.TryGetShoppingPlan(ItemId, out marketPlan);
        }

        var hqOnly = quality == "HQ";
        var estimate = MarketPurchaseCostProjectionService.Estimate(
            marketPlan,
            DisplayQuantity,
            hqOnly,
            includeVendor: false);
        if (estimate.IsUnsupportedProjection)
        {
            return "Projected cost; current search scope cannot fill this purchase.";
        }

        if (estimate.World != null)
        {
            return $"{estimate.World.WorldName} can cover {estimate.World.TotalQuantityPurchased}/{marketPlan?.QuantityNeeded}.";
        }

        var recommendedSplit = marketPlan?.RecommendedSplit;
        if (estimate.Kind == MarketPurchaseCostEstimateKind.SupportedEvidence &&
            recommendedSplit != null &&
            recommendedSplit.Sum(split => split.QuantityToBuy) >= DisplayQuantity)
        {
            return $"{recommendedSplit.Count} world split can cover market purchase.";
        }

        if (!string.IsNullOrWhiteSpace(marketPlan?.Error))
        {
            return marketPlan.Error;
        }

        if (AppState.IsMarketEvidenceHydrating)
        {
            return "Refreshing current market price...";
        }

        if ((hqOnly ? HqUnitPrice : UnitPrice) > 0)
        {
            return "Current market price was unavailable after automatic refresh.";
        }

        return "Run Market Analysis for actionable market evidence.";
    }

    private string GetVendorDetail()
    {
        if (VendorOptions.Any(vendor => vendor.IsGilVendor) != true)
        {
            return "No gil vendor price loaded.";
        }

        var vendor = VendorOptions
            .Where(vendor => vendor.IsGilVendor)
            .OrderBy(vendor => vendor.Price)
            .First();

        return $"{vendor.Name} - {vendor.Location}";
    }

    private bool TryGetOptionCost(AcquisitionSource source, out decimal cost)
    {
        if (Node == null)
        {
            cost = 0;
            return false;
        }

        if (Row != null)
        {
            return AcquisitionEvaluationCostCalculator.TryGetCost(Row, source, CostContext, out cost);
        }

        return AcquisitionPlanningService.TryGetAcquisitionCost(Node, source, CostContext, out cost);
    }

    private bool IsProjectedUnsupportedOption(AcquisitionSource source)
    {
        var hqOnly = source == AcquisitionSource.MarketBuyHq;
        if (source is not (AcquisitionSource.MarketBuyNq or AcquisitionSource.MarketBuyHq))
        {
            return false;
        }

        var marketPlan = MarketPlan;
        if (marketPlan == null && ItemId != 0)
        {
            CostContext.TryGetShoppingPlan(ItemId, out marketPlan);
        }

        return MarketPurchaseCostProjectionService
            .Estimate(marketPlan, DisplayQuantity, hqOnly, includeVendor: false)
            .IsUnsupportedProjection;
    }

    private IReadOnlyList<RecipeDemandVendorOption> GetNodeVendorOptions()
    {
        if (Node == null)
        {
            return Array.Empty<RecipeDemandVendorOption>();
        }

        return Node.VendorOptions
            .Select(vendor => new RecipeDemandVendorOption(
                vendor.Name,
                vendor.Location,
                vendor.Price,
                vendor.Currency))
            .ToList();
    }

    private record AcquisitionOptionView(
        AcquisitionSource Source,
        string Name,
        string Detail,
        string CostText,
        bool IsAvailable,
        bool IsProjectedUnsupported);
}
