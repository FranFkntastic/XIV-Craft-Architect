@using FFXIV_Craft_Architect.Core.Helpers
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services
@inject NavigationManager NavigationManager

<div class="rp-column">
    @if (Row == null)
    {
        <div class="rp-empty-state">
            <div class="rp-empty-title">Acquisition Details</div>
            <div class="rp-empty-subtitle">Select a recipe node to review acquisition options.</div>
        </div>
    }
    else
    {
        <div class="rp-panel">
            <div class="rp-panel-header">
                <div class="rp-header-title">Acquisition Details</div>
                <div class="rp-header-actions">
                    @if (Row.IsMarketCandidate)
                    {
                        <button type="button"
                                class="rp-header-action"
                                title="Open this item in Market Analysis"
                                @onclick="GoToMarketAnalysis">
                            Market
                        </button>
                    }
                </div>
            </div>
            <div class="rp-details-wrap">
                <div class="rp-item-name">@Row.ItemName</div>
                <div class="rp-item-meta">Quantity: @Row.TotalQuantity</div>

                <div class="rp-detail-row">
                    <span class="rp-detail-label">Current source</span>
                    <span class="rp-detail-value" style="color: @RecipePlanDisplayHelpers.GetSourceHexColor(Row.Source)">
                        @RecipePlanDisplayHelpers.GetSourceDisplayName(Row.Source)
                    </span>
                </div>
            </div>
        </div>

        @if (Row.IsMarketUnavailable)
        {
            <div class="rp-warning-block">
                <div class="rp-warning-title">Market data unavailable</div>
                <div>This item was not included in market pricing.</div>
            </div>
        }

        <div class="rp-panel">
            <div class="rp-panel-header">
                <div class="rp-header-title">Acquisition Options</div>
            </div>
            <div class="rp-details-wrap">
                <div class="rp-method-list">
                    @foreach (var option in Row.Options)
                    {
                        <button class="@GetOptionClass(option)"
                                title="@(option.IsProjectedUnsupported ? ProjectedUnsupportedOptionTooltip : null)"
                                disabled="@(!option.IsAvailable)"
                                @onclick="() => SelectSource(option.Source)">
                            <span class="rp-method-main">
                                <span class="rp-method-name">@option.Name</span>
                                <span class="rp-method-detail">@option.Detail</span>
                            </span>
                            <span class="rp-method-cost @(option.IsProjectedUnsupported ? "projected-unsupported" : null)">@option.CostText</span>
                        </button>
                    }
                </div>
            </div>
        </div>

        <ShoppingListPanel
            HasPlan="HasPlan"
            TargetCount="TargetCount"
            Materials="ActiveProcurementItems"
            UnavailableMarketItems="UnavailableMarketItems" />
    }
</div>

@code {
    [Parameter] public WorkerAcquisitionRowProjection? Row { get; set; }
    [Parameter] public bool HasPlan { get; set; }
    [Parameter] public int TargetCount { get; set; }
    [Parameter] public IReadOnlyList<MaterialAggregate>? ActiveProcurementItems { get; set; }
    [Parameter] public IReadOnlyList<CoreMarketDataUnavailableItem> UnavailableMarketItems { get; set; } =
        Array.Empty<CoreMarketDataUnavailableItem>();
    [Parameter] public EventCallback<AcquisitionSource> OnSourceChanged { get; set; }

    private const string ProjectedUnsupportedOptionTooltip =
        "This is a projected cost. The current search scope cannot support this purchase.";

    private Task SelectSource(AcquisitionSource source) =>
        OnSourceChanged.InvokeAsync(source);

    private void GoToMarketAnalysis()
    {
        if (Row is not null)
        {
            NavigationManager.NavigateTo($"/market?itemId={Row.ItemId}");
        }
    }

    private string GetOptionClass(WorkerAcquisitionOptionProjection option)
    {
        var classes = new List<string> { "rp-method-row" };
        if (Row?.Source == option.Source)
        {
            classes.Add("selected");
        }
        if (option.IsProjectedUnsupported)
        {
            classes.Add("projected-unsupported");
        }
        return string.Join(" ", classes);
    }
}
