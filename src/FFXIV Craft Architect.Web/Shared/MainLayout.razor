@inherits LayoutComponentBase
@using FFXIV_Craft_Architect.Web.Services
@using FFXIV_Craft_Architect.Web.Dialogs
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@inject NavigationManager NavigationManager
@inject AppState AppState
@inject ISettingsService Settings
@inject WebPlanPersistenceService PlanPersistence
@inject PackagedWorldDirectoryService PackagedWorldDirectory
@inject StartupInitializationService StartupInitialization
@inject CraftArchitectEngineHost EngineHost
@inject WorkerProjectionStore WorkerProjections
@inject WorkerSessionCoordinator WorkerSession
@inject IJSRuntime JSRuntime
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject RecipeCalculationService RecipeService
@inject UniversalisService UniversalisService
@inject NativePlanImportClassifier NativePlanImportClassifier
@inject RecipePlanDiagnosticDumpService RecipePlanDiagnosticDumpService
@inject ILogger<MainLayout> Logger
@implements IDisposable

<MudThemeProvider @ref="_mudThemeProvider" Theme="_theme" @bind-IsDarkMode="_isDarkMode" />
@if (AppState.SecretDebugToolsEnabled)
{
    var recipeProbe = WorkerProjections.Recipe;
    var marketProbe = WorkerProjections.Market;
    var routeProbe = WorkerProjections.Procurement;
    var workerBusy = EngineHost.Health.IsExecuting;
    <div data-benchmark-id="operation-lifecycle"
         hidden
         data-plan-session-version="@WorkerProjections.Shell.PlanSessionVersion"
         data-plan-root-count="@(recipeProbe?.Roots.Count ?? 0)"
         data-plan-node-count="@CountRecipeNodes(recipeProbe?.Roots)"
         data-plan-edge-count="@CountRecipeEdges(recipeProbe?.Roots)"
         data-market-candidate-count="@(marketProbe?.CandidateCount ?? WorkerProjections.Acquisition?.MarketCandidateCount ?? 0)"
         data-plan-leaf-item-ids="@string.Join(",", GetRecipeLeafItemIds(recipeProbe?.Roots))"
         data-market-analysis-count="@WorkerProjections.Shell.MarketAnalysisCount"
         data-market-intelligence-id="@WorkerProjections.Shell.Versions.MarketAnalysisVersion"
         data-publication-plan-session-version="@WorkerProjections.Shell.PlanSessionVersion"
         data-publication-market-version="@WorkerProjections.Shell.Versions.MarketAnalysisVersion"
         data-publication-kind="@(marketProbe?.HasAnalysis == true ? "Known" : "None")"
         data-route-validity="@(routeProbe?.HasRoute == true ? "Current" : "None")"
         data-route-has-decision="@BoolText(routeProbe?.HasRoute == true)"
         data-route-failure=""
         data-route-reconciling="@BoolText(false)"
         data-route-reconciliation-scheduled="@BoolText(false)"
         data-is-busy="@BoolText(workerBusy)"
         data-progress-percent="@(workerBusy ? 1 : 0)"
         data-current-operation="@(workerBusy ? "Worker command" : null)"
         data-status-message="@(workerBusy ? "Working" : "Ready")"
         data-active-workflows="@(workerBusy ? "Worker" : null)"
         data-dirty-persisted-buckets="">
    </div>
}
<MudDialogProvider />
<MudSnackbarProvider MaxDisplayedSnackbars="3" 
                     SnackbarDefaults="new SnackbarOptions { ShowCloseIcon = false, HideIcon = true }" />

<MudLayout Style="height: 100vh; display: flex; flex-direction: column;">
    <!-- Title Bar with Menu - Fixed at top -->
    <MudAppBar Elevation="0" Style="@GetAppBarStyle()">
        <MudMenu Dense="true"
                 AnchorOrigin="Origin.BottomLeft"
                 TransformOrigin="Origin.TopLeft"
                 Color="Color.Secondary">
            <ActivatorContent>
                <MudButton Style="@GetWorkspaceButtonStyle()"
                           Size="Size.Medium"
                           EndIcon="@Icons.Material.Filled.KeyboardArrowDown">
                    @GetWorkspaceTitle()
                </MudButton>
            </ActivatorContent>
            <ChildContent>
                <MudMenuItem OnClick="@(() => NavigateTo(""))" Icon="@Icons.Material.Filled.Build">
                    FFXIV Craft Architect
                </MudMenuItem>
                <MudMenuItem OnClick="@(() => NavigateTo("trade/orders"))" Icon="@Icons.Material.Filled.Payments">
                    FFXIV Trade Architect
                </MudMenuItem>
            </ChildContent>
        </MudMenu>
        
        <!-- Navigation Tabs -->
        <MudButtonGroup Size="Size.Small" Style="margin-right: 24px;">
            @if (IsTradeMode)
            {
                <MudButton OnClick="@(() => NavigateTo("trade/orders"))"
                           Color="@GetTabColor("orders")"
                           Variant="@GetTabVariant("orders")"
                           Style="@GetTabStyle("orders")">
                    Orders
                </MudButton>
                <MudButton OnClick="@(() => NavigateTo("trade/crafters"))"
                           Color="@GetTabColor("crafters")"
                           Variant="@GetTabVariant("crafters")"
                           Style="@GetTabStyle("crafters")">
                    Crafters
                </MudButton>
            }
            else
            {
                <MudButton OnClick="@(() => NavigateTo(""))"
                           Color="@GetTabColor("planner")"
                           Variant="@GetTabVariant("planner")">
                    Recipe Planner
                </MudButton>
                <MudButton OnClick="@(() => NavigateTo("market"))"
                           Color="@GetTabColor("market")"
                           Variant="@GetTabVariant("market")"
                           data-benchmark-id="@BenchmarkHook("main-nav-market-analysis")">
                    Market Analysis
                </MudButton>
                <MudButton OnClick="@(() => NavigateTo("acquisition"))"
                           Color="@GetTabColor("acquisition")"
                           Variant="@GetTabVariant("acquisition")">
                    Acquisition Evaluation
                </MudButton>
                <MudButton OnClick="@(() => NavigateTo("procurement"))"
                           Color="@GetTabColor("procurement")"
                           Variant="@GetTabVariant("procurement")">
                    Procurement Plan
                </MudButton>
            }
        </MudButtonGroup>
        
        <!-- Menu Bar using MudMenu -->
        <div style="display: flex; gap: 4px; flex-shrink: 0;">
            <MudMenu Dense="true" 
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Color="Color.Secondary">
                <ActivatorContent>
                    <MudButton Style="color: #cccccc; text-transform: none;" 
                               EndIcon="@Icons.Material.Filled.KeyboardArrowDown">File</MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="OnNewPlan" Icon="@Icons.Material.Filled.Add">New Plan</MudMenuItem>
                    <MudMenuItem OnClick="OnOpenPlanBrowser" Icon="@Icons.Material.Filled.FolderOpen">Plan Browser...</MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="OnViewLogs" Icon="@Icons.Material.Filled.Info">Session Status</MudMenuItem>
                </ChildContent>
            </MudMenu>
            
            <MudMenu Dense="true"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Color="Color.Secondary">
                <ActivatorContent>
                    <MudButton Style="color: #cccccc; text-transform: none;"
                               EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                               data-benchmark-id="@BenchmarkHook("main-import-menu")">Import</MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="() => ShowImportDialog(0)"
                                 Icon="@Icons.Material.Filled.FolderOpen"
                                 data-benchmark-id="@BenchmarkHook("main-import-native-plan")">
                        From Craft Architect (Native)...
                    </MudMenuItem>
                    <MudMenuItem OnClick="() => ShowImportDialog(1)" Icon="@Icons.Material.Filled.ContentPaste">
                        From Teamcraft (Text)...
                    </MudMenuItem>
                    <MudMenuItem OnClick="() => ShowImportDialog(2)" Icon="@Icons.Material.Filled.Code">
                        From Artisan (JSON)...
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
            
            <MudMenu Dense="true"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Color="Color.Secondary">
                <ActivatorContent>
                    <MudButton Style="color: #cccccc; text-transform: none;"
                               EndIcon="@Icons.Material.Filled.KeyboardArrowDown">Export</MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="OnExportNative" Icon="@Icons.Material.Filled.FolderOpen">
                        To Craft Architect (Native)...
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="OnExportTeamcraft" Icon="@Icons.Material.Filled.Link">
                        To Teamcraft URL...
                    </MudMenuItem>
                    <MudMenuItem OnClick="OnExportArtisan" Icon="@Icons.Material.Filled.Code">
                        To Artisan (JSON)...
                    </MudMenuItem>
                    <MudDivider />
                    <MudMenuItem OnClick="OnCopyPlainText" Icon="@Icons.Material.Filled.ContentCopy">
                        Copy as Plain Text
                    </MudMenuItem>
                    <MudMenuItem OnClick="OnCopyCsv" Icon="@Icons.Material.Filled.GridOn">
                        Copy as CSV
                    </MudMenuItem>
                </ChildContent>
            </MudMenu>
            
            <MudMenu Dense="true"
                     AnchorOrigin="Origin.BottomLeft"
                     TransformOrigin="Origin.TopLeft"
                     Color="Color.Secondary">
                <ActivatorContent>
                    <MudButton Style="color: #cccccc; text-transform: none;"
                               EndIcon="@Icons.Material.Filled.KeyboardArrowDown">Tools</MudButton>
                </ActivatorContent>
                <ChildContent>
                    <MudMenuItem OnClick="OnOptions" Icon="@Icons.Material.Filled.Settings">
                        Options...
                    </MudMenuItem>
                    @if (IsDebugToolsAvailable)
                    {
                        <MudDivider />
                        <MudMenuItem OnClick="OnLoadDevCraftPlanFixture" Icon="@Icons.Material.Filled.BugReport">
                            Load Dev Craftplan...
                        </MudMenuItem>
                        <MudMenuItem OnClick="ToggleDebugToolsMenu"
                                     Icon="@Icons.Material.Filled.BugReport"
                                     AutoClose="false">
                            <div style="display: flex; align-items: center; justify-content: space-between; width: 100%; gap: 24px;">
                                <span>Developer</span>
                                <MudIcon Icon="@(_debugToolsMenuOpen ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                         Size="Size.Small" />
                            </div>
                        </MudMenuItem>
                        @if (_debugToolsMenuOpen)
                        {
                            <MudMenuItem OnClick="OnDumpRecipePlanDiagnostics"
                                         Icon="@Icons.Material.Filled.Assignment"
                                         Style="padding-left: 32px;">
                                Dump Recipe Plan Pricing State
                            </MudMenuItem>
                        }
                    }
                </ChildContent>
            </MudMenu>
        </div>
        
        <MudSpacer />

        <MudLink Href="https://github.com/FranFkntastic/XIV-Craft-Architect"
                 Target="_blank" 
                 Style="color: #d4a73a; text-decoration: none; font-size: 14px;">GitHub</MudLink>
    </MudAppBar>
    
    <MudMainContent Class="ca-main-content" Style="background-color: #1e1e1e; flex: 1; overflow-y: auto; overflow-x: hidden;">
        @Body
    </MudMainContent>
    
    <!-- Status Bar -->
    <StatusBar />
</MudLayout>

<StartupLoadingOverlay Status="StartupInitialization.Status"
                       OnContinue="StartupInitialization.ContinueAfterWarning" />

@code {
    private bool _isDarkMode = true;
    private MudThemeProvider _mudThemeProvider = null!;
    private string _activeTab = "market";
    private bool _disposed = false;
    private bool _resetMainScrollAfterRender;
    private bool _debugToolsMenuOpen;
    private bool IsDebugToolsAvailable => AppState.SecretDebugToolsEnabled;
    private bool IsTradeMode => IsTradeRoute(NavigationManager.Uri);
    private string? BenchmarkHook(string id) => AppState.SecretDebugToolsEnabled ? id : null;
    
    private readonly MudTheme _theme = AppTheme.CreateTheme();

    protected override void OnInitialized()
    {
        Console.WriteLine("[DIAG] MainLayout.OnInitialized()");
        
        // Benchmark runs may defer automatic reconciliation so they can lock a
        // deterministic acquisition fixture before explicitly exercising the route.
        AppState.SetBenchmarkWorkflowDeferral(IsLocalBenchmarkWorkflowRequest());

        // Set initial active tab based on current URL
        UpdateActiveTab(NavigationManager.Uri);
        
        // Listen for navigation changes
        NavigationManager.LocationChanged += OnLocationChanged;
        StartupInitialization.StatusChanged += OnStartupStatusChanged;
        AppState.OnStateChanged += OnAppStateChanged;
        WorkerProjections.Changed += OnWorkerProjectionChanged;
    }
    
    protected override void OnAfterRender(bool firstRender)
    {
        if (firstRender)
        {
            Console.WriteLine("[DIAG] MainLayout.OnAfterRender(firstRender=true)");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_resetMainScrollAfterRender)
        {
            _resetMainScrollAfterRender = false;
            await JSRuntime.InvokeVoidAsync(
                "mudScrollManager.scrollTo",
                ".ca-main-content",
                0,
                0,
                "auto");
        }

        if (firstRender)
        {
            await StartupInitialization.InitializeAsync(new StartupInitializationSteps(
                LoadSettingsAsync: _ => LoadSettingsAsync(),
                BootstrapEngineSessionAsync: BootstrapEngineSessionAsync,
                InitializeWorldDataAsync: _ => AppState.InitializeWorldDataAsync(
                    PackagedWorldDirectory,
                    UniversalisService),
                StartAutoSave: () => { },
                RestoreAutoSaveAsync: _ => RestoreAutoSaveAsync()));
        }
    }

    private async Task BootstrapEngineSessionAsync(CancellationToken cancellationToken)
    {
        await WorkerSession.BootstrapAsync(cancellationToken);
    }

    private void OnStartupStatusChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnWorkerProjectionChanged() =>
        _ = InvokeAsync(StateHasChanged);

    private void OnAppStateChanged(AppStateChange change)
    {
        if (change.HasScope(AppStateChangeScope.Settings) ||
            AppState.SecretDebugToolsEnabled && change.Scopes != AppStateChangeScope.None)
        {
            // The hidden lifecycle probe is hosted by the layout. In developer mode it
            // must follow the same plan/market/procurement/status publications as the
            // feature pages rather than remaining frozen at its last settings render.
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleDebugToolsMenu()
    {
        _debugToolsMenuOpen = !_debugToolsMenuOpen;
    }
    
    private async Task LoadSettingsAsync()
    {
        try
        {
            var autoSave = await Settings.GetAsync("ui.auto_save_enabled", true);
            var defaultDc = await Settings.GetAsync("market.default_datacenter", "Aether") ?? "Aether";
            var region = await Settings.GetAsync("market.region", "North America") ?? "North America";
            var secretDebugToolsEnabled = await Settings.GetAsync("debug.secret_tools_enabled", false);
            var deferAutomaticRoute = await Settings.GetAsync("debug.defer_automatic_route_reconciliation", false);
            var defaultScope = ParseMarketFetchScope(
                await Settings.GetAsync("market.default_search_scope", nameof(MarketFetchScope.EntireRegion)));
            var selectedDataCenter = string.IsNullOrEmpty(AppState.SelectedDataCenter)
                ? defaultDc
                : AppState.SelectedDataCenter;
            var procurementSearchEntireRegion = await Settings.GetAsync("procurement.search_entire_region", true);
            var procurementEnableSplits = await Settings.GetAsync("procurement.enable_split_world_purchases", true);
            var procurementTravelTolerance = await Settings.GetAsync("procurement.travel_tolerance", 0);
            var procurementExclusionDuration = await Settings.GetAsync("procurement.world_exclusion_duration_minutes", 60);
            var procurementStartFromHome = await Settings.GetAsync("procurement.start_from_home_data_center", false);
            var procurementTravelPriority = ParseTravelPriority(
                await Settings.GetAsync(
                    "procurement.travel_priority",
                    nameof(MarketTravelPriority.DataCenterTransfersFirst)));

            AppState.SetAutoSaveEnabled(autoSave);
            AppState.SetSecretDebugToolsEnabled(secretDebugToolsEnabled);
            AppState.SetBenchmarkWorkflowDeferral(
                secretDebugToolsEnabled && deferAutomaticRoute || IsLocalBenchmarkWorkflowRequest());
            AppState.SetMarketEvidenceSettings(
                selectedDataCenter,
                region,
                defaultScope,
                defaultScope == MarketFetchScope.EntireRegion);
            AppState.SetProcurementSettings(
                procurementSearchEntireRegion,
                procurementEnableSplits,
                procurementTravelTolerance,
                procurementExclusionDuration);
            AppState.SetProcurementHomeDataCenterOrigin(procurementStartFromHome);
            AppState.SetProcurementTravelPriority(procurementTravelPriority);
        }
        catch { /* Ignore settings load errors */ }
    }

    private Task<StartupAutoSaveRestoreResult> RestoreAutoSaveAsync()
    {
        var shell = WorkerProjections.Shell;
        if (!shell.HasSession)
        {
            return Task.FromResult(StartupAutoSaveRestoreResult.NoAutoSave());
        }

        Snackbar.Add("Restored previous session", Severity.Info);
        return Task.FromResult(
            StartupAutoSaveRestoreResult.Restored(shell.RestoreWarning));
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        if (_disposed) return;
        
        UpdateActiveTab(e.Location);
        _resetMainScrollAfterRender = true;
        _ = InvokeAsync(StateHasChanged);
    }

    private void UpdateActiveTab(string uri)
    {
        var uriLower = uri.ToLowerInvariant();
        if (IsTradeRoute(uri) && uriLower.Contains("/trade/orders"))
            _activeTab = "orders";
        else if (IsTradeRoute(uri) && uriLower.Contains("/trade/crafters"))
            _activeTab = "crafters";
        else if (IsTradeRoute(uri))
            _activeTab = "orders";
        else if (uriLower.Contains("/procurement"))
            _activeTab = "procurement";
        else if (uriLower.Contains("/acquisition"))
            _activeTab = "acquisition";
        else if (uriLower.Contains("/market"))
            _activeTab = "market";
        else
            _activeTab = "planner";
    }
    
    private bool IsActiveTab(string tab)
    {
        return _activeTab == tab;
    }

    private Color GetTabColor(string tab)
    {
        return IsActiveTab(tab) ? Color.Primary : Color.Secondary;
    }

    private Variant GetTabVariant(string tab)
    {
        return IsActiveTab(tab) ? Variant.Filled : Variant.Text;
    }

    private string? GetTabStyle(string tab)
    {
        if (!IsActiveTab(tab))
        {
            return "text-transform: none;";
        }

        var accent = IsTradeMode ? "#8fbf7f" : "#d4a73a";
        return $"background-color: {accent}; color: #111; font-weight: 700; text-transform: none;";
    }

    private void NavigateTo(string page)
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo(string.IsNullOrEmpty(page) ? "./" : page);
    }

    private bool IsTradeRoute(string uri)
    {
        var relativePath = NavigationManager.ToBaseRelativePath(uri).TrimStart('/');
        return relativePath.StartsWith("trade", StringComparison.OrdinalIgnoreCase);
    }

    private string GetWorkspaceTitle()
    {
        return IsTradeMode ? "FFXIV Trade Architect" : "FFXIV Craft Architect";
    }

    private string GetAppBarStyle()
    {
        var accent = IsTradeMode ? "#8fbf7f" : "#d4a73a";
        return $"background-color: #1a1a1a; border-bottom: 1px solid {accent}; flex-shrink: 0;";
    }

    private string GetWorkspaceButtonStyle()
    {
        var accent = IsTradeMode ? "#8fbf7f" : "#d4a73a";
        return $"color: {accent}; font-size: 1rem; line-height: 1.5; font-weight: 600; margin-right: 24px; text-transform: none; padding-left: 0; padding-right: 0; min-width: 0;";
    }

    // ==================== FILE MENU ====================
    
    private async Task OnNewPlan()
    {
        await WorkerSession.ClearSessionAsync();
        Snackbar.Add("New plan started", Severity.Info);
    }

    private async Task OnOpenPlanBrowser()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Large };
        await DialogService.ShowAsync<PlanBrowserDialog>("Plan Browser", options);
    }
    
    private async Task LoadPlanByIdAsync(string planId)
    {
        try
        {
            var stored = await PlanPersistence.LoadPlanPayloadAsync(planId);
            if (stored == null)
            {
                Snackbar.Add("Plan not found", Severity.Error);
                return;
            }
            await WorkerSession.ReplaceStoredPlanAsync(
                stored,
                trackStoredPlanIdentity: true);
            Snackbar.Add($"Loaded '{stored.Name}'", Severity.Success);
            
            // Navigate to planner if we have a plan
            if (stored.PlanJson != null || stored.ProjectItems.Count > 0)
            {
                // Use relative path (no leading slash) so it resolves against base href correctly
                NavigationManager.NavigateTo("./");
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to load plan: {ex.Message}", Severity.Error);
        }
    }
    
    private async Task RefreshSavedPlansListAsync()
    {
        var summaries = await PlanPersistence.LoadPlanSummariesAsync();
        AppState.ReplaceSavedPlans(summaries.Where(p => p.Id != "autosave"));
    }

    private async Task OnViewLogs()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        DialogService.Show<LogsDialog>("Session Status", options);
    }

    // ==================== IMPORT MENU ====================
    
    private async Task ShowImportDialog(int activeTab)
    {
        var parameters = new DialogParameters { ["ActiveTab"] = activeTab };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Medium };
        var dialog = DialogService.Show<ImportDialog>("Import", parameters, options);
        var result = await dialog.Result;
        
        if (result?.Data is ImportDialog.ImportResult importResult)
        {
            var items = importResult.Items;
            
            // If we have a native plan, restore it fully
            var rebuildNativePlan = importResult.NativePlan != null &&
                await NativePlanImportClassifier.RequiresRecipeGraphBuildAsync(importResult.NativePlan);
            if (importResult.NativePlan != null && !rebuildNativePlan)
            {
                await LoadNativePlanAsync(
                    importResult.NativePlan,
                    $"Imported native plan '{importResult.NativePlan.Name}' with {items.Count} {(items.Count == 1 ? "item" : "items")}",
                    refreshPrices: true,
                    clearCurrentPlanId: true);
            }
            else
            {
                var projectItems = importResult.NativePlan != null
                    ? CraftPlanStateMapper.GetRootProjectItems(importResult.NativePlan)
                    : items
                        .Select(item => new ProjectItem
                        {
                            Id = item.Id,
                            Name = item.Name,
                            IconId = item.IconId,
                            Quantity = item.Quantity,
                            MustBeHq = item.MustBeHq
                        })
                        .ToList();
                await WorkerSession.MutateProjectItemsAsync(
                    new WorkerProjectItemsMutation(
                        "replace",
                        Items: projectItems));
                WorkerRecipeBuildOutcome? importCommandResult = null;
                if (projectItems.Count > 0)
                {
                    importCommandResult = await WorkerSession.BuildRecipeAsync(
                        new WorkerRecipeBuildRequest(
                            projectItems,
                            WorkerProjections.Shell.SelectedDataCenter,
                            WorkerProjections.Shell.SelectedRegion,
                            MarketFetchScope.EntireRegion));
                }

                Snackbar.Add($"Imported {items.Count} {(items.Count == 1 ? "item" : "items")}", Severity.Success);
                if (importCommandResult is not null)
                {
                    if (importCommandResult.Built)
                    {
                        Snackbar.Add("Plan rebuilt from imported items", Severity.Success);
                    }
                    else if (importCommandResult.MessageLevel == RecipePlannerCommandMessageLevel.Error)
                    {
                        Snackbar.Add($"Failed to rebuild plan: {importCommandResult.Message}", Severity.Error);
                    }
                    else
                    {
                        Snackbar.Add(importCommandResult.Message, Severity.Info);
                    }
                }
            }
            
            // Navigate to planner
            if (items.Count > 0)
            {
                // Use relative path (no leading slash) so it resolves against base href correctly
                NavigationManager.NavigateTo("./");
            }
        }
    }

    private async Task OnLoadDevCraftPlanFixture()
    {
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        var dialog = DialogService.Show<DevCraftPlanDialog>("Load Dev Craftplan", options);
        var result = await dialog.Result;

        if (result?.Canceled != false || result.Data is not string input || string.IsNullOrWhiteSpace(input))
        {
            return;
        }

        var devPlanPath = NormalizeDevPlanPath(input);
        try
        {
            AppState.SetStatus($"Loading {devPlanPath}...", busy: true);
            var json = await Http.GetStringAsync(devPlanPath);
            var plan = RecipeService.DeserializePlan(json)
                ?? throw new InvalidOperationException("Could not parse the craftplan JSON.");

            await LoadNativePlanAsync(
                plan,
                $"Loaded dev craftplan '{devPlanPath}'",
                refreshPrices: false,
                clearCurrentPlanId: true);

            NavigationManager.NavigateTo("./");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to load dev craftplan fixture {Path}", devPlanPath);
            Snackbar.Add($"Failed to load dev craftplan: {ex.Message}", Severity.Error);
            AppState.SetStatus("Ready", busy: false);
        }
    }

    private async Task OnDumpRecipePlanDiagnostics()
    {
        if (!IsDebugToolsAvailable)
        {
            Snackbar.Add("Diagnostic builds are not available.", Severity.Warning);
            return;
        }

        try
        {
            var stored = await WorkerSession.ExportStoredPlanAsync(
                "diagnostic",
                WorkerProjections.Recipe?.PlanName ?? "Plan");
            var exportedAt = DateTime.UtcNow;
            var json = System.Text.Json.JsonSerializer.Serialize(
                new
                {
                    SchemaVersion = 2,
                    ExportedAtUtc = exportedAt,
                    Revision = WorkerProjections.Shell.Revision,
                    Session = stored,
                    Recipe = WorkerProjections.Recipe,
                    Acquisition = WorkerProjections.Acquisition,
                    Market = WorkerProjections.Market,
                    Procurement = WorkerProjections.Procurement
                },
                new System.Text.Json.JsonSerializerOptions(
                    System.Text.Json.JsonSerializerDefaults.Web)
                {
                    WriteIndented = true
                });
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            using var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            var fileName = RecipePlanDiagnosticDumpService.CreateFileName(
                WorkerProjections.Recipe?.PlanName,
                exportedAt);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
            Snackbar.Add($"Downloaded {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to capture Recipe Planner state: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadNativePlanAsync(
        CraftingPlan plan,
        string successMessage,
        bool refreshPrices,
        bool clearCurrentPlanId)
    {
        try
        {
            var stored = new StoredPlan
            {
                Id = "import",
                Name = plan.Name,
                DataCenter = string.IsNullOrWhiteSpace(plan.DataCenter)
                    ? WorkerProjections.Shell.SelectedDataCenter
                    : plan.DataCenter,
                ProjectItems = CraftPlanStateMapper.GetRootProjectItems(plan)
                    .Select(item => new StoredProjectItem
                    {
                        Id = item.Id,
                        Name = item.Name,
                        IconId = item.IconId,
                        Quantity = item.Quantity,
                        MustBeHq = item.MustBeHq
                    })
                    .ToList(),
                PlanJson = RecipeService.SerializePlan(plan),
                SavedAt = DateTime.UtcNow,
                ModifiedAt = DateTime.UtcNow
            };
            await WorkerSession.ReplaceStoredPlanAsync(
                stored,
                trackStoredPlanIdentity: !clearCurrentPlanId);

            Snackbar.Add(successMessage, Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to rebuild plan: {ex.Message}", Severity.Warning);
        }
    }

    private bool IsLocalBenchmarkWorkflowRequest()
    {
        var uri = new Uri(NavigationManager.Uri);
        return (uri.IsLoopback || string.Equals(uri.Host, "localhost", StringComparison.OrdinalIgnoreCase)) &&
            uri.Query.Contains("benchmark-defer-route=1", StringComparison.Ordinal);
    }

    private static string BoolText(bool value) => value ? "true" : "false";

    private static int CountRecipeNodes(
        IReadOnlyList<WorkerRecipeNodeProjection>? roots) =>
        roots?.Sum(CountRecipeNodes) ?? 0;

    private static int CountRecipeNodes(WorkerRecipeNodeProjection node) =>
        1 + node.Children.Sum(CountRecipeNodes);

    private static int CountRecipeEdges(
        IReadOnlyList<WorkerRecipeNodeProjection>? roots) =>
        Math.Max(0, CountRecipeNodes(roots) - (roots?.Count ?? 0));

    private static IEnumerable<int> GetRecipeLeafItemIds(
        IReadOnlyList<WorkerRecipeNodeProjection>? roots) =>
        roots is null
            ? []
            : roots.SelectMany(GetRecipeLeafItemIds).Distinct().Order();

    private static IEnumerable<int> GetRecipeLeafItemIds(
        WorkerRecipeNodeProjection node) =>
        node.Children.Count == 0
            ? [node.ItemId]
            : node.Children.SelectMany(GetRecipeLeafItemIds);

    private static string NormalizeDevPlanPath(string input)
    {
        var path = input.Trim().Replace('\\', '/').TrimStart('/');
        return path.StartsWith("dev-plans/", StringComparison.OrdinalIgnoreCase)
            ? path
            : $"dev-plans/{path}";
    }

