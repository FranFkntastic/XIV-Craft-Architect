        }
    }

    private static MarketFetchScope ParseMarketFetchScope(string? value)
    {
        return Enum.TryParse<MarketFetchScope>(value, ignoreCase: true, out var scope)
            ? scope
            : MarketFetchScope.EntireRegion;
    }

    private static MarketTravelPriority ParseTravelPriority(string? value)
    {
        return Enum.TryParse<MarketTravelPriority>(value, ignoreCase: true, out var priority)
            ? priority
            : MarketTravelPriority.DataCenterTransfersFirst;
    }
