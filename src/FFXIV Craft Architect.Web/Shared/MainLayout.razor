    public void Dispose()
    {
        if (!_disposed)
        {
            NavigationManager.LocationChanged -= OnLocationChanged;
            StartupInitialization.StatusChanged -= OnStartupStatusChanged;
            AppState.OnStateChanged -= OnAppStateChanged;
            ProcurementRouteReconciliation.Dispose();
            
            // Stop auto-save timer
            AppState.StopAutoSaveTimer();
            
            // Final auto-save on dispose
            if (AppState.IsAutoSaveEnabled)
            {
                _ = FinalAutoSaveAsync();
            }
            
            _disposed = true;
        }
    }

    private async Task FinalAutoSaveAsync()
    {
        try
        {
            await IndexedDb.AutoSaveStateAsync(AppState);
        }
        catch (Exception ex)
        {
            Logger?.LogError(ex, "Final auto-save failed");
        }
    }
    
    private static MarketFetchScope ParseMarketFetchScope(string? value)
    {
        return Enum.TryParse<MarketFetchScope>(value, ignoreCase: true, out var scope)
            ? scope
            : MarketFetchScope.EntireRegion;
    }

    private static MarketTravelPriority ParseTravelPriority(string? value)
    {
        return Enum.TryParse<MarketTravelPriority>(value, ignoreCase: true, out var priority)
            ? priority
            : MarketTravelPriority.DataCenterTransfersFirst;
    }
