@using FFXIV_Craft_Architect.Web.Services

<div class="ma-controls-column">
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Market Analysis</MudText>

    @if (!string.IsNullOrWhiteSpace(AppState.MarketAnalysisScopeWarning))
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            @AppState.MarketAnalysisScopeWarning
        </MudAlert>
    }

    <div class="ma-field-block">
        <div class="ma-field-label">Lens</div>
        <MudSelect T="MarketAcquisitionLens"
                   Value="AppState.MarketAnalysisLens"
                   ValueChanged="OnLensChangedRequested"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Title="@LensSelectorTooltip"
                   Class="ma-full-width">
            <MudSelectItem Value="@MarketAcquisitionLens.MinimumUpfrontCost" Title="@MinimumUpfrontCostLensTooltip">Minimum Upfront Cost</MudSelectItem>
            <MudSelectItem Value="@MarketAcquisitionLens.BulkValue" Title="@BulkValueLensTooltip">Best Value / Bulk Acquisition</MudSelectItem>
        </MudSelect>
    </div>

    <div class="ma-field-block">
        <div class="ma-field-label">Evidence Overlay</div>
        <MudSelect T="MarketAnalysisEvidenceOverlay"
                   Value="AppState.MarketAnalysisEvidenceOverlay"
                   ValueChanged="OnEvidenceOverlayChanged"
                   Variant="Variant.Outlined"
                   Dense="true"
                   Class="ma-full-width">
            <MudSelectItem Value="@MarketAnalysisEvidenceOverlay.ShelfOverlay">Shelf Overlay</MudSelectItem>
            <MudSelectItem Value="@MarketAnalysisEvidenceOverlay.PriceBandOverlay">Price Band Overlay</MudSelectItem>
        </MudSelect>
    </div>

    <div class="ma-region-toggle-block">
        <MudCheckBox T="bool"
                     Value="AppState.SearchEntireRegion"
                     ValueChanged="OnSearchEntireRegionChanged"
                     Dense="true"
                     Color="Color.Primary"
                     Class="ma-region-toggle">
            <MudText Typo="Typo.body2" Class="ma-region-toggle-text">Search entire region</MudText>
        </MudCheckBox>
        <MudText Typo="Typo.caption" Class="ma-region-toggle-caption">
            Slower but finds best prices across all data centers in @AppState.SelectedRegion
        </MudText>
    </div>

    <MudButton OnClick="OnRunAnalysisRequested"
               Disabled="@(!CanAnalyze || IsAnalyzing)"
               Color="Color.Primary"
               Variant="Variant.Filled"
               FullWidth="true"
               Class="mb-4"
               StartIcon="@(IsAnalyzing ? "" : Icons.Material.Filled.Analytics)"
               data-benchmark-id="@BenchmarkHook("market-analysis-run")">
        @if (IsAnalyzing)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Analyzing...</span>
        }
        else
        {
            <span>Run Analysis</span>
        }
    </MudButton>

    <MudButton OnClick="OnRefreshPricesRequested"
               Disabled="@(!CanRefreshPrices || IsRefreshingPrices)"
               Color="Color.Secondary"
               Variant="Variant.Outlined"
               FullWidth="true"
               Class="mb-4"
               StartIcon="@(IsRefreshingPrices ? "" : Icons.Material.Filled.Refresh)"
               data-benchmark-id="@BenchmarkHook("market-analysis-refresh-prices")">
        @if (IsRefreshingPrices)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Refreshing...</span>
        }
        else
        {
            <span>Refresh Prices</span>
        }
    </MudButton>

    <MudButton OnClick="OnGoToPlannerRequested"
               Color="Color.Info"
               Variant="Variant.Outlined"
               FullWidth="true"
               Class="mb-2"
               StartIcon="@Icons.Material.Filled.ArrowBack">
        Back to Planner
    </MudButton>

    @if (AppState.ShoppingPlans.Any())
    {
        <MudButton OnClick="OnGoToProcurementRequested"
                   Color="Color.Success"
                   Variant="Variant.Outlined"
                   FullWidth="true"
                   EndIcon="@Icons.Material.Filled.ArrowForward">
            Acquisition Evaluation
        </MudButton>
    }
</div>

@code {
    [Parameter, EditorRequired] public AppState AppState { get; set; } = default!;
    [Parameter] public bool IsAnalyzing { get; set; }
    [Parameter] public bool IsRefreshingPrices { get; set; }
    [Parameter] public bool CanAnalyze { get; set; }
    [Parameter] public bool CanRefreshPrices { get; set; }

    [Parameter] public EventCallback<MarketAcquisitionLens> OnLensChangedRequested { get; set; }
    [Parameter] public EventCallback OnRunAnalysisRequested { get; set; }
    [Parameter] public EventCallback OnRefreshPricesRequested { get; set; }
    [Parameter] public EventCallback OnGoToPlannerRequested { get; set; }
    [Parameter] public EventCallback OnGoToProcurementRequested { get; set; }

    private const string LensSelectorTooltip = "Acquisition lenses change how worlds are ranked for buying logistics; they do not change the underlying market evidence.";
    private const string MinimumUpfrontCostLensTooltip = "Minimum upfront cost ranks worlds by needed-quantity coverage and estimated cost to cover the plan need.";
    private const string BulkValueLensTooltip = "Best value / bulk acquisition favors deeper competitive stock and partial shelves that may still be useful.";

    private void OnSearchEntireRegionChanged(bool searchEntireRegion)
    {
        AppState.SetMarketEvidenceSettings(
            AppState.SelectedDataCenter,
            AppState.SelectedRegion,
            AppState.DefaultMarketFetchScope,
            searchEntireRegion);
    }

    private void OnEvidenceOverlayChanged(MarketAnalysisEvidenceOverlay overlay)
    {
        AppState.SetMarketAnalysisEvidenceOverlay(overlay);
    }

    private string? BenchmarkHook(string id) => AppState.SecretDebugToolsEnabled ? id : null;
}
