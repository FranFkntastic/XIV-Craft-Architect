@using FFXIV_Craft_Architect.Web.Services

<div class="ma-controls-column">
    <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-4">Market Analysis</MudText>

    @if (!string.IsNullOrWhiteSpace(ScopeWarning))
    {
        <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
            @ScopeWarning
        </MudAlert>
    }

    <div class="ma-field-block">
        <CompactSelectField Id="market-buying-strategy"
                            Label="Buying strategy"
                            Value="@Lens.ToString()"
                            ValueChanged="OnLensValueChanged"
                            Options="LensOptions"
                            Tooltip="@LensSelectorTooltip"
                            Class="ma-full-width" />
    </div>

    <div class="ma-field-block">
        <CompactSelectField Id="market-listing-colors"
                            Label="Listing colors"
                            Value="@EvidenceOverlay.ToString()"
                            ValueChanged="OnEvidenceOverlayValueChanged"
                            Options="EvidenceOverlayOptions"
                            Class="ma-full-width" />
    </div>

    <div class="ma-region-toggle-block">
        <MudCheckBox T="bool"
                     Value="SearchEntireRegion"
                     ValueChanged="OnSearchEntireRegionChanged"
                     Dense="true"
                     Color="Color.Primary"
                     Class="ma-region-toggle">
            <MudText Typo="Typo.body2" Class="ma-region-toggle-text">Search entire region</MudText>
        </MudCheckBox>
        <MudText Typo="Typo.caption" Class="ma-region-toggle-caption">
            Slower, but finds the best prices across all data centers in @SelectedRegion.
        </MudText>
    </div>

    <MudButton OnClick="OnRunAnalysisRequested"
               Disabled="@(!CanAnalyze || IsAnalyzing)"
               Color="Color.Primary"
               Variant="Variant.Filled"
               FullWidth="true"
               Class="mb-4"
               StartIcon="@(IsAnalyzing ? "" : Icons.Material.Filled.Analytics)"
               data-benchmark-id="@BenchmarkHook("market-analysis-run")"
               data-can-analyze="@(CanAnalyze ? "true" : "false")"
               data-is-analyzing="@(IsAnalyzing ? "true" : "false")">
        @if (IsAnalyzing)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Analyzing...</span>
        }
        else
        {
            <span>Run Analysis</span>
        }
    </MudButton>

    <MudButton OnClick="OnRefreshPricesRequested"
               Disabled="@(!CanRefreshPrices || IsRefreshingPrices)"
               Color="Color.Secondary"
               Variant="Variant.Outlined"
               FullWidth="true"
               Class="mb-4"
               StartIcon="@(IsRefreshingPrices ? "" : Icons.Material.Filled.Refresh)"
               data-benchmark-id="@BenchmarkHook("market-analysis-refresh-prices")">
        @if (IsRefreshingPrices)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
            <span>Refreshing...</span>
        }
        else
        {
            <span>Refresh Prices</span>
        }
    </MudButton>

    @if (HasShoppingPlans)
    {
        <MudButton OnClick="OnGoToProcurementRequested"
                   Color="Color.Success"
                   Variant="Variant.Outlined"
                   FullWidth="true"
                   EndIcon="@Icons.Material.Filled.ArrowForward">
            Acquisition Evaluation
        </MudButton>
    }
</div>

@code {
    [Parameter] public MarketAcquisitionLens Lens { get; set; }
    [Parameter] public MarketAnalysisEvidenceOverlay EvidenceOverlay { get; set; } =
        MarketAnalysisEvidenceOverlay.CompetitivenessOverlay;
    [Parameter] public bool SearchEntireRegion { get; set; }
    [Parameter] public string SelectedRegion { get; set; } = "North America";
    [Parameter] public string? ScopeWarning { get; set; }
    [Parameter] public bool HasShoppingPlans { get; set; }
    [Parameter] public bool SecretDebugToolsEnabled { get; set; }
    [Parameter] public bool IsAnalyzing { get; set; }
    [Parameter] public bool IsRefreshingPrices { get; set; }
    [Parameter] public bool CanAnalyze { get; set; }
    [Parameter] public bool CanRefreshPrices { get; set; }

    [Parameter] public EventCallback<MarketAcquisitionLens> OnLensChangedRequested { get; set; }
    [Parameter] public EventCallback<MarketAnalysisEvidenceOverlay> OnEvidenceOverlayChangedRequested { get; set; }
    [Parameter] public EventCallback<bool> OnSearchEntireRegionChangedRequested { get; set; }
    [Parameter] public EventCallback OnRunAnalysisRequested { get; set; }
    [Parameter] public EventCallback OnRefreshPricesRequested { get; set; }
    [Parameter] public EventCallback OnGoToProcurementRequested { get; set; }

    private const string LensSelectorTooltip = "Buying strategy changes how worlds are ranked without changing the listings CA found.";
    private static readonly IReadOnlyList<CompactSelectOption> LensOptions =
    [
        new(nameof(MarketAcquisitionLens.MinimumUpfrontCost), "Lowest upfront cost"),
        new(nameof(MarketAcquisitionLens.BulkValue), "Best bulk value")
    ];
    private static readonly IReadOnlyList<CompactSelectOption> EvidenceOverlayOptions =
    [
        new(nameof(MarketAnalysisEvidenceOverlay.CompetitivenessOverlay), "Deals vs typical price"),
        new(nameof(MarketAnalysisEvidenceOverlay.PriceBandOverlay), "Price bands")
    ];

    private Task OnSearchEntireRegionChanged(bool searchEntireRegion) =>
        OnSearchEntireRegionChangedRequested.InvokeAsync(searchEntireRegion);

    private async Task OnLensValueChanged(string value)
    {
        if (Enum.TryParse<MarketAcquisitionLens>(value, out var lens))
        {
            await OnLensChangedRequested.InvokeAsync(lens);
        }
    }

    private Task OnEvidenceOverlayValueChanged(string value)
    {
        if (Enum.TryParse<MarketAnalysisEvidenceOverlay>(value, out var overlay))
        {
            return OnEvidenceOverlayChangedRequested.InvokeAsync(overlay);
        }

        return Task.CompletedTask;
    }

    private string? BenchmarkHook(string id) => SecretDebugToolsEnabled ? id : null;
}
