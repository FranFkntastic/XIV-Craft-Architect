<div class="@RootClass">
    @if (!string.IsNullOrWhiteSpace(Tooltip))
    {
        <MudTooltip Text="@Tooltip">
            <label class="compact-select-field-label" for="@ControlId">@Label</label>
        </MudTooltip>
    }
    else
    {
        <label class="compact-select-field-label" for="@ControlId">@Label</label>
    }
    <select id="@ControlId"
            class="compact-select-field-select"
            value="@Value"
            disabled="@Disabled"
            @onchange="OnChanged">
        @foreach (var option in Options)
        {
            <option value="@option.Value"
                    selected="@(string.Equals(option.Value, Value, StringComparison.Ordinal))"
                    disabled="@option.Disabled">@option.Label</option>
        }
    </select>
</div>

@code {
    private readonly string _generatedId = $"compact-select-{Guid.NewGuid():N}";

    [Parameter, EditorRequired] public string Label { get; set; } = string.Empty;
    [Parameter] public string? Id { get; set; }
    [Parameter] public string Value { get; set; } = string.Empty;
    [Parameter] public EventCallback<string> ValueChanged { get; set; }
    [Parameter] public IReadOnlyList<CompactSelectOption> Options { get; set; } = [];
    [Parameter] public string? Tooltip { get; set; }
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string? Class { get; set; }

    private string ControlId => string.IsNullOrWhiteSpace(Id) ? _generatedId : Id;

    private string RootClass => string.Join(" ", new[]
    {
        "compact-select-field",
        Class
    }.Where(value => !string.IsNullOrWhiteSpace(value)));

    private async Task OnChanged(ChangeEventArgs args)
    {
        Value = args.Value?.ToString() ?? string.Empty;
        await ValueChanged.InvokeAsync(Value);
    }
}
