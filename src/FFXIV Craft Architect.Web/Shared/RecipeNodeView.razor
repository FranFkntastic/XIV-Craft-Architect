@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@implements IDisposable

@if (Node != null)
{
    var display = GetDisplayState();
    <div class="rp-node-branch @(Depth == 0 ? "rp-node-root" : null)">
        <div class="rp-node-row @(IsSelected ? "selected" : null)"
             style="--rp-node-depth: @Depth"
             @onclick="SelectNode">
            @if (HasChildren)
            {
                <button type="button"
                        class="rp-node-expander"
                        @onclick="ToggleExpanded"
                        @onclick:stopPropagation
                        aria-expanded="@_isExpanded.ToString().ToLowerInvariant()"
                        aria-label="@($"{(_isExpanded ? "Collapse" : "Expand")} {Node.Name}")"
                        title="@(_isExpanded ? "Collapse materials" : "Expand materials")">
                    <span aria-hidden="true">@(_isExpanded ? "▼" : "▶")</span>
                </button>
            }
            else
            {
                <span class="rp-node-expander-spacer" aria-hidden="true"></span>
            }

            @if (Node.CanBeHq)
            {
                <button type="button"
                        class="rp-node-quality @(Node.MustBeHq ? "required" : null)"
                        @onclick="OnHqToggle"
                        @onclick:stopPropagation
                        aria-label="@(Node.MustBeHq ? $"Allow normal quality for {Node.Name}" : $"Require high quality for {Node.Name}")"
                        aria-pressed="@Node.MustBeHq.ToString().ToLowerInvariant()"
                        title="@(Node.MustBeHq ? "High quality required" : "Normal quality allowed")">
                    <span aria-hidden="true">★</span>
                </button>
            }
            else
            {
                <span class="rp-node-quality-spacer" aria-hidden="true"></span>
            }

            <span class="rp-node-item" style="--rp-source-color: @display.SourceColor">
                @display.HqPrefix@Node.Name <span class="rp-node-quantity">×@Node.Quantity.ToString("N0")</span>
                @if (Node.IsCircularReference)
                {
                    <span class="rp-node-circular" title="This item is already being crafted higher in the recipe chain, so CA prevents recursive expansion.">↻</span>
                }
            </span>

            <span class="rp-node-recipe">@display.RecipeInfo</span>

            <a href="market"
               class="rp-node-quote @display.QuoteStatusClass @GetMethodClass()"
               @onclick="OpenMarketAnalysis"
               @onclick:stopPropagation
               aria-label="@GetQuoteAriaLabel(display)">
                <span class="rp-node-quote-method">@display.QuoteMethodText</span>
                <span class="rp-node-quote-amount">@display.PriceText</span>
                <span class="rp-node-quote-open" aria-hidden="true">›</span>

                <span class="rp-node-quote-card" role="tooltip">
                    <span class="rp-node-quote-card-header">
                        <strong>@GetQuoteHeading(display)</strong>
                        @if (display.QuoteStatusClass == "actionable")
                        {
                            <b>@display.PriceText</b>
                        }
                    </span>
                    @if (!string.IsNullOrWhiteSpace(display.QuoteUnitText))
                    {
                        <span class="rp-node-quote-card-line"><em>Unit cost</em><span>@display.QuoteUnitText</span></span>
                    }
                    <span class="rp-node-quote-card-line"><em>Coverage</em><span>@display.QuoteCoverageText</span></span>
                    @if (!string.IsNullOrWhiteSpace(display.QuoteLocationText))
                    {
                        <span class="rp-node-quote-card-line"><em>Route</em><span>@display.QuoteLocationText</span></span>
                    }
                    <span class="rp-node-quote-card-footer">
                        @display.QuoteBasisText@if (!string.IsNullOrWhiteSpace(display.QuoteEvidenceText)){<text> · @display.QuoteEvidenceText</text>}
                    </span>
                </span>
            </a>
        </div>

        @if (HasChildren && _isExpanded)
        {
            <div class="rp-node-children">
                @foreach (var child in Node.Children)
                {
                    <RecipeNodeView Node="child"
                                    Depth="Depth + 1"
                                    IsSelected="@(SelectedNodeId == child.NodeId)"
                                    SelectedNodeId="@SelectedNodeId"
                                    DisplayStates="DisplayStates"
                                    OnNodeSelected="OnNodeSelected"
                                    OnHqChanged="OnHqChanged" />
                }
            </div>
        }
    </div>
}

@code {
    [Parameter] public PlanNode? Node { get; set; }
    [Parameter] public int Depth { get; set; }
    [Parameter] public bool IsSelected { get; set; }
    [Parameter] public string? SelectedNodeId { get; set; }
    [Parameter] public IReadOnlyDictionary<string, RecipeNodeDisplayState> DisplayStates { get; set; } =
        new Dictionary<string, RecipeNodeDisplayState>();
    [Parameter] public EventCallback<PlanNode> OnNodeSelected { get; set; }
    [Parameter] public EventCallback<PlanNodeHqChangeRequest> OnHqChanged { get; set; }

    private bool _isExpanded = true;
    private int _lastExpandVersion = -1;
    private bool _isDisposed;

    private bool HasChildren => Node?.Children.Any() == true;

    protected override void OnInitialized()
    {
        AppState.OnRecipeTreeExpandChanged += OnRecipeTreeExpandChanged;
    }

    protected override void OnParametersSet()
    {
        if (_lastExpandVersion != AppState.RecipeTreeExpandVersion)
        {
            _isExpanded = AppState.RecipeTreeAllExpanded;
            _lastExpandVersion = AppState.RecipeTreeExpandVersion;
        }
    }

    public void Dispose()
    {
        _isDisposed = true;
        AppState.OnRecipeTreeExpandChanged -= OnRecipeTreeExpandChanged;
    }

    private void OnRecipeTreeExpandChanged()
    {
        if (_isDisposed || _lastExpandVersion == AppState.RecipeTreeExpandVersion)
        {
            return;
        }

        _isExpanded = AppState.RecipeTreeAllExpanded;
        _lastExpandVersion = AppState.RecipeTreeExpandVersion;
        InvokeAsync(StateHasChanged);
    }

    private void ToggleExpanded()
    {
        _isExpanded = !_isExpanded;
    }

    private Task SelectNode()
    {
        return Node == null ? Task.CompletedTask : OnNodeSelected.InvokeAsync(Node);
    }

    private void OpenMarketAnalysis()
    {
        if (Node != null)
        {
            AppState.RequestMarketItemAutoExpand(Node.ItemId);
        }
    }

    private async Task OnHqToggle()
    {
        if (Node?.CanBeHq == true)
        {
            await OnHqChanged.InvokeAsync(new PlanNodeHqChangeRequest(Node, !Node.MustBeHq));
        }
    }

    private string GetMethodClass()
    {
        return Node?.Source switch
        {
            AcquisitionSource.MarketBuyNq or AcquisitionSource.MarketBuyHq => "market",
            AcquisitionSource.VendorBuy => "vendor",
            _ => "craft"
        };
    }

    private string GetQuoteAriaLabel(RecipeNodeDisplayState display)
    {
        return $"{display.QuoteMethodText} {Node?.Name}: {display.PriceText}. Open in Market Analysis";
    }

    private string GetQuoteHeading(RecipeNodeDisplayState display)
    {
        return display.QuoteStatusClass switch
        {
            "refreshing" => $"Pricing {Node?.Name}",
            "unavailable" => "No actionable quote",
            _ => $"{GetMethodHeading()} {Node?.Quantity:N0}"
        };
    }

    private string GetMethodHeading()
    {
        return Node?.Source switch
        {
            AcquisitionSource.Craft => "Craft",
            AcquisitionSource.MarketBuyNq => "Buy",
            AcquisitionSource.MarketBuyHq => "Buy HQ",
            AcquisitionSource.VendorBuy => "Vendor buy",
            _ => "Acquire"
        };
    }

    private RecipeNodeDisplayState GetDisplayState()
    {
        if (Node != null && DisplayStates.TryGetValue(Node.NodeId, out var display))
        {
            return display;
        }

        return Node != null
            ? RecipePlanTreeDisplayBuilder.BuildWithoutCost(Node)
            : new RecipeNodeDisplayState(
                string.Empty,
                "#ccc",
                "Unavailable",
                "—",
                "unavailable",
                "Acquisition quote",
                string.Empty,
                "No acquisition quote is available.",
                string.Empty,
                string.Empty,
                string.Empty,
                null);
    }
}
