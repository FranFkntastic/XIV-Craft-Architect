@using FFXIV_Craft_Architect.Core.Models

<div class="ma-ledger-shell">
    <div class="ma-ledger-workspace">
        <div class="ma-ledger-list">
            <MudDataGrid T="DetailedShoppingPlan"
                         Items="GetGridPlans()"
                         Dense="true"
                         Hover="true"
                         Bordered="false"
                         Striped="false"
                         Square="true"
                         Elevation="0"
                         FixedHeader="true"
                         Height="100%"
                         SortMode="SortMode.Single"
                         Filterable="false"
                         Groupable="false"
                         Hideable="false"
                         ShowMenuIcon="false"
                         ReadOnly="true"
                         MultiSelection="false"
                         SelectOnRowClick="true"
                         SelectedItem="_selectedPlan"
                         SelectedItemChanged="SelectPlan"
                         ColumnResizeMode="ResizeMode.Column"
                         HorizontalScrollbar="false"
                         RowClassFunc="GetRowClass"
                         Class="ma-data-grid">
                <Columns>
                    <TemplateColumn T="DetailedShoppingPlan"
                                    HeaderStyle="@ItemColumnStyle"
                                    CellStyle="@ItemColumnStyle"
                                    CellClass="ma-item-column">
                        <HeaderTemplate>
                            @SortHeader("Item", MarketAnalysisGridSortColumn.Item)
                        </HeaderTemplate>
                        <CellTemplate>
                            <span class="ma-item-cell">
                                <a class="ma-item-name"
                                   href="@context.Item.UniversalisUrl"
                                   target="_blank"
                                   rel="noopener noreferrer"
                                   title="Open @context.Item.Name on Universalis"
                                   @onclick:stopPropagation>
                                    @context.Item.Name
                                </a>
                                <span class="ma-item-kind">@GetSourceLabel(context.Item)</span>
                            </span>
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn T="DetailedShoppingPlan"
                                    HeaderStyle="@QuantityColumnStyle"
                                    CellStyle="@QuantityColumnStyle"
                                    CellClass="ma-number-column">
                        <HeaderTemplate>
                            @SortHeader("Qty", MarketAnalysisGridSortColumn.Quantity)
                        </HeaderTemplate>
                        <CellTemplate>
                            <span class="@GetStockClass(context.Item)">@GetQuantityLabel(context.Item)</span>
                        </CellTemplate>
                    </TemplateColumn>

                    <TemplateColumn T="DetailedShoppingPlan"
                                    HeaderStyle="@CoverageColumnStyle"
                                    CellStyle="@CoverageColumnStyle"
                                    CellClass="ma-recommendation-column">
                        <HeaderTemplate>
                            @SortHeader("Coverage", MarketAnalysisGridSortColumn.Coverage)
                        </HeaderTemplate>
                        <CellTemplate>
                            <span title="@GetCoverageLabel(context.Item)">@GetCoverageLabel(context.Item)</span>
                        </CellTemplate>
                    </TemplateColumn>

                    @if (ShowWorldsColumn)
                    {
                        <TemplateColumn T="DetailedShoppingPlan"
                                        HeaderStyle="width: 7%;"
                                        CellStyle="width: 7%;"
                                        CellClass="ma-number-column">
                            <HeaderTemplate>
                                @SortHeader("Worlds", MarketAnalysisGridSortColumn.Worlds)
                            </HeaderTemplate>
                            <CellTemplate>
                                @GetWorldCount(context.Item)
                            </CellTemplate>
                        </TemplateColumn>
                    }

                    <TemplateColumn T="DetailedShoppingPlan"
                                    HeaderStyle="@TotalColumnStyle"
                                    CellStyle="@TotalColumnStyle"
                                    CellClass="ma-total-column">
                        <HeaderTemplate>
                            @SortHeader("Total", MarketAnalysisGridSortColumn.Total)
                        </HeaderTemplate>
                        <CellTemplate>
                            @GetTotalCost(context.Item).ToString("N0")g
                        </CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>
        </div>

        <aside class="ma-detail-pane">
            @if (_selectedPlan == null)
            {
                <div class="ma-detail-empty">
                    <MudIcon Icon="@Icons.Material.Filled.TableRows" Size="Size.Large" />
                    <MudText Typo="Typo.body2">Select an item to inspect its market detail.</MudText>
                </div>
            }
            else
            {
                <div class="ma-detail-header">
                    <div>
                        <a class="ma-detail-title"
                           href="@_selectedPlan.UniversalisUrl"
                           target="_blank"
                           rel="noopener noreferrer"
                           title="Open @_selectedPlan.Name on Universalis">
                            @_selectedPlan.Name
                        </a>
                        <MudText Typo="Typo.caption" Class="ma-detail-subtitle">
                            @FormatQuantity(_selectedPlan.QuantityNeeded) needed
                        </MudText>
                    </div>
                    <MudText Typo="Typo.subtitle1" Class="ma-detail-total">
                        @GetTotalCost(_selectedPlan).ToString("N0")g
                    </MudText>
                </div>

                <div class="ma-detail-scroll">
                    @if (GetSelectedAnalysis() is { } analysis)
                    {
                        <MarketAnalysisWorldGrid Analysis="analysis"
                                                 Lens="CurrentLens"
                                                 ItemId="_selectedPlan.ItemId"
                                                 ExpandedWorldKeys="ExpandedWorldKeys"
                                                 OnWorldExpansionToggled="OnWorldExpansionToggled" />
                    }
                    else
                    {
                        <div class="ma-analysis-missing">
                            <MudIcon Icon="@Icons.Material.Filled.SyncProblem" Size="Size.Large" />
                            <MudText Typo="Typo.body2">
                                Analytics for this item are not available in the current session. Run Market Analysis again to rebuild the source data.
                            </MudText>
                        </div>
                    }
                </div>
            }
        </aside>
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<DetailedShoppingPlan> ShoppingPlans { get; set; } = Array.Empty<DetailedShoppingPlan>();
    [Parameter] public IReadOnlyList<MarketItemAnalysis> MarketItemAnalyses { get; set; } = Array.Empty<MarketItemAnalysis>();
    [Parameter] public MarketAcquisitionLens CurrentLens { get; set; } = MarketAcquisitionLens.MinimumUpfrontCost;
    [Parameter] public MarketSortOption CurrentSort { get; set; } = MarketSortOption.ByRecommended;
    [Parameter] public MarketAnalysisGridSortColumn? SortColumn { get; set; }
    [Parameter] public bool SortDescending { get; set; }
    [Parameter] public int? SelectedItemId { get; set; }
    [Parameter] public IReadOnlySet<MarketAnalysisExpandedWorldKey> ExpandedWorldKeys { get; set; } = new HashSet<MarketAnalysisExpandedWorldKey>();
    [Parameter] public int? AutoExpandItemId { get; set; }
    [Parameter] public bool ShowWorldsColumn { get; set; }
    [Parameter] public EventCallback<int?> OnSelectedItemChanged { get; set; }
    [Parameter] public EventCallback<MarketAnalysisExpandedWorldKey> OnWorldExpansionToggled { get; set; }
    [Parameter] public EventCallback<MarketAnalysisGridSortState> OnSortChanged { get; set; }
    [Parameter] public EventCallback<int> OnAutoExpandConsumed { get; set; }

    private DetailedShoppingPlan? _selectedPlan;
    private bool _autoExpandProcessed;

    private string ItemColumnStyle => ShowWorldsColumn ? "width: 27%;" : "width: 29%;";

    private string QuantityColumnStyle => ShowWorldsColumn ? "width: 12%;" : "width: 13%;";

    private string CoverageColumnStyle => ShowWorldsColumn ? "width: 36%;" : "width: 39%;";

    private string TotalColumnStyle => ShowWorldsColumn ? "width: 18%;" : "width: 19%;";

    protected override void OnParametersSet()
    {
        if (!_autoExpandProcessed && AutoExpandItemId.HasValue)
        {
            var targetPlan = ShoppingPlans.FirstOrDefault(p => p.ItemId == AutoExpandItemId.Value);
            if (targetPlan != null)
            {
                _selectedPlan = targetPlan;
                _autoExpandProcessed = true;
                _ = OnSelectedItemChanged.InvokeAsync(targetPlan.ItemId);
                _ = OnAutoExpandConsumed.InvokeAsync(targetPlan.ItemId);
            }
        }
        else if (!AutoExpandItemId.HasValue)
        {
            _autoExpandProcessed = false;
        }

        var orderedPlans = GetGridPlans().ToList();
        _selectedPlan = MarketAnalysisGridViewService.ResolveSelectedPlan(orderedPlans, SelectedItemId);
        if (_selectedPlan?.ItemId != SelectedItemId)
        {
            _ = OnSelectedItemChanged.InvokeAsync(_selectedPlan?.ItemId);
        }
    }

    private async Task SelectPlan(DetailedShoppingPlan plan)
    {
        _selectedPlan = plan;
        await OnSelectedItemChanged.InvokeAsync(plan.ItemId);
    }

    private RenderFragment SortHeader(string label, MarketAnalysisGridSortColumn column) => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "button");
        builder.AddAttribute(sequence++, "type", "button");
        builder.AddAttribute(sequence++, "class", GetSortHeaderClass(column));
        builder.AddAttribute(sequence++, "onclick", EventCallback.Factory.Create(this, () => ToggleSort(column)));
        builder.AddContent(sequence++, label);
        if (SortColumn == column)
        {
            builder.OpenElement(sequence++, "span");
            builder.AddAttribute(sequence++, "class", "ma-sort-direction");
            builder.AddContent(sequence++, SortDescending ? "desc" : "asc");
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private string GetSortHeaderClass(MarketAnalysisGridSortColumn column)
    {
        return SortColumn == column
            ? "ma-sort-header is-active"
            : "ma-sort-header";
    }

    private async Task ToggleSort(MarketAnalysisGridSortColumn column)
    {
        var next = MarketAnalysisGridViewService.ToggleSort(SortColumn, SortDescending, column);
        await OnSortChanged.InvokeAsync(next);
    }

    private MarketItemAnalysis? GetSelectedAnalysis()
    {
        return _selectedPlan == null
            ? null
            : MarketItemAnalyses.FirstOrDefault(analysis => analysis.ItemId == _selectedPlan.ItemId);
    }

    private IEnumerable<DetailedShoppingPlan> GetGridPlans()
    {
        return MarketAnalysisGridViewService.GetOrderedPlans(
            ShoppingPlans,
            MarketItemAnalyses,
            CurrentLens,
            CurrentSort,
            SortColumn,
            SortDescending);
    }

    private static bool IsVendorPlan(DetailedShoppingPlan plan)
    {
        return plan.RecommendedWorld?.WorldName == MarketShoppingConstants.VendorWorldName || plan.Vendors.Any();
    }

    private static bool HasWarning(DetailedShoppingPlan plan)
    {
        return !string.IsNullOrWhiteSpace(plan.Error) ||
            !string.IsNullOrWhiteSpace(plan.MarketDataWarning) ||
            !plan.HasSufficientStock;
    }

    private static string GetSourceLabel(DetailedShoppingPlan plan)
    {
        if (!string.IsNullOrWhiteSpace(plan.Error))
            return "Error";
        if (IsVendorPlan(plan))
            return "Vendor";
        if (plan.RequiresSplitPurchase)
            return "Split";
        return "Market";
    }

    private string GetCoverageLabel(DetailedShoppingPlan plan)
    {
        var analysis = MarketItemAnalyses.FirstOrDefault(item => item.ItemId == plan.ItemId);
        if (analysis != null)
        {
            var full = analysis.Worlds.Count(world => GetDisplayCoverageBucket(world) == MarketCoverageBucket.Full);
            var partial = analysis.Worlds.Count(world =>
                GetDisplayCoverageBucket(world) is MarketCoverageBucket.PartialDeep or MarketCoverageBucket.PartialThin);
            if (analysis.Worlds.Count == 0)
            {
                return analysis.Warning ?? "No market data";
            }

            return $"{full} full, {partial} partial across {analysis.Worlds.Count} worlds";
        }

        if (!string.IsNullOrWhiteSpace(plan.Error))
            return plan.Error;
        return "Analytics unavailable; rerun analysis";
    }

    private static int GetWorldCount(DetailedShoppingPlan plan)
    {
        if (plan.RequiresSplitPurchase && plan.RecommendedSplit?.Any() == true)
            return plan.RecommendedSplit.Select(s => s.WorldName).Distinct(StringComparer.OrdinalIgnoreCase).Count();
        return plan.RecommendedWorld == null ? 0 : 1;
    }

    private static string GetQuantityLabel(DetailedShoppingPlan plan)
    {
        if (IsVendorPlan(plan))
            return FormatQuantity(plan.QuantityNeeded);
        if (!plan.HasSufficientStock)
            return $"{plan.TotalAvailableQuantity:N0}/{plan.QuantityNeeded:N0}";
        return FormatQuantity(plan.QuantityNeeded);
    }

    private static int GetAvailableSortValue(DetailedShoppingPlan plan)
    {
        if (IsVendorPlan(plan))
            return int.MaxValue;
        return plan.TotalAvailableQuantity;
    }

    private static string FormatQuantity(int quantity)
    {
        return $"x{quantity:N0}";
    }

    private string GetRowClass(DetailedShoppingPlan plan, int rowNumber)
    {
        var classes = new List<string>();
        if (_selectedPlan?.ItemId == plan.ItemId)
        {
            classes.Add("is-selected");
        }

        if (HasWarning(plan))
        {
            classes.Add("has-warning");
        }

        return string.Join(" ", classes);
    }

    private static string GetStockClass(DetailedShoppingPlan plan)
    {
        return !plan.HasSufficientStock && !IsVendorPlan(plan)
            ? "ma-stock-warning"
            : "ma-stock-ok";
    }

    private static MarketCoverageBucket GetDisplayCoverageBucket(WorldMarketAnalysis world)
    {
        var saneQuantity = world.SaneThresholdUnitPrice > 0
            ? world.ScopeSaneQuantity
            : world.TotalSaneQuantity;
        if (world.QuantityNeeded <= 0 || saneQuantity <= 0)
        {
            return MarketCoverageBucket.None;
        }

        if (saneQuantity >= world.QuantityNeeded)
        {
            return MarketCoverageBucket.Full;
        }

        var competitiveQuantity = world.SaneThresholdUnitPrice > 0
            ? world.ScopeCompetitiveQuantity
            : world.CompetitiveQuantity;
        return competitiveQuantity >= Math.Max(world.QuantityNeeded / 2, 1)
            ? MarketCoverageBucket.PartialDeep
            : MarketCoverageBucket.PartialThin;
    }

    private static long GetTotalCost(DetailedShoppingPlan plan)
    {
        if (plan.SplitTotalCost.HasValue)
            return plan.SplitTotalCost.Value;
        return MarketAnalysisGridViewService.GetTotalCost(plan);
    }

}
