@using FFXIV_Craft_Architect.Web.Services
<div class="mp-column" id="recipe-tree-container">
    <div class="mp-header-row">
        <div class="mp-title">Recipe Plan</div>
    </div>

    @if (Recipe?.Roots.Count > 0)
    {
        <div class="mp-control-bar">
            @if (ShowPlanEditor)
            {
                <button @onclick="OnOpenPlanEditorRequested" title="Open Plan Editor" class="mp-editor-btn">
                    Plan Editor
                </button>
            }
            <span class="mp-price-basis">@GetPriceBasisText()</span>
            <div class="mp-tree-actions">
                <button @onclick="OnExpandAllRequested" title="Expand All" class="mp-tree-action-btn">
                    + Expand All
                </button>
                <button @onclick="OnCollapseAllRequested" title="Collapse All" class="mp-tree-action-btn">
                    - Collapse All
                </button>
            </div>
        </div>
    }

    @if (Recipe?.Roots.Count is not > 0)
    {
        <div class="mp-empty-state">
            <div class="mp-empty-card">
                <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Class="mp-empty-icon" />
                <div class="mp-empty-title">No Plan Built Yet</div>
                <div class="mp-empty-subtitle">Search for items on the left to add them to your project, then build the recipe plan to see every required material.</div>
            </div>

            @if (SavedPlans.Any())
            {
                <div class="mp-saved-section">
                    <div class="mp-saved-title">Saved Plans:</div>
                    @foreach (var plan in SavedPlans)
                    {
                        <div class="mp-saved-plan-row">
                            <div>
                                <div class="mp-saved-plan-name">@plan.Name</div>
                                <div class="mp-saved-plan-meta">
                                    @plan.DataCenter • @FormatItemCount(plan.ItemCount) • @plan.SavedAt.ToString("MMM dd, HH:mm")
                                </div>
                            </div>
                            <div class="mp-saved-actions">
                                <button @onclick="() => OnLoadPlanRequested.InvokeAsync(plan.Id)" class="mp-load-btn">
                                    Load
                                </button>
                                <button @onclick="() => OnDeletePlanRequested.InvokeAsync(plan.Id)"
                                        aria-label="Delete saved plan @plan.Name"
                                        title="Delete saved plan"
                                        class="mp-delete-btn">
                                    ×
                                </button>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    }
    else
    {
        <div class="mp-tree-panel">
            @foreach (var rootItem in Recipe.Roots)
            {
                <RecipeNodeView Node="rootItem"
                                Depth="0"
                                IsSelected="@(SelectedNode?.NodeId == rootItem.NodeId)"
                                SelectedNodeId="@SelectedNode?.NodeId"
                                ExpandVersion="ExpandVersion"
                                ExpandAll="ExpandAll"
                                OnNodeSelected="OnNodeSelected"
                                OnHqChanged="OnNodeHqChanged" />
            }
        </div>

    }
</div>

@code {
    [Parameter] public WorkerRecipePlannerProjection? Recipe { get; set; }
    [Parameter] public IReadOnlyList<StoredPlanSummary> SavedPlans { get; set; } = Array.Empty<StoredPlanSummary>();

    [Parameter] public EventCallback OnExpandAllRequested { get; set; }
    [Parameter] public EventCallback OnCollapseAllRequested { get; set; }
    [Parameter] public EventCallback OnOpenPlanEditorRequested { get; set; }
    [Parameter] public bool ShowPlanEditor { get; set; } = true;
    [Parameter] public EventCallback<string> OnLoadPlanRequested { get; set; }
    [Parameter] public EventCallback<string> OnDeletePlanRequested { get; set; }
    [Parameter] public WorkerRecipeNodeProjection? SelectedNode { get; set; }
    [Parameter] public EventCallback<WorkerRecipeNodeProjection> OnNodeSelected { get; set; }
    [Parameter] public EventCallback<WorkerRecipeNodeHqChangeRequest> OnNodeHqChanged { get; set; }
    [Parameter] public int ExpandVersion { get; set; }
    [Parameter] public bool ExpandAll { get; set; } = true;

    private static string FormatItemCount(int count) => $"{count:N0} item{(count == 1 ? string.Empty : "s")}";

    private string GetPriceBasisText()
    {
        return Recipe?.HasMarketEvidence == true
            ? "Current acquisition prices"
            : "Building actionable prices";
    }
}
