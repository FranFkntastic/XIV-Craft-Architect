<div class="ma-results-column">
    @if (!BuyItems.Any() && !ShoppingPlans.Any())
    {
        <MudPaper Elevation="2" Class="pa-4 ma-state-paper">
            <div class="ma-state-inner">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Large" Class="ma-state-icon" />
                <MudText Typo="Typo.h6" Class="ma-state-title">No Items to Analyze</MudText>
                <MudText Typo="Typo.body2" Class="ma-state-body">
                    Build a plan in the Recipe Planner and mark items to buy from the market.
                </MudText>

                <MudButton OnClick="OnGoToPlannerRequested"
                           Color="Color.Primary"
                           Variant="Variant.Filled"
                           Size="Size.Large"
                           StartIcon="@Icons.Material.Filled.ArrowBack">
                    Go to Recipe Planner
                </MudButton>
            </div>
        </MudPaper>
    }
    else if (ShoppingPlans.Any())
    {
        <MarketAnalysisListPanel ShoppingPlans="ShoppingPlans"
                                 MarketItemAnalyses="MarketItemAnalyses"
                                 CurrentLens="CurrentLens"
                                 CurrentSort="CurrentSort"
                                 EvidenceOverlay="EvidenceOverlay"
                                 SortColumn="SortColumn"
                                 SortDescending="SortDescending"
                                 WorldSortColumn="WorldSortColumn"
                                 WorldSortDescending="WorldSortDescending"
                                 SelectedItemId="SelectedItemId"
                                 ExpandedWorldKeys="ExpandedWorldKeys"
                                 ShowWorldsColumn="ShowWorldsColumn"
                                 IsRefreshingItem="IsRefreshingItem"
                                 OnSelectedItemChanged="OnSelectedItemChanged"
                                 OnRefreshItemRequested="OnRefreshItemRequested"
                                 OnWorldExpansionToggled="OnWorldExpansionToggled"
                                 OnSortChanged="OnSortChanged"
                                 OnWorldSortChanged="OnWorldSortChanged" />
    }
    else if (ProjectedItems.Any())
    {
        <div class="ma-restored-shell">
            <div class="ma-restored-list">
                <table class="ma-restored-table">
                    <thead>
                        <tr>
                            <th>Item</th>
                            <th class="ma-restored-number">Qty</th>
                            <th>Coverage</th>
                            @if (ShowWorldsColumn)
                            {
                                <th class="ma-restored-number">Worlds</th>
                            }
                            <th class="ma-restored-number">Cash Out</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in GetProjectedItems())
                        {
                            <tr class="@GetProjectedRowClass(item)"
                                @onclick="() => SelectProjectedItem(item)">
                                <td>
                                    <a href="@GetUniversalisUrl(item.ItemId)"
                                       target="_blank"
                                       rel="noopener noreferrer"
                                       @onclick:stopPropagation>
                                        @item.Name
                                    </a>
                                </td>
                                <td class="ma-restored-number">@FormatQuantity(item.QuantityNeeded)</td>
                                <td>@FormatCoverage(item)</td>
                                @if (ShowWorldsColumn)
                                {
                                    <td class="ma-restored-number">@item.WorldCount</td>
                                }
                                <td class="ma-restored-number">@FormatGil(item.EstimatedTotalCost)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <aside class="ma-restored-detail">
                @if (_selectedProjectedItem is null)
                {
                    <div class="ma-restored-empty">Select an item to inspect its route.</div>
                }
                else
                {
                    <div class="ma-restored-detail-header">
                        <div>
                            <a href="@GetUniversalisUrl(_selectedProjectedItem.ItemId)"
                               target="_blank"
                               rel="noopener noreferrer">
                                @_selectedProjectedItem.Name
                            </a>
                            <small>@FormatQuantity(_selectedProjectedItem.QuantityNeeded) needed</small>
                        </div>
                        <div class="ma-restored-actions">
                            <strong>@FormatGil(_selectedProjectedItem.EstimatedTotalCost)</strong>
                            <MudIconButton Icon="@Icons.Material.Filled.Refresh"
                                           Size="Size.Small"
                                           Disabled="IsRefreshingItem"
                                           OnClick="() => RefreshProjectedItemAsync(_selectedProjectedItem)"
                                           Title="Refresh market data for this item"
                                           AriaLabel="Refresh market data for this item" />
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_selectedProjectedItem.Warning))
                    {
                        <div class="ma-restored-warning">@_selectedProjectedItem.Warning</div>
                    }
                    <div class="ma-restored-worlds">
                        <table class="ma-restored-table">
                            <thead>
                                <tr>
                                    <th>Data Center</th>
                                    <th>World</th>
                                    <th class="ma-restored-number">Stock</th>
                                    <th class="ma-restored-number">Unit</th>
                                    <th class="ma-restored-number">Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var world in _selectedProjectedItem.Worlds)
                                {
                                    <tr>
                                        <td>@world.DataCenter</td>
                                        <td>@world.WorldName</td>
                                        <td class="ma-restored-number">@FormatQuantity(world.Quantity)</td>
                                        <td class="ma-restored-number">@FormatGil(world.AverageUnitPrice)</td>
                                        <td class="ma-restored-number">@FormatGil(world.TotalCost)</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
            </aside>
        </div>
    }
    else
    {
        <MudPaper Elevation="2" Class="pa-4 ma-state-paper">
            <div class="ma-state-inner">
                <MudIcon Icon="@Icons.Material.Filled.Analytics" Size="Size.Large" Class="ma-state-icon" />
                <MudText Typo="Typo.h6" Class="ma-state-title">Ready to Analyze</MudText>
                <MudText Typo="Typo.body2" Class="ma-state-body">
                    @FormatItemCount(BuyItems.Count) ready for market comparison.
                </MudText>
            </div>
        </MudPaper>
    }
</div>

@code {
    [Parameter] public List<MaterialAggregate> BuyItems { get; set; } = new();
    [Parameter] public IReadOnlyList<WorkerMarketItemProjection> ProjectedItems { get; set; } = Array.Empty<WorkerMarketItemProjection>();
    [Parameter] public IReadOnlyList<DetailedShoppingPlan> ShoppingPlans { get; set; } = Array.Empty<DetailedShoppingPlan>();
    [Parameter] public IReadOnlyList<MarketItemAnalysis> MarketItemAnalyses { get; set; } = Array.Empty<MarketItemAnalysis>();
    [Parameter] public MarketAcquisitionLens CurrentLens { get; set; }
    [Parameter] public MarketSortOption CurrentSort { get; set; }
    [Parameter] public MarketAnalysisEvidenceOverlay EvidenceOverlay { get; set; } = MarketAnalysisEvidenceOverlay.CompetitivenessOverlay;
    [Parameter] public MarketAnalysisGridSortColumn? SortColumn { get; set; }
    [Parameter] public bool SortDescending { get; set; }
    [Parameter] public MarketAnalysisWorldGridSortColumn? WorldSortColumn { get; set; }
    [Parameter] public bool WorldSortDescending { get; set; }
    [Parameter] public int? SelectedItemId { get; set; }
    [Parameter] public IReadOnlySet<MarketAnalysisExpandedWorldKey> ExpandedWorldKeys { get; set; } = new HashSet<MarketAnalysisExpandedWorldKey>();
    [Parameter] public bool ShowWorldsColumn { get; set; }
    [Parameter] public bool IsRefreshingItem { get; set; }

    [Parameter] public EventCallback OnGoToPlannerRequested { get; set; }
    [Parameter] public EventCallback<int?> OnSelectedItemChanged { get; set; }
    [Parameter] public EventCallback<DetailedShoppingPlan> OnRefreshItemRequested { get; set; }
    [Parameter] public EventCallback<WorkerMarketItemProjection> OnRefreshProjectedItemRequested { get; set; }
    [Parameter] public EventCallback<MarketAnalysisExpandedWorldKey> OnWorldExpansionToggled { get; set; }
    [Parameter] public EventCallback<MarketAnalysisGridSortState> OnSortChanged { get; set; }
    [Parameter] public EventCallback<MarketAnalysisWorldGridSortState> OnWorldSortChanged { get; set; }

    private WorkerMarketItemProjection? _selectedProjectedItem;

    protected override void OnParametersSet()
    {
        _selectedProjectedItem = ProjectedItems.FirstOrDefault(item => item.ItemId == SelectedItemId)
            ?? ProjectedItems.FirstOrDefault();
    }

    private IEnumerable<WorkerMarketItemProjection> GetProjectedItems()
    {
        var items = ProjectedItems.AsEnumerable();
        IOrderedEnumerable<WorkerMarketItemProjection> ordered = SortColumn switch
        {
            MarketAnalysisGridSortColumn.Quantity => SortDescending
                ? items.OrderByDescending(item => item.QuantityNeeded)
                : items.OrderBy(item => item.QuantityNeeded),
            MarketAnalysisGridSortColumn.Coverage => SortDescending
                ? items.OrderByDescending(item => item.AvailableQuantity)
                : items.OrderBy(item => item.AvailableQuantity),
            MarketAnalysisGridSortColumn.Worlds => SortDescending
                ? items.OrderByDescending(item => item.WorldCount)
                : items.OrderBy(item => item.WorldCount),
            MarketAnalysisGridSortColumn.Total => SortDescending
                ? items.OrderByDescending(item => item.EstimatedTotalCost)
                : items.OrderBy(item => item.EstimatedTotalCost),
            _ => SortDescending
                ? items.OrderByDescending(item => item.Name, StringComparer.OrdinalIgnoreCase)
                : items.OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase)
        };
        return ordered.ThenBy(item => item.ItemId);
    }

    private async Task SelectProjectedItem(WorkerMarketItemProjection item)
    {
        _selectedProjectedItem = item;
        await OnSelectedItemChanged.InvokeAsync(item.ItemId);
    }

    private Task RefreshProjectedItemAsync(WorkerMarketItemProjection item) =>
        OnRefreshProjectedItemRequested.InvokeAsync(item);

    private string GetProjectedRowClass(WorkerMarketItemProjection item) =>
        item.ItemId == _selectedProjectedItem?.ItemId ? "is-selected" : string.Empty;

    private static string FormatCoverage(WorkerMarketItemProjection item) =>
        item.IsAvailable
            ? $"{FormatQuantity(item.AvailableQuantity)} / {FormatQuantity(item.QuantityNeeded)}"
            : "Unavailable";

    private static string FormatQuantity(int value) => value.ToString("N0");

    private static string FormatGil(decimal value) => $"{value:N0}g";

    private static string GetUniversalisUrl(int itemId) =>
        $"https://universalis.app/market/{itemId}";

    private static string FormatItemCount(int count) => $"{count:N0} item{(count == 1 ? string.Empty : "s")}";
}
