@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject WorkerProjectionStore WorkerProjections
@inject CraftArchitectEngineHost EngineHost
@inject NavigationManager NavigationManager
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@implements IDisposable

<div class="status-bar">
    <div class="status-left">
        @if (IsBusy)
        {
            <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Primary" Class="status-spinner" />
        }
        else
        {
            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" 
                     Size="Size.Small" 
                     Color="Color.Success" 
                     Class="status-icon" />
        }
        <span class="status-text @(IsBusy ? "busy" : "ready")">@StatusMessage</span>
    </div>
    
    <div class="status-center">
        @if (IsTradeRoute && !string.IsNullOrWhiteSpace(_tradeCompanyName))
        {
            <span class="status-badge trade-company-badge">
                <MudIcon Icon="@Icons.Material.Filled.Business" Size="Size.Small" />
                @_tradeCompanyName
            </span>
        }
        @if (!string.IsNullOrEmpty(SelectedRegion))
        {
            <span class="status-badge region-badge">
                <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" />
                @SelectedRegion
            </span>
        }
        @if (!string.IsNullOrEmpty(SelectedDataCenter))
        {
            <span class="status-badge dc-badge">
                <MudIcon Icon="@Icons.Material.Filled.DataUsage" Size="Size.Small" />
                @SelectedDataCenter
            </span>
        }
        @if (MaterialCount > 0)
        {
            <span class="status-badge">
                <MudIcon Icon="@Icons.Material.Filled.ShoppingCart" Size="Size.Small" />
                @FormatCount(MaterialCount, "material")
            </span>
        }
        @if (TargetCount > 0)
        {
            <span class="status-badge">
                <MudIcon Icon="@Icons.Material.Filled.ListAlt" Size="Size.Small" />
                @FormatCount(TargetCount, "target")
            </span>
        }
    </div>
    
    <div class="status-right">
        @if (IsTradeRoute && AppState.IsBusy && AppState.ProgressPercent > 0)
        {
            <span class="progress-text">@AppState.ProgressPercent.ToString("F0")%</span>
        }
    </div>
</div>

<style>
    .status-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 4px 16px;
        background: linear-gradient(180deg, #252525 0%, #1e1e1e 100%);
        border-top: 1px solid #333;
        font-size: 12px;
        height: 28px;
        flex-shrink: 0;
    }
    
    .status-left {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 1;
        min-width: 0;
    }
    
    .status-spinner {
        width: 14px !important;
        height: 14px !important;
    }
    
    .status-icon {
        width: 14px;
        height: 14px;
    }
    
    .status-text {
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
    }
    
    .status-text.ready {
        color: #aaa;
    }
    
    .status-text.busy {
        color: #d4a73a;
        font-weight: 500;
    }
    
    .status-center {
        display: flex;
        align-items: center;
        gap: 8px;
        justify-content: center;
    }
    
    .status-badge {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 2px 8px;
        background: #333;
        border-radius: 12px;
        color: #ccc;
        font-size: 11px;
    }
    
    .status-badge.region-badge {
        background: #3d3d2d;
        color: #d4a73a;
    }
    
    .status-badge.dc-badge {
        background: #2d4a3e;
        color: #90EE90;
    }

    .status-badge.trade-company-badge {
        background: #2e3f2a;
        color: #b6d7a8;
    }
    
    .status-right {
        display: flex;
        align-items: center;
        gap: 12px;
        flex: 1;
        justify-content: flex-end;
    }
    
    .progress-text {
        color: #d4a73a;
        font-weight: 600;
        font-variant-numeric: tabular-nums;
    }
</style>

@code {
    private string? _tradeCompanyName;
    private bool IsBusy => IsTradeRoute ? AppState.IsBusy : EngineHost.Health.IsExecuting;
    private string StatusMessage => IsTradeRoute
        ? AppState.StatusMessage
        : IsBusy ? "Working" : "Ready";
    private string SelectedRegion => IsTradeRoute
        ? AppState.SelectedRegion
        : WorkerProjections.Shell.SelectedRegion;
    private string SelectedDataCenter => IsTradeRoute
        ? AppState.SelectedDataCenter
        : WorkerProjections.Shell.SelectedDataCenter;
    private int MaterialCount => IsTradeRoute
        ? AppState.ShoppingItems.Count
        : WorkerProjections.Procurement?.ActiveItemCount
          ?? WorkerProjections.Acquisition?.ActiveProcurementCount
          ?? 0;
    private int TargetCount => IsTradeRoute
        ? AppState.ProjectItemCount
        : WorkerProjections.Shell.ProjectItemCount;
    private static string FormatCount(int count, string noun) =>
        $"{count:N0} {noun}{(count == 1 ? string.Empty : "s")}";

    private bool IsTradeRoute => NavigationManager
        .ToBaseRelativePath(NavigationManager.Uri)
        .TrimStart('/')
        .StartsWith("trade", StringComparison.OrdinalIgnoreCase);

    protected override void OnInitialized()
    {
        AppState.OnStatusChanged += OnStatusChanged;
        AppState.OnShoppingListChanged += OnStatusChanged;
        AppState.OnPlanChanged += OnStatusChanged;
        WorkerProjections.Changed += OnStatusChanged;
        NavigationManager.LocationChanged += OnLocationChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadTradeCompanyNameAsync();
    }
    
    private void OnStatusChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnLocationChanged(object? sender, LocationChangedEventArgs e)
    {
        _ = InvokeAsync(async () =>
        {
            await LoadTradeCompanyNameAsync();
            StateHasChanged();
        });
    }

    private async Task LoadTradeCompanyNameAsync()
    {
        if (!IsTradeRoute)
        {
            _tradeCompanyName = null;
            return;
        }

        try
        {
            var profile = await TradeOperationsPersistence.GetOrCreateActiveCompanyProfileAsync();
            _tradeCompanyName = profile.Name;
        }
        catch
        {
            _tradeCompanyName = null;
        }
    }
    
    public void Dispose()
    {
        AppState.OnStatusChanged -= OnStatusChanged;
        AppState.OnShoppingListChanged -= OnStatusChanged;
        AppState.OnPlanChanged -= OnStatusChanged;
        WorkerProjections.Changed -= OnStatusChanged;
        NavigationManager.LocationChanged -= OnLocationChanged;
    }
}
