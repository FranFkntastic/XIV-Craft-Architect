@using FFXIV_Craft_Architect.Core.Models

<div class="ma-detail-grid-shell">
    @if (!string.IsNullOrWhiteSpace(Plan.Error))
    {
        <div class="ma-detail-alert is-error">
            <MudIcon Icon="@Icons.Material.Filled.ErrorOutline" Size="Size.Small" />
            <div>
                <strong>Could not analyze market data</strong>
                <span>@Plan.Error</span>
            </div>
        </div>

        <MudDataGrid T="DetailFact"
                     Items="GetErrorFacts()"
                     Dense="true"
                     Bordered="false"
                     Square="true"
                     Elevation="0"
                     Hideable="false"
                     Filterable="false"
                     Groupable="false"
                     SortMode="SortMode.Single"
                     ShowMenuIcon="false"
                     Class="ma-detail-data-grid ma-fact-grid">
            <Columns>
                <TemplateColumn T="DetailFact" Title="Field" SortBy="fact => fact.Label" CellClass="ma-fact-label">
                    <CellTemplate>@context.Item.Label</CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="DetailFact" Title="Value" SortBy="fact => fact.Value" CellClass="ma-fact-value">
                    <CellTemplate>@context.Item.Value</CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>
    }
    else if (IsVendorPlan)
    {
        <MudDataGrid T="VendorInfo"
                     Items="GetVendors()"
                     Dense="true"
                     Bordered="false"
                     Square="true"
                     Elevation="0"
                     FixedHeader="true"
                     Hideable="false"
                     Filterable="false"
                     Groupable="false"
                     SortMode="SortMode.Single"
                     ShowMenuIcon="false"
                     Class="ma-detail-data-grid ma-vendor-grid">
            <Columns>
                <TemplateColumn T="VendorInfo" Title="Vendor" SortBy="vendor => vendor.Name">
                    <CellTemplate>
                        <span class="ma-detail-primary">@context.Item.Name</span>
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="VendorInfo" Title="Location" SortBy="vendor => vendor.Location">
                    <CellTemplate>
                        <span>@context.Item.Location</span>
                        @if (context.Item.HasCoordinates)
                        {
                            <span class="ma-detail-muted">@context.Item.CoordinatesDisplay</span>
                        }
                    </CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="VendorInfo" Title="Unit" SortBy="vendor => vendor.Price" CellClass="ma-detail-number">
                    <CellTemplate>@context.Item.Price.ToString("N0")g</CellTemplate>
                </TemplateColumn>
                <TemplateColumn T="VendorInfo" Title="Total" SortBy="vendor => vendor.Price * Plan.QuantityNeeded" CellClass="ma-detail-total-cell">
                    <CellTemplate>@((context.Item.Price * Plan.QuantityNeeded).ToString("N0"))g</CellTemplate>
                </TemplateColumn>
            </Columns>
        </MudDataGrid>

        <div class="ma-detail-alert is-info">
            <MudIcon Icon="@Icons.Material.Filled.Store" Size="Size.Small" />
            <span>Vendor purchase. Stock is treated as unlimited.</span>
        </div>
    }
    else
    {
        @if (!Plan.HasSufficientStock)
        {
            <div class="ma-detail-alert is-warning">
                <MudIcon Icon="@Icons.Material.Filled.Warning" Size="Size.Small" />
                <span>
                    Only @Plan.TotalAvailableQuantity.ToString("N0") of @Plan.QuantityNeeded.ToString("N0") available.
                    Shortfall: @Plan.StockShortfall.ToString("N0").
                </span>
            </div>
        }

        <section class="ma-detail-section">
            <div class="ma-detail-section-title">
                <MudIcon Icon="@Icons.Material.Filled.Recommend" Size="Size.Small" />
                <span>Recommended Purchase</span>
            </div>

            <MudDataGrid T="RecommendedPurchaseRow"
                         Items="GetRecommendedRows()"
                         Dense="true"
                         Bordered="false"
                         Square="true"
                         Elevation="0"
                         Hideable="false"
                         Filterable="false"
                         Groupable="false"
                         SortMode="SortMode.Single"
                         ShowMenuIcon="false"
                         Class="ma-detail-data-grid">
                <Columns>
                    <TemplateColumn T="RecommendedPurchaseRow" Title="World" SortBy="row => row.WorldName">
                        <CellTemplate>
                            <button class="ma-link-button" type="button" @onclick="() => ToggleWorldListings(context.Item.WorldName)">
                                <MudIcon Icon="@(IsWorldExpanded(context.Item.WorldName) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight)" Size="Size.Small" />
                                <span>@context.Item.WorldName</span>
                            </button>
                        </CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn T="RecommendedPurchaseRow" Title="Qty" SortBy="row => row.Quantity" CellClass="ma-detail-number">
                        <CellTemplate>@FormatQuantity(context.Item.Quantity)</CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn T="RecommendedPurchaseRow" Title="Unit / Eff." SortBy="row => row.UnitPrice" CellClass="ma-detail-number">
                        <CellTemplate>@context.Item.PriceDisplay</CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn T="RecommendedPurchaseRow" Title="Total" SortBy="row => row.TotalCost" CellClass="ma-detail-total-cell">
                        <CellTemplate>@context.Item.TotalCost.ToString("N0")g</CellTemplate>
                    </TemplateColumn>
                    <TemplateColumn T="RecommendedPurchaseRow" Title="Type" SortBy="row => row.Kind">
                        <CellTemplate>@context.Item.Kind</CellTemplate>
                    </TemplateColumn>
                </Columns>
            </MudDataGrid>

            @foreach (var worldName in _expandedRecommendedWorlds)
            {
                var listings = GetRecommendedListings(worldName).ToList();
                if (listings.Any())
                {
                    <div class="ma-detail-subtable">
                        <div class="ma-detail-subtitle">@worldName listings</div>
                        @RenderListingsGrid(listings)
                    </div>
                }
            }
        </section>

        <section class="ma-detail-section">
            <button type="button" class="ma-detail-section-toggle" @onclick="() => _showAllWorlds = !_showAllWorlds">
                <span class="ma-detail-section-title">
                    <MudIcon Icon="@Icons.Material.Filled.Public" Size="Size.Small" />
                    <span>All Worlds</span>
                    <span class="ma-detail-muted">@Plan.WorldOptions.Count options</span>
                </span>
                <MudIcon Icon="@(_showAllWorlds ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
            </button>

            @if (_showAllWorlds)
            {
                <div class="ma-detail-data-grid ma-detail-table ma-world-grid">
                    <div class="ma-world-table-scroll">
                        <table>
                            <thead>
                                <tr>
                                    <th>@RenderWorldSortHeader("World", WorldSortColumn.World)</th>
                                    <th>@RenderWorldSortHeader("Qty", WorldSortColumn.Quantity)</th>
                                    <th>@RenderWorldSortHeader("Unit", WorldSortColumn.Unit)</th>
                                    <th>@RenderWorldSortHeader("Total", WorldSortColumn.Total)</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var world in GetWorldsByFavorability())
                                {
                                    <tr class="@GetWorldRowClass(world, 0)">
                                        <td>
                                            <button class="ma-link-button" type="button" @onclick="() => ToggleAllWorld(world.WorldName)">
                                                <MudIcon Icon="@(_expandedAllWorlds.Contains(world.WorldName) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ChevronRight)" Size="Size.Small" />
                                                <span>@world.WorldName</span>
                                            </button>
                                        </td>
                                        <td class="ma-detail-number">
                                            <span class="@(world.HasSufficientStock ? "ma-stock-ok" : "ma-stock-warning")">
                                                @FormatWorldQuantity(world)
                                            </span>
                                        </td>
                                        <td class="ma-detail-number">@world.AveragePricePerUnit.ToString("N0")g</td>
                                        <td class="ma-detail-total-cell">@world.TotalCost.ToString("N0")g</td>
                                    </tr>

                                    @if (_expandedAllWorlds.Contains(world.WorldName))
                                    {
                                        var listings = GetAllListings(world).ToList();
                                        if (listings.Any())
                        {
                                            <tr class="ma-detail-expanded-row">
                                                <td colspan="4">
                                                    <div class="ma-detail-subtable ma-detail-child-subtable">
                                                        <div class="ma-detail-subtitle">@world.WorldName listings</div>
                                                        @RenderListingsGrid(listings, world.ExcludedListings, world.ModePricePerUnit)
                                                    </div>
                                                </td>
                                            </tr>
                        }
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </section>
    }
</div>

@code {
    [Parameter] public DetailedShoppingPlan Plan { get; set; } = default!;

    private readonly HashSet<string> _expandedRecommendedWorlds = new(StringComparer.OrdinalIgnoreCase);
    private readonly HashSet<string> _expandedAllWorlds = new(StringComparer.OrdinalIgnoreCase);
    private bool _showAllWorlds;
    private WorldSortColumn _worldSortColumn = WorldSortColumn.Total;
    private bool _worldSortAscending = true;

    private bool IsVendorPlan => Plan.RecommendedWorld?.WorldName == MarketShoppingConstants.VendorWorldName || Plan.Vendors.Any();

    protected override void OnParametersSet()
    {
        _expandedRecommendedWorlds.Clear();
        _expandedAllWorlds.Clear();
        _showAllWorlds = false;
    }

    private IEnumerable<RecommendedPurchaseRow> GetRecommendedRows()
    {
        if (Plan.RequiresSplitPurchase && Plan.RecommendedSplit?.Any() == true)
        {
            return Plan.RecommendedSplit.Select(split => new RecommendedPurchaseRow(
                split.WorldName,
                split.QuantityToBuy,
                split.EffectivePricePerNeededUnit,
                split.TotalCost,
                split.TravelContext,
                true));
        }

        if (Plan.RecommendedWorld != null)
        {
            return new[]
            {
                new RecommendedPurchaseRow(
                    Plan.RecommendedWorld.WorldName,
                    Plan.QuantityNeeded,
                    Plan.RecommendedWorld.AveragePricePerUnit,
                    Plan.RecommendedWorld.TotalCost,
                    "Single world")
            };
        }

        return Array.Empty<RecommendedPurchaseRow>();
    }

    private IEnumerable<ShoppingListingEntry> GetRecommendedListings(string worldName)
    {
        if (Plan.RequiresSplitPurchase && Plan.RecommendedSplit?.Any() == true)
        {
            var split = Plan.RecommendedSplit.FirstOrDefault(s => string.Equals(s.WorldName, worldName, StringComparison.OrdinalIgnoreCase));
            if (split?.Listings?.Any() == true)
            {
                return split.Listings.OrderBy(l => l.PricePerUnit);
            }
        }

        var world = Plan.WorldOptions.FirstOrDefault(w => string.Equals(w.WorldName, worldName, StringComparison.OrdinalIgnoreCase));
        return world?.Listings?.Where(l => !l.IsAdditionalOption).OrderBy(l => l.PricePerUnit)
            ?? Enumerable.Empty<ShoppingListingEntry>();
    }

    private IEnumerable<WorldShoppingSummary> GetWorldsByFavorability()
    {
        var worlds = Plan.WorldOptions ?? Enumerable.Empty<WorldShoppingSummary>();

        return (_worldSortColumn, _worldSortAscending) switch
        {
            (WorldSortColumn.World, true) => worlds.OrderBy(w => w.WorldName),
            (WorldSortColumn.World, false) => worlds.OrderByDescending(w => w.WorldName),
            (WorldSortColumn.Quantity, true) => worlds.OrderBy(w => w.TotalQuantityPurchased).ThenBy(w => w.WorldName),
            (WorldSortColumn.Quantity, false) => worlds.OrderByDescending(w => w.TotalQuantityPurchased).ThenBy(w => w.WorldName),
            (WorldSortColumn.Unit, true) => worlds.OrderBy(w => w.AveragePricePerUnit).ThenBy(w => w.WorldName),
            (WorldSortColumn.Unit, false) => worlds.OrderByDescending(w => w.AveragePricePerUnit).ThenBy(w => w.WorldName),
            (WorldSortColumn.Total, false) => worlds.OrderByDescending(w => w.TotalCost).ThenBy(w => w.WorldName),
            _ => worlds.OrderBy(w => w.TotalCost).ThenBy(w => w.WorldName)
        };
    }

    private IEnumerable<ShoppingListingEntry> GetAllListings(WorldShoppingSummary? world)
    {
        if (world == null)
            return Enumerable.Empty<ShoppingListingEntry>();

        var normalListings = world.Listings?.Where(l => !l.IsAdditionalOption) ?? Enumerable.Empty<ShoppingListingEntry>();
        var excludedListings = world.ExcludedListings ?? Enumerable.Empty<ShoppingListingEntry>();
        return normalListings.Concat(excludedListings).OrderBy(l => l.PricePerUnit);
    }

    private RenderFragment RenderListingsGrid(
        IReadOnlyList<ShoppingListingEntry> listings,
        IReadOnlyList<ShoppingListingEntry>? excludedListings = null,
        long modePrice = 0) => @<MudDataGrid T="ShoppingListingEntry"
                                             Items="listings"
                                             Dense="true"
                                             Bordered="false"
                                             Square="true"
                                             Elevation="0"
                                             Hideable="false"
                                             Filterable="false"
                                             Groupable="false"
                                             SortMode="SortMode.Single"
                                             ShowMenuIcon="false"
                                             RowClassFunc="(listing, row) => GetListingRowClass(listing, excludedListings)"
                                             Class="ma-detail-data-grid ma-listing-grid">
        <Columns>
            <TemplateColumn T="ShoppingListingEntry" Title="Qty" SortBy="listing => listing.Quantity" CellClass="ma-detail-number">
                <CellTemplate>@FormatQuantity(context.Item.Quantity)</CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="ShoppingListingEntry" Title="Price" SortBy="listing => listing.PricePerUnit" CellClass="ma-detail-number">
                <CellTemplate>
                    <span class="@(context.Item.IsHq ? "ma-hq-price" : null)">
                        @(context.Item.IsHq ? "HQ " : null)@context.Item.PricePerUnit.ToString("N0")g
                    </span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="ShoppingListingEntry" Title="Total" SortBy="listing => listing.Quantity * listing.PricePerUnit" CellClass="ma-detail-total-cell">
                <CellTemplate>@((context.Item.Quantity * context.Item.PricePerUnit).ToString("N0"))g</CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="ShoppingListingEntry" Title="Retainer" SortBy="listing => listing.RetainerName">
                <CellTemplate>
                    <span class="ma-retainer-cell">@context.Item.RetainerName</span>
                </CellTemplate>
            </TemplateColumn>
            <TemplateColumn T="ShoppingListingEntry" Title="Note" SortBy="listing => IsExcluded(listing, excludedListings)">
                <CellTemplate>
                    @if (IsExcluded(context.Item, excludedListings))
                    {
                        var priceMultiplier = modePrice > 0 ? (decimal)context.Item.PricePerUnit / modePrice : 0;
                        <span class="ma-detail-note">too expensive@(priceMultiplier > 0 ? $" ({priceMultiplier:F1}x)" : "")</span>
                    }
                </CellTemplate>
            </TemplateColumn>
        </Columns>
    </MudDataGrid>;

    private void ToggleWorldListings(string worldName)
    {
        if (!_expandedRecommendedWorlds.Add(worldName))
        {
            _expandedRecommendedWorlds.Remove(worldName);
        }
    }

    private bool IsWorldExpanded(string worldName)
    {
        return _expandedRecommendedWorlds.Contains(worldName);
    }

    private void ToggleAllWorld(string worldName)
    {
        if (!_expandedAllWorlds.Add(worldName))
        {
            _expandedAllWorlds.Remove(worldName);
        }
    }

    private RenderFragment RenderWorldSortHeader(string label, WorldSortColumn column) => @<button
        type="button"
        class="ma-sort-header"
        @onclick="() => ToggleWorldSort(column)">
        <span>@label</span>
        @if (_worldSortColumn == column)
        {
            <MudIcon Icon="@(_worldSortAscending ? Icons.Material.Filled.ArrowUpward : Icons.Material.Filled.ArrowDownward)" Size="Size.Small" />
        }
    </button>;

    private void ToggleWorldSort(WorldSortColumn column)
    {
        if (_worldSortColumn == column)
        {
            _worldSortAscending = !_worldSortAscending;
            return;
        }

        _worldSortColumn = column;
        _worldSortAscending = true;
    }

    private string GetWorldRowClass(WorldShoppingSummary world, int rowNumber)
    {
        return _expandedAllWorlds.Contains(world.WorldName) ? "is-selected" : string.Empty;
    }

    private static string GetListingRowClass(
        ShoppingListingEntry listing,
        IReadOnlyList<ShoppingListingEntry>? excludedListings)
    {
        return IsExcluded(listing, excludedListings) ? "is-excluded" : string.Empty;
    }

    private static bool IsExcluded(
        ShoppingListingEntry listing,
        IReadOnlyList<ShoppingListingEntry>? excludedListings)
    {
        return excludedListings?.Contains(listing) == true;
    }

    private IEnumerable<DetailFact> GetErrorFacts()
    {
        return new[]
        {
            new DetailFact("Item", Plan.Name),
            new DetailFact("Item ID", Plan.ItemId.ToString()),
            new DetailFact("Need", FormatQuantity(Plan.QuantityNeeded))
        };
    }

    private IEnumerable<VendorInfo> GetVendors()
    {
        return Plan.Vendors ?? Enumerable.Empty<VendorInfo>();
    }

    private static string FormatQuantity(int quantity)
    {
        return $"x{quantity:N0}";
    }

    private string FormatWorldQuantity(WorldShoppingSummary world)
    {
        if (world.HasSufficientStock)
        {
            return FormatQuantity(Plan.QuantityNeeded);
        }

        return $"{world.TotalQuantityPurchased:N0}/{Plan.QuantityNeeded:N0}";
    }

    private readonly record struct DetailFact(string Label, string Value);

    private readonly record struct RecommendedPurchaseRow(
        string WorldName,
        int Quantity,
        decimal UnitPrice,
        long TotalCost,
        string Kind,
        bool IsEffectiveCost = false)
    {
        public string PriceDisplay => IsEffectiveCost
            ? $"{UnitPrice:N0}g eff."
            : $"{UnitPrice:N0}g";
    }

    private enum WorldSortColumn
    {
        World,
        Quantity,
        Unit,
        Total
    }
}
