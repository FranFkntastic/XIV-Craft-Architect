@page "/"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Dialogs
@using FFXIV_Craft_Architect.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject GarlandService GarlandService
@inject RecipeCalculationService RecipeCalculationService
@inject RecipePlannerCommandService RecipePlannerCommandService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AppState AppState
@inject IndexedDbService IndexedDb
@inject WebPlanPersistenceService PlanPersistence
@inject AcquisitionDecisionService AcquisitionDecisionService
@inject ILogger<Index> Logger
@implements IDisposable

<!-- Planner layout: project inputs and recipe visualization only. -->
<div style="display: grid; grid-template-columns: 280px 1fr; gap: 0; height: calc(100vh - 64px);">

    <!-- Left Column: Project Items -->
    <ProjectItemsPanel
        SearchQuery="@_searchQuery"
        SearchQueryChanged="OnSearchQueryChanged"
        OnSearchKeyUp="OnSearchKeyUp"
        IsSearching="@_isSearching"
        IsBuildingPlan="@_isBuildingPlan"
        ShowPlanActions="@(AppState.CurrentPlan != null || AppState.ProjectItems.Any())"
        LastAutoSave="@AppState.LastAutoSave"
        SearchResults="@_searchResults"
        ProjectItems="@AppState.ProjectItems"
        OnSearchRequested="SearchItemsAsync"
        OnOpenPlanBuilderRequested="OpenPlanBuilderAsync"
        OnAddProjectItem="AddProjectItem"
        OnToggleItemHq="ToggleItemHq"
        OnRemoveProjectItem="RemoveProjectItem"
        OnBuildPlanRequested="BuildPlanAsync"
        OnSavePlanRequested="SaveToBrowserAsync"
        OnExportPlanRequested="ExportPlanAsync" />

    <!-- Middle Column: Recipe Tree -->
    <RecipePlanPanel
        CurrentPlan="@AppState.CurrentPlan"
        ShoppingPlans="@AppState.ShoppingPlans"
        SavedPlans="@AppState.SavedPlans"
        OnExpandAllRequested="ExpandAllRecipeNodes"
        OnCollapseAllRequested="CollapseAllRecipeNodes"
        OnOpenPlanEditorRequested="OpenPlanEditorAsync"
        OnLoadPlanRequested="LoadSavedPlanAsync"
        OnDeletePlanRequested="DeleteSavedPlanAsync"
        SelectedNode="@_selectedNode"
        OnNodeSelected="OnNodeSelected"
        OnNodeHqChanged="OnNodeHqChanged" />

</div>

@code {
    private string _searchQuery = string.Empty;
    private bool _isSearching = false;
    private List<GarlandSearchResult> _searchResults = new();

    private bool _isBuildingPlan = false;
    private PlanNode? _selectedNode;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to state changes
        AppState.OnPlanChanged += OnPlanChanged;

        // Load saved plans list
        await RefreshSavedPlansListAsync();

        // Note: WorldData, auto-save restoration, and auto-save timer are now
        // all handled centrally in MainLayout.razor
    }

    private void OnPlanChanged()
    {
        EnsureSelectedNode();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnPlanChanged -= OnPlanChanged;

        // Note: Auto-save timer is now managed centrally in MainLayout.razor
    }

    private async Task RefreshSavedPlansListAsync()
    {
        var summaries = await PlanPersistence.LoadPlanSummariesAsync();
        AppState.SavedPlans = summaries
            .Where(p => p.Id != "autosave") // Don't show autosave in list
            .ToList();
        AppState.NotifySavedPlansChanged();
    }

    private async Task SearchItemsAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return;

        _isSearching = true;
        _searchResults.Clear();

        try
        {
            var results = await GarlandService.SearchAsync(_searchQuery);
            _searchResults = results.Take(10).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSearching = false;
            StateHasChanged(); // Force re-render to update button text and results
        }
    }

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = SearchItemsAsync();
        }
    }

    private Task OnSearchQueryChanged(string value)
    {
        _searchQuery = value;
        return Task.CompletedTask;
    }

    private Task ExpandAllRecipeNodes()
    {
        AppState.ExpandAllRecipeNodes();
        return Task.CompletedTask;
    }

    private Task CollapseAllRecipeNodes()
    {
        AppState.CollapseAllRecipeNodes();
        return Task.CompletedTask;
    }

    private void AddProjectItem(GarlandSearchResult result)
    {
        AppState.AddProjectItem(new ProjectItem
            {
                Id = result.Id,
                Name = result.Object.Name,
                IconId = result.Object.IconId,
                Quantity = 1,
                MustBeHq = false
            });

        _searchResults.Clear();
        _searchQuery = string.Empty;
    }

    private void RemoveProjectItem(ProjectItem item)
    {
        AppState.RemoveProjectItem(item);
    }

    private void ToggleItemHq(ProjectItem item)
    {
        AppState.ToggleProjectItemHq(item);
    }

    private async Task OpenPlanBuilderAsync()
    {
        var parameters = new DialogParameters
        {
            ["InitialItems"] = AppState.ProjectItems
                .Select(CloneProjectItem)
                .ToList()
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<PlanBuilderDialog>("Plan Builder", parameters, options);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not PlanBuilderDialog.PlanBuilderResult builderResult)
        {
            return;
        }

        AppState.ReplaceProjectItems(builderResult.Items);

        if (builderResult.BuildAfterApply)
        {
            await BuildPlanAsync();
        }
    }

    private static ProjectItem CloneProjectItem(ProjectItem item)
    {
        return new ProjectItem
        {
            Id = item.Id,
            Name = item.Name,
            IconId = item.IconId,
            Quantity = item.Quantity,
            MustBeHq = item.MustBeHq
        };
    }

    private async Task OpenPlanEditorAsync()
    {
        if (AppState.CurrentPlan == null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            ["CurrentPlan"] = AppState.CurrentPlan,
            ["SelectedNode"] = _selectedNode
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<PlanEditorDialog>("Plan Editor", parameters, options);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not PlanEditorDialog.PlanEditorResult editorResult)
        {
            return;
        }

        var editResult = RecipePlannerCommandService.ApplyPlanEditorEdit(new ApplyPlanEditorEditRequest(
            editorResult.NodeIds,
            editorResult.Options,
            editorResult.RequireHqMaterials));
        Snackbar.Add(editResult.Message, Severity.Success);
    }

    private async Task BuildPlanAsync()
    {
        if (!AppState.ProjectItems.Any() || _isBuildingPlan)
            return;

        _isBuildingPlan = true;
        StateHasChanged();

        try
        {
            var result = await RecipePlannerCommandService.BuildPlanAsync(
                new BuildRecipePlanRequest(
                    AppState.ProjectItems,
                    AppState.SelectedDataCenter,
                    AppState.SelectedRegion,
                    AppState.DefaultMarketFetchScope));
            _selectedNode = result.SelectedNode;
            Snackbar.Add(
                result.Message,
                result.MessageLevel switch
                {
                    RecipePlannerCommandMessageLevel.Success => Severity.Success,
                    RecipePlannerCommandMessageLevel.Warning => Severity.Warning,
                    RecipePlannerCommandMessageLevel.Error => Severity.Error,
                    _ => Severity.Info
                });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to build plan: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBuildingPlan = false;
        }
    }

    private IReadOnlyList<string> GetCurrentRegionDataCenters()
    {
        return MarketFetchScopeResolver.GetDataCenters(
            MarketFetchScope.EntireRegion,
            AppState.SelectedDataCenter,
            AppState.SelectedRegion);
    }

    private void OnNodeSelected(PlanNode node)
    {
        _selectedNode = node;
    }

    private void EnsureSelectedNode()
    {
        if (AppState.CurrentPlan == null)
        {
            _selectedNode = null;
            return;
        }

        if (_selectedNode == null || AppState.CurrentPlan.FindNode(_selectedNode.ItemId) == null)
        {
            _selectedNode = AppState.CurrentPlan.RootItems.FirstOrDefault();
        }
    }

    private void OnNodeHqChanged(PlanNodeHqChangeRequest request)
    {
        AcquisitionDecisionService.ChangeMarketHq(request.Node, request.MustBeHq);
    }

    private async Task SaveToBrowserAsync()
    {
        if (!AppState.ProjectItems.Any())
            return;

        try
        {
            // Use existing plan ID if available (overwrite), otherwise generate new
            var planId = AppState.CurrentPlanId ?? Guid.NewGuid().ToString();
            var planName = AppState.CurrentPlanName ?? AppState.CurrentPlan?.Name ?? $"Plan_{DateTime.Now:yyyyMMdd_HHmm}";

            // If this is a new save (no CurrentPlanId), set it for future overwrites
            if (AppState.CurrentPlanId == null)
            {
                AppState.CurrentPlanId = planId;
                AppState.CurrentPlanName = planName;
            }

            var existingSummary = AppState.SavedPlans.FirstOrDefault(plan => plan.Id == planId);
            var success = await PlanPersistence.SaveCurrentPlanAsync(
                planId,
                planName,
                existingSummary?.SavedAt);
            if (success)
            {
                var action = AppState.CurrentPlanId == planId ? "Updated" : "Saved";
                Snackbar.Add($"{action} '{planName}' to browser storage", Severity.Success);
                await RefreshSavedPlansListAsync();
            }
            else
            {
                Snackbar.Add("Failed to save plan", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadSavedPlanAsync(string planId)
    {
        try
        {
            var result = await PlanPersistence.LoadPlanIntoSessionAsync(planId);
            if (result == null)
            {
                Snackbar.Add("Plan not found", Severity.Error);
                return;
            }
            if (!string.IsNullOrWhiteSpace(result.Warning))
            {
                Snackbar.Add($"Warning: {result.Warning}", Severity.Warning);
            }

            _selectedNode = AppState.CurrentPlan?.RootItems.FirstOrDefault();

            Snackbar.Add($"Loaded '{result.StoredPlan.Name}'", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSavedPlanAsync(string planId)
    {
        try
        {
            var success = await PlanPersistence.DeletePlanAsync(planId);
            if (success)
            {
                Snackbar.Add("Plan deleted", Severity.Success);
                await RefreshSavedPlansListAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportPlanAsync()
    {
        if (AppState.CurrentPlan == null)
            return;

        try
        {
            var json = RecipeCalculationService.SerializePlan(AppState.CurrentPlan);
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var stream = new MemoryStream(bytes);

            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", $"{AppState.CurrentPlan.Name}.json", streamRef);

            Snackbar.Add("Plan exported to Downloads!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

}
