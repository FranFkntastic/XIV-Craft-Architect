@page "/"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Dialogs
@using FFXIV_Craft_Architect.Web.Services
@using Microsoft.AspNetCore.Components.Forms
@inject GarlandService GarlandService
@inject RecipeCalculationService RecipeCalculationService
@inject RecipePlannerCommandService RecipePlannerCommandService
@inject WorkerSessionCoordinator WorkerSession
@inject WorkerProjectionStore WorkerProjections
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject AppState AppState
@inject IndexedDbService IndexedDb
@inject WebPlanPersistenceService PlanPersistence
@inject AcquisitionDecisionService AcquisitionDecisionService
@inject ILogger<Index> Logger
@implements IDisposable

<!-- Planner layout: project inputs and recipe visualization only. -->
<div style="display: grid; grid-template-columns: 280px 1fr; gap: 0; height: calc(100vh - 64px);">

    <!-- Left Column: Project Items -->
    <ProjectItemsPanel
        SearchQuery="@_searchQuery"
        SearchQueryChanged="OnSearchQueryChanged"
        OnSearchKeyUp="OnSearchKeyUp"
        IsSearching="@_isSearching"
        IsBuildingPlan="@_isBuildingPlan"
        ShowPlanActions="@(_recipe?.ProjectItems.Count > 0 || _recipe?.Roots.Count > 0)"
        LastAutoSave="@AppState.LastAutoSave"
        SearchResults="@_searchResults"
        ProjectItems="@(_recipe?.ProjectItems ?? Array.Empty<ProjectItem>())"
        OnSearchRequested="SearchItemsAsync"
        OnOpenPlanBuilderRequested="OpenPlanBuilderAsync"
        OnAddProjectItem="AddProjectItem"
        OnToggleItemHq="ToggleItemHq"
        OnRemoveProjectItem="RemoveProjectItem"
        OnUpdateItemQuantity="UpdateItemQuantity"
        OnBuildPlanRequested="BuildPlanAsync"
        OnSavePlanRequested="SaveToBrowserAsync"
        OnExportPlanRequested="ExportPlanAsync" />

    <!-- Middle Column: Recipe Tree -->
    <RecipePlanPanel
        Recipe="@_recipe"
        SavedPlans="@AppState.SavedPlans"
        OnExpandAllRequested="ExpandAllRecipeNodes"
        OnCollapseAllRequested="CollapseAllRecipeNodes"
        OnOpenPlanEditorRequested="OpenPlanEditorAsync"
        OnLoadPlanRequested="LoadSavedPlanAsync"
        OnDeletePlanRequested="DeleteSavedPlanAsync"
        SelectedNode="@_selectedNode"
        ExpandVersion="_expandVersion"
        ExpandAll="_expandAll"
        OnNodeSelected="OnNodeSelected"
        OnNodeHqChanged="OnNodeHqChanged" />

</div>

@code {
    private string _searchQuery = string.Empty;
    private bool _isSearching = false;
    private List<GarlandSearchResult> _searchResults = new();

    private bool _isBuildingPlan = false;
    private WorkerRecipePlannerProjection? _recipe;
    private WorkerRecipeNodeProjection? _selectedNode;
    private int _expandVersion;
    private bool _expandAll = true;

    protected override async Task OnInitializedAsync()
    {
        // Subscribe to state changes
        AppState.OnPlanChanged += OnPlanChanged;
        AppState.OnShoppingListChanged += OnShoppingListChanged;
        WorkerProjections.Changed += OnWorkerProjectionChanged;

        // Load saved plans list
        await RefreshSavedPlansListAsync();
        _recipe = await WorkerSession.GetRecipeProjectionAsync();
        EnsureSelectedNode();

        // Note: WorldData, auto-save restoration, and auto-save timer are now
        // all handled centrally in MainLayout.razor
    }

    private void OnPlanChanged()
    {
        EnsureSelectedNode();
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnPlanChanged -= OnPlanChanged;
        AppState.OnShoppingListChanged -= OnShoppingListChanged;
        WorkerProjections.Changed -= OnWorkerProjectionChanged;

        // Note: Auto-save timer is now managed centrally in MainLayout.razor
    }

    private void OnWorkerProjectionChanged()
    {
        _recipe = WorkerProjections.Recipe;
        EnsureSelectedNode();
        _ = InvokeAsync(StateHasChanged);
    }

    private void OnShoppingListChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private async Task RefreshSavedPlansListAsync()
    {
        var summaries = await PlanPersistence.LoadPlanSummariesAsync();
        AppState.ReplaceSavedPlans(summaries.Where(p => p.Id != "autosave")); // Don't show autosave in list
    }

    private async Task SearchItemsAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery))
            return;

        _isSearching = true;
        _searchResults.Clear();

        try
        {
            var results = await GarlandService.SearchAsync(_searchQuery);
            _searchResults = results.Take(10).ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSearching = false;
            StateHasChanged(); // Force re-render to update button text and results
        }
    }

    private void OnSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            _ = SearchItemsAsync();
        }
    }

    private Task OnSearchQueryChanged(string value)
    {
        _searchQuery = value;
        return Task.CompletedTask;
    }

    private Task ExpandAllRecipeNodes()
    {
        _expandAll = true;
        _expandVersion++;
        return Task.CompletedTask;
    }

    private Task CollapseAllRecipeNodes()
    {
        _expandAll = false;
        _expandVersion++;
        return Task.CompletedTask;
    }

    private async Task AddProjectItem(GarlandSearchResult result)
    {
        await WorkerSession.MutateProjectItemsAsync(
            new WorkerProjectItemsMutation(
                "add",
                new ProjectItem
                {
                    Id = result.Id,
                    Name = result.Object.Name,
                    IconId = result.Object.IconId,
                    Quantity = 1,
                    MustBeHq = false
                }));

        _searchResults.Clear();
        _searchQuery = string.Empty;
    }

    private async Task RemoveProjectItem(ProjectItem item)
    {
        await WorkerSession.MutateProjectItemsAsync(
            new WorkerProjectItemsMutation("remove", ItemId: item.Id));
    }

    private async Task ToggleItemHq(ProjectItem item)
    {
        await WorkerSession.MutateProjectItemsAsync(
            new WorkerProjectItemsMutation(
                "hq",
                ItemId: item.Id,
                MustBeHq: !item.MustBeHq));
    }

    private async Task UpdateItemQuantity(ProjectItemsPanel.ProjectItemQuantityChangeRequest request)
    {
        await WorkerSession.MutateProjectItemsAsync(
            new WorkerProjectItemsMutation(
                "quantity",
                ItemId: request.Item.Id,
                Quantity: request.Quantity));
    }

    private async Task OpenPlanBuilderAsync()
    {
        var parameters = new DialogParameters
        {
            ["InitialItems"] = _recipe?.ProjectItems ?? Array.Empty<ProjectItem>()
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.ExtraLarge,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<PlanBuilderDialog>("Plan Builder", parameters, options);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not PlanBuilderDialog.PlanBuilderResult builderResult)
        {
            return;
        }

        await WorkerSession.MutateProjectItemsAsync(
            new WorkerProjectItemsMutation(
                "replace",
                Items: builderResult.Items));

        if (builderResult.BuildAfterApply)
        {
            await BuildPlanAsync();
        }
    }

    private async Task OpenPlanEditorAsync()
    {
        var stored = await WorkerSession.ExportStoredPlanAsync(
            "editor",
            _recipe?.PlanName ?? "Plan");
        var currentPlan = stored?.PlanJson is { Length: > 0 } planJson
            ? RecipeCalculationService.DeserializePlan(planJson)
            : null;
        if (currentPlan == null || stored is null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            ["CurrentPlan"] = currentPlan,
            ["SelectedNode"] = currentPlan.FindNodeByNodeId(_selectedNode?.NodeId)
        };
        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true
        };

        var dialog = await DialogService.ShowAsync<PlanEditorDialog>("Plan Editor", parameters, options);
        var result = await dialog.Result;
        if (result.Canceled || result.Data is not PlanEditorDialog.PlanEditorResult editorResult)
        {
            return;
        }

        var selectedNodeIds = editorResult.NodeIds.ToHashSet(StringComparer.Ordinal);
        var selectedNodes = PlanBulkEditService
            .FlattenPlanNodes(currentPlan)
            .Where(row => selectedNodeIds.Contains(row.Node.NodeId))
            .Select(row => row.Node)
            .ToList();
        var editResult = PlanBulkEditService.ApplyBulkEdit(
            selectedNodes,
            editorResult.Options);
        if (editorResult.RequireHqMaterials)
        {
            foreach (var node in selectedNodes.Where(node => node.Children.Any()))
            {
                var materialResult = PlanBulkEditService.RequireHqMaterials(
                    node,
                    includeNested: true);
                editResult.ChangedNodes += materialResult.ChangedNodes;
                editResult.SkippedNodes += materialResult.SkippedNodes;
                editResult.SwitchedMarketBuys += materialResult.SwitchedMarketBuys;
            }
        }
        stored.PlanJson = RecipeCalculationService.SerializePlan(currentPlan);
        stored.MarketPlansJson = null;
        stored.MarketIntelligenceJson = null;
        stored.MarketItemAnalysesJson = null;
        stored.ProcurementRouteJson = null;
        await WorkerSession.ReplaceStoredPlanAsync(
            stored,
            trackStoredPlanIdentity: false);
        _recipe = await WorkerSession.GetRecipeProjectionAsync();
        Snackbar.Add(
            $"Updated {editResult.ChangedNodes} node{(editResult.ChangedNodes == 1 ? "" : "s")}; skipped {editResult.SkippedNodes}.",
            Severity.Success);
    }

    private async Task BuildPlanAsync()
    {
        if (_recipe?.ProjectItems.Count is not > 0 || _isBuildingPlan)
            return;

        _isBuildingPlan = true;
        StateHasChanged();

        try
        {
            var result = await WorkerSession.BuildRecipeAsync(
                new WorkerRecipeBuildRequest(
                    _recipe.ProjectItems,
                    _recipe.SelectedDataCenter,
                    _recipe.SelectedRegion,
                    MarketFetchScope.EntireRegion));
            _recipe = result.Recipe;
            _selectedNode = result.Recipe.Roots.FirstOrDefault();
            Snackbar.Add(
                result.Message,
                result.MessageLevel switch
                {
                    RecipePlannerCommandMessageLevel.Success => Severity.Success,
                    RecipePlannerCommandMessageLevel.Warning => Severity.Warning,
                    RecipePlannerCommandMessageLevel.Error => Severity.Error,
                    _ => Severity.Info
                });
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to build plan: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isBuildingPlan = false;
        }
    }

    private IReadOnlyList<string> GetCurrentRegionDataCenters()
    {
        return MarketFetchScopeResolver.GetDataCenters(
            MarketFetchScope.EntireRegion,
            AppState.SelectedDataCenter,
            AppState.SelectedRegion);
    }

    private void OnNodeSelected(WorkerRecipeNodeProjection node)
    {
        _selectedNode = node;
    }

    private void EnsureSelectedNode()
    {
        if (_recipe?.Roots.Count is not > 0)
        {
            _selectedNode = null;
            return;
        }

        _selectedNode = FindRecipeNode(_recipe.Roots, _selectedNode?.NodeId)
            ?? _recipe.Roots.FirstOrDefault();
    }

    private async Task OnNodeHqChanged(WorkerRecipeNodeHqChangeRequest request)
    {
        _recipe = await WorkerSession.MutateAcquisitionAsync(
            new WorkerAcquisitionMutation(
                request.Node.ItemId,
                Source: null,
                MustBeHq: request.MustBeHq));
    }

    private static WorkerRecipeNodeProjection? FindRecipeNode(
        IEnumerable<WorkerRecipeNodeProjection> roots,
        string? nodeId)
    {
        if (string.IsNullOrWhiteSpace(nodeId))
        {
            return null;
        }

        var pending = new Stack<WorkerRecipeNodeProjection>(roots.Reverse());
        while (pending.Count > 0)
        {
            var node = pending.Pop();
            if (string.Equals(node.NodeId, nodeId, StringComparison.Ordinal))
            {
                return node;
            }
            foreach (var child in node.Children.Reverse())
            {
                pending.Push(child);
            }
        }
        return null;
    }

    private async Task SaveToBrowserAsync()
    {
        if (_recipe?.ProjectItems.Count is not > 0)
            return;

        try
        {
            var planId = _recipe.PlanId ?? Guid.NewGuid().ToString();
            var planName = _recipe.PlanName ?? $"Plan_{DateTime.Now:yyyyMMdd_HHmm}";
            var isNewSave = _recipe.PlanId == null;
            var snapshot = await WorkerSession.ExportStoredPlanAsync(
                planId,
                planName,
                includeSourcePlanIdentity: true);
            if (snapshot is null)
            {
                return;
            }
            snapshot.SourcePlanId = planId;
            snapshot.SourcePlanName = planName;
            var success = await PlanPersistence.SaveSnapshotAsync(snapshot);
            if (success)
            {
                if (isNewSave)
                {
                    await WorkerSession.ReplaceStoredPlanAsync(
                        snapshot,
                        trackStoredPlanIdentity: true);
                    _recipe = await WorkerSession.GetRecipeProjectionAsync();
                }
                var action = isNewSave ? "Saved" : "Updated";
                Snackbar.Add($"{action} '{planName}' to browser storage", Severity.Success);
                await RefreshSavedPlansListAsync();
            }
            else
            {
                Snackbar.Add("Failed to save plan", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Save failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task LoadSavedPlanAsync(string planId)
    {
        try
        {
            var stored = await PlanPersistence.LoadPlanPayloadAsync(planId);
            if (stored == null)
            {
                Snackbar.Add("Plan not found", Severity.Error);
                return;
            }
            await WorkerSession.ReplaceStoredPlanAsync(
                stored,
                trackStoredPlanIdentity: true);
            _recipe = await WorkerSession.GetRecipeProjectionAsync();
            _selectedNode = _recipe?.Roots.FirstOrDefault();

            Snackbar.Add($"Loaded '{stored.Name}'", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Load failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task DeleteSavedPlanAsync(string planId)
    {
        try
        {
            var success = await PlanPersistence.DeletePlanAsync(planId);
            if (success)
            {
                Snackbar.Add("Plan deleted", Severity.Success);
                await RefreshSavedPlansListAsync();
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Delete failed: {ex.Message}", Severity.Error);
        }
    }

    private async Task ExportPlanAsync()
    {
        var stored = await WorkerSession.ExportStoredPlanAsync(
            "export",
            _recipe?.PlanName ?? "Plan");
        if (stored?.PlanJson is not { Length: > 0 } planJson)
            return;

        try
        {
            var bytes = System.Text.Encoding.UTF8.GetBytes(planJson);
            var stream = new MemoryStream(bytes);

            using var streamRef = new DotNetStreamReference(stream);
            await JSRuntime.InvokeVoidAsync(
                "downloadFileFromStream",
                $"{_recipe?.PlanName ?? "plan"}.json",
                streamRef);

            Snackbar.Add("Plan exported to Downloads!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Export failed: {ex.Message}", Severity.Error);
        }
    }

}
