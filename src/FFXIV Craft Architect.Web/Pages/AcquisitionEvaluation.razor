@page "/acquisition"
@using FFXIV_Craft_Architect.Core.Helpers
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject WebPlanPersistenceService PlanPersistence
@inject MarketShoppingService MarketShoppingService
@inject AcquisitionDecisionService AcquisitionDecisionService
@inject IRecipeLayerWorkflowService RecipeLayerWorkflowService
@inject AcquisitionEvaluationWorkflowService AcquisitionEvaluationWorkflow
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ILogger<AcquisitionEvaluation> Logger
@implements IDisposable

@{
    var rows = _snapshot.Rows;
    var visibleRows = _snapshot.VisibleRows;
    var marketCandidateCount = _snapshot.MarketAnalysisCandidates.Count;
    var activeProcurementCount = _snapshot.ActiveProcurementItems.Count;
    var columnTemplate = GetColumnTemplate();
}

<div class="ae-page">
    <aside class="ae-controls">
        <div class="ae-title">Acquisition Evaluation</div>

        <div class="ae-stat-grid">
            <div class="ae-stat">
                <span>@rows.Count</span>
                <small>unique items</small>
            </div>
            <div class="ae-stat">
                <span>@marketCandidateCount</span>
                <small>market candidates</small>
            </div>
            <div class="ae-stat">
                <span>@activeProcurementCount</span>
                <small>procurement items</small>
            </div>
            <div class="ae-stat">
                <span>@AppState.ShoppingPlans.Count</span>
                <small>analyzed</small>
            </div>
        </div>

        <div class="ae-filter-group">
            <button class="@GetFilterClass(AcquisitionFilter.All)" @onclick="() => SetFilter(AcquisitionFilter.All)">All</button>
            <button class="@GetFilterClass(AcquisitionFilter.Active)" @onclick="() => SetFilter(AcquisitionFilter.Active)">Active</button>
            <button class="@GetFilterClass(AcquisitionFilter.Market)" @onclick="() => SetFilter(AcquisitionFilter.Market)">Market</button>
            <button class="@GetFilterClass(AcquisitionFilter.Suppressed)" @onclick="() => SetFilter(AcquisitionFilter.Suppressed)">Suppressed</button>
        </div>

        <div class="ae-info">
            <div class="ae-info-title">Current Model</div>
            <div>Market Analysis evaluates every purchasable candidate. Acquisition Evaluation chooses which nodes remain active. Procurement only routes active leaves.</div>
        </div>

        <div class="ae-actions">
            <button @onclick="GoToMarket">Market Analysis</button>
            <button @onclick="GoToProcurement" disabled="@(!AppState.ShoppingPlans.Any())">Procurement Plan</button>
        </div>
    </aside>

    <main class="ae-ledger">
        @if (AppState.CurrentPlan == null)
        {
            <div class="ae-empty">
                <div class="ae-empty-title">No plan loaded</div>
                <div class="ae-empty-body">Build or load a recipe plan first, then return here to choose acquisition sources.</div>
            </div>
        }
        else
        {
            <div class="ae-ledger-header">
                <div>
                    <div class="ae-ledger-title">Decision Ledger</div>
                    <div class="ae-ledger-subtitle">@visibleRows.Count shown from @rows.Count unique items</div>
                </div>
                <div class="ae-legend">
                    <span><i class="is-active"></i>Active</span>
                    <span><i class="is-suppressed"></i>Suppressed</span>
                    <span><i class="is-market"></i>Market evidence</span>
                </div>
            </div>

            <div class="ae-table" @onmousemove="OnColumnResizeMove" @onmouseup="StopColumnResize" @onmouseleave="StopColumnResize">
                <div class="ae-table-inner" style="width: @GetTableWidth()px">
                    <div class="ae-table-head" style="grid-template-columns: @columnTemplate">
                        @for (var i = 0; i < ColumnHeaders.Length; i++)
                        {
                            var columnIndex = i;
                            <span class="ae-head-cell">
                                @ColumnHeaders[i]
                                @if (i < ColumnHeaders.Length - 1)
                                {
                                    <button type="button"
                                            class="ae-resize-handle"
                                            title="Resize column"
                                            @onmousedown="args => StartColumnResize(columnIndex, args)"
                                            @onmousedown:stopPropagation />
                                }
                            </span>
                        }
                    </div>

                    @foreach (var row in visibleRows)
                    {
                        <div class="ae-row @(IsSelected(row.Node) ? "selected" : null) @(row.IsActiveProcurement ? "active" : null) @(row.IsFullySuppressed ? "suppressed" : null) @(row.HasSuppressedOccurrences && !row.IsFullySuppressed ? "partial" : null)"
                             style="grid-template-columns: @columnTemplate"
                             role="button"
                             tabindex="0"
                             @onclick="() => SelectNode(row.Node)">
                            <span class="ae-item-cell">
                                <span class="ae-item-name">@row.ItemName</span>
                                <small>x@(row.TotalQuantity)</small>
                            </span>
                            <span class="ae-source-cell" @onclick:stopPropagation>
                                <select class="ae-source-select"
                                        style="border-color: @RecipePlanDisplayHelpers.GetSourceHexColor(row.Source); color: @RecipePlanDisplayHelpers.GetSourceHexColor(row.Source)"
                                        value="@row.Source"
                                        disabled="@(!row.HasEditableOccurrences)"
                                        @onchange="args => OnNodeSourceSelected(row.Node, args)">
                                    @foreach (var option in GetSourceOptions(row.Node))
                                    {
                                        <option value="@option">@RecipePlanDisplayHelpers.GetSourceDisplayName(option)</option>
                                    }
                                </select>
                            </span>
                            <span class="ae-used-cell" title="@row.UsedIn">@row.UsedIn</span>
                            <span class="ae-role-cell">
                                @GetDecisionStatus(row)
                            </span>
                            <span class="ae-market-cell">
                                @row.MarketEvidence
                            </span>
                            <span class="ae-cost-cell">@row.EstimatedCost</span>
                        </div>
                    }
                </div>
            </div>
        }
    </main>

    <AcquisitionDetailsPanel
        Node="@_selectedNode"
        Row="@GetSelectedRow()"
        CurrentPlan="@AppState.CurrentPlan"
        MarketPlan="@GetMarketPlan(GetSelectedRow())"
        MarketPlans="@AppState.ShoppingPlans"
        CostContext="@_snapshot.CostContext"
        ActiveProcurementItems="@_snapshot.ActiveProcurementItems"
        UnavailableMarketItems="@AppState.UnavailableMarketItems"
        OnSourceChanged="OnNodeSourceChanged" />
</div>

@code {
    [SupplyParameterFromQuery(Name = "nodeId")]
    public string? RequestedNodeId { get; set; }

    private PlanNode? _selectedNode;
    private AcquisitionFilter _filter = AcquisitionFilter.All;
    private readonly AcquisitionEvaluationLedgerCache _ledgerCache = new();
    private AcquisitionEvaluationSnapshot _snapshot = AcquisitionEvaluationSnapshotBuilder.Build(
        null,
        Array.Empty<DetailedShoppingPlan>(),
        Array.Empty<CoreMarketDataUnavailableItem>(),
        AcquisitionFilter.All,
        new RecipeDemandProjection([], [], [], []));
    private readonly int[] _columnWidths = { 300, 150, 260, 150, 170, 110 };
    private static readonly string[] ColumnHeaders = { "Item", "Source", "Used In", "Role", "Market Evidence", "Estimate" };
    private int? _resizingColumnIndex;
    private double _resizeStartX;
    private int _resizeStartWidth;
    private CancellationTokenSource? _refreshCts;
    private long _refreshRequestId;
    private string? _appliedRequestedNodeId;

    protected override async Task OnInitializedAsync()
    {
        AppState.OnStateChanged += OnStateChanged;
        await RefreshLedgerSnapshotAsync();
    }

    protected override void OnParametersSet()
    {
        if (!string.Equals(RequestedNodeId, _appliedRequestedNodeId, StringComparison.Ordinal))
        {
            SelectRequestedNodeFromSnapshot();
        }
    }

    public void Dispose()
    {
        AppState.OnStateChanged -= OnStateChanged;
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
    }

    private void OnStateChanged(AppStateChange change)
    {
        if (!AcquisitionEvaluationLedgerCache.IsRelevantStateChange(change.Scopes))
        {
            return;
        }

        InvalidateLedgerSnapshot();
        _ = InvokeAsync(async () =>
        {
            await RefreshLedgerSnapshotAsync();
            StateHasChanged();
        });
    }

    private async Task LoadSavedPlanAsync(string planId)
    {
        var result = await PlanPersistence.LoadPlanIntoSessionAsync(planId);
        if (result == null)
        {
            Snackbar.Add("Plan not found", Severity.Error);
            return;
        }
        if (!string.IsNullOrWhiteSpace(result.Warning))
        {
            Snackbar.Add($"Warning: {result.Warning}", Severity.Warning);
        }

        PopulateShoppingListFromPlan();
        await RefreshLedgerSnapshotAsync();

        Snackbar.Add($"Loaded '{result.StoredPlan.Name}'", Severity.Success);
    }

    private void SelectNode(PlanNode node)
    {
        _selectedNode = node;
    }

    private void OnNodeSourceChanged(AcquisitionSourceChangeRequest request)
    {
        ApplyNodeSourceChange(request.Node, request.Source);
    }

    private void OnNodeSourceSelected(PlanNode node, ChangeEventArgs args)
    {
        if (args.Value is string value && Enum.TryParse<AcquisitionSource>(value, out var source))
        {
            ApplyNodeSourceChange(node, source);
        }
    }

    private void ApplyNodeSourceChange(PlanNode node, AcquisitionSource source)
    {
        AcquisitionDecisionService.ChangeSource(node, source);
        _ = InvokeAsync(async () =>
        {
            await RefreshLedgerSnapshotAsync();
            StateHasChanged();
        });
    }

    private void PopulateShoppingListFromPlan()
    {
        AppState.ReplaceShoppingItemsFromActivePlan(
            RecipeLayerWorkflowService.BuildActiveProcurementItems(AppState.CurrentPlan));
    }

    private DetailedShoppingPlan? GetMarketPlan(PlanNode? node)
    {
        if (node == null)
        {
            return null;
        }

        _snapshot.CostContext.TryGetShoppingPlan(node.ItemId, out var marketPlan);
        return marketPlan;
    }

    private DetailedShoppingPlan? GetMarketPlan(DecisionRow? row)
    {
        if (row == null)
        {
            return null;
        }

        _snapshot.CostContext.TryGetShoppingPlan(row.ItemId, out var marketPlan);
        return marketPlan;
    }

    private DecisionRow? GetSelectedRow()
    {
        if (_selectedNode == null)
        {
            return null;
        }

        return _snapshot.Rows.FirstOrDefault(row => row.NodeId == _selectedNode.NodeId) ??
            _snapshot.Rows.FirstOrDefault(row => row.ItemId == _selectedNode.ItemId);
    }

    private string GetFilterClass(AcquisitionFilter filter)
    {
        return _filter == filter ? "selected" : string.Empty;
    }

    private void SetFilter(AcquisitionFilter filter)
    {
        _filter = filter;
        _ = InvokeAsync(async () =>
        {
            await RefreshLedgerSnapshotAsync();
            StateHasChanged();
        });
    }

    private bool IsSelected(PlanNode node)
    {
        return _selectedNode?.NodeId == node.NodeId;
    }

    private string GetColumnTemplate()
    {
        return string.Join(" ", _columnWidths.Select(width => $"{width}px"));
    }

    private int GetTableWidth()
    {
        var gridGaps = (ColumnHeaders.Length - 1) * 8;
        var rowPadding = 14;
        return _columnWidths.Sum() + gridGaps + rowPadding;
    }

    private void StartColumnResize(int columnIndex, MouseEventArgs args)
    {
        _resizingColumnIndex = columnIndex;
        _resizeStartX = args.ClientX;
        _resizeStartWidth = _columnWidths[columnIndex];
    }

    private void OnColumnResizeMove(MouseEventArgs args)
    {
        if (_resizingColumnIndex is not { } columnIndex)
        {
            return;
        }

        var delta = args.ClientX - _resizeStartX;
        _columnWidths[columnIndex] = Math.Max(90, _resizeStartWidth + (int)Math.Round(delta));
    }

    private void StopColumnResize()
    {
        _resizingColumnIndex = null;
    }

    private async Task RefreshLedgerSnapshotAsync()
    {
        var elapsed = System.Diagnostics.Stopwatch.StartNew();
        var requestId = Interlocked.Increment(ref _refreshRequestId);
        _refreshCts?.Cancel();
        _refreshCts?.Dispose();
        _refreshCts = new CancellationTokenSource();
        var token = _refreshCts.Token;
        var plan = AppState.CurrentPlan;
        var planSessionVersion = AppState.PlanSessionVersion;

        var key = CreateLedgerKey();
        if (_ledgerCache.TryGet(key, _filter, out var cachedSnapshot))
        {
            _snapshot = cachedSnapshot;
        }
        else
        {
            try
            {
                var snapshot = await AcquisitionEvaluationWorkflow.BuildCurrentSnapshotAsync(
                    plan,
                    AppState.ShoppingPlans,
                    AppState.UnavailableMarketItems,
                    _filter,
                    token);
                if (snapshot == null ||
                    requestId != _refreshRequestId ||
                    token.IsCancellationRequested ||
                    !AppState.IsCurrentPlanSession(plan, planSessionVersion))
                {
                    return;
                }

                _snapshot = _ledgerCache.Store(key, _filter, snapshot);
            }
            catch (OperationCanceledException) when (token.IsCancellationRequested)
            {
                return;
            }
        }

        EnsureSelectedNodeFromSnapshot();
        elapsed.Stop();

        if (elapsed.ElapsedMilliseconds > 100)
        {
            Logger.LogInformation(
                "Acquisition evaluation snapshot ensured in {ElapsedMs} ms with {RowCount} rows and {VisibleRowCount} visible rows",
                elapsed.ElapsedMilliseconds,
                _snapshot.Rows.Count,
                _snapshot.VisibleRows.Count);
        }
    }

    private AcquisitionEvaluationLedgerKey CreateLedgerKey()
    {
        var versions = AppState.CurrentVersions;
        return new AcquisitionEvaluationLedgerKey(
            versions.PlanStructureVersion,
            versions.PlanDecisionVersion,
            versions.PlanPriceVersion,
            versions.MarketAnalysisVersion);
    }

    private void InvalidateLedgerSnapshot()
    {
        _ledgerCache.Invalidate();
    }

    private static string GetDecisionStatus(DecisionRow row)
    {
        if (row.IsFullySuppressed)
        {
            return $"Skipped by {string.Join(", ", row.SuppressedBy)}";
        }

        if (row.IsActiveProcurement && row.CanBuyFromMarket && row.MarketEvidence == "Not analyzed")
        {
            return "Needs analysis";
        }

        if (row.IsActiveProcurement && row.CanBuyFromMarket && row.MarketEvidence == "Needs data")
        {
            return "Missing market data";
        }

        if (row.IsActiveProcurement)
        {
            return row.HasSuppressedOccurrences
                ? "Partially active"
                : "Ready for procurement";
        }

        if (row.Source == AcquisitionSource.Craft)
        {
            return "Craft path";
        }

        return "Reference";
    }

    private static List<AcquisitionSource> GetSourceOptions(PlanNode node)
    {
        var options = AcquisitionPlanningService.GetAvailableSources(node);
        if (!options.Contains(node.Source))
        {
            options.Insert(0, node.Source);
        }

        return options;
    }

    private void EnsureSelectedNodeFromSnapshot()
    {
        if (AppState.CurrentPlan == null)
        {
            _selectedNode = null;
            return;
        }

        if (SelectRequestedNodeFromSnapshot())
        {
            return;
        }

        if (_selectedNode == null || !_snapshot.Rows.Any(row => row.Node.NodeId == _selectedNode.NodeId))
        {
            _selectedNode = _snapshot.Rows.FirstOrDefault()?.Node;
        }
    }

    private bool SelectRequestedNodeFromSnapshot()
    {
        if (string.IsNullOrWhiteSpace(RequestedNodeId) ||
            string.Equals(RequestedNodeId, _appliedRequestedNodeId, StringComparison.Ordinal))
        {
            return false;
        }

        var row = _snapshot.Rows.FirstOrDefault(row => row.NodeId == RequestedNodeId);
        if (row == null)
        {
            return false;
        }

        _selectedNode = row.Node;
        _appliedRequestedNodeId = RequestedNodeId;
        return true;
    }

    private void GoToMarket()
    {
        NavigationManager.NavigateTo("market");
    }

    private void GoToProcurement()
    {
        NavigationManager.NavigateTo("procurement");
    }

}
