@page "/acquisition"
@using FFXIV_Craft_Architect.Core.Helpers
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services
@inject WorkerSessionCoordinator WorkerSession
@inject WorkerProjectionStore WorkerProjections
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@implements IDisposable

@{
    var rows = _projection?.Rows ?? Array.Empty<WorkerAcquisitionRowProjection>();
    var visibleRows = GetOrderedVisibleRows();
}

<div class="ae-page">
    <aside class="ae-controls">
        <div class="ae-title">Acquisition Evaluation</div>

        <div class="ae-stat-grid">
            <div class="ae-stat">
                <span>@rows.Count</span>
                <small>items in plan</small>
            </div>
            <div class="ae-stat">
                <span>@(_projection?.MarketCandidateCount ?? 0)</span>
                <small>items compared</small>
            </div>
            <div class="ae-stat">
                <span>@(_projection?.ActiveProcurementCount ?? 0)</span>
                <small>items to obtain</small>
            </div>
            <div class="ae-stat">
                <span>@(_projection?.PricedItemCount ?? 0)</span>
                <small>with prices</small>
            </div>
        </div>

        <div class="ae-filter-group">
            <button class="@GetFilterClass(AcquisitionFilter.All)" @onclick="() => SetFilterAsync(AcquisitionFilter.All)">All</button>
            <button class="@GetFilterClass(AcquisitionFilter.Active)" @onclick="() => SetFilterAsync(AcquisitionFilter.Active)">Active</button>
            <button class="@GetFilterClass(AcquisitionFilter.Market)" @onclick="() => SetFilterAsync(AcquisitionFilter.Market)">Market</button>
            <button class="@GetFilterClass(AcquisitionFilter.Suppressed)" @onclick="() => SetFilterAsync(AcquisitionFilter.Suppressed)">Skipped</button>
        </div>

        <div class="ae-info">
            <div class="ae-info-title">How automatic choices work</div>
            <div>CA compares every item you could buy and chooses what to craft or purchase. Procurement then routes the selected purchases. Your manual choices stay locked. Items marked Skipped are already covered by a parent item you are buying.</div>
        </div>

        <div class="ae-actions">
            <button @onclick="GoToMarket">Market Analysis</button>
            <button @onclick="GoToProcurement" disabled="@(_projection?.HasProcurementRoute != true && _projection?.ActiveProcurementCount < 1)">Procurement Plan</button>
        </div>
    </aside>

    <main class="ae-ledger">
        @if (_projection?.HasPlan != true)
        {
            <div class="ae-empty">
                <MudIcon Icon="@Icons.Material.Filled.FactCheck" Size="Size.Large" Class="ae-empty-icon" />
                <div class="ae-empty-title">No Plan Loaded</div>
                <div class="ae-empty-body">Build or load a recipe plan first, then return here to choose acquisition sources.</div>
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="GoToPlanner">
                    Go to Recipe Planner
                </MudButton>
            </div>
        }
        else
        {
            <div class="ae-ledger-header">
                <div>
                    <div class="ae-ledger-title">Acquisition decisions</div>
                    <div class="ae-ledger-subtitle">@visibleRows.Count shown from @FormatUniqueItemCount(rows.Count)</div>
                </div>
                <div class="ae-legend">
                    <span><i class="is-active"></i>Active</span>
                    <span><i class="is-suppressed"></i>Skipped</span>
                    <span><i class="is-market"></i>Market evidence</span>
                </div>
            </div>

            <WebGridTable TItem="WorkerAcquisitionRowProjection"
                          TColumnId="AcquisitionDecisionLedgerSortColumn"
                          CssClass="ae-table"
                          Items="@visibleRows"
                          Columns="@GetLedgerColumns()"
                          GetRowKey="row => row.NodeId"
                          GetRowClass="GetLedgerRowClass"
                          Selection="@GetLedgerSelection()"
                          RowActionLabel="@(row => $"Select {row.ItemName}")"
                          RowActivated="SelectRow"
                          SortState="@_sortState"
                          SortChanged="OnLedgerSortChanged"
                          Resizable="false"
                          FitToContainer="true" />
        }
    </main>

    <AcquisitionDetailsPanel
        Row="@GetSelectedRow()"
        HasPlan="@(_projection?.HasPlan == true)"
        TargetCount="@(_projection?.RootItemCount ?? 0)"
        ActiveProcurementItems="@(_projection?.ActiveProcurementItems ?? Array.Empty<MaterialAggregate>())"
        UnavailableMarketItems="@(_projection?.UnavailableMarketItems ?? Array.Empty<CoreMarketDataUnavailableItem>())"
        OnSourceChanged="OnSelectedSourceChanged" />
</div>

@code {
    [SupplyParameterFromQuery(Name = "nodeId")]
    public string? RequestedNodeId { get; set; }

    [SupplyParameterFromQuery(Name = "itemId")]
    public int? RequestedItemId { get; set; }

    private WorkerAcquisitionProjection? _projection;
    private string? _selectedNodeId;
    private AcquisitionFilter _filter = AcquisitionFilter.All;
    private WebTableSortState<AcquisitionDecisionLedgerSortColumn> _sortState =
        WebTableSortState<AcquisitionDecisionLedgerSortColumn>.Unsorted;
    private const string CalculatedTotalHeaderTooltip =
        "Calculated Total is the gil cost computed for the row's selected source and needed quantity.";

    protected override async Task OnInitializedAsync()
    {
        WorkerProjections.Changed += ProjectionChanged;
        await RefreshProjectionAsync();
    }

    protected override void OnParametersSet()
    {
        ApplyRequestedSelection();
    }

    private void ProjectionChanged()
    {
        if (WorkerProjections.Acquisition is { } projection &&
            projection.Revision == WorkerProjections.Shell.Revision)
        {
            _projection = projection;
            EnsureSelection();
            _ = InvokeAsync(StateHasChanged);
        }
    }

    private async Task RefreshProjectionAsync()
    {
        _projection = await WorkerSession.GetAcquisitionProjectionAsync(
            _filter.ToString());
        EnsureSelection();
    }

    private async Task SetFilterAsync(AcquisitionFilter filter)
    {
        _filter = filter;
        await RefreshProjectionAsync();
    }

    private string GetFilterClass(AcquisitionFilter filter) =>
        _filter == filter ? "selected" : string.Empty;

    private WorkerAcquisitionRowProjection? GetSelectedRow() =>
        _projection?.Rows.FirstOrDefault(row => row.NodeId == _selectedNodeId) ??
        _projection?.Rows.FirstOrDefault();

    private void EnsureSelection()
    {
        ApplyRequestedSelection();
        if (_projection?.Rows.Any(row => row.NodeId == _selectedNodeId) != true)
        {
            _selectedNodeId = _projection?.Rows.FirstOrDefault()?.NodeId;
        }
    }

    private void ApplyRequestedSelection()
    {
        if (_projection is null)
        {
            return;
        }

        var requested = !string.IsNullOrWhiteSpace(RequestedNodeId)
            ? _projection.Rows.FirstOrDefault(row => row.NodeId == RequestedNodeId)
            : RequestedItemId.HasValue
                ? _projection.Rows
                    .OrderByDescending(row => row.IsActiveProcurement)
                    .FirstOrDefault(row => row.ItemId == RequestedItemId.Value)
                : null;
        if (requested is not null)
        {
            _selectedNodeId = requested.NodeId;
        }
    }

    private Task SelectRow(WorkerAcquisitionRowProjection row)
    {
        _selectedNodeId = row.NodeId;
        return Task.CompletedTask;
    }

    private async Task OnSelectedSourceChanged(AcquisitionSource source)
    {
        var row = GetSelectedRow();
        if (row is null)
        {
            return;
        }

        try
        {
            _projection = await WorkerSession.MutateAcquisitionAndProjectAsync(
                new WorkerAcquisitionMutation(
                    row.ItemId,
                    source,
                    MustBeHq: null),
                _filter.ToString());
            _selectedNodeId = _projection.Rows
                .FirstOrDefault(candidate => candidate.ItemId == row.ItemId)
                ?.NodeId;
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Acquisition choice could not be saved: {ex.Message}", Severity.Error);
        }
    }

    private async Task OnSourceSelected(
        WorkerAcquisitionRowProjection row,
        ChangeEventArgs args)
    {
        if (!Enum.TryParse<AcquisitionSource>(
                args.Value?.ToString(),
                out var source))
        {
            return;
        }

        _selectedNodeId = row.NodeId;
        await OnSelectedSourceChanged(source);
    }

    private IReadOnlyList<WorkerAcquisitionRowProjection> GetOrderedVisibleRows()
    {
        var rows = _projection?.Rows ?? Array.Empty<WorkerAcquisitionRowProjection>();
        if (!_sortState.Column.HasValue)
        {
            return rows;
        }

        Func<WorkerAcquisitionRowProjection, object> selector =
            _sortState.Column.Value switch
            {
                AcquisitionDecisionLedgerSortColumn.Source => row => row.Source,
                AcquisitionDecisionLedgerSortColumn.UsedIn => row => row.UsedIn,
                AcquisitionDecisionLedgerSortColumn.Role => row => GetDecisionStatus(row),
                AcquisitionDecisionLedgerSortColumn.MarketEvidence => row => row.MarketEvidence,
                AcquisitionDecisionLedgerSortColumn.CalculatedTotal => row => row.EstimatedCost,
                _ => row => row.ItemName
            };
        return (_sortState.Descending
                ? rows.OrderByDescending(selector)
                : rows.OrderBy(selector))
            .ThenBy(row => row.ItemName, StringComparer.OrdinalIgnoreCase)
            .ToArray();
    }

    private IReadOnlyList<WebTableColumn<WorkerAcquisitionRowProjection, AcquisitionDecisionLedgerSortColumn>> GetLedgerColumns()
    {
        return
        [
            new()
            {
                Id = AcquisitionDecisionLedgerSortColumn.Item,
                Header = "Item",
                Size = new WebTableColumnSize(260, 120),
                HeaderCssClass = "ae-head-cell",
                CellCssClass = "ae-item-cell",
                CellTemplate = RenderItemCell
            },
            new()
            {
                Id = AcquisitionDecisionLedgerSortColumn.Source,
                Header = "Source",
                Size = new WebTableColumnSize(140, 105),
                HeaderCssClass = "ae-head-cell",
                CellCssClass = "ae-source-cell",
                SuppressRowActivation = true,
                CellTemplate = RenderSourceCell
            },
            new()
            {
                Id = AcquisitionDecisionLedgerSortColumn.UsedIn,
                Header = "Used In",
                Size = new WebTableColumnSize(210, 105),
                HeaderCssClass = "ae-head-cell",
                CellCssClass = "ae-used-cell",
                CellTitleSelector = row => row.UsedIn,
                CellTemplate = row => builder => builder.AddContent(0, row.UsedIn)
            },
            new()
            {
                Id = AcquisitionDecisionLedgerSortColumn.Role,
                Header = "Role",
                Size = new WebTableColumnSize(155, 105),
                HeaderCssClass = "ae-head-cell",
                CellCssClass = "ae-role-cell",
                CellTemplate = RenderRoleCell
            },
            new()
            {
                Id = AcquisitionDecisionLedgerSortColumn.MarketEvidence,
                Header = "Market Evidence",
                Size = new WebTableColumnSize(170, 115),
                HeaderCssClass = "ae-head-cell",
                CellCssClass = "ae-market-cell",
                CellTitleSelector = row => row.MarketEvidence,
                CellTemplate = row => builder => builder.AddContent(0, row.MarketEvidence)
            },
            new()
            {
                Id = AcquisitionDecisionLedgerSortColumn.CalculatedTotal,
                Header = "Total",
                HeaderTooltip = CalculatedTotalHeaderTooltip,
                Size = new WebTableColumnSize(145, 100),
                HeaderCssClass = "ae-head-cell",
                CellCssClassSelector = row => row.MarketEvidence == "Projected only"
                    ? "ae-cost-cell projected-unsupported"
                    : "ae-cost-cell",
                CellTitleSelector = GetCalculatedTotalTooltip,
                CellTemplate = row => builder => builder.AddContent(0, row.EstimatedCost)
            }
        ];
    }

    private RenderFragment<WorkerAcquisitionRowProjection> RenderItemCell => row => builder =>
    {
        builder.OpenElement(0, "span");
        builder.AddAttribute(1, "class", "ae-item-name");
        builder.AddContent(2, row.ItemName);
        builder.CloseElement();
        builder.OpenElement(3, "small");
        builder.AddContent(4, $"x{row.TotalQuantity}");
        builder.CloseElement();
    };

    private RenderFragment<WorkerAcquisitionRowProjection> RenderSourceCell => row => builder =>
    {
        var sequence = 0;
        builder.OpenElement(sequence++, "select");
        builder.AddAttribute(sequence++, "class", "ae-source-select");
        builder.AddAttribute(sequence++, "aria-label", $"Acquisition source for {row.ItemName}");
        builder.AddAttribute(sequence++, "style", $"border-color: {RecipePlanDisplayHelpers.GetSourceHexColor(row.Source)}; color: {RecipePlanDisplayHelpers.GetSourceHexColor(row.Source)}");
        builder.AddAttribute(sequence++, "value", row.Source.ToString());
        builder.AddAttribute(sequence++, "disabled", !row.HasEditableOccurrences);
        builder.AddAttribute(sequence++, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(
            this,
            args => OnSourceSelected(row, args)));

        foreach (var option in row.AvailableSources)
        {
            builder.OpenElement(sequence++, "option");
            builder.AddAttribute(sequence++, "value", option.ToString());
            builder.AddContent(sequence++, RecipePlanDisplayHelpers.GetSourceDisplayName(option));
            builder.CloseElement();
        }
        builder.CloseElement();
    };

    private RenderFragment<WorkerAcquisitionRowProjection> RenderRoleCell => row => builder =>
    {
        builder.OpenComponent<MudTooltip>(0);
        builder.AddAttribute(1, "Text", GetDecisionStatus(row));
        builder.AddAttribute(2, "ChildContent", (RenderFragment)(content =>
            content.AddContent(0, GetDecisionStatus(row))));
        builder.CloseComponent();
    };

    private WebTableSelection<string> GetLedgerSelection() =>
        string.IsNullOrWhiteSpace(_selectedNodeId)
            ? WebTableSelection<string>.None
            : WebTableSelection<string>.Single(_selectedNodeId);

    private string GetLedgerRowClass(WorkerAcquisitionRowProjection row) =>
        WebTableColumn<WorkerAcquisitionRowProjection, AcquisitionDecisionLedgerSortColumn>.CombineClasses(
            "ae-row",
            row.NodeId == _selectedNodeId ? "selected" : null,
            row.IsActiveProcurement ? "active" : null,
            row.IsFullySuppressed ? "suppressed" : null,
            row.HasSuppressedOccurrences && !row.IsFullySuppressed ? "partial" : null);

    private Task OnLedgerSortChanged(
        WebTableSortState<AcquisitionDecisionLedgerSortColumn> sortState)
    {
        _sortState = sortState;
        return Task.CompletedTask;
    }

    private static string GetDecisionStatus(WorkerAcquisitionRowProjection row)
    {
        if (row.IsFullySuppressed)
        {
            return $"Skipped by {string.Join(", ", row.SuppressedBy)}";
        }
        if (row.IsActiveProcurement && row.CanBuyFromMarket && row.MarketEvidence == "Not analyzed")
        {
            return "Needs analysis";
        }
        if (row.IsActiveProcurement && row.CanBuyFromMarket && row.MarketEvidence == "Needs data")
        {
            return "Missing market data";
        }
        if (row.IsActiveProcurement)
        {
            return row.HasSuppressedOccurrences
                ? "Partially active"
                : "Ready for procurement";
        }
        return row.Source == AcquisitionSource.Craft ? "Craft path" : "Reference";
    }

    private static string GetCalculatedTotalTooltip(WorkerAcquisitionRowProjection row)
    {
        var source = RecipePlanDisplayHelpers.GetSourceDisplayName(row.Source);
        var text = $"Calculated Total is the gil cost computed for {row.TotalQuantity:N0} needed from {source}.";
        return row.MarketEvidence == "Projected only"
            ? $"{text} The current market search scope cannot support this projected purchase."
            : text;
    }

    private void GoToMarket() => NavigationManager.NavigateTo("market");
    private void GoToPlanner() => NavigationManager.NavigateTo("");
    private void GoToProcurement() => NavigationManager.NavigateTo("procurement");

    private static string FormatUniqueItemCount(int count) =>
        $"{count:N0} unique item{(count == 1 ? string.Empty : "s")}";

    public void Dispose()
    {
        WorkerProjections.Changed -= ProjectionChanged;
    }
}
