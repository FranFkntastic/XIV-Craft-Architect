            JobLevels = crafter.JobLevels.ToArray(),
            RemoteId = crafter.RemoteId,
            SyncState = crafter.SyncState,
            CreatedAtUtc = crafter.CreatedAtUtc,
            UpdatedAtUtc = crafter.UpdatedAtUtc
