@page "/trade/crafters"
@using FFXIV_Craft_Architect.Web.Shared.TablePrimitives
@inject AppState AppState
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@inject ILodestoneCrafterLookupService LodestoneCrafterLookup
@inject TradeCrafterProfileImportMapper LodestoneImportMapper
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="trade-crafters-page">
    @if (!AppState.SecretDebugToolsEnabled)
    {
        <MudAlert Severity="Severity.Info" Class="ma-4">Returning to Craft Architect...</MudAlert>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">
                <MudText Typo="Typo.subtitle2">Trade operations storage is unavailable.</MudText>
                <MudText Typo="Typo.body2">@_loadError</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Class="mt-2"
                           OnClick="LoadAsync">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else
        {
            <div class="trade-crafters-layout">
            <section class="trade-crafters-main">
                <section class="trade-crafters-panel trade-crafters-lodestone-import">
                    <MudText Typo="Typo.subtitle1">Import from Lodestone</MudText>
                    <div class="trade-crafters-lodestone-search-row">
                        <MudTextField @bind-Value="_lodestoneSearchName"
                                      Label="Character name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />
                        <MudSelect T="string"
                                   @bind-Value="_lodestoneSearchWorld"
                                   Label="World"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">Use selected data center</MudSelectItem>
                            @foreach (var world in GetWorldsForDataCenter(GetDefaultDataCenter()))
                            {
                                <MudSelectItem Value="@world">@world</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="SearchLodestoneAsync"
                                   Disabled="@(_lodestoneIsBusy || string.IsNullOrWhiteSpace(_lodestoneSearchName))">
                            Search Lodestone
                        </MudButton>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_lodestoneError))
                    {
                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">@_lodestoneError</MudAlert>
                    }
                    @if (_lodestoneCandidates.Count > 0)
                    {
                        <div class="trade-crafters-lodestone-results">
                            @foreach (var candidate in _lodestoneCandidates)
                            {
                                <button type="button"
                                        class="trade-crafters-lodestone-result"
                                        @onclick="@(() => PreviewLodestoneCandidateAsync(candidate))">
                                    <span>@candidate.DisplayName</span>
                                    <small>@FormatLodestoneCandidateLocation(candidate) @candidate.LodestoneCharacterId</small>
                                </button>
                            }
                        </div>
                    }
                    @if (_lodestonePreview != null)
                    {
                        <div class="trade-crafters-lodestone-preview">
                            <div class="trade-crafters-lodestone-preview-heading">
                                <strong>@_lodestonePreview.DisplayName</strong>
                                <span>@FormatPreviewLocation(_lodestonePreview)</span>
                            </div>
                            <span>@FormatImportedJobSummary(_lodestonePreview)</span>
                            @if (!string.IsNullOrWhiteSpace(_lodestonePreview.FreeCompanyName))
                            {
                                <span>@_lodestonePreview.FreeCompanyName</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(FormatLodestonePreviewIdentity(_lodestonePreview)))
                            {
                                <span>@FormatLodestonePreviewIdentity(_lodestonePreview)</span>
                            }
                            <div class="trade-crafters-lodestone-actions">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="CreateCrafterFromLodestoneAsync"
                                           Disabled="@_lodestoneIsBusy">
                                    Create Crafter From Lodestone
                                </MudButton>
                                @if (_selectedCrafter != null)
                                {
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               OnClick="UpdateSelectedCrafterFromLodestoneAsync"
                                               Disabled="@_lodestoneIsBusy">
                                        Update Selected Crafter
                                    </MudButton>
                                }
                            </div>
                        </div>
                    }
                </section>

                <section class="trade-crafters-panel">
                    <MudText Typo="Typo.subtitle1">Create Crafter</MudText>
                    <div class="trade-crafters-create-row">
                        <MudTextField @bind-Value="_newCrafterName"
                                      Label="Display name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />
                        <MudSelect T="string"
                                   Value="@_newCrafterRegion"
                                   ValueChanged="SetNewCrafterRegion"
                                   Label="Region"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            @foreach (var region in TradeRegions)
                            {
                                <MudSelectItem Value="@region">@region</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string"
                                   Value="@_newCrafterDataCenter"
                                   ValueChanged="SetNewCrafterDataCenter"
                                   Label="Data center"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            @foreach (var dataCenter in GetDataCentersForRegion(_newCrafterRegion))
                            {
                                <MudSelectItem Value="@dataCenter">@dataCenter</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string"
                                   Value="@_newCrafterWorld"
                                   ValueChanged="SetNewCrafterWorld"
                                   Label="World"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">No world selected</MudSelectItem>
                            @foreach (var world in GetWorldsForDataCenter(_newCrafterDataCenter))
                            {
                                <MudSelectItem Value="@world">@world</MudSelectItem>
                            }
                        </MudSelect>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="CreateCrafterAsync">
                            Create Crafter
                        </MudButton>
                    </div>
                </section>

                <section class="trade-crafters-panel">
                    <MudText Typo="Typo.subtitle1">Roster</MudText>
                    <WebDataTable TItem="TradeCrafterProfile"
                                  TColumnId="TradeCrafterColumn"
                                  Items="SortedCrafters"
                                  Columns="CrafterColumns"
                                  GetRowKey="GetCrafterKey"
                                  GetRowClass="GetCrafterRowClass"
                                  RowClicked="SelectCrafter"
                                  CssClass="trade-crafters-table">
                        <EmptyContent>
                            <span>No crafters on the roster.</span>
                        </EmptyContent>
                    </WebDataTable>
                </section>
            </section>

            <aside class="trade-crafters-detail">
                @if (_selectedCrafter == null)
                {
                    <section class="trade-crafters-panel">
                        <MudText Typo="Typo.subtitle1">Crafter Details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Select a crafter to edit profile details, crafting job levels, and current assignments.</MudText>
                    </section>
                }
                else
                {
                    <section class="trade-crafters-panel">
                        <MudText Typo="Typo.subtitle1">Crafter Details</MudText>
                        <MudTextField @bind-Value="_detailName"
                                      Label="Display name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true" />
                        <MudTextField @bind-Value="_detailAlias"
                                      Label="Alias"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_detailContact"
                                      Label="General contact"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_detailDiscordHandle"
                                      Label="Discord"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudTextField @bind-Value="_detailSocialProfileUrl"
                                      Label="Social/profile URL"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                        <MudSelect T="string"
                                   Value="@_detailRegion"
                                   ValueChanged="SetDetailRegion"
                                   Label="Region"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            @foreach (var region in TradeRegions)
                            {
                                <MudSelectItem Value="@region">@region</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string"
                                   Value="@_detailDataCenter"
                                   ValueChanged="SetDetailDataCenter"
                                   Label="Data center"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            @foreach (var dataCenter in GetDataCentersForRegion(_detailRegion))
                            {
                                <MudSelectItem Value="@dataCenter">@dataCenter</MudSelectItem>
                            }
                        </MudSelect>
                        <MudSelect T="string"
                                   Value="@_detailWorld"
                                   ValueChanged="SetDetailWorld"
                                   Label="World"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense">
                            <MudSelectItem Value="@string.Empty">No world selected</MudSelectItem>
                            @foreach (var world in GetWorldsForDataCenter(_detailDataCenter))
                            {
                                <MudSelectItem Value="@world">@world</MudSelectItem>
                            }
                        </MudSelect>
                        @if (HasLodestoneFlair(_selectedCrafter))
                        {
                            <div class="trade-crafter-lodestone-flair">
                                @if (!string.IsNullOrWhiteSpace(_selectedCrafter.LodestonePortraitUrl) ||
                                     !string.IsNullOrWhiteSpace(_selectedCrafter.LodestoneAvatarUrl))
                                {
                                    <img src="@(_selectedCrafter.LodestonePortraitUrl ?? _selectedCrafter.LodestoneAvatarUrl)"
                                         alt=""
                                         loading="lazy" />
                                }
                                <div>
                                    <MudText Typo="Typo.caption" Color="Color.Secondary">Lodestone</MudText>
                                    @if (!string.IsNullOrWhiteSpace(_selectedCrafter.LodestoneProfileUrl))
                                    {
                                        <MudLink Href="@_selectedCrafter.LodestoneProfileUrl"
                                                 Target="_blank"
                                                 Typo="Typo.body2">
                                            Open profile
                                        </MudLink>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(FormatLodestoneIdentity(_selectedCrafter)))
                                    {
                                        <MudText Typo="Typo.body2">@FormatLodestoneIdentity(_selectedCrafter)</MudText>
                                    }
                                    @if (!string.IsNullOrWhiteSpace(_selectedCrafter.LodestoneFreeCompanyName))
                                    {
                                        <MudText Typo="Typo.body2">@_selectedCrafter.LodestoneFreeCompanyName</MudText>
                                    }
                                    @if (_selectedCrafter.LodestoneLastSyncedAtUtc != null)
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                                            Synced @_selectedCrafter.LodestoneLastSyncedAtUtc.Value.ToLocalTime().ToString("yyyy-MM-dd h:mm tt")
                                        </MudText>
                                    }
                                </div>
                            </div>
                        }
                        <MudTextField @bind-Value="_detailPaymentNotes"
                                      Label="Payment notes"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="2" />
                        <MudTextField @bind-Value="_detailOperatorNotes"
                                      Label="Operator notes"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="2" />
                    </section>

                    <section class="trade-crafters-panel">
                        <MudText Typo="Typo.subtitle1">Crafting Job Levels</MudText>
                        <div class="trade-crafter-jobs">
                            @foreach (var job in Enum.GetValues<TradeCraftingJob>())
                            {
                                <MudNumericField T="int"
                                                 Value="@GetJobLevel(job)"
                                                 ValueChanged="value => SetJobLevel(job, value)"
                                                 Label="@FormatJob(job)"
                                                 Min="0"
                                                 Max="100"
                                                 Variant="Variant.Outlined"
                                                 Margin="Margin.Dense" />
                            }
                        </div>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="SaveSelectedCrafterAsync"
                                   Disabled="@string.IsNullOrWhiteSpace(_detailName)">
                            Save Crafter
                        </MudButton>
                    </section>

                    <section class="trade-crafters-panel">
                        <MudText Typo="Typo.subtitle1">Current Assignments</MudText>
                        @if (GetAssignmentsForSelectedCrafter().Count == 0)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">No active assignments.</MudText>
                        }
                        else
                        {
                            <div class="trade-crafter-assignments">
                                @foreach (var order in GetAssignmentsForSelectedCrafter())
                                {
                                    <button type="button"
                                            class="trade-crafter-assignment-link"
                                            @onclick="@(() => OpenOrderAssignment(order.Id))">
                                        <span>@order.Title</span>
                                        <small>@FormatStatus(order.Status)</small>
                                    </button>
                                }
                            </div>
                        }
                    </section>
                }
            </aside>
            </div>
        }
    }
</MudContainer>

@code {
    private TradeCompanyProfile? _companyProfile;
    private List<TradeCrafterProfile> _crafters = [];
    private List<TradeOrder> _orders = [];
    private TradeCrafterProfile? _selectedCrafter;
    private bool _hasLoaded;
    private string _newCrafterName = string.Empty;
    private string _newCrafterRegion = string.Empty;
    private string _newCrafterDataCenter = string.Empty;
    private string _newCrafterWorld = string.Empty;
    private string _detailName = string.Empty;
    private string? _detailAlias;
    private string? _detailContact;
    private string? _detailDiscordHandle;
    private string? _detailSocialProfileUrl;
    private string _detailRegion = string.Empty;
    private string _detailWorld = string.Empty;
    private string _detailDataCenter = string.Empty;
    private string? _detailPaymentNotes;
    private string? _detailOperatorNotes;
    private Dictionary<TradeCraftingJob, int> _jobLevels = [];
    private string? _loadError;
    private string _lodestoneSearchName = string.Empty;
    private string _lodestoneSearchWorld = string.Empty;
    private bool _lodestoneIsBusy;
    private string? _lodestoneError;
    private IReadOnlyList<LodestoneCrafterSearchCandidate> _lodestoneCandidates = [];
    private LodestoneCrafterImportPreview? _lodestonePreview;
    private static readonly IReadOnlyList<string> TradeRegions = ["North America", "Europe", "Japan", "Oceania"];

    private IReadOnlyList<TradeCrafterProfile> SortedCrafters => _crafters
        .OrderBy(crafter => crafter.DisplayName, StringComparer.OrdinalIgnoreCase)
        .ToArray();

    private IReadOnlyList<WebTableColumn<TradeCrafterProfile, TradeCrafterColumn>> CrafterColumns => CreateCrafterColumns();

    private IReadOnlyList<WebTableColumn<TradeCrafterProfile, TradeCrafterColumn>> CreateCrafterColumns()
    {
        return
        [
            WebTableColumn<TradeCrafterProfile, TradeCrafterColumn>.Text(TradeCrafterColumn.Name, "Crafter", crafter => crafter.DisplayName, widthPx: 220),
            WebTableColumn<TradeCrafterProfile, TradeCrafterColumn>.Text(TradeCrafterColumn.World, "World", FormatWorld, widthPx: 180),
            new WebTableColumn<TradeCrafterProfile, TradeCrafterColumn>
            {
                Id = TradeCrafterColumn.Assignments,
                Header = "Assignments",
                Size = new WebTableColumnSize(180, 120),
                CellTemplate = crafter => @<div class="trade-crafter-assignment-cell">
                    @{
                        var assignments = GetAssignmentsForCrafter(crafter.Id);
                    }
                    @if (assignments.Count == 0)
                    {
                        <span class="trade-crafter-assignment-empty">None</span>
                    }
                    else
                    {
                        var firstOrder = assignments[0];
                        <button type="button"
                                class="trade-crafter-assignment-chip"
                                title="@firstOrder.Title"
                                @onclick="@(() => OpenOrderAssignment(firstOrder.Id))"
                                @onclick:stopPropagation="true">
                            @(assignments.Count == 1 ? firstOrder.Title : $"{assignments.Count:N0} active")
                        </button>
                    }
                </div>
            },
            WebTableColumn<TradeCrafterProfile, TradeCrafterColumn>.Text(TradeCrafterColumn.Jobs, "Jobs", FormatJobSummary, widthPx: 120)
        ];
    }

    private static string GetCrafterKey(TradeCrafterProfile crafter)
    {
        return crafter.Id.ToString("N");
    }

    protected override async Task OnInitializedAsync()
    {
        AppState.OnStateChanged += OnAppStateChanged;
        await EnsureLoadedForDeveloperModeAsync();
    }

    private void OnAppStateChanged(AppStateChange change)
    {
        if (!change.HasScope(AppStateChangeScope.Settings))
        {
            return;
        }

        _ = InvokeAsync(EnsureLoadedForDeveloperModeAsync);
    }

    private async Task EnsureLoadedForDeveloperModeAsync()
    {
        if (!AppState.SecretDebugToolsEnabled || _hasLoaded)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await LoadAsync();
        _hasLoaded = string.IsNullOrWhiteSpace(_loadError);
        await InvokeAsync(StateHasChanged);
    }

    private async Task LoadAsync()
    {
        try
        {
            _loadError = null;
            _companyProfile = await TradeOperationsPersistence.GetOrCreateActiveCompanyProfileAsync();
            _crafters = (await TradeOperationsPersistence.LoadCraftersAsync(_companyProfile.Id)).ToList();
            _orders = (await TradeOperationsPersistence.LoadOrdersAsync(_companyProfile.Id)).ToList();
            EnsureNewCrafterLocationDefaults();
            _hasLoaded = true;
        }
        catch (Exception ex)
        {
            _hasLoaded = false;
            _companyProfile = null;
            _crafters = [];
            _orders = [];
            _selectedCrafter = null;
            _loadError = ex.Message;
            Snackbar.Add("Trade operations storage is unavailable.", Severity.Error);
        }
    }

    private async Task CreateCrafterAsync()
    {
        if (_companyProfile == null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(_newCrafterName))
        {
            Snackbar.Add("Crafter display name is required.", Severity.Warning);
            return;
        }

        var now = DateTime.UtcNow;
        var crafter = new TradeCrafterProfile
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = _companyProfile.Id,
            DisplayName = _newCrafterName.Trim(),
            DataCenter = NormalizeOptionalText(_newCrafterDataCenter),
            WorldName = NormalizeOptionalText(_newCrafterWorld),
            CreatedAtUtc = now,
            UpdatedAtUtc = now
        };

        var saved = await TradeOperationsPersistence.SaveCrafterAsync(crafter);
        if (!saved)
        {
            Snackbar.Add("Failed to save crafter.", Severity.Error);
            return;
        }

        _newCrafterName = string.Empty;
        await LoadAsync();
        if (!string.IsNullOrWhiteSpace(_loadError) ||
            !SelectCrafterAfterReload(crafter.Id, "Crafter was saved, but it could not be loaded."))
        {
            return;
        }

        Snackbar.Add("Crafter created", Severity.Success);
    }

    private async Task SearchLodestoneAsync()
    {
        _lodestoneIsBusy = true;
        _lodestoneError = null;
        _lodestonePreview = null;
        try
        {
            var result = await LodestoneCrafterLookup.SearchAsync(new LodestoneCrafterSearchRequest(
                _lodestoneSearchName,
                NormalizeOptionalText(_lodestoneSearchWorld),
                string.IsNullOrWhiteSpace(_lodestoneSearchWorld) ? GetDefaultDataCenter() : null));

            if (!result.Succeeded || result.Value == null)
            {
                _lodestoneCandidates = [];
                _lodestoneError = result.ErrorMessage ?? "Lodestone search failed.";
                return;
            }

            _lodestoneCandidates = result.Value;
            if (_lodestoneCandidates.Count == 0)
            {
                _lodestoneError = "No Lodestone characters matched that search.";
            }
        }
        finally
        {
            _lodestoneIsBusy = false;
        }
    }

    private async Task PreviewLodestoneCandidateAsync(LodestoneCrafterSearchCandidate candidate)
    {
        _lodestoneIsBusy = true;
        _lodestoneError = null;
        try
        {
            var result = await LodestoneCrafterLookup.GetImportPreviewAsync(candidate.LodestoneCharacterId);
            if (!result.Succeeded || result.Value == null)
            {
                _lodestonePreview = null;
                _lodestoneError = result.ErrorMessage ?? "Lodestone preview failed.";
                return;
            }

            _lodestonePreview = EnrichPreviewLocation(result.Value);
        }
        finally
        {
            _lodestoneIsBusy = false;
        }
    }

    private async Task CreateCrafterFromLodestoneAsync()
    {
        if (_companyProfile == null || _lodestonePreview == null)
        {
            return;
        }

        var crafter = LodestoneImportMapper.CreateProfile(_companyProfile.Id, _lodestonePreview);
        var saved = await TradeOperationsPersistence.SaveCrafterAsync(crafter);
        if (!saved)
        {
            Snackbar.Add("Failed to save Lodestone crafter.", Severity.Error);
            return;
        }

        await LoadAsync();
        if (_loadError != null ||
            !SelectCrafterAfterReload(crafter.Id, "Crafter imported, but it could not be loaded."))
        {
            return;
        }

        Snackbar.Add("Crafter imported from Lodestone", Severity.Success);
    }

    private async Task UpdateSelectedCrafterFromLodestoneAsync()
    {
        if (_selectedCrafter == null || _lodestonePreview == null)
        {
            return;
        }

        var crafter = LodestoneImportMapper.UpdateProfile(_selectedCrafter, _lodestonePreview);
        var saved = await TradeOperationsPersistence.SaveCrafterAsync(crafter);
        if (!saved)
        {
            Snackbar.Add("Failed to update crafter from Lodestone.", Severity.Error);
            return;
        }

        await LoadAsync();
        if (_loadError != null ||
            !SelectCrafterAfterReload(crafter.Id, "Crafter updated, but it could not be loaded."))
        {
            return;
        }

        Snackbar.Add("Crafter updated from Lodestone", Severity.Success);
    }

    private void SelectCrafter(TradeCrafterProfile crafter)
    {
        _selectedCrafter = crafter;
        _detailName = crafter.DisplayName;
        _detailAlias = crafter.Alias;
        _detailContact = crafter.ContactHandle;
        _detailDiscordHandle = crafter.DiscordHandle;
        _detailSocialProfileUrl = crafter.SocialProfileUrl;
        _detailDataCenter = string.IsNullOrWhiteSpace(crafter.DataCenter)
            ? GetDefaultDataCenter()
            : crafter.DataCenter;
        _detailRegion = MarketFetchScopeResolver.ResolveRegionForDataCenter(_detailDataCenter, GetDefaultRegion());
        _detailWorld = IsWorldInDataCenter(crafter.WorldName, _detailDataCenter) ? crafter.WorldName! : string.Empty;
        _detailPaymentNotes = crafter.PaymentNotes;
        _detailOperatorNotes = crafter.OperatorNotes;
        _jobLevels = crafter.JobLevels.ToDictionary(level => level.Job, level => level.Level);
    }

    private string GetCrafterRowClass(TradeCrafterProfile crafter)
    {
        return _selectedCrafter?.Id == crafter.Id ? "is-selected" : string.Empty;
    }

    private bool SelectCrafterAfterReload(Guid crafterId, string missingMessage)
    {
        var reloadedCrafter = _crafters.FirstOrDefault(crafter => crafter.Id == crafterId);
        if (reloadedCrafter == null)
        {
            _selectedCrafter = null;
            _jobLevels = [];
            Snackbar.Add(missingMessage, Severity.Warning);
            return false;
        }

        SelectCrafter(reloadedCrafter);
        return true;
    }

    private async Task SaveSelectedCrafterAsync()
    {
        if (_selectedCrafter == null || string.IsNullOrWhiteSpace(_detailName))
        {
            return;
        }

        var crafterId = _selectedCrafter.Id;
        var crafterToSave = CopyCrafter(_selectedCrafter);
        crafterToSave.DisplayName = _detailName.Trim();
        crafterToSave.Alias = NormalizeOptionalText(_detailAlias);
        crafterToSave.ContactHandle = NormalizeOptionalText(_detailContact);
        crafterToSave.DiscordHandle = NormalizeOptionalText(_detailDiscordHandle);
        crafterToSave.SocialProfileUrl = NormalizeOptionalText(_detailSocialProfileUrl);
        crafterToSave.WorldName = NormalizeOptionalText(_detailWorld);
        crafterToSave.DataCenter = NormalizeOptionalText(_detailDataCenter);
        crafterToSave.PaymentNotes = _detailPaymentNotes;
        crafterToSave.OperatorNotes = _detailOperatorNotes;
        crafterToSave.UpdatedAtUtc = DateTime.UtcNow;
        crafterToSave.JobLevels = _jobLevels
            .Where(pair => pair.Value > 0)
            .OrderBy(pair => pair.Key)
            .Select(pair => new TradeCraftingJobLevel(pair.Key, pair.Value))
            .ToArray();

        var saved = await TradeOperationsPersistence.SaveCrafterAsync(crafterToSave);
        if (!saved)
        {
            Snackbar.Add("Failed to save crafter.", Severity.Error);
            return;
        }

        await LoadAsync();
        if (!string.IsNullOrWhiteSpace(_loadError) ||
            !SelectCrafterAfterReload(crafterId, "Crafter was saved, but it could not be loaded."))
        {
            return;
        }

        Snackbar.Add("Crafter saved", Severity.Success);
    }

    private int GetJobLevel(TradeCraftingJob job)
    {
        return _jobLevels.TryGetValue(job, out var level) ? level : 0;
    }

    private void SetNewCrafterRegion(string region)
    {
        _newCrafterRegion = string.IsNullOrWhiteSpace(region) ? GetDefaultRegion() : region;
        var dataCenters = GetDataCentersForRegion(_newCrafterRegion);
        if (!dataCenters.Contains(_newCrafterDataCenter, StringComparer.OrdinalIgnoreCase))
        {
            _newCrafterDataCenter = dataCenters.FirstOrDefault() ?? GetDefaultDataCenter();
        }

        if (!IsWorldInDataCenter(_newCrafterWorld, _newCrafterDataCenter))
        {
            _newCrafterWorld = string.Empty;
        }
    }

    private void SetNewCrafterDataCenter(string dataCenter)
    {
        _newCrafterDataCenter = string.IsNullOrWhiteSpace(dataCenter) ? GetDefaultDataCenter() : dataCenter;
        _newCrafterRegion = MarketFetchScopeResolver.ResolveRegionForDataCenter(_newCrafterDataCenter, GetDefaultRegion());
        if (!IsWorldInDataCenter(_newCrafterWorld, _newCrafterDataCenter))
        {
            _newCrafterWorld = string.Empty;
        }
    }

    private void SetNewCrafterWorld(string world)
    {
        _newCrafterWorld = world ?? string.Empty;
    }

    private void SetDetailRegion(string region)
    {
        _detailRegion = string.IsNullOrWhiteSpace(region) ? GetDefaultRegion() : region;
        var dataCenters = GetDataCentersForRegion(_detailRegion);
        if (!dataCenters.Contains(_detailDataCenter, StringComparer.OrdinalIgnoreCase))
        {
            _detailDataCenter = dataCenters.FirstOrDefault() ?? GetDefaultDataCenter();
        }

        if (!IsWorldInDataCenter(_detailWorld, _detailDataCenter))
        {
            _detailWorld = string.Empty;
        }
    }

    private void SetDetailDataCenter(string dataCenter)
    {
        _detailDataCenter = string.IsNullOrWhiteSpace(dataCenter) ? GetDefaultDataCenter() : dataCenter;
        _detailRegion = MarketFetchScopeResolver.ResolveRegionForDataCenter(_detailDataCenter, GetDefaultRegion());
        if (!IsWorldInDataCenter(_detailWorld, _detailDataCenter))
        {
            _detailWorld = string.Empty;
        }
    }

    private void SetDetailWorld(string world)
    {
        _detailWorld = world ?? string.Empty;
    }

    private void SetJobLevel(TradeCraftingJob job, int level)
    {
        _jobLevels[job] = Math.Clamp(level, 0, 100);
    }

    private IReadOnlyList<TradeOrder> GetAssignmentsForSelectedCrafter()
    {
        if (_selectedCrafter == null)
        {
            return [];
        }

        return GetAssignmentsForCrafter(_selectedCrafter.Id);
    }

    private IReadOnlyList<TradeOrder> GetAssignmentsForCrafter(Guid crafterId)
    {
        return _orders
            .Where(order => order.AssignedCrafterId == crafterId && !TradeOrderStatusWorkflow.IsArchived(order.Status))
            .OrderByDescending(order => order.CommissionedAtUtc)
            .ToArray();
    }

    private void OpenOrderAssignment(Guid orderId)
    {
        NavigationManager.NavigateTo($"trade/orders?orderId={Uri.EscapeDataString(orderId.ToString("D"))}");
    }

    private static string FormatWorld(TradeCrafterProfile crafter)
    {
        if (string.IsNullOrWhiteSpace(crafter.WorldName) && string.IsNullOrWhiteSpace(crafter.DataCenter))
        {
            return "No world set";
        }

        if (string.IsNullOrWhiteSpace(crafter.WorldName))
        {
            return $"{crafter.DataCenter} / No world selected";
        }

        return string.IsNullOrWhiteSpace(crafter.DataCenter)
            ? crafter.WorldName
            : $"{crafter.WorldName} / {crafter.DataCenter}";
    }

    private static string FormatStatus(TradeOrderStatus status)
    {
        return status switch
        {
            TradeOrderStatus.ReadyToAssign => "Ready to Assign",
            TradeOrderStatus.Assigned => "Assigned Awaiting Payment",
            TradeOrderStatus.InProgress => "In Progress",
            TradeOrderStatus.AwaitingDelivery => "Awaiting Delivery",
            _ => status.ToString()
        };
    }

    private static string FormatJobSummary(TradeCrafterProfile crafter)
    {
        var maxLevel = crafter.JobLevels.Count == 0 ? 0 : crafter.JobLevels.Max(level => level.Level);
        return maxLevel == 0
            ? "No levels"
            : $"{crafter.JobLevels.Count:N0} jobs / {maxLevel:N0}";
    }

    private static string FormatImportedJobSummary(LodestoneCrafterImportPreview preview)
    {
        var maxLevel = preview.JobLevels.Count == 0 ? 0 : preview.JobLevels.Max(level => level.Level);
        return maxLevel == 0
            ? "No crafter levels found"
            : $"{preview.JobLevels.Count(level => level.Level > 0):N0} jobs / {maxLevel:N0}";
    }

    private static string FormatLodestonePreviewIdentity(LodestoneCrafterImportPreview preview)
    {
        return string.Join(" / ", new[]
        {
            preview.Race,
            preview.Clan,
            preview.Gender
        }.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static bool HasLodestoneFlair(TradeCrafterProfile crafter)
    {
        return !string.IsNullOrWhiteSpace(crafter.LodestoneProfileUrl) ||
               !string.IsNullOrWhiteSpace(crafter.LodestoneAvatarUrl) ||
               !string.IsNullOrWhiteSpace(crafter.LodestonePortraitUrl) ||
               !string.IsNullOrWhiteSpace(crafter.LodestoneFreeCompanyName) ||
               !string.IsNullOrWhiteSpace(crafter.LodestoneRace) ||
               !string.IsNullOrWhiteSpace(crafter.LodestoneClan) ||
               !string.IsNullOrWhiteSpace(crafter.LodestoneGender);
    }

    private static string FormatLodestoneIdentity(TradeCrafterProfile crafter)
    {
        return string.Join(" / ", new[]
        {
            crafter.LodestoneRace,
            crafter.LodestoneClan,
            crafter.LodestoneGender
        }.Where(value => !string.IsNullOrWhiteSpace(value)));
    }

    private static string FormatLodestoneCandidateLocation(LodestoneCrafterSearchCandidate candidate)
    {
        if (!string.IsNullOrWhiteSpace(candidate.WorldName) && !string.IsNullOrWhiteSpace(candidate.DataCenter))
        {
            return $"{candidate.WorldName} / {candidate.DataCenter}";
        }

        if (!string.IsNullOrWhiteSpace(candidate.WorldName))
        {
            return candidate.WorldName;
        }

        return string.IsNullOrWhiteSpace(candidate.DataCenter)
            ? "Lodestone"
            : candidate.DataCenter;
    }

    private static string FormatPreviewLocation(LodestoneCrafterImportPreview preview)
    {
        if (!string.IsNullOrWhiteSpace(preview.WorldName) && !string.IsNullOrWhiteSpace(preview.DataCenter))
        {
            return $"{preview.WorldName} / {preview.DataCenter}";
        }

        return string.IsNullOrWhiteSpace(preview.WorldName)
            ? "No world reported"
            : preview.WorldName;
    }

    private static string FormatJob(TradeCraftingJob job)
    {
        return job switch
        {
            TradeCraftingJob.Carpenter => "Carpenter",
            TradeCraftingJob.Blacksmith => "Blacksmith",
            TradeCraftingJob.Armorer => "Armorer",
            TradeCraftingJob.Goldsmith => "Goldsmith",
            TradeCraftingJob.Leatherworker => "Leatherworker",
            TradeCraftingJob.Weaver => "Weaver",
            TradeCraftingJob.Alchemist => "Alchemist",
            TradeCraftingJob.Culinarian => "Culinarian",
            _ => job.ToString()
        };
    }

    private void EnsureNewCrafterLocationDefaults()
    {
        _newCrafterRegion = string.IsNullOrWhiteSpace(_newCrafterRegion) ? GetDefaultRegion() : _newCrafterRegion;
        _newCrafterDataCenter = string.IsNullOrWhiteSpace(_newCrafterDataCenter) ? GetDefaultDataCenter() : _newCrafterDataCenter;
        _newCrafterRegion = MarketFetchScopeResolver.ResolveRegionForDataCenter(_newCrafterDataCenter, _newCrafterRegion);
        if (!IsWorldInDataCenter(_newCrafterWorld, _newCrafterDataCenter))
        {
            _newCrafterWorld = string.Empty;
        }
    }

    private string GetDefaultRegion()
    {
        return string.IsNullOrWhiteSpace(AppState.SelectedRegion) ? "North America" : AppState.SelectedRegion;
    }

    private string GetDefaultDataCenter()
    {
        return string.IsNullOrWhiteSpace(AppState.SelectedDataCenter) ? "Aether" : AppState.SelectedDataCenter;
    }

    private IReadOnlyList<string> GetDataCentersForRegion(string region)
    {
        return MarketFetchScopeResolver.GetDataCenters(
            MarketFetchScope.EntireRegion,
            GetDefaultDataCenter(),
            string.IsNullOrWhiteSpace(region) ? GetDefaultRegion() : region);
    }

    private IReadOnlyList<string> GetWorldsForDataCenter(string dataCenter)
    {
        if (string.IsNullOrWhiteSpace(dataCenter))
        {
            return [];
        }

        return AppState.WorldData?.DataCenterToWorlds.TryGetValue(dataCenter, out var worlds) == true
            ? worlds.Order(StringComparer.OrdinalIgnoreCase).ToArray()
            : [];
    }

    private LodestoneCrafterImportPreview EnrichPreviewLocation(LodestoneCrafterImportPreview preview)
    {
        if (!string.IsNullOrWhiteSpace(preview.DataCenter) || string.IsNullOrWhiteSpace(preview.WorldName))
        {
            return preview;
        }

        var dataCenter = ResolveDataCenterForWorld(preview.WorldName);
        return string.IsNullOrWhiteSpace(dataCenter)
            ? preview
            : preview with { DataCenter = dataCenter };
    }

    private string? ResolveDataCenterForWorld(string worldName)
    {
        if (AppState.WorldData?.DataCenterToWorlds == null)
        {
            return null;
        }

        foreach (var pair in AppState.WorldData.DataCenterToWorlds)
        {
            if (pair.Value.Contains(worldName, StringComparer.OrdinalIgnoreCase))
            {
                return pair.Key;
            }
        }

        return null;
    }

    private bool IsWorldInDataCenter(string? world, string dataCenter)
    {
        return !string.IsNullOrWhiteSpace(world) &&
               GetWorldsForDataCenter(dataCenter).Contains(world, StringComparer.OrdinalIgnoreCase);
    }

    private static string? NormalizeOptionalText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }

