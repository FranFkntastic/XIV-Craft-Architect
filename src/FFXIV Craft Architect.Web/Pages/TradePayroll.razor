@page "/trade"
@page "/trade/payroll"
@using System.Text
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject TradePayrollDraftFactory DraftFactory
@inject TradeOrderDraftFactory TradeOrderDraftFactory
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@inject TradePayrollPersistenceService TradePayrollPersistence
@inject CommissionPayrollService PayrollService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="trade-page">
    @if (!AppState.SecretDebugToolsEnabled)
    {
        <MudAlert Severity="Severity.Info" Class="ma-4">
            Returning to Craft Architect...
        </MudAlert>
    }
    else if (!string.IsNullOrWhiteSpace(_unavailableReason))
    {
        <section class="trade-empty">
            <MudText Typo="Typo.h5" Class="mb-2">Payroll</MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@_unavailableReason</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Build"
                       OnClick="@(() => NavigationManager.NavigateTo("./"))">
                Return to Craft Architect
            </MudButton>
        </section>
    }
    else if (_source == null || _payroll == null)
    {
        <section class="trade-empty">
            <MudText Typo="Typo.h5" Class="mb-2">Payroll</MudText>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       StartIcon="@Icons.Material.Filled.Payments"
                       OnClick="CreateDraftAsync">
                New payroll calculation from active craft plan
            </MudButton>
        </section>
    }
    else
    {
        <div class="trade-layout">
            <section class="trade-main">
                <div class="trade-section-header">
                    <div>
                        <MudText Typo="Typo.h5">Payroll Calculator</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            @_source.SourcePlanName - @_source.SelectedDataCenter / @_source.SelectedRegion - imported @_source.ImportedAtUtc.ToLocalTime():g
                        </MudText>
                    </div>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Refresh"
                               OnClick="CreateDraftAsync">
                        Re-import Craft Evidence
                    </MudButton>
                </div>

                @if (_source.Warnings.Count > 0)
                {
                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mb-3">
                        This payroll estimate has evidence warnings. They are listed by item and included in the copied summary.
                    </MudAlert>
                }

                <div class="trade-material-table">
                    <div class="trade-material-row trade-material-head">
                        <span>Item</span>
                        <span>Qty</span>
                        <span>Responsibility</span>
                        <span>Unit Cost</span>
                        <span>Payroll Basis</span>
                    </div>
                    @foreach (var line in _lines)
                    {
                        <div class="trade-material-row" @key="line.ItemId">
                            <div>
                                <strong>@line.Name</strong>
                                @if (line.RequiresHq)
                                {
                                    <span class="trade-hq">HQ</span>
                                }
                                <div class="trade-evidence">@line.EvidenceSource</div>
                            </div>
                            <span>@line.Quantity.ToString("N0")</span>
                            <MudSelect T="CommissionMaterialResponsibility"
                                       Value="line.Responsibility"
                                       ValueChanged="value => SetResponsibilityAsync(line, value)"
                                       Dense="true"
                                       Margin="Margin.Dense"
                                       Variant="Variant.Outlined"
                                       Class="trade-responsibility-select"
                                       aria-label="@($"{line.Name} material responsibility")">
                                <MudSelectItem Value="@CommissionMaterialResponsibility.Crafter">Crafter</MudSelectItem>
                                <MudSelectItem Value="@CommissionMaterialResponsibility.Provided">Provided</MudSelectItem>
                            </MudSelect>
                            <span title="@line.UnitCostExplanation">@FormatGil(line.UnitCost)</span>
                            <span title="@line.ResponsibilityExplanation">@FormatGil(line.MaterialBasis)</span>
                        </div>
                    }
                </div>
            </section>

            <aside class="trade-side">
                <section class="trade-panel">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Payroll Details</MudText>
                    <MudSelect T="Guid?"
                               Value="_assignedCrafterId"
                               ValueChanged="SetAssignedCrafterAsync"
                               Label="Assigned Crafter"
                               Variant="Variant.Outlined"
                               Margin="Margin.Dense"
                               Clearable="true"
                               Class="trade-assigned-crafter-select">
                        @foreach (var crafter in _crafters)
                        {
                            <MudSelectItem T="Guid?" Value="@((Guid?)crafter.Id)">@crafter.DisplayName</MudSelectItem>
                        }
                    </MudSelect>
                    <div class="trade-assignment-actions">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.AssignmentTurnedIn"
                                   OnClick="AssignCraftJobAsync"
                                   Disabled="@(!_assignedCrafterId.HasValue)"
                                   Class="trade-assign-button">
                            Assign Craft Job
                        </MudButton>
                        @if (_linkedOrder != null)
                        {
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.ViewList"
                                       OnClick="OpenOrdersBoard"
                                       Class="trade-open-orders-button">
                                Open Orders
                            </MudButton>
                        }
                    </div>
                    <div class="trade-meta-list">
                        <div>
                            <span>Plan</span>
                            <strong>@FormatPayrollDate(_source.ImportedAtUtc)</strong>
                        </div>
                        <div>
                            <span>Order</span>
                            <strong>@FormatLinkedOrder()</strong>
                        </div>
                    </div>
                    <div class="trade-crafted-summary">
                        <span>Being made</span>
                        <div class="trade-crafted-table">
                            @foreach (var item in _source.CraftedItems.OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase))
                            {
                                <div @key="item.Id">
                                    <span>@FormatProjectName(item)</span>
                                    <strong>@TradeDisplayFormatter.FormatQuantity(item.Quantity)</strong>
                                </div>
                            }
                        </div>
                    </div>
                </section>

                <section class="trade-panel trade-totals">
                    <MudText Typo="Typo.subtitle1" Class="mb-3">Payroll</MudText>
                    <div><span>Crafter procures</span><strong>@FormatGil(_payroll.MaterialBasisTotal)</strong></div>
                    <div><span>Provided by commissioner</span><strong>@FormatGil(GetProvidedMaterialTotal())</strong></div>
                    <div><span>Commission (@_commissionPercent.ToString("N0")%)</span><strong>@FormatGil(_payroll.CommissionAmount)</strong></div>
                    <div class="trade-total"><span>Total pay</span><strong>@FormatGil(_payroll.TotalPay)</strong></div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="trade-payroll-note">
                        Commission is @_commissionPercent.ToString("N0")% of full estimated material cost. Crafter-responsible materials are also reimbursed.
                    </MudText>
                    <MudButton FullWidth="true"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.ContentCopy"
                               OnClick="CopyPayrollSummaryAsync">
                        Copy Payroll Summary
                    </MudButton>
                </section>

                @if (_payroll.Warnings.Count > 0)
                {
                    <section class="trade-panel">
                        <MudText Typo="Typo.subtitle1" Class="mb-2">Evidence Warnings</MudText>
                        <ul class="trade-warnings">
                            @foreach (var warning in _payroll.Warnings)
                            {
                                <li>@warning</li>
                            }
                        </ul>
                    </section>
                }
            </aside>
        </div>
    }
</MudContainer>

@code {
    private TradePayrollImportSnapshot? _source;
    private CommissionPayrollRun? _payroll;
    private string? _unavailableReason;
    private List<TradePayrollLineEditor> _lines = [];
    private decimal _commissionPercent = CommissionPayoutPolicy.Default.CommissionPercent;
    private TradeCompanyProfile? _companyProfile;
    private TradePayrollWorkflowDraft? _workflowDraft;
    private TradeOrder? _linkedOrder;
    private List<TradeCrafterProfile> _crafters = [];
    private List<TradeOrder> _orders = [];
    private Guid? _assignedCrafterId;
    private bool _hasLoaded;

    protected override async Task OnInitializedAsync()
    {
        if (IsTradeRootRoute())
        {
            NavigationManager.NavigateTo("trade/orders", replace: true);
            return;
        }

        AppState.OnStateChanged += OnAppStateChanged;
        await EnsureLoadedForDeveloperModeAsync();
    }

    private bool IsTradeRootRoute()
    {
        var path = NavigationManager
            .ToBaseRelativePath(NavigationManager.Uri)
            .Trim('/')
            .Split('?', 2)[0];
        return string.Equals(path, "trade", StringComparison.OrdinalIgnoreCase);
    }

    private void OnAppStateChanged(AppStateChange change)
    {
        if (!change.HasScope(AppStateChangeScope.Settings))
        {
            return;
        }

        _ = InvokeAsync(EnsureLoadedForDeveloperModeAsync);
    }

    private async Task EnsureLoadedForDeveloperModeAsync()
    {
        if (!AppState.SecretDebugToolsEnabled || _hasLoaded)
        {
            await InvokeAsync(StateHasChanged);
            return;
        }

        await CreateDraftAsync();
        _hasLoaded = _source != null && _payroll != null && string.IsNullOrWhiteSpace(_unavailableReason);
        await InvokeAsync(StateHasChanged);
    }

    private async Task CreateDraftAsync()
    {
        var result = DraftFactory.CreateFromCurrentPlan(AppState);
        if (!result.CanCreate || result.Draft == null)
        {
            _source = null;
            _payroll = null;
            _lines.Clear();
            _workflowDraft = null;
            _linkedOrder = null;
            _assignedCrafterId = null;
            _unavailableReason = result.UnavailableReason;
            _hasLoaded = false;
            return;
        }

        _unavailableReason = null;
        _source = result.Draft.Source;
        _payroll = result.Draft.Payroll;
        ResetPolicy(result.Draft.Payroll.Policy);
        await LoadTradeWorkflowAsync();
        var lines = _workflowDraft != null
            ? TradePayrollPersistence.ApplyResponsibilities(_source.Lines, _workflowDraft)
            : _source.Lines;
        _lines = lines.Select(TradePayrollLineEditor.FromInput).ToList();
        if (_workflowDraft != null && _workflowDraft.CommissionPercent > 0)
        {
            _commissionPercent = _workflowDraft.CommissionPercent;
        }

        Recalculate();
        _hasLoaded = true;
    }

    private async Task LoadTradeWorkflowAsync()
    {
        if (_source == null)
        {
            return;
        }

        _companyProfile = await TradeOperationsPersistence.GetOrCreateActiveCompanyProfileAsync();
        _crafters = (await TradeOperationsPersistence.LoadCraftersAsync(_companyProfile.Id)).ToList();
        _orders = (await TradeOperationsPersistence.LoadOrdersAsync(_companyProfile.Id)).ToList();
        _linkedOrder = FindMatchingOrder();

        var orderCrafterId = _linkedOrder?.AssignedCrafterId;
        var orderCrafterName = orderCrafterId.HasValue ? GetCrafterDisplayName(orderCrafterId.Value) : null;
        _workflowDraft = await TradePayrollPersistence.GetOrCreateDraftAsync(
            _companyProfile.Id,
            _linkedOrder?.Id,
            _source.PlanSessionVersion,
            _source.MarketAnalysisVersion,
            _source.SourcePlanName,
            orderCrafterId,
            orderCrafterName);

        _assignedCrafterId = _workflowDraft.AssignedCrafterId;
        await LinkPayrollDraftToOrderAsync();
    }

    private TradeOrder? FindMatchingOrder()
    {
        if (_source == null)
        {
            return null;
        }

        return _orders
            .Where(order => order.SourceSnapshot.PlanSessionVersion == _source.PlanSessionVersion)
            .Where(order => !TradeOrderStatusWorkflow.IsArchived(order.Status))
            .OrderByDescending(order => order.CommissionedAtUtc)
            .FirstOrDefault();
    }

    private void ResetPolicy(CommissionPayoutPolicy policy)
    {
        _commissionPercent = policy.CommissionPercent;
    }

    private async Task SetAssignedCrafterAsync(Guid? crafterId)
    {
        _assignedCrafterId = crafterId;
        if (_workflowDraft == null)
        {
            return;
        }

        _workflowDraft.AssignedCrafterId = crafterId;
        _workflowDraft.AssignedCrafterDisplayName = crafterId.HasValue
            ? GetCrafterDisplayName(crafterId.Value)
            : null;
        await SaveWorkflowDraftAsync();
    }

    private async Task AssignCraftJobAsync()
    {
        if (_source == null || _companyProfile == null || _workflowDraft == null)
        {
            Snackbar.Add("Create a payroll calculation before assigning a craft job.", Severity.Warning);
            return;
        }

        if (!_assignedCrafterId.HasValue)
        {
            Snackbar.Add("Choose an assigned crafter before assigning the craft job.", Severity.Warning);
            return;
        }

        var now = DateTime.UtcNow;
        var isNewOrder = _linkedOrder == null;
        var orderToSave = isNewOrder
            ? CreateAssignedOrderFromCurrentPlan(now)
            : CopyOrder(_linkedOrder!);
        if (orderToSave == null)
        {
            return;
        }

        var previousCrafterId = orderToSave.AssignedCrafterId;
        var previousStatus = orderToSave.Status;
        orderToSave.AssignedCrafterId = _assignedCrafterId;
        orderToSave.Status = GetAssignedOrderStatus(orderToSave.Status);
        orderToSave.PayrollDraftId = _workflowDraft.Id;
        orderToSave.UpdatedAtUtc = now;
        AddAssignmentHistoryIfChanged(orderToSave, previousCrafterId, _assignedCrafterId, now);
        AddStatusHistoryIfChanged(orderToSave, previousStatus, orderToSave.Status, "Assigned from payroll.", now);
        AddPayrollLinkedHistoryIfMissing(orderToSave, now);

        var saved = await TradeOperationsPersistence.SaveOrderAsync(orderToSave);
        if (!saved)
        {
            Snackbar.Add("Failed to save Trade order assignment.", Severity.Error);
            return;
        }

        _workflowDraft.OrderId = orderToSave.Id;
        _workflowDraft.AssignedCrafterId = _assignedCrafterId;
        _workflowDraft.AssignedCrafterDisplayName = GetCrafterDisplayName(_assignedCrafterId.Value);
        var draftSaved = await TradePayrollPersistence.SaveDraftAsync(_workflowDraft);
        if (!draftSaved)
        {
            Snackbar.Add("Order assigned, but failed to update payroll workflow state.", Severity.Warning);
            return;
        }

        await LoadTradeWorkflowAsync();
        Snackbar.Add("Craft job assigned to Trade order.", Severity.Success);
    }

    private TradeOrder? CreateAssignedOrderFromCurrentPlan(DateTime createdAtUtc)
    {
        if (_companyProfile == null)
        {
            return null;
        }

        var result = TradeOrderDraftFactory.CreateFromCurrentPlan(new TradeOrderCreateRequest(
            AppState,
            _companyProfile.Id,
            _assignedCrafterId,
            null,
            createdAtUtc));
        if (!result.CanCreate || result.Order == null)
        {
            Snackbar.Add(result.UnavailableReason ?? "Could not create order from the active plan.", Severity.Warning);
            return null;
        }

        return result.Order;
    }

    private async Task SetResponsibilityAsync(TradePayrollLineEditor line, CommissionMaterialResponsibility responsibility)
    {
        line.Responsibility = responsibility;
        Recalculate();
        await SaveWorkflowDraftAsync();
    }

    private async Task SaveWorkflowDraftAsync()
    {
        if (_workflowDraft == null)
        {
            return;
        }

        _workflowDraft.CommissionPercent = _commissionPercent;
        _workflowDraft.Responsibilities = _lines
            .Select(line => new TradePayrollResponsibilityLine(
                line.ItemId,
                line.RequiresHq,
                line.Responsibility))
            .ToArray();

        var saved = await TradePayrollPersistence.SaveDraftAsync(_workflowDraft);
        if (!saved)
        {
            Snackbar.Add("Failed to save payroll workflow state.", Severity.Error);
        }
    }

    private async Task LinkPayrollDraftToOrderAsync()
    {
        if (_linkedOrder == null || _workflowDraft == null)
        {
            return;
        }

        if (!string.IsNullOrWhiteSpace(_linkedOrder.PayrollDraftId) &&
            !string.Equals(_linkedOrder.PayrollDraftId, _workflowDraft.Id, StringComparison.OrdinalIgnoreCase))
        {
            return;
        }

        var alreadyLinked = string.Equals(_linkedOrder.PayrollDraftId, _workflowDraft.Id, StringComparison.OrdinalIgnoreCase) &&
            _linkedOrder.History.Any(history => history.Kind == TradeOrderHistoryEventKind.PayrollLinked);
        if (alreadyLinked)
        {
            return;
        }

        var orderToSave = CopyOrder(_linkedOrder);
        orderToSave.PayrollDraftId = _workflowDraft.Id;
        orderToSave.UpdatedAtUtc = DateTime.UtcNow;
        AddPayrollLinkedHistoryIfMissing(orderToSave, DateTime.UtcNow);

        var saved = await TradeOperationsPersistence.SaveOrderAsync(orderToSave);
        if (saved)
        {
            _linkedOrder = orderToSave;
            return;
        }

        Snackbar.Add("Failed to link payroll workflow to Trade order.", Severity.Warning);
    }

    private void Recalculate()
    {
        if (_source == null || _lines.Count == 0)
        {
            return;
        }

        var policy = new CommissionPayoutPolicy(_commissionPercent);
        _payroll = PayrollService.Calculate(_lines.Select(line => line.ToInputLine()), policy);
    }

    private async Task CopyPayrollSummaryAsync()
    {
        if (_source == null || _payroll == null)
        {
            return;
        }

        var summary = BuildPayrollSummary();
        try
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", summary);
            Snackbar.Add("Payroll summary copied", Severity.Success);
        }
        catch
        {
            Snackbar.Add("Failed to copy payroll summary", Severity.Error);
        }
    }

    private string BuildPayrollSummary()
    {
        var summary = new StringBuilder();
        summary.AppendLine("FFXIV Trade Architect Payroll");
        summary.AppendLine($"Plan: {FormatPayrollDate(_source!.ImportedAtUtc)}");
        summary.AppendLine($"Assigned crafter: {FormatAssignedCrafterName()}");
        summary.AppendLine();
        AppendCraftedItemsSection(summary, _source.CraftedItems);
        summary.AppendLine();
        AppendMaterialSection(summary, "Crafter procures", _payroll!.Lines.Where(line => line.Responsibility == CommissionMaterialResponsibility.Crafter));
        summary.AppendLine();
        AppendMaterialSection(summary, "Provided by commissioner", _payroll.Lines.Where(line => line.Responsibility == CommissionMaterialResponsibility.Provided));
        summary.AppendLine();
        summary.AppendLine($"Materials reimbursement: {FormatGil(_payroll.MaterialBasisTotal)}");
        summary.AppendLine($"Commission ({_payroll.Policy.CommissionPercent:N0}%): {FormatGil(_payroll.CommissionAmount)}");
        summary.AppendLine($"Total pay: {FormatGil(_payroll.TotalPay)}");

        if (_payroll.Warnings.Count > 0)
        {
            summary.AppendLine();
            summary.AppendLine("Estimate warnings:");
            foreach (var warning in _payroll.Warnings)
            {
                summary.AppendLine($"- {warning}");
            }
        }

        return summary.ToString();
    }

    private void OpenOrdersBoard()
    {
        if (_linkedOrder != null)
        {
            NavigationManager.NavigateTo($"trade/orders?orderId={_linkedOrder.Id:D}");
            return;
        }

        NavigationManager.NavigateTo("trade/orders");
    }

    private void AppendCraftedItemsSection(StringBuilder summary, IEnumerable<ProjectItem> items)
    {
        summary.AppendLine("Being made:");
        var craftedItems = items.OrderBy(item => item.Name, StringComparer.OrdinalIgnoreCase).ToArray();
        if (craftedItems.Length == 0)
        {
            summary.AppendLine("- None");
            return;
        }

        foreach (var item in craftedItems)
        {
            summary.AppendLine($"- {FormatProjectItem(item)}");
        }
    }

    private void AppendMaterialSection(
        StringBuilder summary,
        string heading,
        IEnumerable<CommissionPayrollLine> lines)
    {
        summary.AppendLine($"{heading}:");
        var materialLines = lines.OrderBy(line => line.Name, StringComparer.OrdinalIgnoreCase).ToArray();
        if (materialLines.Length == 0)
        {
            summary.AppendLine("- None");
            return;
        }

        foreach (var line in materialLines)
        {
            var hqSuffix = line.RequiresHq ? " HQ" : string.Empty;
            summary.AppendLine($"- {line.Name}{hqSuffix} x{line.Quantity:N0}: {FormatGil(line.EstimatedMaterialCost)}");
        }
    }

    private decimal GetProvidedMaterialTotal()
    {
        return _payroll?.Lines
            .Where(line => line.Responsibility == CommissionMaterialResponsibility.Provided)
            .Sum(line => line.EstimatedMaterialCost) ?? 0m;
    }

    private string FormatAssignedCrafterName()
    {
        if (_assignedCrafterId.HasValue)
        {
            return GetCrafterDisplayName(_assignedCrafterId.Value) ?? "Assigned";
        }

        return "Unassigned";
    }

    private string FormatLinkedOrder()
    {
        return _linkedOrder == null
            ? "Not assigned"
            : _linkedOrder.Title;
    }

    private string? GetCrafterDisplayName(Guid crafterId)
    {
        return _crafters.FirstOrDefault(crafter => crafter.Id == crafterId)?.DisplayName
            ?? _workflowDraft?.AssignedCrafterDisplayName;
    }

    private static string FormatPayrollDate(DateTime generatedAtUtc)
    {
        return generatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd");
    }

    private static string FormatProjectItem(ProjectItem item)
    {
        var hqSuffix = item.MustBeHq ? " HQ" : string.Empty;
        return $"{item.Name}{hqSuffix} x{item.Quantity:N0}";
    }

    private static string FormatProjectName(ProjectItem item)
    {
        var hqSuffix = item.MustBeHq ? " HQ" : string.Empty;
        return $"{item.Name}{hqSuffix}";
    }

    private static string FormatGil(decimal value)
    {
        return $"{value:N0}g";
    }

    private static TradeOrderStatus GetAssignedOrderStatus(TradeOrderStatus status)
    {
        return status is TradeOrderStatus.Draft or TradeOrderStatus.ReadyToAssign
            ? TradeOrderStatus.Assigned
            : status;
    }

    private string FormatCrafterForHistory(Guid? crafterId)
    {
        return crafterId.HasValue
            ? GetCrafterDisplayName(crafterId.Value) ?? "unknown crafter"
            : "unassigned";
    }

    private void AddAssignmentHistoryIfChanged(TradeOrder order, Guid? previousCrafterId, Guid? newCrafterId, DateTime createdAtUtc)
    {
        if (previousCrafterId == newCrafterId)
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.Assigned,
            Note = newCrafterId.HasValue
                ? $"Assigned to {FormatCrafterForHistory(newCrafterId)} from payroll."
                : "Assignment cleared from payroll.",
            CrafterId = newCrafterId,
            CreatedAtUtc = createdAtUtc
        });
        order.History = history;
    }

    private static void AddStatusHistoryIfChanged(TradeOrder order, TradeOrderStatus previousStatus, TradeOrderStatus newStatus, string note, DateTime createdAtUtc)
    {
        if (previousStatus == newStatus)
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.StatusChanged,
            Note = note,
            FromStatus = previousStatus,
            ToStatus = newStatus,
            CreatedAtUtc = createdAtUtc
        });
        order.History = history;
    }

    private static void AddPayrollLinkedHistoryIfMissing(TradeOrder order, DateTime createdAtUtc)
    {
        if (order.History.Any(history => history.Kind == TradeOrderHistoryEventKind.PayrollLinked))
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.PayrollLinked,
            Note = "Payroll workflow draft linked.",
            CreatedAtUtc = createdAtUtc
        });
        order.History = history;
    }

    private static TradeOrder CopyOrder(TradeOrder order)
    {
        return new TradeOrder
        {
            Id = order.Id,
            CompanyProfileId = order.CompanyProfileId,
            Title = order.Title,
            Status = order.Status,
            AssignedCrafterId = order.AssignedCrafterId,
            CommissionedAtUtc = order.CommissionedAtUtc,
            CreatedAtUtc = order.CreatedAtUtc,
            UpdatedAtUtc = order.UpdatedAtUtc,
            Notes = order.Notes,
            SourceSnapshot = order.SourceSnapshot,
            History = order.History.ToArray(),
            PayrollDraftId = order.PayrollDraftId,
            RemoteId = order.RemoteId,
            SyncState = order.SyncState
        };
    }

    public void Dispose()
    {
        AppState.OnStateChanged -= OnAppStateChanged;
    }

    private sealed class TradePayrollLineEditor
    {
        public int ItemId { get; init; }
        public string Name { get; init; } = string.Empty;
        public int Quantity { get; init; }
        public decimal UnitCost { get; init; }
        public bool RequiresHq { get; init; }
        public CommissionMaterialResponsibility Responsibility { get; set; }
        public string EvidenceSource { get; init; } = string.Empty;
        public string UnitCostExplanation { get; init; } = string.Empty;
        public DateTime? EvidenceTimestampUtc { get; init; }
        public IReadOnlyList<string> Warnings { get; init; } = [];
        public decimal EstimatedMaterialCost => Quantity * UnitCost;
        public decimal MaterialBasis => Responsibility == CommissionMaterialResponsibility.Crafter
            ? EstimatedMaterialCost
            : 0m;
        public string ResponsibilityExplanation => Responsibility == CommissionMaterialResponsibility.Crafter
            ? "Crafter is responsible for this material; it is included in reimbursable material basis."
            : "Material is provided by the guild; it is excluded from reimbursable material basis.";

        public static TradePayrollLineEditor FromInput(CommissionPayrollInputLine line)
        {
            return new TradePayrollLineEditor
            {
                ItemId = line.ItemId,
                Name = line.Name,
                Quantity = line.Quantity,
                UnitCost = line.UnitCost,
                RequiresHq = line.RequiresHq,
                Responsibility = line.Responsibility,
                EvidenceSource = line.EvidenceSource,
                UnitCostExplanation = line.UnitCostExplanation,
                EvidenceTimestampUtc = line.EvidenceTimestampUtc,
                Warnings = line.Warnings.ToArray()
            };
        }

        public CommissionPayrollInputLine ToInputLine()
        {
            return new CommissionPayrollInputLine(
                ItemId,
                Name,
                Quantity,
                UnitCost,
                RequiresHq,
                Responsibility,
                EvidenceSource,
                UnitCostExplanation,
                EvidenceTimestampUtc,
                Warnings);
        }
    }
}
