@page "/trade/orders"
@using System.Text
@using FFXIV_Craft_Architect.Web.Shared.TablePrimitives
@inject AppState AppState
@inject GarlandService GarlandService
@inject TradeOrderDraftFactory TradeOrderDraftFactory
@inject TradeOrderCraftPlanBuildService TradeOrderCraftPlanBuildService
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@inject TradePayrollPersistenceService TradePayrollPersistence
@inject RecipePlannerCommandService RecipePlannerCommandService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="trade-orders-page">
    @if (!AppState.SecretDebugToolsEnabled)
    {
        <MudAlert Severity="Severity.Info" Class="ma-4">Returning to Craft Architect...</MudAlert>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">
                <MudText Typo="Typo.subtitle2">Trade operations storage is unavailable.</MudText>
                <MudText Typo="Typo.body2">@_loadError</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Class="mt-2"
                           OnClick="LoadAsync">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else
        {
            <div class="trade-orders-layout">
            <section class="trade-orders-main">
                <div class="trade-orders-header">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.AddTask"
                               OnClick="ToggleNewOrderPanel">
                        New Order
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Assignment"
                               OnClick="PrepareOrderImport">
                        Create Order from Active Craft Plan
                    </MudButton>
                </div>

                @if (_showNewOrderPanel)
                {
                    <section class="trade-orders-panel trade-orders-new-order">
                        <div class="trade-orders-panel-heading">
                            <MudText Typo="Typo.subtitle1">New Order</MudText>
                            <MudButton Variant="Variant.Text"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       OnClick="ResetNewOrderDraft">
                                Clear
                            </MudButton>
                        </div>
                        <div class="trade-orders-new-order-grid">
                            <MudTextField T="string"
                                          Value="@_newRequestedOrderTitle"
                                          ValueChanged="value => OnRequestedOrderTitleChanged(value)"
                                          Label="Order title"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />
                            <MudSelect T="Guid?"
                                       @bind-Value="_newRequestedOrderCrafterId"
                                       Label="Assigned crafter"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true">
                                @foreach (var crafter in _crafters)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)crafter.Id)">@crafter.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudTextField @bind-Value="_newRequestedOrderNotes"
                                          Label="Notes"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="1" />
                        </div>

                        <div class="trade-orders-search-row">
                            <MudTextField @bind-Value="_requestedOrderSearchQuery"
                                          Label="Add output item"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true"
                                          OnKeyUp="OnRequestedOrderSearchKeyUp" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       OnClick="SearchRequestedOrderItemsAsync"
                                       Disabled="@(_isSearchingRequestedOrderItems || string.IsNullOrWhiteSpace(_requestedOrderSearchQuery))">
                                @(_isSearchingRequestedOrderItems ? "Searching..." : "Search")
                            </MudButton>
                        </div>

                        @if (_requestedOrderSearchResults.Count > 0)
                        {
                            <div class="trade-orders-search-results">
                                @foreach (var result in _requestedOrderSearchResults)
                                {
                                    <button type="button"
                                            class="trade-orders-search-result"
                                            @onclick="() => AddRequestedOrderOutput(result)">
                                        <span>@result.Object.Name</span>
                                        <span>ID @result.Id</span>
                                    </button>
                                }
                            </div>
                        }

                        <div class="trade-orders-output-table">
                            <div class="trade-orders-output-header">
                                <span>Item</span>
                                <span>Qty</span>
                                <span>HQ</span>
                                <span></span>
                            </div>
                            @if (_requestedOrderOutputs.Count == 0)
                            {
                                <div class="trade-orders-output-empty">Add at least one requested output.</div>
                            }
                            else
                            {
                                @foreach (var output in _requestedOrderOutputs)
                                {
                                    <div class="trade-orders-output-row">
                                        <span>@output.Name</span>
                                        <MudNumericField T="int"
                                                         Value="@output.Quantity"
                                                         ValueChanged="quantity => UpdateRequestedOrderOutputQuantity(output, quantity)"
                                                         Min="1"
                                                         Max="9999"
                                                         Variant="Variant.Outlined"
                                                         Margin="Margin.Dense" />
                                        <MudCheckBox T="bool"
                                                     Value="@output.MustBeHq"
                                                     ValueChanged="mustBeHq => UpdateRequestedOrderOutputHq(output, mustBeHq)"
                                                     Color="Color.Primary" />
                                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                       Color="Color.Error"
                                                       Size="Size.Small"
                                                       OnClick="() => RemoveRequestedOrderOutput(output)" />
                                    </div>
                                }
                            }
                        </div>

                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   OnClick="CreateRequestedOrderAsync"
                                   Disabled="@(!CanCreateRequestedOrder || _isCreatingRequestedOrder)">
                            @(_isCreatingRequestedOrder ? "Creating Order..." : "Create Order")
                        </MudButton>
                    </section>
                }

                @if (_pendingImport != null)
                {
                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Suggested title</MudText>
                        <div class="trade-orders-import-grid">
                            <MudTextField @bind-Value="_newOrderTitle"
                                          Label="Order title"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />
                            <MudSelect T="Guid?"
                                       @bind-Value="_newOrderCrafterId"
                                       Label="Assigned crafter"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true">
                                @foreach (var crafter in _crafters)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)crafter.Id)">@crafter.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="CreatePendingOrderAsync"
                                       Disabled="@string.IsNullOrWhiteSpace(_newOrderTitle)">
                                Confirm Order
                            </MudButton>
                        </div>
                    </section>
                }

                @if (ActiveOrderGroups.Count == 0 && ArchivedOrders.Count == 0)
                {
                    <section class="trade-orders-empty-state">
                        <MudText Typo="Typo.subtitle1">No orders yet</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Create an order from the active craft plan to start tracking assignments.</MudText>
                    </section>
                }

                @foreach (var group in ActiveOrderGroups)
                {
                    <section class="trade-orders-group">
                        <button type="button"
                                class="trade-orders-group-title"
                                @onclick="@(() => ToggleStatusGroup(group.Status))"
                                aria-expanded="@(!IsStatusGroupCollapsed(group.Status))">
                            <span class="trade-orders-group-label">
                                <MudIcon Icon="@(IsStatusGroupCollapsed(group.Status) ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle1">@FormatStatus(group.Status)</MudText>
                            </span>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@group.Orders.Count.ToString("N0")</MudChip>
                        </button>
                        @if (!IsStatusGroupCollapsed(group.Status))
                        {
                            <WebDataTable TItem="TradeOrder"
                                          TColumnId="TradeOrderColumn"
                                          Items="group.Orders"
                                          Columns="Columns"
                                          GetRowKey="GetOrderKey"
                                          GetRowClass="GetOrderRowClass"
                                          RowClicked="SelectOrder"
                                          CssClass="trade-orders-table">
                                <EmptyContent>
                                    <span>No orders in @FormatStatus(group.Status).</span>
                                </EmptyContent>
                            </WebDataTable>
                        }
                    </section>
                }

                @if (ArchivedOrders.Count > 0)
                {
                    <section class="trade-orders-group">
                        <button type="button"
                                class="trade-orders-group-title"
                                @onclick="ToggleArchiveGroup"
                                aria-expanded="@(!_isArchiveCollapsed)">
                            <span class="trade-orders-group-label">
                                <MudIcon Icon="@(_isArchiveCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                                <MudText Typo="Typo.subtitle1">Archive</MudText>
                            </span>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@ArchivedOrders.Count.ToString("N0")</MudChip>
                        </button>
                        @if (!_isArchiveCollapsed)
                        {
                            <WebDataTable TItem="TradeOrder"
                                          TColumnId="TradeOrderColumn"
                                          Items="ArchivedOrders"
                                          Columns="Columns"
                                          GetRowKey="GetOrderKey"
                                          GetRowClass="GetOrderRowClass"
                                          RowClicked="SelectOrder"
                                          CssClass="trade-orders-table">
                                <EmptyContent>
                                    <span>No completed or canceled orders.</span>
                                </EmptyContent>
                            </WebDataTable>
                        }
                    </section>
                }
            </section>

            <aside class="trade-orders-detail">
                @if (_selectedOrder == null)
                {
                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Order Details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Select an order to inspect status, assignment, breakdown, and history.</MudText>
                    </section>
                }
                else
                {
                    <section class="trade-orders-panel">
                        <div class="trade-orders-panel-heading">
                            <MudText Typo="Typo.subtitle1">Order Details</MudText>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.OpenInNew"
                                       OnClick="OpenSelectedOrderCraftPlanAsync"
                                       Disabled="@(_isOpeningSelectedOrderCraftPlan || GetOrderRootItems(_selectedOrder).Count == 0)">
                                @(_isOpeningSelectedOrderCraftPlan ? "Opening..." : "Open Craft Plan")
                            </MudButton>
                        </div>
                        <MudTextField @bind-Value="_detailTitle"
                                      Label="Title"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Disabled="@IsSelectedOrderArchived" />
                        <MudSelect T="Guid?"
                                   @bind-Value="_detailCrafterId"
                                   Label="Assigned crafter"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   Disabled="@IsSelectedOrderArchived">
                            @foreach (var crafter in _crafters)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)crafter.Id)">@crafter.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                        @if (IsSelectedOrderArchived)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Archived as @FormatStatus(_selectedOrder.Status).</MudText>
                        }
                        else
                        {
                            <MudSelect T="TradeOrderStatus"
                                       @bind-Value="_detailStatus"
                                       Label="Change status"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                @foreach (var status in TradeOrderStatusWorkflow.ActiveStatuses.Where(status => status != TradeOrderStatus.Draft))
                                {
                                    <MudSelectItem Value="@status">@FormatStatus(status)</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        <MudTextField @bind-Value="_detailNotes"
                                      Label="Notes"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="3"
                                      Disabled="@IsSelectedOrderArchived" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="SaveSelectedOrderAsync"
                                   Disabled="@(IsSelectedOrderArchived || string.IsNullOrWhiteSpace(_detailTitle))">
                            Save Details
                        </MudButton>
                    </section>

                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Payment & Evidence</MudText>
                        <MudText Typo="Typo.subtitle2">Outputs</MudText>
                        <div class="trade-orders-breakdown-table">
                            <div class="trade-orders-breakdown-header">
                                <span>Item</span>
                                <span>Qty</span>
                                <span>HQ</span>
                            </div>
                            @foreach (var item in _selectedOrder.SourceSnapshot.RootItems)
                            {
                                <div class="trade-orders-breakdown-row">
                                    <span>@item.Name</span>
                                    <span>@TradeDisplayFormatter.FormatQuantity(item.Quantity)</span>
                                    <span>@FormatHq(item.MustBeHq)</span>
                                </div>
                            }
                        </div>
                        @if (_selectedOrder.SourceSnapshot.Materials.Count > 0)
                        {
                            var paymentSummary = GetSelectedOrderPaymentSummary();
                            <div class="trade-orders-payment-heading">
                                <MudText Typo="Typo.subtitle2">Materials</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">Responsibility affects reimbursement, not commission.</MudText>
                            </div>
                            <div class="trade-orders-material-table">
                                <div class="trade-orders-material-header">
                                    <span>Item</span>
                                    <span>Qty</span>
                                    <span>Unit</span>
                                    <span>Est. Cost</span>
                                    <span>Resp.</span>
                                </div>
                                @foreach (var material in paymentSummary.Materials)
                                {
                                    <div class="trade-orders-material-row" @key="GetPaymentMaterialKey(material)">
                                        <span class="trade-orders-material-cell">
                                            <strong>@material.Name</strong>
                                            @if (material.RequiresHq)
                                            {
                                                <span class="trade-orders-hq">HQ</span>
                                            }
                                            @if (!string.IsNullOrWhiteSpace(material.EvidenceSource))
                                            {
                                                <span title="@material.UnitCostExplanation">@material.EvidenceSource</span>
                                            }
                                            @if (material.Warnings.Count > 0)
                                            {
                                                <span class="trade-orders-material-warning">@material.Warnings[0]</span>
                                            }
                                        </span>
                                        <span>@TradeDisplayFormatter.FormatQuantity(material.Quantity)</span>
                                        <span>@FormatMaterialUnitCost(material)</span>
                                        <span>@FormatMaterialCost(material)</span>
                                        <MudSelect T="CommissionMaterialResponsibility"
                                                   Value="material.Responsibility"
                                                   ValueChanged="value => SetOrderMaterialResponsibilityAsync(material, value)"
                                                   Dense="true"
                                                   Margin="Margin.Dense"
                                                   Variant="Variant.Outlined"
                                                   Disabled="@IsSelectedOrderArchived"
                                                   aria-label="@($"{material.Name} material responsibility")">
                                            <MudSelectItem Value="@CommissionMaterialResponsibility.Crafter">Crafter</MudSelectItem>
                                            <MudSelectItem Value="@CommissionMaterialResponsibility.Provided">Provided</MudSelectItem>
                                        </MudSelect>
                                    </div>
                                }
                            </div>
                            @if (paymentSummary.Warnings.Count > 0)
                            {
                                <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                    <ul class="trade-orders-warning-list">
                                        @foreach (var warning in paymentSummary.Warnings)
                                        {
                                            <li>@warning</li>
                                        }
                                    </ul>
                                </MudAlert>
                            }
                            <div class="trade-orders-payment-summary">
                                <div class="trade-orders-payment-subtotals">
                                    <div>
                                        <span>Crafter procures</span>
                                        <strong>@FormatGil(paymentSummary.MaterialReimbursementTotal)</strong>
                                    </div>
                                    <div>
                                        <span>Provided by company</span>
                                        <strong>@FormatGil(paymentSummary.ProvidedMaterialTotal)</strong>
                                    </div>
                                    <div>
                                        <span>Commission (@paymentSummary.CommissionPercent.ToString("N0")%)</span>
                                        <strong>@FormatGil(paymentSummary.CommissionAmount)</strong>
                                    </div>
                                </div>
                                <div class="trade-orders-payment-total">
                                    <span>Payment amount</span>
                                    <strong>@FormatGil(paymentSummary.TotalPayment)</strong>
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   Disabled="@(paymentSummary.TotalPayment <= 0)"
                                                   OnClick='@(() => CopyGilAmountAsync(paymentSummary.TotalPayment, "Payment amount copied"))' />
                                </div>
                                <div class="trade-orders-payment-total">
                                    <span>Total estimated procurement</span>
                                    <strong>@FormatGil(paymentSummary.EstimatedProcurementTotal)</strong>
                                    <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   Disabled="@(paymentSummary.EstimatedProcurementTotal <= 0)"
                                                   OnClick='@(() => CopyGilAmountAsync(paymentSummary.EstimatedProcurementTotal, "Procurement estimate copied"))' />
                                </div>
                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Secondary"
                                           StartIcon="@Icons.Material.Filled.ContentCopy"
                                           OnClick="CopyOrderPaymentSummaryAsync">
                                    Copy Payment Summary
                                </MudButton>
                            </div>
                        }
                        else
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Build or refresh the order craft plan to populate material payment details.</MudText>
                        }
                    </section>

                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">History</MudText>
                        <div class="trade-orders-note-row">
                            <MudTextField @bind-Value="_manualNote"
                                          Label="Add Note"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="2" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       OnClick="AddManualNoteAsync"
                                       Disabled="@string.IsNullOrWhiteSpace(_manualNote)">
                                Add Note
                            </MudButton>
                        </div>
                        <ul class="trade-orders-history">
                            @foreach (var item in _selectedOrder.History.OrderByDescending(item => item.CreatedAtUtc))
                            {
                                <li><strong>@FormatHistoryKind(item.Kind)</strong> @item.Note</li>
                            }
                        </ul>
                    </section>

                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Close Order</MudText>
                        @if (TradeOrderStatusWorkflow.IsArchived(_selectedOrder.Status))
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       FullWidth="true"
                                       OnClick="ReopenSelectedOrderAsync">
                                Reopen Order
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       FullWidth="true"
                                       OnClick="@(() => OpenCloseOrderDialogAsync(TradeOrderStatus.Completed))">
                                Complete Order
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       FullWidth="true"
                                       OnClick="@(() => OpenCloseOrderDialogAsync(TradeOrderStatus.Canceled))">
                                Cancel Order
                            </MudButton>
                        }
                    </section>
                }
            </aside>
            </div>
        }
    }
</MudContainer>

@code {
    private TradeCompanyProfile? _companyProfile;
    private List<TradeCrafterProfile> _crafters = [];
    private List<TradeOrder> _orders = [];
    private List<TradePayrollWorkflowDraft> _payrollDrafts = [];
    private TradeOrder? _pendingImport;
    private TradeOrder? _selectedOrder;
    private bool _showNewOrderPanel;
    private string _newOrderTitle = string.Empty;
    private Guid? _newOrderCrafterId;
    private string _newRequestedOrderTitle = string.Empty;
    private bool _usingSuggestedRequestedOrderTitle;
    private Guid? _newRequestedOrderCrafterId;
    private string? _newRequestedOrderNotes;
    private string _requestedOrderSearchQuery = string.Empty;
    private bool _isSearchingRequestedOrderItems;
    private bool _isCreatingRequestedOrder;
    private bool _isOpeningSelectedOrderCraftPlan;
    private List<GarlandSearchResult> _requestedOrderSearchResults = [];
    private List<RequestedOrderOutputEditor> _requestedOrderOutputs = [];
    private string _detailTitle = string.Empty;
    private Guid? _detailCrafterId;
    private TradeOrderStatus _detailStatus;
    private string? _detailNotes;
    private string _manualNote = string.Empty;
    private string? _loadError;
    private Guid? _pendingNavigationOrderId;
    private bool _isArchiveCollapsed = true;
    private HashSet<TradeOrderStatus> _collapsedStatuses = [];

    private IReadOnlyList<WebTableColumn<TradeOrder, TradeOrderColumn>> Columns => CreateColumns();

    private bool CanCreateRequestedOrder =>
        _requestedOrderOutputs.Any(output => output.Quantity > 0);

    private IReadOnlyList<OrderStatusGroup> ActiveOrderGroups => TradeOrderStatusWorkflow.ActiveStatuses
        .Where(status => status != TradeOrderStatus.Draft)
        .Select(status => new OrderStatusGroup(status, GetOrdersForStatus(status)))
        .Where(group => group.Orders.Count > 0)
        .ToArray();

    private IReadOnlyList<TradeOrder> ArchivedOrders => _orders
        .Where(order => TradeOrderStatusWorkflow.IsArchived(order.Status))
        .OrderByDescending(order => order.CommissionedAtUtc)
        .ToArray();

    private IReadOnlyList<WebTableColumn<TradeOrder, TradeOrderColumn>> CreateColumns()
    {
        return
        [
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Title, "Order", order => order.Title, widthPx: 260),
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Commissioned, "Commissioned", order => order.CommissionedAtUtc.ToLocalTime().ToString("g"), widthPx: 160),
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Crafter, "Crafter", FormatAssignedCrafter, widthPx: 140),
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Quantity, "Qty", order => GetRootQuantity(order).ToString("N0"), widthPx: 80, alignEnd: true, headerCssClass: "is-align-end")
        ];
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.SecretDebugToolsEnabled)
        {
            return;
        }

        _pendingNavigationOrderId = TryGetOrderIdFromNavigation();
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loadError = null;
            _companyProfile = await TradeOperationsPersistence.GetOrCreateActiveCompanyProfileAsync();
            _crafters = (await TradeOperationsPersistence.LoadCraftersAsync(_companyProfile.Id)).ToList();
            _orders = (await TradeOperationsPersistence.LoadOrdersAsync(_companyProfile.Id)).ToList();
            _payrollDrafts = (await TradePayrollPersistence.LoadDraftsAsync(_companyProfile.Id)).ToList();
            SelectPendingNavigationOrder();
        }
        catch (Exception ex)
        {
            _companyProfile = null;
            _crafters = [];
            _orders = [];
            _payrollDrafts = [];
            _selectedOrder = null;
            _loadError = ex.Message;
            Snackbar.Add("Trade operations storage is unavailable.", Severity.Error);
        }
    }

    private void PrepareOrderImport()
    {
        if (_companyProfile == null)
        {
            return;
        }

        var result = TradeOrderDraftFactory.CreateFromCurrentPlan(new TradeOrderCreateRequest(
            AppState,
            _companyProfile.Id,
            _newOrderCrafterId,
            null,
            DateTime.UtcNow));
        if (!result.CanCreate || result.Order == null)
        {
            Snackbar.Add(result.UnavailableReason ?? "Could not create order from the active plan.", Severity.Warning);
            return;
        }

        _pendingImport = result.Order;
        _newOrderTitle = result.Order.Title;
    }

    private void ToggleNewOrderPanel()
    {
        _showNewOrderPanel = !_showNewOrderPanel;
        if (_showNewOrderPanel && string.IsNullOrWhiteSpace(_newRequestedOrderTitle))
        {
            RefreshRequestedOrderSuggestedTitle();
        }
    }

    private void ResetNewOrderDraft()
    {
        _newRequestedOrderTitle = string.Empty;
        _usingSuggestedRequestedOrderTitle = false;
        _newRequestedOrderCrafterId = null;
        _newRequestedOrderNotes = null;
        _requestedOrderSearchQuery = string.Empty;
        _requestedOrderSearchResults = [];
        _requestedOrderOutputs = [];
    }

    private async Task SearchRequestedOrderItemsAsync()
    {
        if (string.IsNullOrWhiteSpace(_requestedOrderSearchQuery) || _isSearchingRequestedOrderItems)
        {
            return;
        }

        _isSearchingRequestedOrderItems = true;
        _requestedOrderSearchResults = [];

        try
        {
            _requestedOrderSearchResults = (await GarlandService.SearchAsync(_requestedOrderSearchQuery))
                .Where(result => result.Id > 0 && !string.IsNullOrWhiteSpace(result.Object.Name))
                .Take(8)
                .ToList();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Item search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSearchingRequestedOrderItems = false;
        }
    }

