    private async Task OpenSelectedOrderCraftPlanAsync()
    {
        if (_selectedOrder == null || _isOpeningSelectedOrderCraftPlan)
        {
            return;
        }

        var projectItems = GetOrderRootItems(_selectedOrder)
            .Where(item => item.Quantity > 0)
            .Select(item => new ProjectItem
            {
                Id = item.ItemId,
                Name = item.Name,
                Quantity = item.Quantity,
                MustBeHq = item.MustBeHq
            })
            .ToArray();
        if (projectItems.Length == 0)
        {
            Snackbar.Add("This order does not have requested outputs to open.", Severity.Warning);
            return;
        }

        _isOpeningSelectedOrderCraftPlan = true;

        try
        {
            var result = await RecipePlannerCommandService.ImportProjectItemsAsync(
                new ImportProjectItemsRequest(
                    projectItems,
                    GetOrderDataCenter(_selectedOrder),
                    AppState.SelectedRegion,
                    AppState.DefaultMarketFetchScope));
            Snackbar.Add(
                result.Message,
                result.MessageLevel switch
                {
                    RecipePlannerCommandMessageLevel.Success => Severity.Success,
                    RecipePlannerCommandMessageLevel.Warning => Severity.Warning,
                    RecipePlannerCommandMessageLevel.Error => Severity.Error,
                    _ => Severity.Info
                });

            if (result.BuildResult.Built)
            {
                NavigationManager.NavigateTo("./");
            }
        }
        finally
        {
            _isOpeningSelectedOrderCraftPlan = false;
        }
    }

