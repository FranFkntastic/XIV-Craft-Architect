@page "/trade/orders"
@using System.Text
@using FFXIV_Craft_Architect.Core.Helpers
@inject AppState AppState
@inject GarlandService GarlandService
@inject TradeOrderDraftFactory TradeOrderDraftFactory
@inject TradeOrderPricingWorkflowService TradeOrderPricingWorkflow
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@inject TradePayrollPersistenceService TradePayrollPersistence
@inject WebPlanPersistenceService PlanPersistence
@inject AcquisitionDecisionService AcquisitionDecisionService
@inject AcquisitionEvaluationWorkflowService AcquisitionEvaluationWorkflow
@inject AcquisitionSourceChangeImpactService AcquisitionSourceChangeImpactService
@inject IRecipeLayerWorkflowService RecipeLayerWorkflowService
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject IJSRuntime JSRuntime
@inject NavigationManager NavigationManager

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="trade-orders-page">
    @if (!string.IsNullOrWhiteSpace(_loadError))
    {
        <MudAlert Severity="Severity.Error" Class="ma-4">
            <MudText Typo="Typo.subtitle2">Trade operations storage is unavailable.</MudText>
            <MudText Typo="Typo.body2">@_loadError</MudText>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       Class="mt-2"
                       OnClick="LoadAsync">
                Retry
            </MudButton>
        </MudAlert>
    }
    else
    {
        <div class="trade-orders-board">
                <aside class="trade-orders-rail">
                    <div class="trade-orders-rail-header">
                        <MudText Typo="Typo.subtitle1">Orders</MudText>
                        <MudIconButton Icon="@Icons.Material.Filled.Add"
                                       Color="Color.Primary"
                                       Size="Size.Small"
                                       OnClick="StartNewOrderWorkspace"
                                       aria-label="New order" />
                    </div>
                    <MudTextField @bind-Value="_orderSearchText"
                                  id="order-search"
                                  Placeholder="Search orders"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search" />
                    <div class="trade-orders-rail-scroll">
                        @if (ActiveOrderGroups.Count == 0 && ArchivedOrders.Count == 0)
                        {
                            <div class="trade-orders-rail-empty">No orders yet.</div>
                        }
                        else if (FilteredActiveOrderGroups.Count == 0 && FilteredArchivedOrders.Count == 0)
                        {
                            <div class="trade-orders-rail-empty">No matching orders.</div>
                        }
                        @foreach (var group in FilteredActiveOrderGroups)
                        {
                            <section class="trade-orders-rail-group">
                                <button type="button"
                                        class="trade-orders-rail-group-title"
                                        @onclick="@(() => ToggleStatusGroup(group.Status))"
                                        aria-expanded="@(!IsStatusGroupCollapsed(group.Status))">
                                    <span>
                                        <MudIcon Icon="@(IsStatusGroupCollapsed(group.Status) ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                                        @FormatStatus(group.Status)
                                    </span>
                                    <span class="trade-orders-count-chip">@group.Orders.Count.ToString("N0")</span>
                                </button>
                                @if (!IsStatusGroupCollapsed(group.Status))
                                {
                                    <div class="trade-orders-rail-list">
                                        @foreach (var order in group.Orders)
                                        {
                                            <button type="button"
                                                    class="@GetRailOrderClass(order)"
                                                    @onclick="() => SelectOrder(order)">
                                                <span class="trade-orders-rail-title">@order.Title</span>
                                                <span class="trade-orders-rail-meta">@FormatOrderRailMeta(order)</span>
                                                <span class="trade-orders-status-chip">@FormatRailStatusChip(order)</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </section>
                        }
                        @if (FilteredArchivedOrders.Count > 0)
                        {
                            <section class="trade-orders-rail-group">
                                <button type="button"
                                        class="trade-orders-rail-group-title"
                                        @onclick="ToggleArchiveGroup"
                                        aria-expanded="@(!_isArchiveCollapsed)">
                                    <span>
                                        <MudIcon Icon="@(_isArchiveCollapsed ? Icons.Material.Filled.ChevronRight : Icons.Material.Filled.ExpandMore)" Size="Size.Small" />
                                        Archive
                                    </span>
                                    <span class="trade-orders-count-chip">@FilteredArchivedOrders.Count.ToString("N0")</span>
                                </button>
                                @if (!_isArchiveCollapsed)
                                {
                                    <div class="trade-orders-rail-list">
                                        @foreach (var order in FilteredArchivedOrders)
                                        {
                                            <button type="button"
                                                    class="@GetRailOrderClass(order)"
                                                    @onclick="() => SelectOrder(order)">
                                                <span class="trade-orders-rail-title">@order.Title</span>
                                                <span class="trade-orders-rail-meta">@FormatOrderRailMeta(order)</span>
                                                <span class="trade-orders-status-chip">@FormatRailStatusChip(order)</span>
                                            </button>
                                        }
                                    </div>
                                }
                            </section>
                        }
                    </div>
                </aside>

                <main class="trade-orders-workspace">
                    @if (_pendingImport != null)
                    {
                        <section class="trade-orders-workspace-card is-import">
                            <div class="trade-orders-workspace-header">
                                <div>
                                    <MudText Typo="Typo.overline">Active Craft Plan</MudText>
                                    <MudText Typo="Typo.h6">Create Order</MudText>
                                </div>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="CreatePendingOrderAsync"
                                           Disabled="@string.IsNullOrWhiteSpace(_newOrderTitle)">
                                    Save Order
                                </MudButton>
                            </div>
                            <div class="trade-orders-editor-grid">
                                <MudTextField @bind-Value="_newOrderTitle"
                                              id="imported-order-title"
                                              Label="Order title"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate="true" />
                                <CompactSelectField Id="imported-order-crafter"
                                                    Label="Assigned crafter"
                                                    @bind-Value="NewOrderCrafterValue"
                                                    Options="GetCrafterOptions()" />
                            </div>
                            <section class="trade-orders-work-section">
                                <MudText Typo="Typo.subtitle2">Requested Outputs</MudText>
                                <div class="trade-orders-breakdown-table">
                                    <div class="trade-orders-breakdown-header">
                                        <span>Item</span>
                                        <span>Qty</span>
                                        <span>HQ</span>
                                    </div>
                                    @foreach (var item in GetOrderRootItems(_pendingImport))
                                    {
                                        <div class="trade-orders-breakdown-row">
                                            <span>@item.Name</span>
                                            <span>@TradeDisplayFormatter.FormatQuantity(item.Quantity)</span>
                                            <span>@FormatHq(item.MustBeHq)</span>
                                        </div>
                                    }
                                </div>
                            </section>
                        </section>
                    }
                    else if (_showNewOrderPanel)
                    {
                        <section class="trade-orders-workspace-card is-new">
                            <div class="trade-orders-workspace-header">
                                <div>
                                    <MudText Typo="Typo.overline">New Order</MudText>
                                    <MudText Typo="Typo.h6">Requested Outputs</MudText>
                                </div>
                                <div class="trade-orders-workspace-actions">
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               StartIcon="@Icons.Material.Filled.Close"
                                               OnClick="CloseNewOrderWorkspace">
                                        Cancel
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               StartIcon="@Icons.Material.Filled.Clear"
                                               OnClick="ResetNewOrderDraft">
                                        Clear
                                    </MudButton>
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               StartIcon="@Icons.Material.Filled.Assignment"
                                               OnClick="PrepareOrderImport">
                                        Create From Active Plan
                                    </MudButton>
                                    <MudButton Variant="Variant.Filled"
                                               Color="Color.Primary"
                                               OnClick="CreateRequestedOrderAsync"
                                               Disabled="@(!CanCreateRequestedOrder || _isCreatingRequestedOrder)">
                                        @(_isCreatingRequestedOrder ? "Creating..." : "Save Order")
                                    </MudButton>
                                </div>
                            </div>
                            <div class="trade-orders-editor-grid">
                                <MudTextField T="string"
                                              id="new-order-title"
                                              Value="@_newRequestedOrderTitle"
                                              ValueChanged="value => OnRequestedOrderTitleChanged(value)"
                                              Label="Order title"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate="true" />
                                <CompactSelectField Id="new-order-crafter"
                                                    Label="Assigned crafter"
                                                    @bind-Value="NewRequestedOrderCrafterValue"
                                                    Options="GetCrafterOptions()" />
                                <MudTextField @bind-Value="_newRequestedOrderNotes"
                                              id="new-order-notes"
                                              Label="Notes"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Lines="1" />
                            </div>
                            <section class="trade-orders-work-section">
                                <div class="trade-orders-search-row">
                                    <MudTextField @bind-Value="_requestedOrderSearchQuery"
                                                  id="new-order-output-search"
                                                  Label="Add output item"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Immediate="true"
                                                  OnKeyUp="OnRequestedOrderSearchKeyUp" />
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               OnClick="SearchRequestedOrderItemsAsync"
                                               Disabled="@(_isSearchingRequestedOrderItems || string.IsNullOrWhiteSpace(_requestedOrderSearchQuery))">
                                        @(_isSearchingRequestedOrderItems ? "Searching..." : "Search")
                                    </MudButton>
                                </div>
                                @if (_requestedOrderSearchResults.Count > 0)
                                {
                                    <div class="trade-orders-search-results">
                                        @foreach (var result in _requestedOrderSearchResults)
                                        {
                                            <button type="button"
                                                    class="trade-orders-search-result"
                                                    @onclick="() => AddRequestedOrderOutput(result)">
                                                <span>@result.Object.Name</span>
                                                <span>ID @result.Id</span>
                                            </button>
                                        }
                                    </div>
                                }
                                <div class="trade-orders-output-table">
                                    <div class="trade-orders-output-header">
                                        <span>Item</span>
                                        <span>Qty</span>
                                        <span>HQ</span>
                                        <span></span>
                                    </div>
                                    @if (_requestedOrderOutputs.Count == 0)
                                    {
                                        <div class="trade-orders-output-empty">Add at least one requested output.</div>
                                    }
                                    else
                                    {
                                        @foreach (var output in _requestedOrderOutputs)
                                        {
                                            <div class="trade-orders-output-row">
                                                <span>@output.Name</span>
                                                <MudNumericField T="int"
                                                                 id="@($"new-order-output-quantity-{output.ItemId}")"
                                                                 Value="@output.Quantity"
                                                                 ValueChanged="quantity => UpdateRequestedOrderOutputQuantity(output, quantity)"
                                                                 Min="1"
                                                                 Max="9999"
                                                                 HideSpinButtons="true"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense" />
                                                <MudCheckBox T="bool"
                                                             Value="@output.MustBeHq"
                                                             ValueChanged="mustBeHq => UpdateRequestedOrderOutputHq(output, mustBeHq)"
                                                             Color="Color.Primary" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Color="Color.Error"
                                                               Size="Size.Small"
                                                               OnClick="() => RemoveRequestedOrderOutput(output)" />
                                            </div>
                                        }
                                    }
                                </div>
                            </section>
                        </section>
                    }
                    else if (_selectedOrder != null)
                    {
                        <section class="trade-orders-workspace-card">
                            <div class="trade-orders-workspace-header">
                                <div>
                                    <MudText Typo="Typo.overline">Selected Order</MudText>
                                    <MudText Typo="Typo.h6">@_selectedOrder.Title</MudText>
                                </div>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           OnClick="SaveSelectedOrderAsync"
                                           Disabled="@(IsSelectedOrderArchived || string.IsNullOrWhiteSpace(_detailTitle))">
                                    Save Order
                                </MudButton>
                            </div>
                            <div class="trade-orders-editor-grid">
                                <MudTextField @bind-Value="_detailTitle"
                                              id="selected-order-title"
                                              Label="Order title"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Immediate="true"
                                              Disabled="@IsSelectedOrderArchived" />
                                <CompactSelectField Id="selected-order-crafter"
                                                    Label="Assigned crafter"
                                                    @bind-Value="DetailCrafterValue"
                                                    Options="GetCrafterOptions()"
                                                    Disabled="@IsSelectedOrderArchived" />
                                <MudTextField @bind-Value="_detailNotes"
                                              id="selected-order-notes"
                                              Label="Notes"
                                              Variant="Variant.Outlined"
                                              Margin="Margin.Dense"
                                              Lines="1"
                                              Disabled="@IsSelectedOrderArchived" />
                            </div>
                            <section class="trade-orders-work-section">
                                <div class="trade-orders-section-heading">
                                    <MudText Typo="Typo.subtitle2">Requested Outputs</MudText>
                                    @if (CanEditSelectedOrderOutputs)
                                    {
                                        <div class="trade-orders-section-actions">
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Secondary"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.Undo"
                                                       OnClick="ResetSelectedOrderOutputEdits"
                                                       Disabled="@(!HasSelectedOrderOutputChanges || _isSavingSelectedOrderOutputs)">
                                                Reset
                                            </MudButton>
                                            <MudButton Variant="Variant.Filled"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.Save"
                                                       OnClick="SaveSelectedOrderOutputsAsync"
                                                       Disabled="@(!CanSaveSelectedOrderOutputs)">
                                                @(_isSavingSelectedOrderOutputs ? "Saving..." : "Save Outputs")
                                            </MudButton>
                                        </div>
                                    }
                                </div>
                                @if (CanEditSelectedOrderOutputs)
                                {
                                    <div class="trade-orders-search-row">
                                        <MudTextField @bind-Value="_selectedOrderOutputSearchQuery"
                                                      id="selected-order-output-search"
                                                      Label="Add output item"
                                                      Variant="Variant.Outlined"
                                                      Margin="Margin.Dense"
                                                      Immediate="true"
                                                      OnKeyUp="OnSelectedOrderOutputSearchKeyUp" />
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   OnClick="SearchSelectedOrderOutputItemsAsync"
                                                   Disabled="@(_isSearchingSelectedOrderOutputs || string.IsNullOrWhiteSpace(_selectedOrderOutputSearchQuery))">
                                            @(_isSearchingSelectedOrderOutputs ? "Searching..." : "Search")
                                        </MudButton>
                                    </div>
                                    @if (_selectedOrderOutputSearchResults.Count > 0)
                                    {
                                        <div class="trade-orders-search-results">
                                            @foreach (var result in _selectedOrderOutputSearchResults)
                                            {
                                                <button type="button"
                                                        class="trade-orders-search-result"
                                                        @onclick="() => AddSelectedOrderOutput(result)">
                                                    <span>@result.Object.Name</span>
                                                    <span>ID @result.Id</span>
                                                </button>
                                            }
                                        </div>
                                    }
                                    <div class="trade-orders-output-table">
                                        <div class="trade-orders-output-header">
                                            <span>Item</span>
                                            <span>Qty</span>
                                            <span>HQ</span>
                                            <span></span>
                                        </div>
                                        @foreach (var output in _selectedOrderOutputEditors)
                                        {
                                            <div class="trade-orders-output-row">
                                                <span>@output.Name</span>
                                                <MudNumericField T="int"
                                                                 id="@($"selected-order-output-quantity-{output.ItemId}-{output.MustBeHq}")"
                                                                 Value="@output.Quantity"
                                                                 ValueChanged="quantity => UpdateSelectedOrderOutputQuantity(output, quantity)"
                                                                 Min="1"
                                                                 Max="9999"
                                                                 HideSpinButtons="true"
                                                                 Variant="Variant.Outlined"
                                                                 Margin="Margin.Dense" />
                                                <MudCheckBox T="bool"
                                                             Value="@output.MustBeHq"
                                                             ValueChanged="mustBeHq => UpdateSelectedOrderOutputHq(output, mustBeHq)"
                                                             Color="Color.Primary" />
                                                <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                                               Color="Color.Error"
                                                               Size="Size.Small"
                                                               OnClick="() => RemoveSelectedOrderOutput(output)" />
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <div class="trade-orders-breakdown-table">
                                        <div class="trade-orders-breakdown-header">
                                            <span>Item</span>
                                            <span>Qty</span>
                                            <span>HQ</span>
                                        </div>
                                        @foreach (var item in GetOrderRootItems(_selectedOrder))
                                        {
                                            <div class="trade-orders-breakdown-row">
                                                <span>@item.Name</span>
                                                <span>@TradeDisplayFormatter.FormatQuantity(item.Quantity)</span>
                                                <span>@FormatHq(item.MustBeHq)</span>
                                            </div>
                                        }
                                    </div>
                                }
                            </section>
                            <section class="trade-orders-work-section">
                                <div class="trade-orders-section-heading">
                                    <MudText Typo="Typo.subtitle2">Craft Architect Pipeline</MudText>
                                </div>
                                <div class="trade-orders-pipeline">
                                    <div class="@GetPipelineStageClass(GetOrderRootItems(_selectedOrder).Count > 0)">
                                        <span>1 - Order request</span>
                                        <strong>@(GetOrderRootItems(_selectedOrder).Count > 0 ? "Outputs captured" : "Add requested outputs")</strong>
                                    </div>
                                    <div class="@GetPipelineStageClass(HasLinkedCraftPlan(_selectedOrder), !HasLinkedCraftPlan(_selectedOrder))">
                                        <span>2 - Craft plan</span>
                                        <strong>@(HasLinkedCraftPlan(_selectedOrder) ? "Linked plan saved" : "Craft plan missing")</strong>
                                    </div>
                                    <div class="@GetPipelineStageClass(HasProcurementEvidence(_selectedOrder), HasMaterialBreakdown(_selectedOrder) && !HasProcurementEvidence(_selectedOrder))">
                                        <span>3 - Procurement evidence</span>
                                        <strong>@(HasProcurementEvidence(_selectedOrder) ? "Priced evidence available" : "Pricing evidence missing")</strong>
                                    </div>
                                    <div class="@GetPipelineStageClass(IsPaymentReady(_selectedOrder))">
                                        <span>4 - Settlement</span>
                                        <strong>@GetSettlementStageLabel(_selectedOrder)</strong>
                                    </div>
                                </div>
                            </section>
                            <section class="trade-orders-work-section">
                                <div class="trade-orders-section-heading">
                                    <MudText Typo="Typo.subtitle2">Linked Craft Plan</MudText>
                                    <div class="trade-orders-section-actions">
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.Build"
                                                   OnClick="CreateOrReplaceSelectedOrderCraftPlanAsync"
                                                   Disabled="@(_isSavingSelectedOrderCraftPlan || _isRepricingSelectedOrder || IsSelectedOrderArchived || GetOrderRootItems(_selectedOrder).Count == 0)">
                                            @GetCraftPlanBuildButtonText(_selectedOrder)
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.PriceCheck"
                                                   OnClick="RepriceSelectedOrderAsync"
                                                   Disabled="@(_isRepricingSelectedOrder || _isSavingSelectedOrderCraftPlan || IsSelectedOrderArchived || !HasLinkedCraftPlan(_selectedOrder))">
                                            @(_isRepricingSelectedOrder ? "Repricing..." : "Reprice Order")
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   StartIcon="@Icons.Material.Filled.OpenInNew"
                                                   OnClick="OpenSelectedOrderCraftPlanAsync"
                                                   Disabled="@(_isOpeningSelectedOrderCraftPlan || !HasLinkedCraftPlan(_selectedOrder))">
                                            @(_isOpeningSelectedOrderCraftPlan ? "Opening..." : "Open Craft Plan")
                                        </MudButton>
                                    </div>
                                </div>
                                <div class="trade-orders-linked-plan-grid">
                                    <div>
                                        <span>Plan</span>
                                        <strong>@GetLinkedCraftPlanName(_selectedOrder)</strong>
                                    </div>
                                    <div>
                                        <span>Procurement evidence</span>
                                        <strong>@GetProcurementEvidenceLabel(_selectedOrder)</strong>
                                    </div>
                                    <div>
                                        <span>Last saved</span>
                                        <strong>@FormatLinkedCraftPlanDate(_selectedOrder)</strong>
                                    </div>
                                </div>
                            </section>
                        </section>
                    }
                    else
                    {
                        <section class="trade-orders-workspace-card">
                            <div class="trade-orders-workspace-empty">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment"
                                         Size="Size.Large"
                                         Class="trade-orders-workspace-empty-icon" />
                                <MudText Typo="Typo.h6">No Order Selected</MudText>
                                <MudText Typo="Typo.body2" Color="Color.Secondary">
                                    Select an order from the list, or start a new one.
                                </MudText>
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           StartIcon="@Icons.Material.Filled.Add"
                                           OnClick="StartNewOrderWorkspace">
                                    New Order
                                </MudButton>
                            </div>
                        </section>
                    }
                </main>

                <aside class="trade-orders-ops">
                    @if (_selectedOrder == null)
                    {
                        <section class="trade-orders-panel">
                            <MudText Typo="Typo.subtitle1">Operations</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Select an order to view payment, procurement, and history.</MudText>
                        </section>
                    }
                    else
                    {
                        var paymentSummary = GetSelectedOrderPaymentSummary();
                        <div class="trade-orders-ops-header">
                            <div>
                                <MudText Typo="Typo.subtitle1">@_selectedOrder.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">@GetLatestHistoryCue(_selectedOrder)</MudText>
                            </div>
                        </div>
                        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="trade-orders-tab-panel" @bind-ActivePanelIndex="_activeOpsTab">
                            <MudTabPanel Text="Payment">
                                <div class="trade-orders-payment-metrics">
                                    <div class="trade-orders-payment-metric">
                                        <span>Payment amount</span>
                                        <strong>@FormatGil(paymentSummary.TotalPayment)</strong>
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="@(paymentSummary.TotalPayment <= 0)"
                                                       OnClick='@(() => CopyGilAmountAsync(paymentSummary.TotalPayment, "Payment amount copied"))'
                                                       aria-label="Copy payment amount" />
                                    </div>
                                    <div class="trade-orders-payment-metric">
                                        <span>Total estimated procurement</span>
                                        <strong>@FormatGil(paymentSummary.EstimatedProcurementTotal)</strong>
                                        <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                                       Color="Color.Primary"
                                                       Size="Size.Small"
                                                       Disabled="@(paymentSummary.EstimatedProcurementTotal <= 0)"
                                                       OnClick='@(() => CopyGilAmountAsync(paymentSummary.EstimatedProcurementTotal, "Procurement estimate copied"))'
                                                       aria-label="Copy procurement amount" />
                                    </div>
                                </div>
                                @if (paymentSummary.Materials.Count > 0 && paymentSummary.EstimatedProcurementTotal <= 0)
                                {
                                    <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">Material lines are captured, but pricing evidence is missing. Run market analysis from the linked craft plan before using payment totals.</MudAlert>
                                }
                                <div class="trade-orders-payment-policy">
                                    <div>
                                        <span>Payment policy</span>
                                        <strong>@GetSelectedOrderPaymentPolicyLabel()</strong>
                                    </div>
                                    <div class="trade-orders-payment-policy-controls">
                                        <MudSwitch T="bool"
                                                   Value="@SelectedOrderUsesCompanyPaymentPolicy"
                                                   ValueChanged="SetSelectedOrderUseCompanyPolicyAsync"
                                                   Color="Color.Primary"
                                                   Dense="true"
                                                   Label="Use company default" />
                                        <CompactSelectField Id="selected-order-payment-contract"
                                                            Label="Payment contract"
                                                            Value="@SelectedOrderPaymentContract.ToString()"
                                                            ValueChanged="SetSelectedOrderPaymentContractValueAsync"
                                                            Options="PaymentContractOptions"
                                                            Disabled="@SelectedOrderUsesCompanyPaymentPolicy" />
                                    </div>
                                </div>
                                @if (paymentSummary.Materials.Count > 0)
                                {
                                    <div class="trade-orders-payment-table">
                                        <div class="trade-orders-payment-table-title">
                                            <span>Payment Breakdown</span>
                                            <span>Current route</span>
                                        </div>
                                        <div class="trade-orders-payment-breakdown-header">
                                            <span>Line</span>
                                            <span>Basis</span>
                                            <span>Amount</span>
                                        </div>
                                        <div class="trade-orders-payment-breakdown-row">
                                            <span>Crafter-procured materials</span>
                                            <span>Payable materials</span>
                                            <strong>@FormatGil(paymentSummary.MaterialReimbursementTotal)</strong>
                                        </div>
                                        <div class="trade-orders-payment-breakdown-row">
                                            <span>Company-provided materials</span>
                                            <span>Estimate only</span>
                                            <strong>@FormatGilAllowZero(paymentSummary.ProvidedMaterialTotal)</strong>
                                        </div>
                                        <div class="trade-orders-payment-breakdown-row">
                                            <span>@FormatActiveMaterialAdjustmentLabel(paymentSummary.Active.Contract)</span>
                                            <span>@paymentSummary.CommissionPercent.ToString("N0")% of procurement</span>
                                            <strong>@FormatGil(paymentSummary.CommissionAmount)</strong>
                                        </div>
                                        @if (paymentSummary.Active.Contract == TradePaymentContractMode.LaborStandard)
                                        {
                                            <div class="trade-orders-payment-breakdown-row">
                                                <span>Craft labor</span>
                                                <span>@FormatCraftLaborBasis(paymentSummary.LaborStandard)</span>
                                                <strong>@FormatGilAllowZero(paymentSummary.LaborStandard.CraftLaborTotal)</strong>
                                            </div>
                                        }
                                        <div class="trade-orders-payment-breakdown-row is-total">
                                            <span>Total payment</span>
                                            <span>@FormatPaymentContract(paymentSummary.Active.Contract)</span>
                                            <strong>@FormatGil(paymentSummary.TotalPayment)</strong>
                                        </div>
                                    </div>
                                    <div class="trade-orders-payment-table">
                                        <div class="trade-orders-payment-table-title">
                                            <span>Policy Comparison</span>
                                            <span>Same current route</span>
                                        </div>
                                        <div class="trade-orders-policy-comparison-header">
                                            <span>Contract</span>
                                            <span>Includes</span>
                                            <span>Payment</span>
                                            <span>Delta</span>
                                        </div>
                                        <div class="trade-orders-policy-comparison-row">
                                            <span>Legacy commission</span>
                                            <span>Materials + @paymentSummary.Legacy.CommissionPercent.ToString("N0")% legacy commission</span>
                                            <strong>@FormatPaymentBreakdown(paymentSummary.Legacy)</strong>
                                            <span>Baseline</span>
                                        </div>
                                        <div class="trade-orders-policy-comparison-row">
                                            <span>Labor standard</span>
                                            <span>Materials + @paymentSummary.LaborStandard.CommissionPercent.ToString("N0")% bonus + labor</span>
                                            <strong>@FormatPaymentBreakdown(paymentSummary.LaborStandard)</strong>
                                            <span>@FormatPaymentDifference(paymentSummary.LaborStandard, paymentSummary.Legacy)</span>
                                        </div>
                                    </div>
                                    <div class="trade-orders-payment-heading">
                                        <MudText Typo="Typo.subtitle2">Material Responsibility</MudText>
                                        <div class="trade-orders-payment-copy-actions">
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Secondary"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.ReceiptLong"
                                                       OnClick="CopyOrderPaymentReceiptAsync">
                                                Copy Receipt
                                            </MudButton>
                                            <MudButton Variant="Variant.Outlined"
                                                       Color="Color.Secondary"
                                                       Size="Size.Small"
                                                       StartIcon="@Icons.Material.Filled.ContentCopy"
                                                       OnClick="CopyOrderPaymentSummaryAsync">
                                                Copy Summary
                                            </MudButton>
                                        </div>
                                    </div>
                                    <div class="trade-orders-material-table is-compact">
                                        <div class="trade-orders-material-header">
                                            <span>Item</span>
                                            <span>Qty</span>
                                            <span>Unit cost</span>
                                            <span>Total cost</span>
                                            <span>Resp.</span>
                                            <span>Payment impact</span>
                                        </div>
                                        @foreach (var material in paymentSummary.Materials)
                                        {
                                            <div class="trade-orders-material-row" @key="GetPaymentMaterialKey(material)">
                                                <span class="trade-orders-material-cell">
                                                    <strong>@material.Name</strong>
                                                    @if (material.RequiresHq)
                                                    {
                                                        <span class="trade-orders-hq">HQ</span>
                                                    }
                                                </span>
                                                <span>@TradeDisplayFormatter.FormatQuantity(material.Quantity)</span>
                                                <span>@FormatMaterialUnitCost(material)</span>
                                                <span>@FormatMaterialCost(material)</span>
                                                <CompactSelectField Id="@($"order-material-responsibility-{material.ItemId}")"
                                                                    Label="@($"{material.Name} responsibility")"
                                                                    Value="@material.Responsibility.ToString()"
                                                                    ValueChanged="value => SetOrderMaterialResponsibilityValueAsync(material, value)"
                                                                    Options="MaterialResponsibilityOptions"
                                                                    Disabled="@IsSelectedOrderArchived" />
                                                <span>@FormatMaterialPaymentImpact(material)</span>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">Create a linked craft plan, then run market analysis to populate payment evidence.</MudAlert>
                                }
                                <section class="trade-orders-status-panel">
                                    <MudText Typo="Typo.subtitle2">Status</MudText>
                                    @if (IsSelectedOrderArchived)
                                    {
                                        <MudText Typo="Typo.body2" Color="Color.Secondary">Archived as @FormatStatus(_selectedOrder.Status).</MudText>
                                    }
                                    else
                                    {
                                        <CompactSelectField Id="selected-order-status"
                                                            Label="Order status"
                                                            @bind-Value="DetailStatusValue"
                                                            Options="GetActiveStatusOptions()" />
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Primary"
                                                   FullWidth="true"
                                                   OnClick="SaveSelectedOrderAsync"
                                                   Disabled="@(string.IsNullOrWhiteSpace(_detailTitle))">
                                            Save Status
                                        </MudButton>
                                    }
                                </section>
                                <section class="trade-orders-close-panel">
                                    <MudText Typo="Typo.subtitle2">Close Order</MudText>
                                    @if (TradeOrderStatusWorkflow.IsArchived(_selectedOrder.Status))
                                    {
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Secondary"
                                                   FullWidth="true"
                                                   OnClick="ReopenSelectedOrderAsync">
                                            Reopen Order
                                        </MudButton>
                                    }
                                    else
                                    {
                                        <MudButton Variant="Variant.Filled"
                                                   Color="Color.Success"
                                                   FullWidth="true"
                                                   OnClick="@(() => OpenCloseOrderDialogAsync(TradeOrderStatus.Completed))">
                                            Complete Order
                                        </MudButton>
                                        <MudButton Variant="Variant.Outlined"
                                                   Color="Color.Error"
                                                   FullWidth="true"
                                                   OnClick="@(() => OpenCloseOrderDialogAsync(TradeOrderStatus.Canceled))">
                                            Cancel Order
                                        </MudButton>
                                    }
                                </section>
                            </MudTabPanel>
                            <MudTabPanel Text="Procurement">
                                <MudText Typo="Typo.subtitle2">Procurement Evidence</MudText>
                                @{
                                    var procurementRows = GetSelectedOrderProcurementRows();
                                }
                                @if (procurementRows.Count == 0)
                                {
                                    <MudAlert Severity="Severity.Info" Dense="true">No material evidence has been captured for this order yet.</MudAlert>
                                }
                                else
                                {
                                    <WebGridTable TItem="TradeOrderProcurementRow"
                                                  TColumnId="TradeOrderProcurementColumn"
                                                  CssClass="trade-orders-procurement-grid"
                                                  Items="@GetOrderedProcurementRows(procurementRows)"
                                                  Columns="@GetProcurementColumns()"
                                                  GetRowKey="row => row.RowKey"
                                                  GetRowClass="GetProcurementRowClass"
                                                  SortState="@_procurementSortState"
                                                  SortChanged="OnProcurementSortChanged"
                                                  ColumnGapPx="4"
                                                  HorizontalPaddingPx="8" />
                                    @if (paymentSummary.Warnings.Count > 0)
                                    {
                                        <MudAlert Severity="Severity.Warning" Dense="true" Class="mt-2">
                                            <ul class="trade-orders-warning-list">
                                                @foreach (var warning in paymentSummary.Warnings)
                                                {
                                                    <li>@warning</li>
                                                }
                                            </ul>
                                        </MudAlert>
                                    }
                                }
                            </MudTabPanel>
                            <MudTabPanel Text="History">
                                <div class="trade-orders-note-row">
                                    <MudTextField @bind-Value="_manualNote"
                                                  id="selected-order-history-note"
                                                  Label="Add Note"
                                                  Variant="Variant.Outlined"
                                                  Margin="Margin.Dense"
                                                  Lines="2" />
                                    <MudButton Variant="Variant.Outlined"
                                               Color="Color.Secondary"
                                               OnClick="AddManualNoteAsync"
                                               Disabled="@string.IsNullOrWhiteSpace(_manualNote)">
                                        Add Note
                                    </MudButton>
                                </div>
                                <ul class="trade-orders-history">
                                    @foreach (var item in _selectedOrder.History.OrderByDescending(item => item.CreatedAtUtc))
                                    {
                                        <li><strong>@FormatHistoryKind(item.Kind)</strong> @item.Note</li>
                                    }
                                </ul>
                            </MudTabPanel>
                        </MudTabs>
                    }
                </aside>
        </div>
    }
</MudContainer>

@code {
    private RenderFragment<TradeOrderProcurementRow> RenderProcurementSourceCell => row => @<div class="trade-orders-source-cell">
        <div class="trade-orders-source-primary">
            <button type="button"
                    class="trade-orders-link-button"
                    @onclick="@(() => OpenAcquisitionEvaluationForProcurementRowAsync(row))">
                @row.SourceLabel
            </button>
            @if (CanEditProcurementSource(row))
            {
                <MudMenu Icon="@Icons.Material.Filled.KeyboardArrowDown"
                         Dense="true"
                         Size="Size.Small"
                         AnchorOrigin="Origin.BottomRight"
                         TransformOrigin="Origin.TopRight"
                         Class="trade-orders-source-menu">
                    @foreach (var source in GetProcurementSourceOptions())
                    {
                        <MudMenuItem OnClick="@(() => ChangeProcurementRowSourceAsync(row, source))">
                            @RecipePlanDisplayHelpers.GetSourceDisplayName(source)
                        </MudMenuItem>
                    }
                </MudMenu>
            }
            else if (row.IsLiveAcquisitionRow)
            {
                <span class="trade-orders-source-locked">locked</span>
            }
        </div>
        @if (!string.IsNullOrWhiteSpace(row.EvidenceSource) &&
            !string.Equals(row.EvidenceSource, row.SourceLabel, StringComparison.OrdinalIgnoreCase))
        {
            <span class="trade-orders-source-evidence" title="@row.UnitCostExplanation">@row.EvidenceSource</span>
        }
        @if (!string.IsNullOrWhiteSpace(row.WarningSummary))
        {
            <span class="trade-orders-source-warning">@row.WarningSummary</span>
        }
    </div>;
}
