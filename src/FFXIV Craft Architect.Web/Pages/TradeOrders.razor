            CraftPlanName = order.CraftPlanName,
            CraftPlanSavedAtUtc = order.CraftPlanSavedAtUtc,
            CraftPlanLinkKind = order.CraftPlanLinkKind,
            RemoteId = order.RemoteId,
            SyncState = order.SyncState
        };
