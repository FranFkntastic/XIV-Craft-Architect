    private static void AddHistoryIfStatusChanged(TradeOrder order, TradeOrderStatus previousStatus, TradeOrderStatus newStatus, string note)
    {
        if (previousStatus == newStatus)
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderStatusWorkflow.IsArchived(newStatus) ? TradeOrderHistoryEventKind.Closed : TradeOrderHistoryEventKind.StatusChanged,
            Note = note,
            FromStatus = previousStatus,
            ToStatus = newStatus,
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

    private static void AddReopenedHistory(TradeOrder order, TradeOrderStatus previousStatus, TradeOrderStatus newStatus)
    {
        if (previousStatus == newStatus)
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.Reopened,
            Note = "Reopened order.",
            FromStatus = previousStatus,
            ToStatus = newStatus,
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

    private static void AddPayrollLinkedHistory(TradeOrder order)
    {
        if (order.History.Any(history => history.Kind == TradeOrderHistoryEventKind.PayrollLinked))
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.PayrollLinked,
            Note = "Payment workflow draft linked.",
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

    private void AddHistoryIfAssignmentChanged(TradeOrder order, Guid? previousCrafterId, Guid? newCrafterId)
    {
        if (previousCrafterId == newCrafterId)
        {
            return;
        }

        var crafterName = newCrafterId.HasValue
            ? _crafters.FirstOrDefault(crafter => crafter.Id == newCrafterId.Value)?.DisplayName ?? "unknown crafter"
            : "unassigned";
        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.Assigned,
            Note = newCrafterId.HasValue ? $"Assigned to {crafterName}." : "Assignment cleared.",
            CrafterId = newCrafterId,
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

