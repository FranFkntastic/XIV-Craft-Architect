@page "/trade/orders"
@using FFXIV_Craft_Architect.Web.Shared.TablePrimitives
@inject AppState AppState
@inject TradeOrderDraftFactory TradeOrderDraftFactory
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@inject TradePayrollPersistenceService TradePayrollPersistence
@inject ISnackbar Snackbar
@inject IDialogService DialogService

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="trade-orders-page">
    @if (!AppState.SecretDebugToolsEnabled)
    {
        <MudAlert Severity="Severity.Info" Class="ma-4">Returning to Craft Architect...</MudAlert>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_loadError))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">
                <MudText Typo="Typo.subtitle2">Trade operations storage is unavailable.</MudText>
                <MudText Typo="Typo.body2">@_loadError</MudText>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           Class="mt-2"
                           OnClick="LoadAsync">
                    Retry
                </MudButton>
            </MudAlert>
        }
        else
        {
            <div class="trade-orders-layout">
            <section class="trade-orders-main">
                <div class="trade-orders-header">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.Assignment"
                               OnClick="PrepareOrderImport">
                        Create Order from Active Craft Plan
                    </MudButton>
                </div>

                @if (_pendingImport != null)
                {
                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Suggested title</MudText>
                        <div class="trade-orders-import-grid">
                            <MudTextField @bind-Value="_newOrderTitle"
                                          Label="Order title"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />
                            <MudSelect T="Guid?"
                                       @bind-Value="_newOrderCrafterId"
                                       Label="Assigned crafter"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense"
                                       Clearable="true">
                                @foreach (var crafter in _crafters)
                                {
                                    <MudSelectItem T="Guid?" Value="@((Guid?)crafter.Id)">@crafter.DisplayName</MudSelectItem>
                                }
                            </MudSelect>
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Primary"
                                       OnClick="CreatePendingOrderAsync"
                                       Disabled="@string.IsNullOrWhiteSpace(_newOrderTitle)">
                                Confirm Order
                            </MudButton>
                        </div>
                    </section>
                }

                @if (ActiveOrderGroups.Count == 0 && ArchivedOrders.Count == 0)
                {
                    <section class="trade-orders-empty-state">
                        <MudText Typo="Typo.subtitle1">No orders yet</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Create an order from the active craft plan to start tracking assignments.</MudText>
                    </section>
                }

                @foreach (var group in ActiveOrderGroups)
                {
                    <section class="trade-orders-group">
                        <div class="trade-orders-group-title">
                            <MudText Typo="Typo.subtitle1">@FormatStatus(group.Status)</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@group.Orders.Count.ToString("N0")</MudChip>
                        </div>
                        <WebDataTable TItem="TradeOrder"
                                      TColumnId="TradeOrderColumn"
                                      Items="group.Orders"
                                      Columns="Columns"
                                      GetRowKey="GetOrderKey"
                                      GetRowClass="GetOrderRowClass"
                                      RowClicked="SelectOrder"
                                      CssClass="trade-orders-table">
                            <EmptyContent>
                                <span>No orders in @FormatStatus(group.Status).</span>
                            </EmptyContent>
                        </WebDataTable>
                    </section>
                }

                @if (ArchivedOrders.Count > 0)
                {
                    <section class="trade-orders-group">
                        <div class="trade-orders-group-title">
                            <MudText Typo="Typo.subtitle1">Archive</MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined">@ArchivedOrders.Count.ToString("N0")</MudChip>
                        </div>
                        <WebDataTable TItem="TradeOrder"
                                      TColumnId="TradeOrderColumn"
                                      Items="ArchivedOrders"
                                      Columns="Columns"
                                      GetRowKey="GetOrderKey"
                                      GetRowClass="GetOrderRowClass"
                                      RowClicked="SelectOrder"
                                      CssClass="trade-orders-table">
                            <EmptyContent>
                                <span>No completed or canceled orders.</span>
                            </EmptyContent>
                        </WebDataTable>
                    </section>
                }
            </section>

            <aside class="trade-orders-detail">
                @if (_selectedOrder == null)
                {
                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Order Details</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Select an order to inspect status, assignment, breakdown, and history.</MudText>
                    </section>
                }
                else
                {
                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Order Details</MudText>
                        <MudTextField @bind-Value="_detailTitle"
                                      Label="Title"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Disabled="@IsSelectedOrderArchived" />
                        <MudSelect T="Guid?"
                                   @bind-Value="_detailCrafterId"
                                   Label="Assigned crafter"
                                   Variant="Variant.Outlined"
                                   Margin="Margin.Dense"
                                   Clearable="true"
                                   Disabled="@IsSelectedOrderArchived">
                            @foreach (var crafter in _crafters)
                            {
                                <MudSelectItem T="Guid?" Value="@((Guid?)crafter.Id)">@crafter.DisplayName</MudSelectItem>
                            }
                        </MudSelect>
                        @if (IsSelectedOrderArchived)
                        {
                            <MudText Typo="Typo.body2" Color="Color.Secondary">Archived as @FormatStatus(_selectedOrder.Status).</MudText>
                        }
                        else
                        {
                            <MudSelect T="TradeOrderStatus"
                                       @bind-Value="_detailStatus"
                                       Label="Change status"
                                       Variant="Variant.Outlined"
                                       Margin="Margin.Dense">
                                @foreach (var status in TradeOrderStatusWorkflow.ActiveStatuses.Where(status => status != TradeOrderStatus.Draft))
                                {
                                    <MudSelectItem Value="@status">@FormatStatus(status)</MudSelectItem>
                                }
                            </MudSelect>
                        }
                        <MudTextField @bind-Value="_detailNotes"
                                      Label="Notes"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Lines="3"
                                      Disabled="@IsSelectedOrderArchived" />
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   FullWidth="true"
                                   OnClick="SaveSelectedOrderAsync"
                                   Disabled="@(IsSelectedOrderArchived || string.IsNullOrWhiteSpace(_detailTitle))">
                            Save Details
                        </MudButton>
                    </section>

                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Breakdown</MudText>
                        <MudText Typo="Typo.subtitle2">Outputs</MudText>
                        <ul class="trade-orders-list">
                            @foreach (var item in _selectedOrder.SourceSnapshot.RootItems)
                            {
                                <li>@item.Name @TradeDisplayFormatter.FormatQuantity(item.Quantity) @FormatHq(item.MustBeHq)</li>
                            }
                        </ul>
                        @if (_selectedOrder.SourceSnapshot.Materials.Count > 0)
                        {
                            var paymentSummary = GetSelectedOrderPaymentSummary();
                            <MudText Typo="Typo.subtitle2">Materials</MudText>
                            <ul class="trade-orders-list">
                                @foreach (var material in paymentSummary.Materials)
                                {
                                    <li>@material.Name @TradeDisplayFormatter.FormatQuantity(material.Quantity) @FormatHq(material.RequiresHq) - @FormatMaterialCost(material) - @FormatResponsibility(material.Responsibility)</li>
                                }
                            </ul>
                            <div class="trade-orders-payment-summary">
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Payment amount: @FormatGil(paymentSummary.TotalPayment)
                                </MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    Total estimated procurement: @FormatGil(paymentSummary.EstimatedProcurementTotal)
                                </MudText>
                            </div>
                        }
                    </section>

                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">History</MudText>
                        <div class="trade-orders-note-row">
                            <MudTextField @bind-Value="_manualNote"
                                          Label="Add Note"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Lines="2" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       OnClick="AddManualNoteAsync"
                                       Disabled="@string.IsNullOrWhiteSpace(_manualNote)">
                                Add Note
                            </MudButton>
                        </div>
                        <ul class="trade-orders-history">
                            @foreach (var item in _selectedOrder.History.OrderByDescending(item => item.CreatedAtUtc))
                            {
                                <li><strong>@FormatHistoryKind(item.Kind)</strong> @item.Note</li>
                            }
                        </ul>
                    </section>

                    <section class="trade-orders-panel">
                        <MudText Typo="Typo.subtitle1">Close Order</MudText>
                        @if (TradeOrderStatusWorkflow.IsArchived(_selectedOrder.Status))
                        {
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       FullWidth="true"
                                       OnClick="ReopenSelectedOrderAsync">
                                Reopen Order
                            </MudButton>
                        }
                        else
                        {
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Success"
                                       FullWidth="true"
                                       OnClick="@(() => OpenCloseOrderDialogAsync(TradeOrderStatus.Completed))">
                                Complete Order
                            </MudButton>
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Error"
                                       FullWidth="true"
                                       OnClick="@(() => OpenCloseOrderDialogAsync(TradeOrderStatus.Canceled))">
                                Cancel Order
                            </MudButton>
                        }
                    </section>
                }
            </aside>
            </div>
        }
    }
</MudContainer>

@code {
    private TradeCompanyProfile? _companyProfile;
    private List<TradeCrafterProfile> _crafters = [];
    private List<TradeOrder> _orders = [];
    private List<TradePayrollWorkflowDraft> _payrollDrafts = [];
    private TradeOrder? _pendingImport;
    private TradeOrder? _selectedOrder;
    private string _newOrderTitle = string.Empty;
    private Guid? _newOrderCrafterId;
    private string _detailTitle = string.Empty;
    private Guid? _detailCrafterId;
    private TradeOrderStatus _detailStatus;
    private string? _detailNotes;
    private string _manualNote = string.Empty;
    private string? _loadError;

    private IReadOnlyList<WebTableColumn<TradeOrder, TradeOrderColumn>> Columns => CreateColumns();

    private IReadOnlyList<OrderStatusGroup> ActiveOrderGroups => TradeOrderStatusWorkflow.ActiveStatuses
        .Where(status => status != TradeOrderStatus.Draft)
        .Select(status => new OrderStatusGroup(status, GetOrdersForStatus(status)))
        .Where(group => group.Orders.Count > 0)
        .ToArray();

    private IReadOnlyList<TradeOrder> ArchivedOrders => _orders
        .Where(order => TradeOrderStatusWorkflow.IsArchived(order.Status))
        .OrderByDescending(order => order.CommissionedAtUtc)
        .ToArray();

    private IReadOnlyList<WebTableColumn<TradeOrder, TradeOrderColumn>> CreateColumns()
    {
        return
        [
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Title, "Order", order => order.Title, widthPx: 260),
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Commissioned, "Commissioned", order => order.CommissionedAtUtc.ToLocalTime().ToString("g"), widthPx: 160),
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Crafter, "Crafter", FormatAssignedCrafter, widthPx: 140),
            WebTableColumn<TradeOrder, TradeOrderColumn>.Text(TradeOrderColumn.Quantity, "Qty", order => GetRootQuantity(order).ToString("N0"), widthPx: 80, alignEnd: true, headerCssClass: "is-align-end")
        ];
    }

    protected override async Task OnInitializedAsync()
    {
        if (!AppState.SecretDebugToolsEnabled)
        {
            return;
        }

        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        try
        {
            _loadError = null;
            _companyProfile = await TradeOperationsPersistence.GetOrCreateActiveCompanyProfileAsync();
            _crafters = (await TradeOperationsPersistence.LoadCraftersAsync(_companyProfile.Id)).ToList();
            _orders = (await TradeOperationsPersistence.LoadOrdersAsync(_companyProfile.Id)).ToList();
            _payrollDrafts = (await TradePayrollPersistence.LoadDraftsAsync(_companyProfile.Id)).ToList();
        }
        catch (Exception ex)
        {
            _companyProfile = null;
            _crafters = [];
            _orders = [];
            _payrollDrafts = [];
            _selectedOrder = null;
            _loadError = ex.Message;
            Snackbar.Add("Trade operations storage is unavailable.", Severity.Error);
        }
    }

    private void PrepareOrderImport()
    {
        if (_companyProfile == null)
        {
            return;
        }

        var result = TradeOrderDraftFactory.CreateFromCurrentPlan(new TradeOrderCreateRequest(
            AppState,
            _companyProfile.Id,
            _newOrderCrafterId,
            null,
            DateTime.UtcNow));
        if (!result.CanCreate || result.Order == null)
        {
            Snackbar.Add(result.UnavailableReason ?? "Could not create order from the active plan.", Severity.Warning);
            return;
        }

        _pendingImport = result.Order;
        _newOrderTitle = result.Order.Title;
    }

    private async Task CreatePendingOrderAsync()
    {
        if (_companyProfile == null || _pendingImport == null)
        {
            return;
        }

        var result = TradeOrderDraftFactory.CreateFromCurrentPlan(new TradeOrderCreateRequest(
            AppState,
            _companyProfile.Id,
            _newOrderCrafterId,
            _newOrderTitle,
            DateTime.UtcNow));
        if (!result.CanCreate || result.Order == null)
        {
            Snackbar.Add(result.UnavailableReason ?? "Could not create order from the active plan.", Severity.Warning);
            return;
        }

        var saved = await TradeOperationsPersistence.SaveOrderAsync(result.Order);
        if (!saved)
        {
            Snackbar.Add("Failed to save Trade order.", Severity.Error);
            return;
        }

        _pendingImport = null;
        _newOrderTitle = string.Empty;
        _newOrderCrafterId = null;
        await LoadAsync();
        if (!string.IsNullOrWhiteSpace(_loadError) ||
            !SelectOrderAfterReload(result.Order.Id, "Trade order was saved, but it could not be loaded."))
        {
            return;
        }

        Snackbar.Add("Trade order created", Severity.Success);
    }

    private IReadOnlyList<TradeOrder> GetOrdersForStatus(TradeOrderStatus status)
    {
        return _orders
            .Where(order => order.Status == status)
            .OrderByDescending(order => order.CommissionedAtUtc)
            .ToArray();
    }

    private static string GetOrderKey(TradeOrder order)
    {
        return order.Id.ToString("N");
    }

    private string GetOrderRowClass(TradeOrder order)
    {
        return _selectedOrder?.Id == order.Id ? "is-selected" : string.Empty;
    }

    private void SelectOrder(TradeOrder order)
    {
        _selectedOrder = order;
        _detailTitle = order.Title;
        _detailCrafterId = order.AssignedCrafterId;
        _detailStatus = order.Status;
        _detailNotes = order.Notes;
        _manualNote = string.Empty;
    }

    private bool IsSelectedOrderArchived => _selectedOrder != null && TradeOrderStatusWorkflow.IsArchived(_selectedOrder.Status);

    private bool SelectOrderAfterReload(Guid orderId, string missingMessage)
    {
        var reloadedOrder = _orders.FirstOrDefault(order => order.Id == orderId);
        if (reloadedOrder == null)
        {
            _selectedOrder = null;
            _manualNote = string.Empty;
            Snackbar.Add(missingMessage, Severity.Warning);
            return false;
        }

        SelectOrder(reloadedOrder);
        return true;
    }

    private async Task SaveSelectedOrderAsync()
    {
        if (_selectedOrder == null)
        {
            return;
        }

        if (TradeOrderStatusWorkflow.IsArchived(_selectedOrder.Status))
        {
            Snackbar.Add("Reopen archived orders before editing details.", Severity.Warning);
            return;
        }

        var title = _detailTitle.Trim();
        if (string.IsNullOrWhiteSpace(title))
        {
            Snackbar.Add("Order title is required.", Severity.Warning);
            return;
        }

        if (TradeOrderStatusWorkflow.IsArchived(_detailStatus) || _detailStatus == TradeOrderStatus.Draft)
        {
            Snackbar.Add("Use the close order controls for archive transitions.", Severity.Warning);
            return;
        }

        if (_detailCrafterId.HasValue && _detailStatus == TradeOrderStatus.ReadyToAssign)
        {
            Snackbar.Add("Change status to Assigned before saving this assignment.", Severity.Warning);
            return;
        }
        else if (!_detailCrafterId.HasValue && _detailStatus == TradeOrderStatus.Assigned)
        {
            Snackbar.Add("Change status to Ready to Assign before clearing this assignment.", Severity.Warning);
            return;
        }
        else if (!_detailCrafterId.HasValue && (_detailStatus == TradeOrderStatus.InProgress || _detailStatus == TradeOrderStatus.AwaitingDelivery))
        {
            Snackbar.Add("Assign a crafter before using this status.", Severity.Warning);
            return;
        }

        var previousStatus = _selectedOrder.Status;
        var previousCrafterId = _selectedOrder.AssignedCrafterId;
        var orderId = _selectedOrder.Id;
        var orderToSave = CopyOrder(_selectedOrder);
        orderToSave.Title = title;
        orderToSave.AssignedCrafterId = _detailCrafterId;
        orderToSave.Status = _detailStatus;
        orderToSave.Notes = _detailNotes;
        orderToSave.UpdatedAtUtc = DateTime.UtcNow;
        AddHistoryIfAssignmentChanged(orderToSave, previousCrafterId, _detailCrafterId);
        AddHistoryIfStatusChanged(orderToSave, previousStatus, _detailStatus, "Status changed from detail panel.");
        var saved = await TradeOperationsPersistence.SaveOrderAsync(orderToSave);
        if (!saved)
        {
            Snackbar.Add("Failed to save Trade order.", Severity.Error);
            return;
        }

        await LoadAsync();
        if (string.IsNullOrWhiteSpace(_loadError))
        {
            SelectOrderAfterReload(orderId, "Trade order was saved, but it could not be loaded.");
        }
    }

    private async Task AddManualNoteAsync()
    {
        if (_selectedOrder == null || _companyProfile == null || string.IsNullOrWhiteSpace(_manualNote))
        {
            return;
        }

        var orderId = _selectedOrder.Id;
        var orderToSave = CopyOrder(_selectedOrder);
        var history = orderToSave.History.ToList();
        history.Add(TradeOrderHistoryEvent.CreateManualNote(_companyProfile.Id, orderToSave.Id, _manualNote.Trim(), DateTime.UtcNow));
        orderToSave.History = history;
        orderToSave.UpdatedAtUtc = DateTime.UtcNow;
        var saved = await TradeOperationsPersistence.SaveOrderAsync(orderToSave);
        if (!saved)
        {
            Snackbar.Add("Failed to save Trade order.", Severity.Error);
            return;
        }

        _manualNote = string.Empty;
        await LoadAsync();
        if (string.IsNullOrWhiteSpace(_loadError))
        {
            SelectOrderAfterReload(orderId, "Trade order note was saved, but the order could not be loaded.");
        }
    }

    private async Task OpenCloseOrderDialogAsync(TradeOrderStatus status)
    {
        if (_selectedOrder == null)
        {
            return;
        }

        var parameters = new DialogParameters
        {
            ["Status"] = status,
            ["OrderTitle"] = _selectedOrder.Title
        };
        var options = new DialogOptions { CloseOnEscapeKey = true, MaxWidth = MaxWidth.Small };
        var dialog = await DialogService.ShowAsync<TradeOrderCloseDialog>("Close Order", parameters, options);
        var result = await dialog.Result;

        if (result?.Data is TradeOrderCloseDialogResult closeResult)
        {
            await CloseSelectedOrderAsync(closeResult.Status, closeResult.Note);
        }
    }

    private async Task CloseSelectedOrderAsync(TradeOrderStatus status, string? note)
    {
        if (_selectedOrder == null)
        {
            return;
        }

        var previousStatus = _selectedOrder.Status;
        var orderId = _selectedOrder.Id;
        var orderToSave = CopyOrder(_selectedOrder);
        orderToSave.Status = status;
        orderToSave.UpdatedAtUtc = DateTime.UtcNow;
        AddHistoryIfStatusChanged(orderToSave, previousStatus, status, string.IsNullOrWhiteSpace(note) ? FormatStatus(status) : note.Trim());
        var saved = await TradeOperationsPersistence.SaveOrderAsync(orderToSave);
        if (!saved)
        {
            Snackbar.Add("Failed to save Trade order.", Severity.Error);
            return;
        }

        await LoadAsync();
        if (string.IsNullOrWhiteSpace(_loadError))
        {
            SelectOrderAfterReload(orderId, "Trade order was closed, but it could not be loaded.");
        }
    }

    private string FormatAssignedCrafter(TradeOrder order)
    {
        if (!order.AssignedCrafterId.HasValue)
        {
            return "Unassigned";
        }

        return _crafters.FirstOrDefault(crafter => crafter.Id == order.AssignedCrafterId.Value)?.DisplayName ?? "Assigned";
    }

    private async Task ReopenSelectedOrderAsync()
    {
        if (_selectedOrder == null)
        {
            return;
        }

        var previousStatus = _selectedOrder.Status;
        var orderId = _selectedOrder.Id;
        var orderToSave = CopyOrder(_selectedOrder);
        orderToSave.Status = orderToSave.AssignedCrafterId.HasValue
            ? TradeOrderStatus.Assigned
            : TradeOrderStatus.ReadyToAssign;
        orderToSave.UpdatedAtUtc = DateTime.UtcNow;
        AddReopenedHistory(orderToSave, previousStatus, orderToSave.Status);
        var saved = await TradeOperationsPersistence.SaveOrderAsync(orderToSave);
        if (!saved)
        {
            Snackbar.Add("Failed to save Trade order.", Severity.Error);
            return;
        }

        await LoadAsync();
        if (string.IsNullOrWhiteSpace(_loadError))
        {
            SelectOrderAfterReload(orderId, "Trade order was reopened, but it could not be loaded.");
        }
    }

    private static void AddHistoryIfStatusChanged(TradeOrder order, TradeOrderStatus previousStatus, TradeOrderStatus newStatus, string note)
    {
        if (previousStatus == newStatus)
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderStatusWorkflow.IsArchived(newStatus) ? TradeOrderHistoryEventKind.Closed : TradeOrderHistoryEventKind.StatusChanged,
            Note = note,
            FromStatus = previousStatus,
            ToStatus = newStatus,
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

    private static void AddReopenedHistory(TradeOrder order, TradeOrderStatus previousStatus, TradeOrderStatus newStatus)
    {
        if (previousStatus == newStatus)
        {
            return;
        }

        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.Reopened,
            Note = "Reopened order.",
            FromStatus = previousStatus,
            ToStatus = newStatus,
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

    private void AddHistoryIfAssignmentChanged(TradeOrder order, Guid? previousCrafterId, Guid? newCrafterId)
    {
        if (previousCrafterId == newCrafterId)
        {
            return;
        }

        var crafterName = newCrafterId.HasValue
            ? _crafters.FirstOrDefault(crafter => crafter.Id == newCrafterId.Value)?.DisplayName ?? "unknown crafter"
            : "unassigned";
        var history = order.History.ToList();
        history.Add(new TradeOrderHistoryEvent
        {
            Id = Guid.NewGuid(),
            CompanyProfileId = order.CompanyProfileId,
            OrderId = order.Id,
            Kind = TradeOrderHistoryEventKind.Assigned,
            Note = newCrafterId.HasValue ? $"Assigned to {crafterName}." : "Assignment cleared.",
            CrafterId = newCrafterId,
            CreatedAtUtc = DateTime.UtcNow
        });
        order.History = history;
    }

    private static string FormatStatus(TradeOrderStatus status)
    {
        return status switch
        {
            TradeOrderStatus.ReadyToAssign => "Ready to Assign",
            TradeOrderStatus.InProgress => "In Progress",
            TradeOrderStatus.AwaitingDelivery => "Awaiting Delivery",
            _ => status.ToString()
        };
    }

    private static string FormatHistoryKind(TradeOrderHistoryEventKind kind)
    {
        return kind switch
        {
            TradeOrderHistoryEventKind.ManualNote => "Note",
            TradeOrderHistoryEventKind.StatusChanged => "Status",
            TradeOrderHistoryEventKind.Reopened => "Reopened",
            TradeOrderHistoryEventKind.PayrollLinked => "Payroll",
            _ => kind.ToString()
        };
    }

    private static string FormatHq(bool mustBeHq)
    {
        return mustBeHq ? "HQ" : string.Empty;
    }

    private static int GetRootQuantity(TradeOrder order)
    {
        return order.SourceSnapshot.RootItems.Sum(item => item.Quantity);
    }

    private static decimal GetTotalMaterialCost(TradeOrder order)
    {
        return order.SourceSnapshot.Materials.Sum(material => material.TotalCost);
    }

    private TradeCommissionPaymentSummary GetSelectedOrderPaymentSummary()
    {
        if (_selectedOrder == null)
        {
            return TradeCommissionPaymentSummary.FromOrder(new TradeOrder(), draft: null);
        }

        return TradeCommissionPaymentSummary.FromOrder(_selectedOrder, GetPayrollDraftForOrder(_selectedOrder));
    }

    private TradePayrollWorkflowDraft? GetPayrollDraftForOrder(TradeOrder order)
    {
        return _payrollDrafts.FirstOrDefault(draft =>
                !string.IsNullOrWhiteSpace(order.PayrollDraftId) &&
                string.Equals(draft.Id, order.PayrollDraftId, StringComparison.OrdinalIgnoreCase))
            ?? _payrollDrafts.FirstOrDefault(draft => draft.OrderId == order.Id)
            ?? _payrollDrafts.FirstOrDefault(draft =>
                !draft.OrderId.HasValue &&
                draft.PlanSessionVersion == order.SourceSnapshot.PlanSessionVersion);
    }

    private static string FormatMaterialCost(TradeCommissionPaymentMaterial material)
    {
        if (material.UnitCost <= 0 || material.TotalCost <= 0)
        {
            return "Not priced";
        }

        return $"{FormatGil(material.TotalCost)} total";
    }

    private static string FormatResponsibility(CommissionMaterialResponsibility responsibility)
    {
        return responsibility == CommissionMaterialResponsibility.Provided
            ? "Provided"
            : "Crafter procures";
    }

    private static string FormatGil(decimal value)
    {
        return value > 0 ? $"{value:N0} gil" : "Not priced";
    }

    private static TradeOrder CopyOrder(TradeOrder order)
    {
        return new TradeOrder
        {
            Id = order.Id,
            CompanyProfileId = order.CompanyProfileId,
            Title = order.Title,
            Status = order.Status,
            AssignedCrafterId = order.AssignedCrafterId,
            CommissionedAtUtc = order.CommissionedAtUtc,
            CreatedAtUtc = order.CreatedAtUtc,
            UpdatedAtUtc = order.UpdatedAtUtc,
            Notes = order.Notes,
            SourceSnapshot = order.SourceSnapshot,
            History = order.History.ToArray(),
            PayrollDraftId = order.PayrollDraftId,
            RemoteId = order.RemoteId,
            SyncState = order.SyncState
        };
    }

    private enum TradeOrderColumn
    {
        Title,
        Commissioned,
        Crafter,
        Quantity
    }

    private sealed record OrderStatusGroup(TradeOrderStatus Status, IReadOnlyList<TradeOrder> Orders);
}
