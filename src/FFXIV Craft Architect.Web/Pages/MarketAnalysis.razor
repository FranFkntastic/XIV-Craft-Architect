@page "/market"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Services
@using static FFXIV_Craft_Architect.Core.Models.MarketSortOption
@inject RecipePlannerCommandService RecipePlannerCommandService
@inject MarketAnalysisWorkflowService MarketAnalysisWorkflow
@inject MarketAnalysisItemRefreshService MarketAnalysisItemRefreshService
@inject ISnackbar Snackbar
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject CancellableOperationService CancellableOperations
@inject IRecipeLayerWorkflowService RecipeLayerWorkflowService
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 ma-page-container">
    <div class="ma-grid-layout">
        <MarketAnalysisControlsPanel
            AppState="AppState"
            IsAnalyzing="_isAnalyzing"
            IsRefreshingPrices="_isRefreshingPrices"
            CanAnalyze="CanAnalyze()"
            CanRefreshPrices="CanRefreshPrices()"
            OnLensChangedRequested="OnLensChanged"
            OnRunAnalysisRequested="RunMarketAnalysisAsync"
            OnRefreshPricesRequested="RefreshPricesAsync"
            OnGoToProcurementRequested="GoToProcurement" />

        <MarketAnalysisResultsPanel
            BuyItems="GetBuyItems()"
            ShoppingPlans="AppState.ShoppingPlans"
            MarketItemAnalyses="AppState.MarketItemAnalyses"
            CurrentLens="AppState.MarketAnalysisLens"
            CurrentSort="AppState.MarketSortPreference"
            EvidenceOverlay="AppState.MarketAnalysisEvidenceOverlay"
            SortColumn="AppState.MarketAnalysisGridSortColumn"
            SortDescending="AppState.MarketAnalysisGridSortDescending"
            WorldSortColumn="AppState.MarketAnalysisWorldGridSortColumn"
            WorldSortDescending="AppState.MarketAnalysisWorldGridSortDescending"
            SelectedItemId="AppState.SelectedMarketAnalysisItemId"
            ExpandedWorldKeys="AppState.ExpandedMarketAnalysisWorlds"
            ShowWorldsColumn="AppState.SearchEntireRegion"
            IsAnalyzing="_isAnalyzing"
            IsRefreshingItem="_isRefreshingSelectedItem || _isAnalyzing || _isRefreshingPrices"
            OnSelectedItemChanged="SelectMarketAnalysisItem"
            OnRefreshItemRequested="RefreshSelectedMarketItemAsync"
            OnWorldExpansionToggled="ToggleMarketAnalysisWorld"
            OnSortChanged="SetMarketAnalysisSort"
            OnWorldSortChanged="SetMarketAnalysisWorldSort"
            OnGoToPlannerRequested="GoToPlanner"
            OnRunAnalysisRequested="RunMarketAnalysisAsync" />
    </div>
</MudContainer>

@code {
    private bool _isAnalyzing = false;
    private bool _isRefreshingPrices = false;
    private bool _isRefreshingSelectedItem = false;
    private CancellableOperationLease? _marketAnalysisOperation;
    private CancellableOperationLease? _priceRefreshOperation;
    private CancellableOperationLease? _itemRefreshOperation;

    // Settings now stored in AppState for persistence across page navigations

    protected override void OnInitialized()
    {
        // Subscribe to plan changes (including restoration from auto-save)
        AppState.OnStateChanged += OnStateChanged;
        AppState.OnPlanChanged += OnPlanChanged;
        AppState.OnShoppingListChanged += OnShoppingListChanged;
        AppState.ApplyPendingMarketItemAutoExpand();
    }

    private void OnStateChanged(AppStateChange change)
    {
        if (change.HasScope(AppStateChangeScope.MarketAnalysisView))
        {
            InvokeAsync(StateHasChanged);
        }
    }

    private void OnPlanChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnShoppingListChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void SelectMarketAnalysisItem(int? itemId)
    {
        AppState.SelectMarketAnalysisItem(itemId);
    }

    private void ToggleMarketAnalysisWorld(MarketAnalysisExpandedWorldKey key)
    {
        AppState.ToggleMarketAnalysisWorld(key.ItemId, key.DataCenter, key.WorldName);
    }

    private void SetMarketAnalysisSort(MarketAnalysisGridSortState sort)
    {
        AppState.SetMarketAnalysisGridSort(sort.Column, sort.Descending);
    }

    private void SetMarketAnalysisWorldSort(MarketAnalysisWorldGridSortState sort)
    {
        AppState.SetMarketAnalysisWorldGridSort(sort.Column, sort.Descending);
    }

    public void Dispose()
    {
        CancellableOperations.Cancel(CancellableOperationWorkflow.MarketAnalysis);
        CancellableOperations.Cancel(CancellableOperationWorkflow.PriceRefresh);
        CancellableOperations.Cancel(CancellableOperationWorkflow.ItemMarketRefresh);
        _marketAnalysisOperation = null;
        _priceRefreshOperation = null;
        _itemRefreshOperation = null;
        AppState.OnStateChanged -= OnStateChanged;
        AppState.OnPlanChanged -= OnPlanChanged;
        AppState.OnShoppingListChanged -= OnShoppingListChanged;
    }

    /// <summary>
    /// Get the current items marked for buying from the recipe plan.
    /// This dynamically reflects any changes made in the recipe tree.
    /// </summary>
    private List<MaterialAggregate> GetBuyItems()
    {
        return RecipeLayerWorkflowService
            .BuildMarketAnalysisCandidates(AppState.CurrentPlan)
            .ToList();
    }

    private bool CanAnalyze()
    {
        return GetBuyItems().Any() && !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    private bool CanRefreshPrices()
    {
        return AppState.CurrentPlan != null && !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    private async Task RefreshPricesAsync()
    {
        if (AppState.CurrentPlan == null) return;

        CancellableOperations.Cancel(CancellableOperationWorkflow.ItemMarketRefresh);
        _isRefreshingPrices = true;
        using var operation = CancellableOperations.Start(
            CancellableOperationWorkflow.PriceRefresh,
            "Price Refresh",
            "Fetching latest market data...");
        _priceRefreshOperation = operation;

        try
        {
            operation.ReportStatus("Fetching market prices...");
            await RecipePlannerCommandService.RefreshPricesAsync(
                new RefreshRecipePlanPricesRequest(
                    AppState.SearchEntireRegion ? MarketFetchScope.EntireRegion : MarketFetchScope.SelectedDataCenter,
                    AppState.SelectedDataCenter,
                    AppState.SelectedRegion,
                    ForceRefreshData: true),
                operation.Token);
            if (!operation.IsCurrent)
            {
                return;
            }

            // Recompute from the freshly updated cache so Procurement reflects the manual refresh.
            var canReanalyze = GetBuyItems().Any() && !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
            if (canReanalyze)
            {
                var rebuilt = await RunMarketAnalysisAsync(forceRefreshData: false, showCompletionSnackbar: false);
                if (!operation.IsCurrent)
                {
                    return;
                }

                if (rebuilt)
                {
                    if (AppState.UnavailableMarketItems.Any())
                    {
                        var warning = CoreMarketPriceAvailability.FormatUnavailableMessage(AppState.UnavailableMarketItems);
                        Snackbar.Add($"Prices refreshed with warnings. {warning}", Severity.Warning);
                    }
                    else
                    {
                        Snackbar.Add("Prices refreshed and procurement plan rebuilt", Severity.Success);
                    }
                }
                else
                {
                    Snackbar.Add("Prices refreshed, but failed to rebuild procurement plan", Severity.Warning);
                }
            }
            else
            {
                operation.Complete("Prices refreshed");
                if (AppState.UnavailableMarketItems.Any())
                {
                    Snackbar.Add(CoreMarketPriceAvailability.FormatUnavailableMessage(AppState.UnavailableMarketItems), Severity.Warning);
                }
                else
                {
                    Snackbar.Add("Prices refreshed", Severity.Success);
                }
            }
        }
        catch (OperationCanceledException ex) when (!operation.ShouldReportError(ex))
        {
            operation.Cancel();
        }
        catch (Exception ex)
        {
            if (operation.ShouldReportError(ex))
            {
                operation.Complete($"Price refresh failed: {ex.Message}");
                Snackbar.Add($"Failed to refresh prices: {ex.Message}", Severity.Error);
            }
        }
        finally
        {
            if (ReferenceEquals(_priceRefreshOperation, operation))
            {
                _priceRefreshOperation = null;
                _isRefreshingPrices = false;
            }
        }
    }

    private async Task RefreshSelectedMarketItemAsync(DetailedShoppingPlan plan)
    {
        if (AppState.CurrentPlan == null)
        {
            Snackbar.Add("Refresh market data failed: no active recipe plan.", Severity.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(AppState.SelectedDataCenter))
        {
            Snackbar.Add("Refresh market data failed: no selected data center.", Severity.Warning);
            return;
        }

        var refreshScope = AppState.SearchEntireRegion
            ? MarketFetchScope.EntireRegion
            : MarketFetchScope.SelectedDataCenter;
        var selectedDataCenter = AppState.SelectedDataCenter;
        var selectedRegion = AppState.SelectedRegion;
        var lens = AppState.MarketAnalysisLens;

        _isRefreshingSelectedItem = true;
        using var operation = CancellableOperations.Start(
            CancellableOperationWorkflow.ItemMarketRefresh,
            "Item Market Refresh",
            $"Refreshing {plan.Name} market data...");
        _itemRefreshOperation = operation;

        try
        {
            var progress = new Progress<string>(message => operation.ReportStatus(message));
            var result = await MarketAnalysisItemRefreshService.RefreshItemMarketDataAsync(
                new MarketAnalysisItemRefreshWorkflowRequest(
                    plan.ItemId,
                    IsCurrentOperation: () => operation.IsCurrent,
                    ExecutionOptions: MarketAnalysisExecutionOptions.Interactive)
                {
                    Scope = refreshScope,
                    IsCurrentConfiguration = () =>
                        (AppState.SearchEntireRegion ? MarketFetchScope.EntireRegion : MarketFetchScope.SelectedDataCenter) == refreshScope &&
                        string.Equals(AppState.SelectedDataCenter, selectedDataCenter, StringComparison.Ordinal) &&
                        string.Equals(AppState.SelectedRegion, selectedRegion, StringComparison.Ordinal) &&
                        AppState.MarketAnalysisLens == lens
                },
                progress,
                operation.Token);
            if (!operation.IsCurrent)
            {
                return;
            }

            if (result.Status == MarketAnalysisItemRefreshStatus.Refreshed)
            {
                if (string.IsNullOrWhiteSpace(result.ItemName))
                {
                    throw new InvalidOperationException("Item refresh reported success without a refreshed item name.");
                }

                operation.Complete($"{result.ItemName} market data refreshed.");
                Snackbar.Add($"Refreshed {result.ItemName} market data.", Severity.Success);
                return;
            }

            if (IsDiscardedItemRefreshStatus(result.Status))
            {
                operation.Cancel(FormatItemRefreshStatus(result.Status));
                Snackbar.Add($"Item refresh was discarded: {FormatItemRefreshStatus(result.Status)}.", Severity.Info);
                return;
            }

            operation.Complete($"Refresh market data failed: {result.Status}");
            Snackbar.Add($"Refresh market data failed for {plan.Name}: {FormatItemRefreshStatus(result.Status)}", Severity.Warning);
        }
        catch (OperationCanceledException ex) when (!operation.ShouldReportError(ex))
        {
            operation.Cancel();
        }
        catch (Exception ex)
        {
            if (operation.ShouldReportError(ex))
            {
                operation.Complete($"Refresh market data failed: {ex.Message}");
                Snackbar.Add($"Refresh market data failed for {plan.Name}: {ex.Message}", Severity.Error);
            }
        }
        finally
        {
            if (ReferenceEquals(_itemRefreshOperation, operation))
            {
                _itemRefreshOperation = null;
                _isRefreshingSelectedItem = false;
            }
        }
    }

    private async Task RunMarketAnalysisAsync()
    {
        await RunMarketAnalysisAsync(forceRefreshData: false, showCompletionSnackbar: true);
    }

    private async Task<bool> RunMarketAnalysisAsync(bool forceRefreshData, bool showCompletionSnackbar)
    {
        var materials = GetBuyItems();

        var plan = AppState.CurrentPlan;
        if (plan == null || !materials.Any() || string.IsNullOrWhiteSpace(AppState.SelectedDataCenter))
        {
            return false;
        }

        _isAnalyzing = true;
        AppState.ClearMarketAnalysisState();
        CancellableOperations.Cancel(CancellableOperationWorkflow.ItemMarketRefresh);
        using var operation = CancellableOperations.Start(
            CancellableOperationWorkflow.MarketAnalysis,
            "Market Analysis",
            $"Analyzing {materials.Count} items on {AppState.SelectedDataCenter}...");
        _marketAnalysisOperation = operation;

        try
        {
            var progress = new Progress<string>(msg => operation.ReportStatus(msg));
            var result = await MarketAnalysisWorkflow.RunAnalysisAsync(
                new MarketAnalysisWorkflowRequest(forceRefreshData),
                progress,
                operation.Token,
                executionOptions: MarketAnalysisExecutionOptions.Interactive);
            if (!operation.IsCurrent)
            {
                return false;
            }

            if (!result.Published)
            {
                return false;
            }

            // Ensure the status message is properly set to completion
            var analyzedItemLabel = result.AnalyzedCount == 1 ? "item" : "items";
            operation.Complete($"Analysis complete. {result.AnalyzedCount} {analyzedItemLabel} analyzed.");
            if (showCompletionSnackbar)
            {
                Snackbar.Add("Market analysis complete!", Severity.Success);
            }

            return true;
        }
        catch (OperationCanceledException ex) when (!operation.ShouldReportError(ex))
        {
            operation.Cancel();
            return false;
        }
        catch (Exception ex)
        {
            if (operation.ShouldReportError(ex))
            {
                operation.Complete($"Analysis failed: {ex.Message}");
                Snackbar.Add($"Market analysis failed: {ex.Message}", Severity.Error);
            }
            return false;
        }
        finally
        {
            if (ReferenceEquals(_marketAnalysisOperation, operation))
            {
                _marketAnalysisOperation = null;
                _isAnalyzing = false;
            }
        }
    }

    private async Task OnLensChanged(MarketAcquisitionLens lens)
    {
        await MarketAnalysisWorkflow.ApplyLensAsync(lens);
    }

    private static string FormatItemRefreshStatus(MarketAnalysisItemRefreshStatus status)
    {
        return status switch
        {
            MarketAnalysisItemRefreshStatus.NoPlan => "no active recipe plan",
            MarketAnalysisItemRefreshStatus.NotFound => "item is not present in the current market-analysis candidate set",
            MarketAnalysisItemRefreshStatus.NoData => "Universalis returned no market data for the item",
            MarketAnalysisItemRefreshStatus.StaleDecision => "plan decisions changed before the refresh finished",
            MarketAnalysisItemRefreshStatus.StaleConfiguration => "market analysis settings changed before the refresh finished",
            MarketAnalysisItemRefreshStatus.StalePlan => "recipe plan changed before the refresh finished",
            MarketAnalysisItemRefreshStatus.Superseded => "a newer item refresh replaced this request",
            _ => status.ToString()
        };
    }

    private static bool IsDiscardedItemRefreshStatus(MarketAnalysisItemRefreshStatus status)
    {
        return status is
            MarketAnalysisItemRefreshStatus.StaleDecision or
            MarketAnalysisItemRefreshStatus.StaleConfiguration or
            MarketAnalysisItemRefreshStatus.StalePlan or
            MarketAnalysisItemRefreshStatus.Superseded;
    }

    private void GoToPlanner()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("./");
    }

    private void GoToProcurement()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("acquisition");
    }

}
