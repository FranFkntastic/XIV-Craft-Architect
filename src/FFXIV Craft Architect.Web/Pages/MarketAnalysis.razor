@page "/market"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services
@inject WorkerSessionCoordinator WorkerSession
@inject WorkerProjectionStore WorkerProjections
@inject ISettingsService Settings
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 ma-page-container">
    <div class="ma-grid-layout">
        <MarketAnalysisControlsPanel
            Lens="@(_market?.Lens ?? MarketAcquisitionLens.MinimumUpfrontCost)"
            EvidenceOverlay="_evidenceOverlay"
            SearchEntireRegion="_searchEntireRegion"
            SelectedRegion="@(_market?.SelectedRegion ?? WorkerProjections.Shell.SelectedRegion)"
            HasShoppingPlans="@(_market?.ShoppingPlans.Count > 0)"
            SecretDebugToolsEnabled="_secretDebugToolsEnabled"
            IsAnalyzing="_isAnalyzing"
            IsRefreshingPrices="_isRefreshingPrices"
            CanAnalyze="CanAnalyze"
            CanRefreshPrices="CanRefreshPrices"
            OnLensChangedRequested="OnLensChanged"
            OnEvidenceOverlayChangedRequested="SetEvidenceOverlay"
            OnSearchEntireRegionChangedRequested="SetSearchEntireRegion"
            OnRunAnalysisRequested="RunMarketAnalysisAsync"
            OnRefreshPricesRequested="RefreshPricesAsync"
            OnGoToProcurementRequested="GoToProcurement" />

        <MarketAnalysisResultsPanel
            BuyItems="@(_market?.CandidateItems.ToList() ?? new List<MaterialAggregate>())"
            ShoppingPlans="@(_market?.ShoppingPlans ?? Array.Empty<DetailedShoppingPlan>())"
            MarketItemAnalyses="@(_market?.ItemAnalyses ?? Array.Empty<MarketItemAnalysis>())"
            CurrentLens="@(_market?.Lens ?? MarketAcquisitionLens.MinimumUpfrontCost)"
            CurrentSort="_marketSort"
            EvidenceOverlay="_evidenceOverlay"
            SortColumn="_sortColumn"
            SortDescending="_sortDescending"
            WorldSortColumn="_worldSortColumn"
            WorldSortDescending="_worldSortDescending"
            SelectedItemId="_selectedItemId"
            ExpandedWorldKeys="_expandedWorldKeys"
            ShowWorldsColumn="_searchEntireRegion"
            IsRefreshingItem="@(_isRefreshingSelectedItem || _isAnalyzing || _isRefreshingPrices)"
            OnSelectedItemChanged="SelectMarketAnalysisItem"
            OnRefreshItemRequested="RefreshSelectedMarketItemAsync"
            OnWorldExpansionToggled="ToggleMarketAnalysisWorld"
            OnSortChanged="SetMarketAnalysisSort"
            OnWorldSortChanged="SetMarketAnalysisWorldSort"
            OnGoToPlannerRequested="GoToPlanner" />
    </div>
</MudContainer>

@code {
    [SupplyParameterFromQuery(Name = "itemId")]
    public int? RequestedItemId { get; set; }

    private WorkerMarketProjection? _market;
    private bool _isAnalyzing;
    private bool _isRefreshingPrices;
    private bool _isRefreshingSelectedItem;
    private bool _searchEntireRegion = true;
    private bool _secretDebugToolsEnabled;
    private MarketSortOption _marketSort = MarketSortOption.ByRecommended;
    private MarketAnalysisEvidenceOverlay _evidenceOverlay =
        MarketAnalysisEvidenceOverlay.CompetitivenessOverlay;
    private MarketAnalysisGridSortColumn? _sortColumn;
    private bool _sortDescending;
    private MarketAnalysisWorldGridSortColumn? _worldSortColumn;
    private bool _worldSortDescending;
    private int? _selectedItemId;
    private readonly HashSet<MarketAnalysisExpandedWorldKey> _expandedWorldKeys = [];

    private bool CanAnalyze =>
        !_isAnalyzing &&
        WorkerProjections.Shell.HasSession &&
        (_market?.CandidateCount ?? 0) > 0;

    private bool CanRefreshPrices =>
        !_isAnalyzing &&
        !_isRefreshingPrices &&
        WorkerProjections.Shell.HasSession;

    protected override async Task OnInitializedAsync()
    {
        WorkerProjections.Changed += ProjectionChanged;
        _searchEntireRegion = await Settings.GetAsync("market.search_entire_region", true);
        _secretDebugToolsEnabled = await Settings.GetAsync("debug.secret_tools_enabled", false);
        var overlay = await Settings.GetAsync(
            "market.analysis_evidence_overlay",
            nameof(MarketAnalysisEvidenceOverlay.CompetitivenessOverlay));
        if (Enum.TryParse(overlay, ignoreCase: true, out MarketAnalysisEvidenceOverlay parsedOverlay))
        {
            _evidenceOverlay = parsedOverlay;
        }

        _market = await WorkerSession.GetMarketProjectionAsync();
        ApplyRequestedItem();
    }

    protected override void OnParametersSet()
    {
        ApplyRequestedItem();
    }

    private void ProjectionChanged()
    {
        _market = WorkerProjections.Market ?? _market;
        ApplyRequestedItem();
        _ = InvokeAsync(StateHasChanged);
    }

    private void ApplyRequestedItem()
    {
        if (RequestedItemId.HasValue &&
            _market?.ShoppingPlans.Any(plan => plan.ItemId == RequestedItemId.Value) == true)
        {
            _selectedItemId = RequestedItemId;
        }
    }

    private Task SelectMarketAnalysisItem(int? itemId)
    {
        _selectedItemId = itemId;
        return Task.CompletedTask;
    }

    private Task ToggleMarketAnalysisWorld(MarketAnalysisExpandedWorldKey key)
    {
        if (!_expandedWorldKeys.Add(key))
        {
            _expandedWorldKeys.Remove(key);
        }
        return Task.CompletedTask;
    }

    private Task SetMarketAnalysisSort(MarketAnalysisGridSortState sort)
    {
        _sortColumn = sort.Column;
        _sortDescending = sort.Descending;
        return Task.CompletedTask;
    }

    private Task SetMarketAnalysisWorldSort(MarketAnalysisWorldGridSortState sort)
    {
        _worldSortColumn = sort.Column;
        _worldSortDescending = sort.Descending;
        return Task.CompletedTask;
    }

    private async Task SetEvidenceOverlay(MarketAnalysisEvidenceOverlay overlay)
    {
        _evidenceOverlay = overlay;
        await Settings.SetAsync("market.analysis_evidence_overlay", overlay.ToString());
    }

    private async Task SetSearchEntireRegion(bool searchEntireRegion)
    {
        _searchEntireRegion = searchEntireRegion;
        await Settings.SetAsync("market.search_entire_region", searchEntireRegion);
    }

    private async Task OnLensChanged(MarketAcquisitionLens lens)
    {
        if (_market?.HasAnalysis != true)
        {
            return;
        }

        try
        {
            _market = await WorkerSession.ApplyMarketLensAsync(lens);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Buying strategy could not be applied: {ex.Message}", Severity.Error);
        }
    }

    private Task RunMarketAnalysisAsync() => RunMarketAnalysisAsync(
        forceRefreshData: false,
        showCompletionSnackbar: true);

    private async Task RefreshPricesAsync()
    {
        _isRefreshingPrices = true;
        try
        {
            await RunMarketAnalysisAsync(
                forceRefreshData: true,
                showCompletionSnackbar: true);
        }
        finally
        {
            _isRefreshingPrices = false;
        }
    }

    private async Task RefreshSelectedMarketItemAsync(DetailedShoppingPlan plan)
    {
        _selectedItemId = plan.ItemId;
        _isRefreshingSelectedItem = true;
        try
        {
            var outcome = await WorkerSession.RefreshMarketItemAsync(
                new WorkerMarketItemRefreshRequest(
                    plan.ItemId,
                    plan.Name,
                    _searchEntireRegion
                        ? MarketFetchScope.EntireRegion
                        : MarketFetchScope.SelectedDataCenter,
                    _market?.SelectedDataCenter ?? WorkerProjections.Shell.SelectedDataCenter,
                    _market?.SelectedRegion ?? WorkerProjections.Shell.SelectedRegion,
                    _market?.Lens ?? MarketAcquisitionLens.MinimumUpfrontCost));
            _market = outcome.Market;
            Snackbar.Add($"Refreshed {plan.Name}", Severity.Success);
        }
        finally
        {
            _isRefreshingSelectedItem = false;
        }
    }

    private async Task RunMarketAnalysisAsync(
        bool forceRefreshData,
        bool showCompletionSnackbar)
    {
        if (!CanAnalyze || _market is null)
        {
            return;
        }

        _isAnalyzing = true;
        try
        {
            var outcome = await WorkerSession.RunMarketAnalysisAsync(
                new WorkerMarketAnalysisRequest(
                    forceRefreshData,
                    _searchEntireRegion
                        ? MarketFetchScope.EntireRegion
                        : MarketFetchScope.SelectedDataCenter,
                    _market.SelectedDataCenter,
                    _market.SelectedRegion,
                    _market.Lens));
            _market = outcome.Market;
            if (showCompletionSnackbar)
            {
                Snackbar.Add(
                    $"Analyzed {outcome.AnalyzedCount:N0} items with {outcome.FetchedCount:N0} market fetches.",
                    Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Market analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private void GoToPlanner() => NavigationManager.NavigateTo("");
    private void GoToProcurement() => NavigationManager.NavigateTo("acquisition");

    public void Dispose()
    {
        WorkerProjections.Changed -= ProjectionChanged;
    }
}
