@page "/market"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services
@inject WorkerSessionCoordinator WorkerSession
@inject WorkerProjectionStore WorkerProjections
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 ma-page-container">
    <div class="ma-grid-layout">
        <aside class="ma-controls-column">
            <MudText Typo="Typo.h6" Color="Color.Primary" Class="mb-1">Market Analysis</MudText>
            <MudText Typo="Typo.caption" Class="ma-context mb-4">@ScopeSummary</MudText>

            <div class="ma-field-block">
                <MudSelect T="MarketAcquisitionLens"
                           Value="_lens"
                           ValueChanged="SetLensAsync"
                           Label="Buying strategy"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Disabled="@(_isAnalyzing || _market?.HasAnalysis != true)"
                           Class="ma-full-width">
                    <MudSelectItem Value="MarketAcquisitionLens.MinimumUpfrontCost">
                        Lowest checkout cost
                    </MudSelectItem>
                    <MudSelectItem Value="MarketAcquisitionLens.BulkValue">
                        Best bulk value
                    </MudSelectItem>
                </MudSelect>
            </div>

            <div class="ma-region-toggle-block">
                <MudCheckBox T="bool"
                             Value="@(_scope == MarketFetchScope.EntireRegion)"
                             ValueChanged="SetRegionalScope"
                             Dense="true"
                             Color="Color.Primary"
                             Class="ma-region-toggle"
                             Disabled="_isAnalyzing">
                    <MudText Typo="Typo.body2" Class="ma-region-toggle-text">
                        Search the whole region
                    </MudText>
                </MudCheckBox>
                <MudText Typo="Typo.caption" Class="ma-region-toggle-caption">
                    Uses listings from every data center in @(_market?.SelectedRegion ?? "North America").
                </MudText>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="mb-3"
                       StartIcon="@(_isAnalyzing ? string.Empty : Icons.Material.Filled.Analytics)"
                       Disabled="@(!CanAnalyze)"
                       data-benchmark-id="market-analysis-run"
                       data-can-analyze="@CanAnalyze.ToString().ToLowerInvariant()"
                       data-is-analyzing="@_isAnalyzing.ToString().ToLowerInvariant()"
                       OnClick="@(() => RunAsync(forceRefresh: false))">
                @if (_isAnalyzing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Analyzing...</span>
                }
                else
                {
                    <span>@(_market?.HasAnalysis == true ? "Reconcile" : "Run Analysis")</span>
                }
            </MudButton>

            <MudButton Variant="Variant.Outlined"
                       Color="Color.Secondary"
                       FullWidth="true"
                       Class="mb-3"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Disabled="@(!CanAnalyze)"
                       OnClick="@(() => RunAsync(forceRefresh: true))">
                Refresh Prices
            </MudButton>

            @if (_market?.HasAnalysis == true)
            {
                <div class="ma-summary-grid">
                    <div><strong>@_market.CandidateCount</strong><span>candidates</span></div>
                    <div><strong>@_market.AvailableCount</strong><span>priced</span></div>
                    <div><strong>@_market.UnavailableCount</strong><span>unavailable</span></div>
                    <div><strong>@($"{_market.EstimatedTotalCost:N0}g")</strong><span>checkout</span></div>
                </div>

                <MudButton Variant="Variant.Outlined"
                           Color="Color.Success"
                           FullWidth="true"
                           EndIcon="@Icons.Material.Filled.ArrowForward"
                           OnClick="@(() => Navigation.NavigateTo("/acquisition"))">
                    Acquisition Evaluation
                </MudButton>
            }
        </aside>

        <main class="ma-results-column">
            @if (_market?.HasAnalysis == true)
            {
                var selected = GetSelectedItem();
                <div class="ma-ledger-shell">
                    <div class="ma-ledger-workspace">
                        <div class="ma-ledger-list">
                            <div class="ma-table-scroll">
                                <table class="ma-ledger-table">
                                    <thead>
                                        <tr>
                                            <th style="width:32%;">Item</th>
                                            <th style="width:13%;">Qty</th>
                                            <th style="width:29%;">Coverage</th>
                                            <th style="width:11%;">Worlds</th>
                                            <th style="width:15%;">Cash Out</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _market.Items)
                                        {
                                            <tr class="@GetItemRowClass(item)"
                                                @onclick="@(() => SelectItem(item.ItemId))">
                                                <td>
                                                    <span class="ma-item-cell">
                                                        <span class="ma-item-name">@item.Name</span>
                                                        <span class="ma-item-kind">@FormatQuality(item.DataQuality)</span>
                                                    </span>
                                                </td>
                                                <td class="ma-number-column">@($"{item.QuantityNeeded:N0}")</td>
                                                <td class="ma-recommendation-column">
                                                    <span>@FormatCoverage(item)</span>
                                                </td>
                                                <td class="ma-number-column">@item.WorldCount</td>
                                                <td class="ma-total-column">
                                                    @(item.IsAvailable ? $"{item.EstimatedTotalCost:N0}g" : "Unavailable")
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <aside class="ma-detail-pane">
                            @if (selected is null)
                            {
                                <div class="ma-detail-empty">
                                    <MudIcon Icon="@Icons.Material.Filled.TableRows" Size="Size.Large" />
                                    <MudText Typo="Typo.body2">
                                        Select an item to inspect its market detail.
                                    </MudText>
                                </div>
                            }
                            else
                            {
                                <div class="ma-detail-header">
                                    <div class="ma-detail-title-block">
                                        <div class="ma-detail-title-row">
                                            <span class="ma-detail-title">@selected.Name</span>
                                        </div>
                                        <MudText Typo="Typo.caption" Class="ma-detail-subtitle">
                                            @($"{selected.QuantityNeeded:N0} needed · {selected.AvailableQuantity:N0} listed")
                                        </MudText>
                                    </div>
                                    <MudText Typo="Typo.subtitle1" Class="ma-detail-total">
                                        @(selected.IsAvailable ? $"{selected.EstimatedTotalCost:N0}g" : "Unavailable")
                                    </MudText>
                                </div>

                                @if (!string.IsNullOrWhiteSpace(selected.Warning))
                                {
                                    <div class="ma-inline-warning">@selected.Warning</div>
                                }

                                <div class="ma-detail-scroll">
                                    <table class="ma-ledger-table">
                                        <thead>
                                            <tr>
                                                <th>World</th>
                                                <th>DC</th>
                                                <th>Stock</th>
                                                <th>Unit</th>
                                                <th>Total</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var world in selected.Worlds)
                                            {
                                                <tr>
                                                    <td>@world.WorldName</td>
                                                    <td>@world.DataCenter</td>
                                                    <td class="ma-number-column">@($"{world.Quantity:N0}")</td>
                                                    <td class="ma-number-column">@($"{world.AverageUnitPrice:N0}g")</td>
                                                    <td class="ma-total-column">@($"{world.TotalCost:N0}g")</td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </aside>
                    </div>
                </div>
            }
            else if (_market?.HasPlan == true)
            {
                <MudPaper Elevation="2" Class="pa-4 ma-state-paper">
                    <div class="ma-state-inner">
                        <MudIcon Icon="@Icons.Material.Filled.Analytics"
                                 Size="Size.Large"
                                 Class="ma-state-icon" />
                        <MudText Typo="Typo.h6" Class="ma-state-title">Ready to Analyze</MudText>
                        <MudText Typo="Typo.body2" Class="ma-state-body">
                            @_market.CandidateCount items are ready for regional pricing.
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Analytics"
                                   Disabled="@(!CanAnalyze)"
                                   OnClick="@(() => RunAsync(forceRefresh: false))">
                            Run Analysis
                        </MudButton>
                    </div>
                </MudPaper>
            }
            else
            {
                <MudPaper Elevation="2" Class="pa-4 ma-state-paper">
                    <div class="ma-state-inner">
                        <MudIcon Icon="@Icons.Material.Filled.ShoppingCart"
                                 Size="Size.Large"
                                 Class="ma-state-icon" />
                        <MudText Typo="Typo.h6" Class="ma-state-title">No Items to Analyze</MudText>
                        <MudText Typo="Typo.body2" Class="ma-state-body">
                            Build a recipe plan first, then return here to price its acquisition candidates.
                        </MudText>
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.ArrowBack"
                                   OnClick="@(() => Navigation.NavigateTo("/"))">
                            Recipe Planner
                        </MudButton>
                    </div>
                </MudPaper>
            }
        </main>
    </div>
</MudContainer>

@code {
    private WorkerMarketProjection? _market;
    private MarketFetchScope _scope = MarketFetchScope.EntireRegion;
    private MarketAcquisitionLens _lens = MarketAcquisitionLens.MinimumUpfrontCost;
    private int? _selectedItemId;
    private bool _isAnalyzing;

    [SupplyParameterFromQuery(Name = "itemId")]
    public int? RequestedItemId { get; set; }

    private bool CanAnalyze =>
        !_isAnalyzing &&
        _market?.HasPlan == true &&
        _market.CandidateCount > 0 &&
        !string.IsNullOrWhiteSpace(_market.SelectedDataCenter);

    private string ScopeSummary =>
        _scope == MarketFetchScope.EntireRegion
            ? $"{_market?.SelectedRegion ?? "North America"} · regional evidence"
            : $"{_market?.SelectedDataCenter ?? "Aether"} · data-center evidence";

    protected override async Task OnInitializedAsync()
    {
        WorkerProjections.Changed += ProjectionChanged;
        _market = await WorkerSession.GetMarketProjectionAsync();
        if (_market is null)
        {
            return;
        }

        _scope = _market.Scope;
        _lens = _market.Lens;
        if (RequestedItemId.HasValue &&
            _market.Items.Any(item => item.ItemId == RequestedItemId.Value))
        {
            _selectedItemId = RequestedItemId.Value;
        }
        EnsureSelectedItem();
    }

    private void ProjectionChanged()
    {
        _market = WorkerProjections.Market ?? _market;
        EnsureSelectedItem();
        _ = InvokeAsync(StateHasChanged);
    }

    private void SetRegionalScope(bool regional) =>
        _scope = regional
            ? MarketFetchScope.EntireRegion
            : MarketFetchScope.SelectedDataCenter;

    private async Task SetLensAsync(MarketAcquisitionLens lens)
    {
        if (_market?.HasAnalysis != true || lens == _lens)
        {
            _lens = lens;
            return;
        }

        _isAnalyzing = true;
        try
        {
            _market = await WorkerSession.ApplyMarketLensAsync(lens);
            _lens = lens;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task RunAsync(bool forceRefresh)
    {
        if (!CanAnalyze || _market is null)
        {
            return;
        }

        _isAnalyzing = true;
        try
        {
            var outcome = await WorkerSession.RunMarketAnalysisAsync(
                new WorkerMarketAnalysisRequest(
                    forceRefresh,
                    _scope,
                    _market.SelectedDataCenter,
                    _market.SelectedRegion,
                    _lens));
            _market = outcome.Market;
            EnsureSelectedItem();
            if (_market.UnavailableCount > 0)
            {
                Snackbar.Add(
                    $"Market Analysis priced {_market.AvailableCount}/{_market.CandidateCount} items; {_market.UnavailableCount} have no usable evidence in this scope.",
                    Severity.Warning);
            }
            else
            {
                Snackbar.Add(
                    $"Market Analysis priced {_market.AvailableCount} items using {outcome.FetchedCount} fresh market responses.",
                    Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Market Analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private void SelectItem(int itemId) =>
        _selectedItemId = itemId;

    private WorkerMarketItemProjection? GetSelectedItem() =>
        _market?.Items.FirstOrDefault(item => item.ItemId == _selectedItemId)
        ?? _market?.Items.FirstOrDefault();

    private void EnsureSelectedItem()
    {
        if (_market?.Items.Any(item => item.ItemId == _selectedItemId) != true)
        {
            _selectedItemId = _market?.Items.FirstOrDefault()?.ItemId;
        }
    }

    private string GetItemRowClass(WorkerMarketItemProjection item)
    {
        var classes = new List<string>();
        if (_selectedItemId == item.ItemId)
        {
            classes.Add("is-selected");
        }
        if (!string.IsNullOrWhiteSpace(item.Warning))
        {
            classes.Add("has-warning");
        }
        return string.Join(" ", classes);
    }

    private static string FormatCoverage(WorkerMarketItemProjection item) =>
        item.IsAvailable
            ? item.HasSufficientStock
                ? item.RecommendedWorld
                : $"{item.AvailableQuantity:N0}/{item.QuantityNeeded:N0} available · {item.RecommendedWorld}"
            : "Unavailable in this scope";

    private static string FormatQuality(MarketDataQualityBucket quality) =>
        quality switch
        {
            MarketDataQualityBucket.Current => "Current",
            MarketDataQualityBucket.Aging => "Aging",
            MarketDataQualityBucket.Old => "Old",
            MarketDataQualityBucket.VeryOld => "Very old",
            MarketDataQualityBucket.Ancient => "Ancient",
            _ => "Missing"
        };

    public void Dispose()
    {
        WorkerProjections.Changed -= ProjectionChanged;
    }
}
