@page "/market"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@using static FFXIV_Craft_Architect.Core.Models.MarketSortOption
@inject GarlandService GarlandService
@inject RecipeCalculationService RecipeCalculationService
@inject MarketShoppingService MarketShoppingService
@inject IMarketCacheService MarketCache
@inject ILogger<MarketAnalysis> Logger
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject AppState AppState
@inject IndexedDbService IndexedDb
@inject NavigationManager NavigationManager
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 ma-page-container">
    <div class="ma-grid-layout">
        <MarketAnalysisControlsPanel
            AppState="AppState"
            IsAnalyzing="_isAnalyzing"
            IsRefreshingPrices="_isRefreshingPrices"
            CanAnalyze="CanAnalyze()"
            CanRefreshPrices="CanRefreshPrices()"
            OnModeChangedRequested="OnModeChanged"
            OnRunAnalysisRequested="RunMarketAnalysisAsync"
            OnRefreshPricesRequested="RefreshPricesAsync"
            OnGoToPlannerRequested="GoToPlanner"
            OnGoToProcurementRequested="GoToProcurement" />

        <MarketAnalysisResultsPanel
            BuyItems="GetBuyItems()"
            ShoppingPlans="AppState.ShoppingPlans"
            CurrentSort="AppState.MarketSortPreference"
            AutoExpandItemId="AppState.AutoExpandItemId"
            ShowWorldsColumn="AppState.SearchEntireRegion"
            IsAnalyzing="_isAnalyzing"
            OnGoToPlannerRequested="GoToPlanner"
            OnRunAnalysisRequested="RunMarketAnalysisAsync" />
    </div>
</MudContainer>

@code {
    private bool _isAnalyzing = false;
    private bool _isRefreshingPrices = false;

    // Settings now stored in AppState for persistence across page navigations

    protected override void OnInitialized()
    {
        // Subscribe to plan changes (including restoration from auto-save)
        AppState.OnPlanChanged += OnPlanChanged;
        AppState.OnShoppingListChanged += OnShoppingListChanged;
    }

    protected override void OnAfterRender(bool firstRender)
    {
        // Clear the auto-expand item ID after the first render
        // This ensures it doesn't persist if the user navigates away and back
        if (firstRender && AppState.AutoExpandItemId.HasValue)
        {
            AppState.AutoExpandItemId = null;
        }
    }

    private void OnPlanChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnShoppingListChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnPlanChanged -= OnPlanChanged;
        AppState.OnShoppingListChanged -= OnShoppingListChanged;
    }

    /// <summary>
    /// Get the current items marked for buying from the recipe plan.
    /// This dynamically reflects any changes made in the recipe tree.
    /// </summary>
    private List<MaterialAggregate> GetBuyItems()
    {
        return AcquisitionPlanningService.GetMarketAnalysisCandidates(AppState.CurrentPlan);
    }

    private bool CanAnalyze()
    {
        return GetBuyItems().Any() && !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    private bool CanRefreshPrices()
    {
        return AppState.CurrentPlan != null && !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    private async Task RefreshPricesAsync()
    {
        if (AppState.CurrentPlan == null) return;

        _isRefreshingPrices = true;
        AppState.SetStatus("Fetching latest market data...", busy: true);

        try
        {
            // Step 1: Fetch vendor prices
            await RecipeCalculationService.FetchVendorPricesAsync(AppState.CurrentPlan);

            // Step 2: Fetch market prices
            var itemIds = AppState.CurrentPlan.GetAllItemIds().ToList();
            if (itemIds.Any())
            {
                AppState.SetStatus("Fetching market prices...", busy: true);
                var marketItemIds = MarketPriceAvailability.GetMarketListableItemIds(AppState.CurrentPlan, itemIds);
                var nonMarketItemIds = MarketPriceAvailability.GetNonMarketListableItemIds(AppState.CurrentPlan, itemIds);
                var marketEntries = await MarketScopedPriceLoader.LoadBestEntriesAsync(
                    MarketCache,
                    marketItemIds,
                    AppState.SearchEntireRegion ? MarketFetchScope.EntireRegion : MarketFetchScope.SelectedDataCenter,
                    AppState.SelectedDataCenter,
                    AppState.SelectedRegion,
                    maxAge: TimeSpan.Zero);
                var refreshResult = MarketPriceAvailability.FromCachedMarketData(AppState.CurrentPlan, marketItemIds, marketEntries, nonMarketItemIds);
                AppState.SetUnavailableMarketItems(refreshResult.UnavailableItems);

                // Update node prices
                UpdateNodeMarketPrices(AppState.CurrentPlan.RootItems, marketEntries);

                Logger.LogInformation("[Market Refresh] Loaded {Count} market entries from cache", marketEntries.Count);
            }

            AppState.NotifyPlanChanged();

            // Recompute from the freshly updated cache so Procurement reflects the manual refresh.
            var canReanalyze = GetBuyItems().Any() && !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
            if (canReanalyze)
            {
                var rebuilt = await RunMarketAnalysisAsync(forceRefreshData: false, showCompletionSnackbar: false);
                if (rebuilt)
                {
                    if (AppState.UnavailableMarketItems.Any())
                    {
                        var warning = MarketPriceAvailability.FormatUnavailableMessage(AppState.UnavailableMarketItems);
                        Snackbar.Add($"Prices refreshed with warnings. {warning}", Severity.Warning);
                    }
                    else
                    {
                        Snackbar.Add("Prices refreshed and procurement plan rebuilt", Severity.Success);
                    }
                }
                else
                {
                    Snackbar.Add("Prices refreshed, but failed to rebuild procurement plan", Severity.Warning);
                }
            }
            else
            {
                AppState.SetStatus("Prices refreshed", busy: false);
                if (AppState.UnavailableMarketItems.Any())
                {
                    Snackbar.Add(MarketPriceAvailability.FormatUnavailableMessage(AppState.UnavailableMarketItems), Severity.Warning);
                }
                else
                {
                    Snackbar.Add("Prices refreshed", Severity.Success);
                }
            }
        }
        catch (Exception ex)
        {
            AppState.SetStatus($"Price refresh failed: {ex.Message}");
            Snackbar.Add($"Failed to refresh prices: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isRefreshingPrices = false;
        }
    }

    private void UpdateNodeMarketPrices(List<PlanNode> nodes, IReadOnlyDictionary<int, CachedMarketData> marketEntries)
    {
        foreach (var node in nodes)
        {
            if (marketEntries.TryGetValue(node.ItemId, out var entry))
            {
                node.MarketPrice = MarketScopedPriceLoader.GetComparableAveragePrice(entry);

                // Calculate HQ price if available
                var hqListings = entry.Worlds.SelectMany(world => world.Listings).Where(listing => listing.IsHq).ToList();
                if (hqListings.Any())
                {
                    node.HqMarketPrice = (decimal)hqListings.Average(listing => listing.PricePerUnit);
                }
            }

            // Recursively update children
            if (node.Children?.Any() == true)
            {
                UpdateNodeMarketPrices(node.Children, marketEntries);
            }
        }
    }

    private async Task RunMarketAnalysisAsync()
    {
        await RunMarketAnalysisAsync(forceRefreshData: false, showCompletionSnackbar: true);
    }

    private async Task<bool> RunMarketAnalysisAsync(bool forceRefreshData, bool showCompletionSnackbar)
    {
        NormalizeRecommendationMode();
        var materials = GetBuyItems();

        var plan = AppState.CurrentPlan;
        if (plan == null || !materials.Any() || string.IsNullOrWhiteSpace(AppState.SelectedDataCenter))
            return false;

        _isAnalyzing = true;
        AppState.ShoppingPlans.Clear();
        AppState.BeginOperation("Market Analysis", $"Analyzing {materials.Count} items on {AppState.SelectedDataCenter}...");

        try
        {
            var progress = new Progress<string>(msg => AppState.SetStatus(msg, busy: true));
            var maxAge = forceRefreshData ? TimeSpan.Zero : (TimeSpan?)null;

            var scope = AppState.SearchEntireRegion ? MarketFetchScope.EntireRegion : MarketFetchScope.SelectedDataCenter;
            var evidence = await MarketEvidenceLoader.LoadAsync(
                MarketCache,
                materials.Select(material => material.ItemId),
                scope,
                AppState.SelectedDataCenter,
                AppState.SelectedRegion,
                maxAge,
                progress);

            Logger.LogInformation("Market Analysis: {FetchedCount} items fetched from API", evidence.FetchedCount);

            // Step 2: Calculate shopping plans from cached data
            var plans = await MarketShoppingService.CalculateDetailedShoppingPlansAsync(
                new MarketAnalysisRequest
                {
                    Items = materials,
                    Evidence = evidence,
                    RecommendationMode = GetEffectiveRecommendationMode(),
                    BlacklistedMarketWorlds = AppState.TemporarilyBlacklistedMarketWorlds
                },
                progress);

            // Apply hard-lock vendor overrides for vendor-buy items
            MarketShoppingService.ApplyVendorPurchaseOverrides(AppState.CurrentPlan, plans);

            AppState.ShoppingPlans = plans;
            AcquisitionPlanningService.ApplyCheapestAcquisitionDefaults(AppState.CurrentPlan, AppState.ShoppingPlans);
            MarketShoppingService.ApplyVendorPurchaseOverrides(AppState.CurrentPlan, AppState.ShoppingPlans);
            AppState.NotifyShoppingListChanged();
            AppState.NotifyPlanChanged();

            // Save market analysis to the current plan for persistence
            if (AppState.CurrentPlanId != null)
            {
                await IndexedDb.SaveMarketAnalysisAsync(AppState.CurrentPlanId, plans, GetEffectiveRecommendationMode());
            }

            // Ensure the status message is properly set to completion
            AppState.EndOperation($"Analysis complete. {AppState.ShoppingPlans.Count} items analyzed.");
            if (showCompletionSnackbar)
            {
                Snackbar.Add("Market analysis complete!", Severity.Success);
            }

            return true;
        }
        catch (Exception ex)
        {
            AppState.SetStatus($"Analysis failed: {ex.Message}");
            Snackbar.Add($"Market analysis failed: {ex.Message}", Severity.Error);
            return false;
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task OnModeChanged(RecommendationMode mode)
    {
        AppState.RecommendationMode = NormalizeRecommendationMode(mode);
        if (GetBuyItems().Any() && AppState.ShoppingPlans.Any())
        {
            await RunMarketAnalysisAsync();
        }
    }

    private void GoToPlanner()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("./");
    }

    private void GoToProcurement()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("acquisition");
    }

    private IReadOnlyList<string> GetCurrentRegionDataCenters()
    {
        return MarketFetchScopeResolver.GetDataCenters(
            MarketFetchScope.EntireRegion,
            AppState.SelectedDataCenter,
            AppState.SelectedRegion);
    }

    private RecommendationMode GetEffectiveRecommendationMode()
    {
        return NormalizeRecommendationMode(AppState.RecommendationMode);
    }

    private void NormalizeRecommendationMode()
    {
        AppState.RecommendationMode = NormalizeRecommendationMode(AppState.RecommendationMode);
    }

    private static RecommendationMode NormalizeRecommendationMode(RecommendationMode mode)
    {
        return mode == RecommendationMode.MaximizeValue
            ? RecommendationMode.MinimizeTotalCost
            : mode;
    }
}
