@page "/market"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Web.Services
@inject WorkerSessionCoordinator WorkerSession
@inject WorkerProjectionStore WorkerProjections
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-4">
    <MudPaper Class="pa-4 mb-3" Elevation="0" Outlined="true">
        <div style="display:flex; align-items:center; gap:16px; flex-wrap:wrap;">
            <div style="min-width:230px; flex:1;">
                <MudText Typo="Typo.h5">Market Analysis</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    @ScopeSummary
                </MudText>
            </div>

            <MudSwitch T="bool"
                       Value="@(_scope == MarketFetchScope.EntireRegion)"
                       ValueChanged="SetRegionalScope"
                       Color="Color.Primary"
                       Dense="true"
                       Label="Search the whole region"
                       Disabled="_isAnalyzing" />

            <MudSelect T="MarketAcquisitionLens"
                       Value="_lens"
                       ValueChanged="SetLensAsync"
                       Label="Buying strategy"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Disabled="@(_isAnalyzing || _market?.HasAnalysis != true)"
                       Style="min-width:190px;">
                <MudSelectItem Value="MarketAcquisitionLens.MinimumUpfrontCost">
                    Lowest checkout cost
                </MudSelectItem>
                <MudSelectItem Value="MarketAcquisitionLens.BulkValue">
                    Best bulk value
                </MudSelectItem>
            </MudSelect>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       Disabled="@(!CanAnalyze)"
                       data-benchmark-id="market-analysis-run"
                       data-can-analyze="@CanAnalyze.ToString().ToLowerInvariant()"
                       data-is-analyzing="@_isAnalyzing.ToString().ToLowerInvariant()"
                       OnClick="@(() => RunAsync(forceRefresh: false))">
                @(_market?.HasAnalysis == true ? "Reconcile" : "Analyze market")
            </MudButton>
            <MudButton Variant="Variant.Outlined"
                       Color="Color.Primary"
                       Disabled="@(!CanAnalyze)"
                       OnClick="@(() => RunAsync(forceRefresh: true))">
                Refresh prices
            </MudButton>
        </div>
    </MudPaper>

    @if (_isAnalyzing)
    {
        <MudProgressLinear Color="Color.Primary" Indeterminate="true" Class="mb-3" />
    }

    @if (_market?.HasAnalysis == true)
    {
        <div style="display:grid; grid-template-columns:repeat(4, minmax(130px, 1fr)); gap:8px; margin-bottom:12px;">
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.caption">Market candidates</MudText>
                <MudText Typo="Typo.h6">@_market.CandidateCount</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.caption">Priced</MudText>
                <MudText Typo="Typo.h6">@_market.AvailableCount</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.caption">Unavailable</MudText>
                <MudText Typo="Typo.h6">@_market.UnavailableCount</MudText>
            </MudPaper>
            <MudPaper Class="pa-3" Elevation="0" Outlined="true">
                <MudText Typo="Typo.caption">Estimated checkout</MudText>
                <MudText Typo="Typo.h6">@($"{_market.EstimatedTotalCost:N0}g")</MudText>
            </MudPaper>
        </div>

        <MudPaper Elevation="0" Outlined="true">
            <MudTable Items="_market.Items" Dense="true" Hover="true" Elevation="0">
                <HeaderContent>
                    <MudTh>Item</MudTh>
                    <MudTh Align="Right">Needed</MudTh>
                    <MudTh>Recommendation</MudTh>
                    <MudTh Align="Right">Unit</MudTh>
                    <MudTh Align="Right">Total</MudTh>
                    <MudTh>Evidence</MudTh>
                </HeaderContent>
                <RowTemplate Context="item">
                    <MudTd DataLabel="Item">
                        <MudButton Variant="Variant.Text"
                                   Size="Size.Small"
                                   OnClick="@(() => ToggleItem(item.ItemId))">
                            @item.Name
                        </MudButton>
                    </MudTd>
                    <MudTd DataLabel="Needed" Align="Right">@item.QuantityNeeded</MudTd>
                    <MudTd DataLabel="Recommendation">
                        @if (item.IsAvailable)
                        {
                            <span>@item.RecommendedWorld</span>
                            @if (!item.HasSufficientStock)
                            {
                                <MudChip T="string" Size="Size.Small" Color="Color.Warning">
                                    @($"{item.AvailableQuantity}/{item.QuantityNeeded}")
                                </MudChip>
                            }
                        }
                        else
                        {
                            <span>Unavailable in this scope</span>
                        }
                    </MudTd>
                    <MudTd DataLabel="Unit" Align="Right">
                        @(item.IsAvailable ? $"{item.EstimatedUnitPrice:N0}g" : "-")
                    </MudTd>
                    <MudTd DataLabel="Total" Align="Right">
                        @(item.IsAvailable ? $"{item.EstimatedTotalCost:N0}g" : "-")
                    </MudTd>
                    <MudTd DataLabel="Evidence">@FormatQuality(item.DataQuality)</MudTd>
                </RowTemplate>
                <ChildRowContent Context="item">
                    @if (_expandedItemId == item.ItemId)
                    {
                        <MudTr>
                            <MudTd ColSpan="6">
                                @if (!string.IsNullOrWhiteSpace(item.Warning))
                                {
                                    <MudText Typo="Typo.body2" Color="Color.Warning">
                                        @item.Warning
                                    </MudText>
                                }
                                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(210px, 1fr)); gap:6px; padding:8px 0;">
                                    @foreach (var world in item.Worlds)
                                    {
                                        <MudPaper Class="pa-2" Elevation="0" Outlined="true">
                                            <MudText Typo="Typo.subtitle2">@world.WorldName</MudText>
                                            <MudText Typo="Typo.caption">@world.DataCenter · @world.Quantity available</MudText>
                                            <MudText Typo="Typo.body2">
                                                @($"{world.AverageUnitPrice:N0}g each · {world.TotalCost:N0}g")
                                            </MudText>
                                        </MudPaper>
                                    }
                                </div>
                            </MudTd>
                        </MudTr>
                    }
                </ChildRowContent>
            </MudTable>
        </MudPaper>

        <div style="display:flex; justify-content:flex-end; margin-top:12px;">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="@(() => Navigation.NavigateTo("/procurement"))">
                Build procurement route
            </MudButton>
        </div>
    }
    else if (_market?.HasPlan == true)
    {
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudText Typo="Typo.h6">Ready to price @_market.CandidateCount items</MudText>
            <MudText Typo="Typo.body2">
                Market Analysis evaluates every valid acquisition candidate. Procurement routing comes afterward and cannot change whether an item should be crafted, bought, or vendor-purchased.
            </MudText>
        </MudPaper>
    }
    else
    {
        <MudPaper Class="pa-6" Elevation="0" Outlined="true">
            <MudText Typo="Typo.h6">Build a recipe plan first</MudText>
        </MudPaper>
    }
</MudContainer>

@code {
    private WorkerMarketProjection? _market;
    private MarketFetchScope _scope = MarketFetchScope.EntireRegion;
    private MarketAcquisitionLens _lens = MarketAcquisitionLens.MinimumUpfrontCost;
    private int? _expandedItemId;
    private bool _isAnalyzing;

    private bool CanAnalyze =>
        !_isAnalyzing &&
        _market?.HasPlan == true &&
        _market.CandidateCount > 0 &&
        !string.IsNullOrWhiteSpace(_market.SelectedDataCenter);

    private string ScopeSummary =>
        _scope == MarketFetchScope.EntireRegion
            ? $"{_market?.SelectedRegion ?? "North America"} · regional evidence"
            : $"{_market?.SelectedDataCenter ?? "Aether"} · data-center evidence";

    protected override async Task OnInitializedAsync()
    {
        WorkerProjections.Changed += ProjectionChanged;
        _market = await WorkerSession.GetMarketProjectionAsync();
        if (_market is not null)
        {
            _scope = _market.Scope;
            _lens = _market.Lens;
        }
    }

    private void ProjectionChanged()
    {
        _market = WorkerProjections.Market ?? _market;
        _ = InvokeAsync(StateHasChanged);
    }

    private void SetRegionalScope(bool regional) =>
        _scope = regional
            ? MarketFetchScope.EntireRegion
            : MarketFetchScope.SelectedDataCenter;

    private async Task SetLensAsync(MarketAcquisitionLens lens)
    {
        if (_market?.HasAnalysis != true || lens == _lens)
        {
            _lens = lens;
            return;
        }

        _isAnalyzing = true;
        try
        {
            _market = await WorkerSession.ApplyMarketLensAsync(lens);
            _lens = lens;
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task RunAsync(bool forceRefresh)
    {
        if (!CanAnalyze || _market is null)
        {
            return;
        }

        _isAnalyzing = true;
        try
        {
            var outcome = await WorkerSession.RunMarketAnalysisAsync(
                new WorkerMarketAnalysisRequest(
                    forceRefresh,
                    _scope,
                    _market.SelectedDataCenter,
                    _market.SelectedRegion,
                    _lens));
            _market = outcome.Market;
            if (_market.UnavailableCount > 0)
            {
                Snackbar.Add(
                    $"Market Analysis priced {_market.AvailableCount}/{_market.CandidateCount} items; {_market.UnavailableCount} have no usable evidence in this scope.",
                    Severity.Warning);
            }
            else
            {
                Snackbar.Add(
                    $"Market Analysis priced {_market.AvailableCount} items using {outcome.FetchedCount} fresh market responses.",
                    Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Market Analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private void ToggleItem(int itemId) =>
        _expandedItemId = _expandedItemId == itemId ? null : itemId;

    private static string FormatQuality(MarketDataQualityBucket quality) =>
        quality switch
        {
            MarketDataQualityBucket.Current => "Current",
            MarketDataQualityBucket.Aging => "Aging",
            MarketDataQualityBucket.Old => "Old",
            MarketDataQualityBucket.VeryOld => "Very old",
            MarketDataQualityBucket.Ancient => "Ancient",
            _ => "Missing"
        };

    public void Dispose()
    {
        WorkerProjections.Changed -= ProjectionChanged;
    }
}
