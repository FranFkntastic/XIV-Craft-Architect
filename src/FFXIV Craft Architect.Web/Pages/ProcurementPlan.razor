@page "/procurement"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject WorkerSessionCoordinator WorkerSession
@inject WorkerProjectionStore WorkerProjections
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@implements IDisposable

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0" Style="height:calc(100vh - 64px);">
    <div style="display:grid; grid-template-columns:320px minmax(0, 1fr); height:100%;">
        <aside style="padding:16px; border-right:1px solid var(--mud-palette-divider); display:flex; flex-direction:column; gap:16px;">
            <div>
                <MudText Typo="Typo.h5">Procurement Plan</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Route the purchases Acquisition Evaluation already chose.
                </MudText>
            </div>

            <MudSwitch T="bool"
                       Value="_regional"
                       ValueChanged="@((bool value) => _regional = value)"
                       Color="Color.Primary"
                       Dense="true"
                       Label="Search the whole region"
                       Disabled="_isAnalyzing" />

            <MudSwitch T="bool"
                       Value="_includeSplitPurchases"
                       ValueChanged="@((bool value) => _includeSplitPurchases = value)"
                       Color="Color.Primary"
                       Dense="true"
                       Label="Allow split purchases"
                       Disabled="_isAnalyzing" />

            <MudSwitch T="bool"
                       Value="_startFromHomeDataCenter"
                       ValueChanged="@((bool value) => _startFromHomeDataCenter = value)"
                       Color="Color.Primary"
                       Dense="true"
                       Label="Start from home data center"
                       Disabled="@(_isAnalyzing || !_regional)" />

            <MudSelect T="MarketTravelPriority"
                       Value="_travelPriority"
                       ValueChanged="@((MarketTravelPriority value) => _travelPriority = value)"
                       Label="Optimize travel by"
                       Dense="true"
                       Variant="Variant.Outlined"
                       Disabled="_isAnalyzing">
                <MudSelectItem Value="MarketTravelPriority.DataCenterTransfersFirst">
                    Data-center transfers first
                </MudSelectItem>
                <MudSelectItem Value="MarketTravelPriority.WorldVisitsFirst">
                    World visits first
                </MudSelectItem>
            </MudSelect>

            <div>
                <div style="display:flex; justify-content:space-between; align-items:baseline;">
                    <MudText Typo="Typo.subtitle2">Travel tolerance</MudText>
                    <MudText Typo="Typo.caption">@_travelTolerance / 11</MudText>
                </div>
                <input type="range"
                       min="0"
                       max="11"
                       value="@_travelTolerance"
                       disabled="@(_isAnalyzing || _route?.HasRoute != true)"
                       @oninput="PreviewTolerance"
                       @onchange="CommitToleranceAsync"
                       style="width:100%;" />
                <MudText Typo="Typo.caption">@ToleranceLabel</MudText>
            </div>

            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       FullWidth="true"
                       Class="pp-primary-action"
                       Disabled="@(!CanGenerate)"
                       OnClick="GenerateAsync">
                @if (_isAnalyzing)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    <span>Building route</span>
                }
                else
                {
                    <span>@(_route?.HasRoute == true ? "Regenerate route" : "Generate route")</span>
                }
            </MudButton>

            <MudButton Variant="Variant.Text"
                       OnClick="@(() => Navigation.NavigateTo("/market"))">
                Market Analysis
            </MudButton>
        </aside>

        <main style="min-width:0; overflow:auto; padding:20px;">
            @if (_route?.HasRoute == true)
            {
                <MudPaper Class="pa-4 mb-3" Elevation="0" Outlined="true">
                    <div style="display:flex; justify-content:space-between; gap:20px; align-items:center; flex-wrap:wrap;">
                        <div>
                            <MudText Typo="Typo.h6">Procurement route</MudText>
                            <MudText Typo="Typo.body2" Color="Color.Secondary">
                                @_route.WorldStops world stops · @_route.DataCenterTransfers data-center transfers
                            </MudText>
                        </div>
                        <div style="text-align:right;">
                            <MudText Typo="Typo.h5">@($"{_route.SelectedGilCost:N0}g")</MudText>
                            @if (_route.PremiumGil > 0)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @($"{_route.PremiumGil:N0}g over the cheapest route")
                                </MudText>
                            }
                        </div>
                    </div>
                    @if (_route.RouteSearchWasTruncated)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Warning" Class="mt-2">
                            This is the best complete route found within the bounded search.
                        </MudText>
                    }
                </MudPaper>

                <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(330px, 1fr)); gap:10px;">
                    @foreach (var world in _route.Worlds)
                    {
                        <MudPaper Elevation="0" Outlined="true">
                            <div style="display:flex; justify-content:space-between; padding:12px 14px; border-bottom:1px solid var(--mud-palette-divider);">
                                <div>
                                    <MudText Typo="Typo.subtitle1">@world.WorldName</MudText>
                                    <MudText Typo="Typo.caption">
                                        @(world.IsVendor ? "Vendor purchases" : world.DataCenter)
                                    </MudText>
                                </div>
                                <div style="text-align:right;">
                                    <MudText Typo="Typo.subtitle1">@($"{world.TotalCost:N0}g")</MudText>
                                    <MudText Typo="Typo.caption">@world.ItemCount items</MudText>
                                </div>
                            </div>
                            <MudTable Items="world.Items" Dense="true" Elevation="0">
                                <HeaderContent>
                                    <MudTh>Item</MudTh>
                                    <MudTh Align="Right">Qty</MudTh>
                                    <MudTh Align="Right">Unit</MudTh>
                                    <MudTh Align="Right">Total</MudTh>
                                </HeaderContent>
                                <RowTemplate Context="item">
                                    <MudTd DataLabel="Item">@item.Name</MudTd>
                                    <MudTd DataLabel="Qty" Align="Right">
                                        @item.Quantity
                                        @if (item.IsSplitPurchase)
                                        {
                                            <span> / @item.TotalQuantityNeeded</span>
                                        }
                                    </MudTd>
                                    <MudTd DataLabel="Unit" Align="Right">@($"{item.UnitPrice:N0}g")</MudTd>
                                    <MudTd DataLabel="Total" Align="Right">@($"{item.TotalCost:N0}g")</MudTd>
                                </RowTemplate>
                            </MudTable>
                        </MudPaper>
                    }
                </div>
            }
            else if (_route?.HasMarketEvidence == true)
            {
                <MudPaper Class="pa-6" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6">Ready to route @_route.ActiveItemCount purchases</MudText>
                    <MudText Typo="Typo.body2">
                        The route generator will reuse Market Analysis evidence and compute every travel-tolerance position in one pass.
                    </MudText>
                </MudPaper>
            }
            else if (_route?.HasPlan == true)
            {
                <MudPaper Class="pa-6" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6">Market evidence required</MudText>
                    <MudText Typo="Typo.body2">
                        Run Market Analysis first. Procurement organizes accepted purchases; it does not decide what should be bought.
                    </MudText>
                    <MudButton Class="mt-3"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               OnClick="@(() => Navigation.NavigateTo("/market"))">
                        Open Market Analysis
                    </MudButton>
                </MudPaper>
            }
            else
            {
                <MudPaper Class="pa-6" Elevation="0" Outlined="true">
                    <MudText Typo="Typo.h6">Build a recipe plan first</MudText>
                </MudPaper>
            }
        </main>
    </div>
</MudContainer>

@code {
    private WorkerProcurementProjection? _route;
    private WorkerMarketProjection? _market;
    private bool _regional = true;
    private bool _includeSplitPurchases;
    private bool _startFromHomeDataCenter = true;
    private MarketTravelPriority _travelPriority =
        MarketTravelPriority.DataCenterTransfersFirst;
    private int _travelTolerance;
    private bool _isAnalyzing;

    private bool CanGenerate =>
        !_isAnalyzing &&
        _route?.HasMarketEvidence == true &&
        _route.ActiveItemCount > 0 &&
        _market is not null;

    private string ToleranceLabel =>
        _route?.HasRoute == true && _route.TravelTolerance == _travelTolerance
            ? _route.TravelToleranceLabel
            : MarketRouteScoring.GetToleranceLabel(_travelTolerance);

    protected override async Task OnInitializedAsync()
    {
        WorkerProjections.Changed += ProjectionChanged;
        _market = await WorkerSession.GetMarketProjectionAsync();
        _route = await WorkerSession.GetProcurementProjectionAsync();
        if (_route is not null)
        {
            _regional = _route.HasRoute ? _route.SearchesEntireRegion : true;
            _travelPriority = _route.TravelPriority;
            _travelTolerance = _route.TravelTolerance;
            _includeSplitPurchases = _route.IncludeSplitPurchases;
        }
    }

    private void ProjectionChanged()
    {
        _route = WorkerProjections.Procurement ?? _route;
        _market = WorkerProjections.Market ?? _market;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task GenerateAsync()
    {
        if (!CanGenerate || _market is null)
        {
            return;
        }

        _isAnalyzing = true;
        try
        {
            var outcome = await WorkerSession.RunProcurementAsync(
                new WorkerProcurementRequest(
                    _regional
                        ? MarketFetchScope.EntireRegion
                        : MarketFetchScope.SelectedDataCenter,
                    _market.SelectedDataCenter,
                    _market.SelectedRegion,
                    _market.Lens,
                    _travelTolerance,
                    _includeSplitPurchases,
                    _startFromHomeDataCenter,
                    _travelPriority));
            _route = outcome.Procurement;
            _travelTolerance = _route.TravelTolerance;
            Snackbar.Add(
                $"Route ready: {_route.WorldStops} worlds, {_route.SelectedGilCost:N0}g.",
                Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Route generation failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private void PreviewTolerance(ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var value))
        {
            _travelTolerance = Math.Clamp(value, 0, 11);
        }
    }

    private async Task CommitToleranceAsync(ChangeEventArgs args)
    {
        PreviewTolerance(args);
        if (_route?.HasRoute != true || _travelTolerance == _route.TravelTolerance)
        {
            return;
        }

        try
        {
            _route = await WorkerSession.SelectProcurementToleranceAsync(
                _travelTolerance);
        }
        catch (Exception ex)
        {
            Snackbar.Add(ex.Message, Severity.Error);
            _travelTolerance = _route.TravelTolerance;
        }
    }

    public void Dispose()
    {
        WorkerProjections.Changed -= ProjectionChanged;
    }
}
