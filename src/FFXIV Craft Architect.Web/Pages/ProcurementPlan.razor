@page "/procurement"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Services
@inject ISnackbar Snackbar
@inject AppState AppState
@inject NavigationManager NavigationManager
@inject CancellableOperationService CancellableOperations
@inject ProcurementWorkflowService ProcurementWorkflow
@inject IRecipeLayerWorkflowService RecipeLayerWorkflowService
@inject BrowserFileExportService FileExportService
@inject CraftAppraisalQuoteExportService CraftAppraisalQuoteExportService
@implements IDisposable

@{
    var procurementShoppingPlans = GetProcurementShoppingPlans();
    var evidenceSummary = GetEvidenceSummary();
}

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 pp-page-container">
    <div class="pp-grid-layout">
        <ProcurementControlsPanel
            AppState="AppState"
            ShoppingPlans="procurementShoppingPlans"
            EvidenceSummary="evidenceSummary"
            IsAnalyzing="_isAnalyzing"
            CanAnalyze="CanAnalyze()"
            NoticeSeverity="@GetProcurementNoticeSeverity(evidenceSummary)"
            NoticeMessage="@GetProcurementNoticeMessage(evidenceSummary)"
            OnRunAnalysisRequested="RunAnalysisAsync"
            CanExportCraftQuote="CanExportCraftQuote()"
            OnExportCraftQuoteRequested="ExportCraftQuoteAsync"
            OnGoToPlannerRequested="GoToPlanner"
            OnGoToMarketAnalysisRequested="GoToMarketAnalysis" />

        <ProcurementResultsShell
            ShoppingPlans="procurementShoppingPlans"
            OnReanalyzeWithoutWorldRequested="ReanalyzeWithoutWorldAsync"
            OnExcludeWorldForItemRequested="ExcludeWorldForItemAsync"
            OnRefreshItemRequested="RefreshItemMarketDataAsync" />
    </div>
</MudContainer>

@code {
    private bool _isAnalyzing = false;
    private CancellableOperationLease? _procurementAnalysisOperation;

    protected override void OnInitialized()
    {
        // Subscribe to changes (including restoration from auto-save)
        AppState.OnPlanChanged += OnPlanChanged;
        AppState.OnShoppingListChanged += OnShoppingListChanged;
    }

    private void OnPlanChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnShoppingListChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        CancellableOperations.Cancel(CancellableOperationWorkflow.ProcurementAnalysis);
        CancellableOperations.Cancel(CancellableOperationWorkflow.ItemMarketRefresh);
        _procurementAnalysisOperation = null;
        AppState.OnPlanChanged -= OnPlanChanged;
        AppState.OnShoppingListChanged -= OnShoppingListChanged;
    }

    private bool CanAnalyze()
    {
        return AppState.CurrentPlan != null &&
               GetBuyItems().Any() &&
               !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    private bool CanExportCraftQuote()
    {
        return AppState.CurrentPlan?.RootItems.Count == 1 && !AppState.IsBusy;
    }

    /// <summary>
    /// Get the current items marked for buying from the recipe plan.
    /// </summary>
    private List<MaterialAggregate> GetBuyItems()
    {
        return RecipeLayerWorkflowService
            .BuildActiveProcurementItems(AppState.CurrentPlan)
            .Where(m => m.TotalQuantity > 0)
            .ToList();
    }

    private IReadOnlyList<DetailedShoppingPlan> GetProcurementShoppingPlans()
    {
        AppState.PruneExpiredTemporaryMarketWorldBlacklists();
        return AppState.ProcurementShoppingPlans;
    }

    private ProcurementEvidenceSummary GetEvidenceSummary()
    {
        return AcquisitionPlanningService.GetProcurementEvidenceSummary(
            RecipeLayerWorkflowService.BuildActiveProcurementItems(AppState.CurrentPlan),
            RecipeLayerWorkflowService.BuildMarketAnalysisCandidates(AppState.CurrentPlan),
            AppState.ShoppingPlans);
    }

    private Severity GetProcurementNoticeSeverity(ProcurementEvidenceSummary evidenceSummary)
    {
        var overlaySummary = AcquisitionPlanningService.GetProcurementEvidenceSummary(
            RecipeLayerWorkflowService.BuildActiveProcurementItems(AppState.CurrentPlan),
            RecipeLayerWorkflowService.BuildMarketAnalysisCandidates(AppState.CurrentPlan),
            AppState.ProcurementShoppingPlans);
        if (overlaySummary.HasCompleteActiveEvidence)
        {
            return Severity.Info;
        }

        if (!CanAnalyze() || evidenceSummary.ActiveItemsMissingEvidence > 0)
        {
            return Severity.Warning;
        }

        return AppState.ShoppingPlans.Any() ? Severity.Info : Severity.Success;
    }

    private string GetProcurementNoticeMessage(ProcurementEvidenceSummary evidenceSummary)
    {
        if (AppState.CurrentPlan == null)
        {
            return "Build a recipe plan before generating a procurement route.";
        }

        if (!GetBuyItems().Any())
        {
            return "Mark at least one active item for purchase before generating a procurement route.";
        }

        if (string.IsNullOrWhiteSpace(AppState.SelectedDataCenter))
        {
            return "Select a data center before generating a procurement route.";
        }

        if (AppState.ShoppingPlans.Any())
        {
            if (evidenceSummary.ActiveItemsMissingEvidence > 0)
            {
                var overlaySummary = AcquisitionPlanningService.GetProcurementEvidenceSummary(
                    AppState.CurrentPlan,
                    AppState.ProcurementShoppingPlans);
                if (overlaySummary.HasCompleteActiveEvidence)
                {
                    return $"Using procurement-only market data for {overlaySummary.ActiveProcurementItemCount} active items. Run Market Analysis to update full comparison.";
                }

                return $"{evidenceSummary.ActiveItemsMissingEvidence} active procurement items need market evidence.";
            }

            var message = $"Using market data for {evidenceSummary.ActiveProcurementItemCount} active procurement items from {evidenceSummary.AnalyzedCandidateCount} analyzed candidates.";
            if (evidenceSummary.SuppressedMarketCandidateCount > 0)
            {
                message += $" {evidenceSummary.SuppressedMarketCandidateCount} analyzed candidates are suppressed by acquisition choices.";
            }

            return message;
        }

        var procurementOverlaySummary = AcquisitionPlanningService.GetProcurementEvidenceSummary(
            AppState.CurrentPlan,
            AppState.ProcurementShoppingPlans);
        if (procurementOverlaySummary.HasCompleteActiveEvidence)
        {
            return $"Using procurement-only market data for {procurementOverlaySummary.ActiveProcurementItemCount} active items. Run Market Analysis to update full comparison.";
        }

        return "Ready to fetch active procurement prices.";
    }

    private async Task RunAnalysisAsync()
    {
        if (!CanAnalyze())
            return;

        var plan = AppState.CurrentPlan;
        if (plan == null)
            return;

        _isAnalyzing = true;
        using var operation = CancellableOperations.Start(
            CancellableOperationWorkflow.ProcurementAnalysis,
            "Procurement Analysis",
            "Generating optimal procurement plan...");
        _procurementAnalysisOperation = operation;

        try
        {
            var progress = new Progress<string>(msg =>
            {
                operation.ReportStatus(msg);
            });

            var result = await ProcurementWorkflow.RunAnalysisAsync(
                new ProcurementWorkflowRequest(
                    IsCurrentOperation: () => operation.IsCurrent,
                    ExecutionOptions: MarketAnalysisExecutionOptions.Interactive),
                progress,
                operation.Token);

            if (result.Status == ProcurementWorkflowStatus.StaleDecision)
            {
                FinishStaleProcurementAnalysis(operation.Operation);
                Snackbar.Add("Procurement route was discarded because acquisition choices changed.", Severity.Info);
                return;
            }

            if (result.Status != ProcurementWorkflowStatus.Published)
            {
                operation.Cancel();
                return;
            }

            operation.Complete("Shopping plans generated!");
            Snackbar.Add("Shopping plans generated successfully!", Severity.Success);
        }
        catch (OperationCanceledException ex) when (!operation.ShouldReportError(ex))
        {
            operation.Cancel();
        }
        catch (Exception ex)
        {
            if (operation.ShouldReportError(ex))
            {
                operation.Complete($"Analysis failed: {ex.Message}");
                Snackbar.Add($"Procurement analysis failed: {ex.Message}", Severity.Error);
            }
        }
        finally
        {
            if (ReferenceEquals(_procurementAnalysisOperation, operation))
            {
                _procurementAnalysisOperation = null;
                _isAnalyzing = false;
            }
        }
    }

    private void FinishStaleProcurementAnalysis(AppStateOperation operation)
    {
        const string message = "Acquisition choices changed; regenerate procurement route when ready.";
        if (AppState.EndOperation(operation, message))
        {
            return;
        }

        if (!AppState.IsBusy)
        {
            AppState.SetStatus(message, busy: false);
        }
    }

    private void GoToPlanner()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("./");
    }

    private void GoToMarketAnalysis()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("market");
    }

    private async Task ExportCraftQuoteAsync()
    {
        try
        {
            var result = await CraftAppraisalQuoteExportService.CreateExportAsync(
                AppState.CurrentPlan,
                AppState.SelectedRegion,
                AppState.SelectedDataCenter);

            if (!result.IsAvailable)
            {
                Snackbar.Add(result.UnavailableReason ?? "Craft quote export is not available.", Severity.Warning);
                return;
            }

            await FileExportService.PrepareTextFileSaveAsync(
                "craft-appraisal-quote",
                result.FileName,
                result.Json,
                "application/json");
            Snackbar.Add($"Craft quote export prepared: {result.FileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Craft quote export failed: {ex.Message}", Severity.Error);
        }
    }

    /// <summary>
    /// Re-runs analysis with the specified world blacklisted.
    /// Called when user clicks "Re-analyze without this world" on a congested world card.
    /// </summary>
    private async Task ReanalyzeWithoutWorldAsync(WorldProcurementCardModel world)
    {
        AppState.BlacklistMarketWorldTemporarily(new MarketWorldKey(world.DataCenter, world.WorldName));

        Snackbar.Add($"Re-analyzing without {world.WorldName} ({world.DataCenter}) for {AppState.TemporaryWorldBlacklistDurationMinutes} minutes...", Severity.Info);

        // Re-run the analysis
        await RunAnalysisAsync();

        // Show results
        var blacklistedCount = AppState.GetActiveBlacklistedMarketWorlds().Count;
        if (blacklistedCount > 0)
        {
            Snackbar.Add($"Analysis complete. Excluded worlds: {FormatBlacklistedMarketWorlds()}", Severity.Success);
        }
    }

    private async Task ExcludeWorldForItemAsync(WorldItemProcurementAction action)
    {
        var world = action.World;
        var item = action.Item;
        AppState.ExcludeItemWorldTemporarily(
            item.ItemId,
            new MarketWorldKey(world.DataCenter, world.WorldName));

        Snackbar.Add($"Removed {world.WorldName} listings from {item.ItemName} and re-running procurement.", Severity.Info);
        await RunAnalysisAsync();
    }

    private async Task RefreshItemMarketDataAsync(WorldItemProcurementAction action)
    {
        using var operation = CancellableOperations.Start(
            CancellableOperationWorkflow.ItemMarketRefresh,
            "Market Refresh",
            $"Refreshing {action.Item.ItemName}...");
        try
        {
            var progress = new Progress<string>(msg => operation.ReportStatus(msg));
            var result = await ProcurementWorkflow.RefreshItemMarketDataAsync(
                new ProcurementItemRefreshWorkflowRequest(
                    ItemId: action.Item.ItemId,
                    ItemName: action.Item.ItemName,
                    IsCurrentOperation: () => operation.IsCurrent,
                    ExecutionOptions: MarketAnalysisExecutionOptions.Interactive),
                progress,
                operation.Token);

            if (result.Status == ProcurementItemRefreshStatus.NotFound)
            {
                operation.Complete($"Could not find {action.Item.ItemName} in the market analysis candidates.");
                Snackbar.Add($"Could not find {action.Item.ItemName} in the market analysis candidates.", Severity.Warning);
                return;
            }

            if (result.Status == ProcurementItemRefreshStatus.NoData)
            {
                operation.Complete($"No refreshed market data was returned for {action.Item.ItemName}.");
                Snackbar.Add($"No refreshed market data was returned for {action.Item.ItemName}.", Severity.Warning);
                return;
            }

            if (result.Status == ProcurementItemRefreshStatus.StaleDecision)
            {
                operation.Cancel("Acquisition choices changed; refresh the item again when ready.");
                Snackbar.Add("Item refresh was discarded because acquisition choices changed.", Severity.Info);
                return;
            }

            if (result.Status != ProcurementItemRefreshStatus.Refreshed)
            {
                operation.Cancel();
                return;
            }

            if (string.IsNullOrWhiteSpace(result.ItemName))
            {
                throw new InvalidOperationException("Item refresh reported success without a refreshed item name.");
            }

            Snackbar.Add($"Refreshed {result.ItemName}; re-running procurement.", Severity.Info);
            await RunAnalysisAsync();
        }
        catch (OperationCanceledException ex) when (!operation.ShouldReportError(ex))
        {
            operation.Cancel();
        }
        catch (Exception ex)
        {
            if (operation.ShouldReportError(ex))
            {
                operation.Complete($"Item refresh failed: {ex.Message}");
                Snackbar.Add($"Failed to refresh {action.Item.ItemName}: {ex.Message}", Severity.Error);
            }
        }
    }

    private string FormatBlacklistedMarketWorlds()
    {
        var activeWorlds = AppState.GetActiveBlacklistedMarketWorlds();
        if (activeWorlds.Count == 0)
        {
            return string.Empty;
        }

        return string.Join(
            ", ",
            activeWorlds
                .OrderBy(world => world.DataCenter)
                .ThenBy(world => world.WorldName)
                .Select(world => $"{world.WorldName} ({world.DataCenter})"));
    }

}
