@page "/procurement"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject GarlandService GarlandService
@inject UniversalisService UniversalisService
@inject RecipeCalculationService RecipeCalculationService
@inject MarketShoppingService MarketShoppingService
@inject IMarketCacheService MarketCache
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject AppState AppState
@inject NavigationManager NavigationManager
@implements IDisposable

@{
    var procurementShoppingPlans = GetProcurementShoppingPlans();
    var evidenceSummary = GetEvidenceSummary();
}

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 pp-page-container">
    <div class="pp-grid-layout">
        <ProcurementControlsPanel
            AppState="AppState"
            ShoppingPlans="procurementShoppingPlans"
            EvidenceSummary="evidenceSummary"
            IsAnalyzing="_isAnalyzing"
            CanAnalyze="CanAnalyze()"
            NoticeSeverity="@GetProcurementNoticeSeverity(evidenceSummary)"
            NoticeMessage="@GetProcurementNoticeMessage(evidenceSummary)"
            OnRunAnalysisRequested="RunAnalysisAsync"
            OnGoToPlannerRequested="GoToPlanner"
            OnGoToMarketAnalysisRequested="GoToMarketAnalysis" />

        <ProcurementResultsShell
            ShoppingPlans="procurementShoppingPlans"
            OnReanalyzeWithoutWorldRequested="ReanalyzeWithoutWorldAsync" />
    </div>
</MudContainer>

@code {
    private bool _isAnalyzing = false;

    protected override void OnInitialized()
    {
        // Subscribe to changes (including restoration from auto-save)
        AppState.OnPlanChanged += OnPlanChanged;
        AppState.OnShoppingListChanged += OnShoppingListChanged;
    }

    private void OnPlanChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnShoppingListChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnPlanChanged -= OnPlanChanged;
        AppState.OnShoppingListChanged -= OnShoppingListChanged;
    }

    private bool CanAnalyze()
    {
        return AppState.CurrentPlan != null &&
               GetBuyItems().Any() &&
               !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    /// <summary>
    /// Get the current items marked for buying from the recipe plan.
    /// </summary>
    private List<MaterialAggregate> GetBuyItems()
    {
        return AcquisitionPlanningService.GetActiveProcurementItems(AppState.CurrentPlan)
            .Where(m => m.TotalQuantity > 0)
            .ToList();
    }

    private List<DetailedShoppingPlan> GetProcurementShoppingPlans()
    {
        return AcquisitionPlanningService.FilterShoppingPlansForActiveProcurement(
            AppState.CurrentPlan,
            AppState.ShoppingPlans);
    }

    private ProcurementEvidenceSummary GetEvidenceSummary()
    {
        return AcquisitionPlanningService.GetProcurementEvidenceSummary(
            AppState.CurrentPlan,
            AppState.ShoppingPlans);
    }

    private Severity GetProcurementNoticeSeverity(ProcurementEvidenceSummary evidenceSummary)
    {
        if (!CanAnalyze() || evidenceSummary.ActiveItemsMissingEvidence > 0)
        {
            return Severity.Warning;
        }

        return AppState.ShoppingPlans.Any() ? Severity.Info : Severity.Success;
    }

    private string GetProcurementNoticeMessage(ProcurementEvidenceSummary evidenceSummary)
    {
        if (AppState.CurrentPlan == null)
        {
            return "Build a recipe plan before generating a procurement route.";
        }

        if (!GetBuyItems().Any())
        {
            return "Mark at least one active item for purchase before generating a procurement route.";
        }

        if (string.IsNullOrWhiteSpace(AppState.SelectedDataCenter))
        {
            return "Select a data center before generating a procurement route.";
        }

        if (AppState.ShoppingPlans.Any())
        {
            if (evidenceSummary.ActiveItemsMissingEvidence > 0)
            {
                return $"{evidenceSummary.ActiveItemsMissingEvidence} active procurement items need market evidence.";
            }

            var message = $"Using market data for {evidenceSummary.ActiveProcurementItemCount} active procurement items from {evidenceSummary.AnalyzedCandidateCount} analyzed candidates.";
            if (evidenceSummary.SuppressedMarketCandidateCount > 0)
            {
                message += $" {evidenceSummary.SuppressedMarketCandidateCount} analyzed candidates are suppressed by acquisition choices.";
            }

            return message;
        }

        return "Ready to fetch active procurement prices.";
    }

    private async Task RunAnalysisAsync()
    {
        if (!CanAnalyze())
            return;

        _isAnalyzing = true;
        AppState.BeginOperation("Procurement Analysis", "Generating optimal procurement plan...");

        try
        {
            var materials = GetBuyItems();
            var progress = new Progress<string>(msg => AppState.SetStatus(msg, busy: true));

            // Use existing market analysis results if available and data center matches
            List<DetailedShoppingPlan> shoppingPlans;

            if (CanReuseCurrentProcurementEvidence())
            {
                // Reuse existing market analysis
                AppState.SetStatus("Using existing market analysis...", busy: true);
                var reusablePlans = GetProcurementEvidenceForCurrentScope();
                shoppingPlans = MarketShoppingService.OptimizeProcurementRoute(
                    reusablePlans,
                    CreateProcurementMarketConfig(),
                    AppState.ProcurementEnableSplitWorldPurchases);

                MergeShoppingPlans(shoppingPlans);
                AppState.NotifyShoppingListChanged();
            }
            else
            {
                AppState.SetStatus("Refreshing active procurement market data...", busy: true);
                shoppingPlans = await AnalyzeActiveProcurementItemsAsync(materials, progress);

                MergeShoppingPlans(shoppingPlans);
                AppState.NotifyShoppingListChanged();
            }

            AppState.NotifyShoppingListChanged();

            AppState.EndOperation("Shopping plans generated!");
            Snackbar.Add("Shopping plans generated successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            AppState.SetStatus($"Analysis failed: {ex.Message}");
            Snackbar.Add($"Procurement analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task<List<DetailedShoppingPlan>> AnalyzeActiveProcurementItemsAsync(
        List<MaterialAggregate> materials,
        IProgress<string> progress)
    {
        if (AppState.ProcurementSearchEntireRegion)
        {
            var config = CreateProcurementMarketConfig();
            var evidence = await MarketEvidenceLoader.LoadAsync(
                MarketCache,
                materials.Select(material => material.ItemId),
                MarketFetchScope.EntireRegion,
                AppState.SelectedDataCenter,
                AppState.SelectedRegion,
                progress: progress);
            var evidencePlans = await MarketShoppingService.CalculateDetailedShoppingPlansAsync(
                new MarketAnalysisRequest
                {
                    Items = materials,
                    Evidence = evidence,
                    RecommendationMode = AppState.ProcurementRecommendationMode,
                    AnalysisConfig = config,
                    BlacklistedMarketWorlds = AppState.TemporarilyBlacklistedMarketWorlds
                },
                progress,
                ct: default);

            return MarketShoppingService.OptimizeProcurementRoute(
                evidencePlans,
                config,
                AppState.ProcurementEnableSplitWorldPurchases);
        }

        var selectedDcEvidence = await MarketEvidenceLoader.LoadAsync(
            MarketCache,
            materials.Select(material => material.ItemId),
            MarketFetchScope.SelectedDataCenter,
            AppState.SelectedDataCenter,
            AppState.SelectedRegion,
            progress: progress);

        if (AppState.ProcurementEnableSplitWorldPurchases)
        {
            var config = CreateProcurementMarketConfig();

            var evidencePlans = await MarketShoppingService.CalculateDetailedShoppingPlansAsync(
                new MarketAnalysisRequest
                {
                    Items = materials,
                    Evidence = selectedDcEvidence,
                    RecommendationMode = AppState.ProcurementRecommendationMode,
                    AnalysisConfig = config,
                    BlacklistedWorlds = AppState.TemporarilyBlacklistedWorlds
                },
                progress);

            return MarketShoppingService.OptimizeProcurementRoute(
                evidencePlans,
                config,
                includeSplitPurchases: true);
        }

        var plans = await MarketShoppingService.CalculateDetailedShoppingPlansAsync(
            new MarketAnalysisRequest
            {
                Items = materials,
                Evidence = selectedDcEvidence,
                RecommendationMode = AppState.ProcurementRecommendationMode,
                BlacklistedWorlds = AppState.TemporarilyBlacklistedWorlds
            },
            progress);

        return MarketShoppingService.OptimizeProcurementRoute(
            plans,
            includeSplitPurchases: false);
    }

    private MarketAnalysisConfig CreateProcurementMarketConfig()
    {
        return new MarketAnalysisConfig
        {
            EnableSplitWorld = AppState.ProcurementEnableSplitWorldPurchases,
            MaxWorldsPerItem = null,
            TravelTolerance = AppState.ProcurementTravelTolerance
        };
    }

    private bool CanReuseCurrentProcurementEvidence()
    {
        if (!AcquisitionPlanningService.HasCompleteProcurementEvidence(
            AppState.CurrentPlan,
            AppState.ShoppingPlans))
        {
            return false;
        }

        var activePlans = GetProcurementShoppingPlans();
        if (AppState.ProcurementSearchEntireRegion)
        {
            return activePlans.All(HasRegionWideEvidence);
        }

        return activePlans.All(plan => HasSelectedDataCenterEvidence(plan, AppState.SelectedDataCenter));
    }

    private List<DetailedShoppingPlan> GetProcurementEvidenceForCurrentScope()
    {
        var activePlans = GetProcurementShoppingPlans();
        if (AppState.ProcurementSearchEntireRegion)
        {
            return activePlans;
        }

        return activePlans
            .Select(plan => FilterPlanToSelectedDataCenter(plan, AppState.SelectedDataCenter))
            .ToList();
    }

    private static DetailedShoppingPlan FilterPlanToSelectedDataCenter(
        DetailedShoppingPlan plan,
        string selectedDataCenter)
    {
        if (IsVendorPlan(plan))
        {
            return plan;
        }

        var worldOptions = plan.WorldOptions
            .Where(world => IsSelectedDataCenter(world.DataCenter, selectedDataCenter))
            .ToList();
        var recommendedWorld = IsSelectedDataCenter(plan.RecommendedWorld?.DataCenter, selectedDataCenter)
            ? plan.RecommendedWorld
            : null;
        var recommendedSplit = plan.RecommendedSplit?
            .Where(split => IsSelectedDataCenter(split.DataCenter, selectedDataCenter))
            .ToList();

        return new DetailedShoppingPlan
        {
            ItemId = plan.ItemId,
            Name = plan.Name,
            IconId = plan.IconId,
            QuantityNeeded = plan.QuantityNeeded,
            DCAveragePrice = plan.DCAveragePrice,
            WorldOptions = worldOptions,
            RecommendedWorld = recommendedWorld,
            RecommendedSplit = recommendedSplit?.Count > 0 ? recommendedSplit : null,
            Error = plan.Error,
            MarketDataWarning = plan.MarketDataWarning,
            HQAveragePrice = plan.HQAveragePrice,
            Vendors = plan.Vendors
        };
    }

    private static bool HasRegionWideEvidence(DetailedShoppingPlan plan)
    {
        if (IsVendorPlan(plan))
        {
            return true;
        }

        return GetEvidenceDataCenters(plan)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .Count() > 1;
    }

    private static bool HasSelectedDataCenterEvidence(DetailedShoppingPlan plan, string selectedDataCenter)
    {
        if (IsVendorPlan(plan))
        {
            return true;
        }

        return GetEvidenceDataCenters(plan)
            .Any(dataCenter => IsSelectedDataCenter(dataCenter, selectedDataCenter));
    }

    private static IEnumerable<string> GetEvidenceDataCenters(DetailedShoppingPlan plan)
    {
        foreach (var world in plan.WorldOptions)
        {
            if (!string.IsNullOrWhiteSpace(world.DataCenter))
            {
                yield return world.DataCenter;
            }
        }

        if (!string.IsNullOrWhiteSpace(plan.RecommendedWorld?.DataCenter))
        {
            yield return plan.RecommendedWorld.DataCenter;
        }

        if (plan.RecommendedSplit == null)
        {
            yield break;
        }

        foreach (var split in plan.RecommendedSplit)
        {
            if (!string.IsNullOrWhiteSpace(split.DataCenter))
            {
                yield return split.DataCenter;
            }
        }
    }

    private static bool IsVendorPlan(DetailedShoppingPlan plan)
    {
        return string.Equals(
            plan.RecommendedWorld?.WorldName,
            MarketShoppingConstants.VendorWorldName,
            StringComparison.OrdinalIgnoreCase);
    }

    private static bool IsSelectedDataCenter(string? dataCenter, string selectedDataCenter)
    {
        return !string.IsNullOrWhiteSpace(dataCenter) &&
               string.Equals(dataCenter, selectedDataCenter, StringComparison.OrdinalIgnoreCase);
    }

    private void MergeShoppingPlans(List<DetailedShoppingPlan> activePlans)
    {
        var activeItemIds = activePlans.Select(plan => plan.ItemId).ToHashSet();
        AppState.ShoppingPlans = AppState.ShoppingPlans
            .Where(plan => !activeItemIds.Contains(plan.ItemId))
            .Concat(activePlans)
            .ToList();
    }

    private void GoToPlanner()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("./");
    }

    private void GoToMarketAnalysis()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("market");
    }

    /// <summary>
    /// Re-runs analysis with the specified world blacklisted.
    /// Called when user clicks "Re-analyze without this world" on a congested world card.
    /// </summary>
    private async Task ReanalyzeWithoutWorldAsync(WorldProcurementCardModel world)
    {
        AppState.TemporarilyBlacklistedMarketWorlds.Add(new MarketWorldKey(world.DataCenter, world.WorldName));
        AppState.TemporarilyBlacklistedWorlds.Add(world.WorldName);

        Snackbar.Add($"Re-analyzing without {world.WorldName} ({world.DataCenter})...", Severity.Info);

        // Clear current shopping plans to force recalculation with blacklist
        AppState.ShoppingPlans = new List<DetailedShoppingPlan>();

        // Re-run the analysis
        await RunAnalysisAsync();

        // Show results
        var blacklistedCount = AppState.TemporarilyBlacklistedMarketWorlds.Count;
        if (blacklistedCount > 0)
        {
            Snackbar.Add($"Analysis complete. Excluded worlds: {FormatBlacklistedMarketWorlds()}", Severity.Success);
        }
    }

    private string FormatBlacklistedMarketWorlds()
    {
        if (AppState.TemporarilyBlacklistedMarketWorlds.Count == 0)
        {
            return string.Join(", ", AppState.TemporarilyBlacklistedWorlds);
        }

        return string.Join(
            ", ",
            AppState.TemporarilyBlacklistedMarketWorlds
                .OrderBy(world => world.DataCenter)
                .ThenBy(world => world.WorldName)
                .Select(world => $"{world.WorldName} ({world.DataCenter})"));
    }

    private IReadOnlyList<string> GetCurrentRegionDataCenters()
    {
        return MarketFetchScopeResolver.GetDataCenters(
            MarketFetchScope.EntireRegion,
            AppState.SelectedDataCenter,
            AppState.SelectedRegion);
    }
}
