@page "/procurement"
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Web.Services
@inject GarlandService GarlandService
@inject UniversalisService UniversalisService
@inject RecipeCalculationService RecipeCalculationService
@inject MarketShoppingService MarketShoppingService
@inject IMarketCacheService MarketCache
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar
@inject AppState AppState
@inject NavigationManager NavigationManager
@implements IDisposable

@{
    var procurementShoppingPlans = GetProcurementShoppingPlans();
    var evidenceSummary = GetEvidenceSummary();
}

<MudContainer MaxWidth="MaxWidth.ExtraExtraLarge" Class="pa-0 pp-page-container">
    <div class="pp-grid-layout">
        <ProcurementControlsPanel
            AppState="AppState"
            ShoppingPlans="procurementShoppingPlans"
            EvidenceSummary="evidenceSummary"
            IsAnalyzing="_isAnalyzing"
            CanAnalyze="CanAnalyze()"
            OnRunAnalysisRequested="RunAnalysisAsync"
            OnGoToPlannerRequested="GoToPlanner"
            OnGoToMarketAnalysisRequested="GoToMarketAnalysis" />

        <ProcurementResultsShell
            ShoppingPlans="procurementShoppingPlans"
            OnReanalyzeWithoutWorldRequested="ReanalyzeWithoutWorldAsync" />
    </div>
</MudContainer>

@code {
    private static readonly string[] NorthAmericanDataCenters = { "Aether", "Primal", "Crystal", "Dynamis" };
    private bool _isAnalyzing = false;

    protected override void OnInitialized()
    {
        // Subscribe to changes (including restoration from auto-save)
        AppState.OnPlanChanged += OnPlanChanged;
        AppState.OnShoppingListChanged += OnShoppingListChanged;
    }

    private void OnPlanChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    private void OnShoppingListChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        AppState.OnPlanChanged -= OnPlanChanged;
        AppState.OnShoppingListChanged -= OnShoppingListChanged;
    }

    private bool CanAnalyze()
    {
        return AppState.CurrentPlan != null &&
               GetBuyItems().Any() &&
               !string.IsNullOrWhiteSpace(AppState.SelectedDataCenter);
    }

    /// <summary>
    /// Get the current items marked for buying from the recipe plan.
    /// </summary>
    private List<MaterialAggregate> GetBuyItems()
    {
        return AcquisitionPlanningService.GetActiveProcurementItems(AppState.CurrentPlan)
            .Where(m => m.TotalQuantity > 0)
            .ToList();
    }

    private List<DetailedShoppingPlan> GetProcurementShoppingPlans()
    {
        return AcquisitionPlanningService.FilterShoppingPlansForActiveProcurement(
            AppState.CurrentPlan,
            AppState.ShoppingPlans);
    }

    private ProcurementEvidenceSummary GetEvidenceSummary()
    {
        return AcquisitionPlanningService.GetProcurementEvidenceSummary(
            AppState.CurrentPlan,
            AppState.ShoppingPlans);
    }

    private async Task RunAnalysisAsync()
    {
        if (!CanAnalyze())
            return;

        _isAnalyzing = true;
        AppState.BeginOperation("Procurement Analysis", "Generating optimal procurement plan...");

        try
        {
            var materials = GetBuyItems();
            var progress = new Progress<string>(msg => AppState.SetStatus(msg, busy: true));

            // Use existing market analysis results if available and data center matches
            List<DetailedShoppingPlan> shoppingPlans;

            if (AcquisitionPlanningService.CanReuseProcurementEvidence(
                AppState.CurrentPlan,
                AppState.ShoppingPlans,
                AppState.EnableMultiWorldSplits))
            {
                // Reuse existing market analysis
                AppState.SetStatus("Using existing market analysis...", busy: true);
                shoppingPlans = MarketShoppingService.OptimizeProcurementRoute(
                    GetProcurementShoppingPlans(),
                    CreateProcurementMarketConfig(),
                    AppState.EnableMultiWorldSplits);

                MergeShoppingPlans(shoppingPlans);
                AppState.NotifyShoppingListChanged();
            }
            else
            {
                AppState.SetStatus("Refreshing active procurement market data...", busy: true);
                shoppingPlans = await AnalyzeActiveProcurementItemsAsync(materials, progress);

                MergeShoppingPlans(shoppingPlans);
                AppState.NotifyShoppingListChanged();
            }

            AppState.NotifyShoppingListChanged();

            AppState.EndOperation("Shopping plans generated!");
            Snackbar.Add("Shopping plans generated successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            AppState.SetStatus($"Analysis failed: {ex.Message}");
            Snackbar.Add($"Procurement analysis failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isAnalyzing = false;
        }
    }

    private async Task<List<DetailedShoppingPlan>> AnalyzeActiveProcurementItemsAsync(
        List<MaterialAggregate> materials,
        IProgress<string> progress)
    {
        if (AppState.SearchEntireRegion)
        {
            foreach (var dc in NorthAmericanDataCenters)
            {
                var requests = materials.Select(item => (item.ItemId, dc)).ToList();
                AppState.SetStatus($"Checking cache for {requests.Count} active items on {dc}...");
                await MarketCache.EnsurePopulatedAsync(requests, progress: progress);
            }

            var config = CreateProcurementMarketConfig();

            var evidencePlans = await MarketShoppingService.CalculateDetailedShoppingPlansMultiDCAsync(
                materials,
                progress,
                mode: AppState.RecommendationMode,
                config: config,
                blacklistedMarketWorlds: AppState.TemporarilyBlacklistedMarketWorlds);

            return MarketShoppingService.OptimizeProcurementRoute(
                evidencePlans,
                config,
                AppState.EnableMultiWorldSplits);
        }

        var cacheRequests = materials.Select(item => (item.ItemId, AppState.SelectedDataCenter)).ToList();
        AppState.SetStatus($"Checking cache for {cacheRequests.Count} active items...");
        await MarketCache.EnsurePopulatedAsync(cacheRequests, progress: progress);

        if (AppState.EnableMultiWorldSplits)
        {
            var config = CreateProcurementMarketConfig();

            var evidencePlans = await MarketShoppingService.CalculateDetailedShoppingPlansAsync(
                materials,
                AppState.SelectedDataCenter,
                progress,
                mode: AppState.RecommendationMode,
                config: config,
                blacklistedWorlds: AppState.TemporarilyBlacklistedWorlds);

            return MarketShoppingService.OptimizeProcurementRoute(
                evidencePlans,
                config,
                includeSplitPurchases: true);
        }

        var plans = await MarketShoppingService.CalculateDetailedShoppingPlansAsync(
            materials,
            AppState.SelectedDataCenter,
            progress,
            mode: AppState.RecommendationMode,
            blacklistedWorlds: AppState.TemporarilyBlacklistedWorlds);

        return MarketShoppingService.OptimizeProcurementRoute(
            plans,
            includeSplitPurchases: false);
    }

    private MarketAnalysisConfig CreateProcurementMarketConfig()
    {
        return new MarketAnalysisConfig
        {
            EnableSplitWorld = AppState.EnableMultiWorldSplits,
            MaxWorldsPerItem = AppState.MaxWorldsPerItem > 0 ? AppState.MaxWorldsPerItem : null
        };
    }

    private void MergeShoppingPlans(List<DetailedShoppingPlan> activePlans)
    {
        var activeItemIds = activePlans.Select(plan => plan.ItemId).ToHashSet();
        AppState.ShoppingPlans = AppState.ShoppingPlans
            .Where(plan => !activeItemIds.Contains(plan.ItemId))
            .Concat(activePlans)
            .ToList();
    }

    private void GoToPlanner()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("./");
    }

    private void GoToMarketAnalysis()
    {
        // Use relative path (no leading slash) so it resolves against base href correctly
        NavigationManager.NavigateTo("market");
    }

    /// <summary>
    /// Re-runs analysis with the specified world blacklisted.
    /// Called when user clicks "Re-analyze without this world" on a congested world card.
    /// </summary>
    private async Task ReanalyzeWithoutWorldAsync(WorldProcurementCardModel world)
    {
        AppState.TemporarilyBlacklistedMarketWorlds.Add(new MarketWorldKey(world.DataCenter, world.WorldName));
        AppState.TemporarilyBlacklistedWorlds.Add(world.WorldName);

        Snackbar.Add($"Re-analyzing without {world.WorldName} ({world.DataCenter})...", Severity.Info);

        // Clear current shopping plans to force recalculation with blacklist
        AppState.ShoppingPlans = new List<DetailedShoppingPlan>();

        // Re-run the analysis
        await RunAnalysisAsync();

        // Show results
        var blacklistedCount = AppState.TemporarilyBlacklistedMarketWorlds.Count;
        if (blacklistedCount > 0)
        {
            Snackbar.Add($"Analysis complete. Excluded worlds: {FormatBlacklistedMarketWorlds()}", Severity.Success);
        }
    }

    private string FormatBlacklistedMarketWorlds()
    {
        if (AppState.TemporarilyBlacklistedMarketWorlds.Count == 0)
        {
            return string.Join(", ", AppState.TemporarilyBlacklistedWorlds);
        }

        return string.Join(
            ", ",
            AppState.TemporarilyBlacklistedMarketWorlds
                .OrderBy(world => world.DataCenter)
                .ThenBy(world => world.WorldName)
                .Select(world => $"{world.WorldName} ({world.DataCenter})"));
    }
}
