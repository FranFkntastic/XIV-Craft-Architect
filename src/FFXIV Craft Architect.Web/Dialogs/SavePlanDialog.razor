@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject WorkerProjectionStore WorkerProjections

<MudDialog>
    <DialogContent>
        <MudTextField @bind-Value="_planName" 
                      id="save-plan-name"
                      Label="Plan name"
                      Variant="Variant.Outlined"
                      Placeholder="Enter plan name..."
                      AutoFocus="true"
                      @onkeyup="OnKeyUp" />
        <MudText Typo="Typo.caption" Class="mt-2 d-block">
            Saving @FormatProjectItemCount() for @SelectedDataCenter
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save" Disabled="string.IsNullOrWhiteSpace(_planName)">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    
    private string _planName = "";

    private string FormatProjectItemCount()
    {
        var count = WorkerProjections.Shell.HasSession
            ? WorkerProjections.Shell.ProjectItemCount
            : AppState.ProjectItemCount;
        return count == 1
            ? "1 target item"
            : $"{count:N0} target items";
    }

    private string SelectedDataCenter =>
        WorkerProjections.Shell.HasSession
            ? WorkerProjections.Shell.SelectedDataCenter
            : AppState.SelectedDataCenter;
    
    protected override void OnInitialized()
    {
        // Default name based on date
        _planName = $"Plan_{DateTime.Now:yyyyMMdd_HHmm}";
        if (!string.IsNullOrWhiteSpace(WorkerProjections.Shell.PlanName))
        {
            _planName = WorkerProjections.Shell.PlanName;
        }
        else if (AppState.CurrentPlan?.Name != null)
        {
            _planName = AppState.CurrentPlan.Name;
        }
    }
    
    private void OnKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !string.IsNullOrWhiteSpace(_planName))
        {
            Save();
        }
    }
    
    private void Save()
    {
        MudDialog.Close(DialogResult.Ok(_planName.Trim()));
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }
}
