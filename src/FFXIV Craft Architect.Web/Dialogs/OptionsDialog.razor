        _laborBenchmarkCalibratedAtUtc = DateTime.UtcNow;
        _laborBenchmarkCalibrationEvidence = "Custom company benchmark.";
    }

    private async Task RecalculateLaborBenchmarkAsync()
    {
        if (_companyProfile == null)
        {
            return;
        }

        if (_laborBenchmarkSynthCount <= 0)
        {
            Snackbar.Add("Benchmark synth count must be greater than zero.", Severity.Error);
            return;
        }

        _companyIsBusy = true;
        _laborBenchmarkIsRecalculating = true;
        _laborBenchmarkStatus = "Recalculating Cobalt Rivets benchmark...";
        _laborBenchmarkStatusColor = Color.Secondary;
        try
        {
            var result = await LaborBenchmarkCalibrationWorkflow.RecalculateManagedCobaltRivetsAsync(
                new TradeLaborBenchmarkCalibrationRequest(
                    _defaultDataCenter,
                    _selectedRegion,
                    _companyLegacyCommissionPercent,
                    _laborBenchmarkSynthCount));

            if (result.LaborStandard == null)
            {
                _laborBenchmarkStatus = result.Message;
                _laborBenchmarkStatusColor = Color.Error;
                Snackbar.Add(result.Message, Severity.Error);
                return;
            }

            ApplyLaborStandardFields(result.LaborStandard);
            _useCustomLaborBenchmark = false;
            _companyProfile.PaymentPolicy = new TradePaymentPolicy(
                _companyPaymentContract,
                _companyLegacyCommissionPercent,
                result.LaborStandard)
            {
                LaborStandardMaterialBonusPercent = _companyLaborMaterialBonusPercent
            };

            var saved = await TradeOperationsPersistence.SaveCompanyProfileAsync(_companyProfile);
            if (!saved)
            {
                _laborBenchmarkStatus = "Benchmark recalculated but company profile save failed.";
                _laborBenchmarkStatusColor = Color.Error;
                Snackbar.Add(_laborBenchmarkStatus, Severity.Error);
                return;
            }

            _laborBenchmarkStatus = result.Message;
            _laborBenchmarkStatusColor = Color.Success;
            Snackbar.Add(result.Message, Severity.Success);
        }
        catch (Exception ex)
        {
            _laborBenchmarkStatus = $"Benchmark recalculation failed: {ex.Message}";
            _laborBenchmarkStatusColor = Color.Error;
            Snackbar.Add(_laborBenchmarkStatus, Severity.Error);
        }
        finally
        {
            _laborBenchmarkIsRecalculating = false;
            _companyIsBusy = false;
        }
    }

    private void ApplyLaborStandardFields(TradeLaborStandard laborStandard)
    {
        _laborStandardName = laborStandard.Name;
        _laborBenchmarkItemId = laborStandard.BenchmarkItemId;
        _laborBenchmarkItemName = laborStandard.BenchmarkItemName;
        _laborBenchmarkQuantity = laborStandard.BenchmarkQuantity;
        _laborBenchmarkRequiresHq = laborStandard.BenchmarkRequiresHq;
        _laborBenchmarkPayout = laborStandard.BenchmarkLaborPayout;
        _laborBenchmarkSynthCount = laborStandard.BenchmarkSynthCount;
        _laborBenchmarkCalibratedAtUtc = laborStandard.CalibratedAtUtc;
        _laborBenchmarkCalibrationEvidence = laborStandard.CalibrationEvidence;
    }

    private async Task ExportCompanyProfileAsync()
    {
        _companyIsBusy = true;
        try
        {
            var package = await TradeOperationsPersistence.ExportActiveCompanyProfilePackageAsync(DateTime.UtcNow);
            var json = JsonSerializer.Serialize(package, CompanyPackageJsonOptions);
            var bytes = System.Text.Encoding.UTF8.GetBytes(json);
            var stream = new MemoryStream(bytes);
            using var streamRef = new DotNetStreamReference(stream);
            var fileName = CreateCompanyProfileExportFileName(package.Profile.Name, package.ExportedAtUtc);
            await JSRuntime.InvokeVoidAsync("downloadFileFromStream", fileName, streamRef);
            Snackbar.Add($"Exported {package.Crafters.Count:N0} crafters to {fileName}", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Company profile export failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _companyIsBusy = false;
        }
    }

    private async Task ImportCompanyProfileAsync(InputFileChangeEventArgs e)
    {
        var file = e.File;
        if (file == null)
        {
            return;
        }

        _companyIsBusy = true;
        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024);
            using var reader = new StreamReader(stream);
            var json = await reader.ReadToEndAsync();
            var package = JsonSerializer.Deserialize<TradeCompanyProfilePackage>(json, CompanyPackageJsonOptions)
                ?? throw new InvalidOperationException("The selected company profile file was empty.");
            var imported = await TradeOperationsPersistence.ImportCompanyProfilePackageAsync(package, DateTime.UtcNow);
            _companyProfile = imported.Profile;
            _companyCrafterCount = imported.Crafters.Count;
            ApplyCompanyProfileFields(imported.Profile);
            Snackbar.Add($"Imported company profile '{imported.Profile.Name}' with {imported.Crafters.Count:N0} crafters", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Company profile import failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _companyIsBusy = false;
        }
    }

    private static string CreateCompanyProfileExportFileName(string profileName, DateTime exportedAtUtc)
    {
        var safeName = string.Join("_", (string.IsNullOrWhiteSpace(profileName) ? "trade-company-profile" : profileName)
            .Split(Path.GetInvalidFileNameChars(), StringSplitOptions.RemoveEmptyEntries));
        if (safeName.Length > 60)
        {
            safeName = safeName[..60];
        }

        return $"trade-company-{safeName}-{exportedAtUtc:yyyyMMdd-HHmmss}.tradeprofile";
    }

