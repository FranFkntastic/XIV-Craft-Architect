            MarketEvidenceHydration.LastRun.Status,
            _prepareDiagnosticAttachment,
            _prepareDiagnosticAttachment ? _diagnosticSnapshotFileName : null));
    }

    private string? GetGitHubIssueClickScript()
    {
        return _prepareDiagnosticAttachment && _diagnosticSnapshotReady
            ? $"window.CraftArchitectFileExport?.downloadPreparedFile('{DiagnosticSnapshotSaveKey}')"
            : null;
    }

    private static string FormatBytes(long bytes)
    {
        return bytes >= 1024 * 1024
            ? $"{bytes / (1024d * 1024d):F1} MB"
            : $"{bytes / 1024d:F1} KB";
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static MarketFetchScope ParseMarketFetchScope(string? value)
    {
        return Enum.TryParse<MarketFetchScope>(value, ignoreCase: true, out var scope)
            ? scope
            : MarketFetchScope.EntireRegion;
    }

    private static MarketTravelPriority ParseTravelPriority(string? value)
    {
        return Enum.TryParse<MarketTravelPriority>(value, ignoreCase: true, out var priority)
            ? priority
            : MarketTravelPriority.DataCenterTransfersFirst;
    }

    private static string? NormalizeOptionalText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }
}
