    private async Task Save()
    {
        if (_companyProfile != null)
        {
            if (string.IsNullOrWhiteSpace(_companyName))
            {
                Snackbar.Add("Company name is required.", Severity.Error);
                return;
            }

            var paymentPolicy = BuildCompanyPaymentPolicy();
            if (paymentPolicy == null)
            {
                return;
            }

            _companyProfile.Name = _companyName.Trim();
            _companyProfile.Description = NormalizeOptionalText(_companyDescription);
            _companyProfile.PaymentPolicy = paymentPolicy;
            var companySaved = await TradeOperationsPersistence.SaveCompanyProfileAsync(_companyProfile);
            if (!companySaved)
            {
                Snackbar.Add("Failed to save company profile.", Severity.Error);
                return;
            }
        }

        AppState.SetAutoSaveEnabled(_autoSaveEnabled);
        AppState.SetMarketEvidenceSettings(
            _defaultDataCenter,
            _selectedRegion,
            _defaultMarketFetchScope,
            _defaultMarketFetchScope == MarketFetchScope.EntireRegion);
        AppState.SetProcurementSettings(
            AppState.ProcurementSearchEntireRegion,
            _procurementEnableSplitWorldPurchases,
            AppState.ProcurementTravelTolerance,
            AppState.TemporaryWorldBlacklistDurationMinutes);
        AppState.SetProcurementHomeDataCenterOrigin(_procurementStartFromHomeDataCenter);
        AppState.SetProcurementTravelPriority(_procurementTravelPriority);

        // Persist settings via ISettingsService
        await Settings.SetAsync("ui.auto_save_enabled", _autoSaveEnabled);
        await Settings.SetAsync("market.default_datacenter", _defaultDataCenter);
        await Settings.SetAsync("market.region", _selectedRegion);
        await Settings.SetAsync("market.default_search_scope", _defaultMarketFetchScope.ToString());
        await Settings.SetAsync("procurement.enable_split_world_purchases", _procurementEnableSplitWorldPurchases);
        await Settings.SetAsync("procurement.start_from_home_data_center", _procurementStartFromHomeDataCenter);
        await Settings.SetAsync("procurement.travel_priority", _procurementTravelPriority.ToString());
        
        Snackbar.Add("Settings saved", Severity.Success);
        MudDialog.Close(DialogResult.Ok(true));
    }

    private async Task ToggleSecretDebugToolsAsync()
    {
        var enabled = !AppState.SecretDebugToolsEnabled;
        AppState.SetSecretDebugToolsEnabled(enabled);
        await Settings.SetAsync("debug.secret_tools_enabled", enabled);
        Snackbar.Add(enabled ? "Developer Mode enabled" : "Developer Mode disabled", Severity.Info);
    }
    
    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static MarketFetchScope ParseMarketFetchScope(string? value)
    {
        return Enum.TryParse<MarketFetchScope>(value, ignoreCase: true, out var scope)
            ? scope
            : MarketFetchScope.EntireRegion;
    }

    private static MarketTravelPriority ParseTravelPriority(string? value)
    {
        return Enum.TryParse<MarketTravelPriority>(value, ignoreCase: true, out var priority)
            ? priority
            : MarketTravelPriority.DataCenterTransfersFirst;
    }

    private static string? NormalizeOptionalText(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? null : value.Trim();
    }
}
