@using FFXIV_Craft_Architect.Web.Services
@using FFXIV_Craft_Architect.Core.Helpers
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using FFXIV_Craft_Architect.Core.Services.Interfaces
@using FFXIV_Craft_Architect.Web.Services.ProfileHosting
@using System.Text.Json
@inject AppState AppState
@inject ISettingsService Settings
@inject IndexedDbService IndexedDb
@inject GarlandService GarlandService
@inject TradeOperationsPersistenceService TradeOperationsPersistence
@inject TradeLaborBenchmarkCalibrationWorkflowService LaborBenchmarkCalibrationWorkflow
@inject ProfileHostClient ProfileHostClient
@inject ProfileSyncLocalStateService ProfileSyncLocalState
@inject ProfileSyncService ProfileSync
@inject MarketMafiosoAcquisitionWorkflowService MarketMafiosoAcquisitionWorkflow
@inject MarketMafiosoIntegrationState MarketMafiosoIntegrationState
@inject DiagnosticSnapshotBundleService DiagnosticSnapshotBundleService
@inject BrowserFileExportService BrowserFileExportService
@inject MarketEvidenceHydrationService MarketEvidenceHydration
@inject IMarketCacheService MarketCache
@inject GitHubIssueReportService GitHubIssueReportService
@inject IJSRuntime JSRuntime
@inject ISnackbar Snackbar

<MudDialog Class="options-dialog" Style="width: min(800px, calc(100vw - 32px)); max-width: 800px;">
    <DialogContent>
        <div class="options-shell">
            <div class="options-tab-list" role="tablist" aria-label="Options sections">
                @for (var index = 0; index < OptionsTabs.Length; index++)
                {
                    var tabIndex = index;
                    <button type="button"
                            @ref="_tabElements[tabIndex]"
                            id="@GetTabId(tabIndex)"
                            class="options-tab @(tabIndex == _activePanelIndex ? "is-active" : null)"
                            role="tab"
                            aria-selected="@(tabIndex == _activePanelIndex ? "true" : "false")"
                            aria-controls="@GetPanelId(tabIndex)"
                            tabindex="@(tabIndex == _activePanelIndex ? 0 : -1)"
                            @onclick="() => SelectTab(tabIndex)"
                            @onkeydown="args => HandleTabKeyDown(args, tabIndex)">
                        @OptionsTabs[tabIndex]
                    </button>
                }
            </div>
            <div class="options-tab-panel"
                 id="@GetPanelId(_activePanelIndex)"
                 role="tabpanel"
                 aria-labelledby="@GetTabId(_activePanelIndex)">
            @if (_activePanelIndex == 0)
            {
                <MudSwitch @bind-Value="_autoSaveEnabled" 
                           Label="Auto-save plans" 
                           Color="Color.Primary"
                           Class="my-2" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Automatically save your work every 30 seconds
                </MudText>
            }
            
            else if (_activePanelIndex == 1)
            {
                <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
                    Configure your default market settings for price lookups.
                </MudText>
                
                <!-- Region Selection -->
                <CompactSelectField Id="options-region"
                                    Label="Region"
                                    @bind-Value="_selectedRegion"
                                    Options="RegionOptions"
                                    Class="options-select my-3" />
                
                <!-- Data Center Selection -->
                <CompactSelectField Id="options-data-center"
                                    Label="Default data center"
                                    @bind-Value="_defaultDataCenter"
                                    Options="GetAvailableDataCenters().Select(ToSelectOption).ToList()"
                                    Class="options-select my-3" />
                
                <MudDivider Class="my-4" />

                <CompactSelectField Id="options-market-scope"
                                    Label="Default search scope"
                                    @bind-Value="DefaultMarketFetchScopeValue"
                                    Options="MarketFetchScopeOptions"
                                    Class="options-select my-3" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Used when building plans and as the startup Market Analysis scope.
                </MudText>

                <MudSwitch T="bool"
                           @bind-Value="_procurementEnableSplitWorldPurchases"
                           Label="Allow split purchases"
                           Color="Color.Primary"
                           Class="mt-4" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Lets one item use listings from multiple worlds when that completes the quantity or produces a better route. Travel preference still decides whether the savings justify the extra stops.
                </MudText>

                <MudSwitch T="bool"
                           @bind-Value="_procurementStartFromHomeDataCenter"
                           Label="Start procurement routes from the home data center"
                           Color="Color.Primary"
                           Class="mt-4" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Counts leaving @_defaultDataCenter as a transfer when comparing region-wide routes. It doesn't require a purchase there.
                </MudText>

                <CompactSelectField Id="options-travel-priority"
                                    Label="Route travel priority"
                                    @bind-Value="ProcurementTravelPriorityValue"
                                    Options="TravelPriorityOptions"
                                    Class="options-select mt-4" />
                <MudText Typo="Typo.caption" Color="Color.Secondary">
                    Applied after the selected gil ceiling. It decides whether CA removes transfers or individual world visits first.
                </MudText>

                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4">
                    These settings determine which market board prices are shown by default.
                </MudText>
            }

            else if (_activePanelIndex == 2)
            {
                <MudPaper Variant="Variant.Outlined" Class="pa-4">
                    <div class="d-flex align-center justify-space-between gap-3 mb-1">
                        <div>
                            <MudText Typo="Typo.h6">MarketMafioso</MudText>
                            <MudText Typo="Typo.caption" Style="opacity: 0.72;">
                                Connect this browser profile to a private Workshop Host work-order inbox.
                            </MudText>
                        </div>
                        <MudChip T="string"
                                 Size="Size.Small"
                                 Variant="Variant.Outlined"
                                 Color="@GetMarketMafiosoConnectionColor()">
                            @GetMarketMafiosoConnectionLabel()
                        </MudChip>
                    </div>

                    <MudSwitch T="bool"
                               @bind-Value="_marketMafiosoEnabled"
                               Label="Enable MarketMafioso integration"
                               Color="Color.Primary"
                               Class="mt-3" />
                    <MudText Typo="Typo.caption" Style="opacity: 0.72;">
                        Adds durable MarketMafioso work-order handoff and evidence-sync actions to Procurement Plan. Leave this off for the standard CA workflow.
                    </MudText>

                    @if (_marketMafiosoEnabled)
                    {
                    <MudTextField @bind-Value="_marketMafiosoApiUrl"
                                  id="market-mafioso-api-url"
                                  Label="Workshop Host API URL"
                                  Placeholder="https://host.example/marketmafioso/api/"
                                  HelperText="Use the API root ending in /api/. If the hosts differ, allow this CA origin in the receiver."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Disabled="_marketMafiosoConnectionIsBusy"
                                  Class="mt-4" />
                    <MudTextField @bind-Value="_marketMafiosoApiKey"
                                  id="market-mafioso-access-key"
                                  Label="Craft Architect access key"
                                  HelperText="Generate a Craft Architect key in the Workshop Host key manager. It is stored only in this browser profile and can be revoked independently."
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  InputType="InputType.Password"
                                  Disabled="_marketMafiosoConnectionIsBusy"
                                  Class="mt-3" />
                    <MudStack Row="true" Spacing="1" Class="mt-1">
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Primary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.OpenInNew"
                                   Disabled="@string.IsNullOrWhiteSpace(_marketMafiosoApiUrl)"
                                   OnClick="OpenMarketMafiosoKeyManagerAsync">
                            Open key manager
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Default"
                                   Size="Size.Small"
                                   Disabled="@string.IsNullOrWhiteSpace(_marketMafiosoApiKey)"
                                   OnClick="ForgetMarketMafiosoKey">
                            Forget saved key
                        </MudButton>
                    </MudStack>

                    <MudGrid Spacing="2" Class="mt-2">
                        <MudItem xs="12" sm="7">
                            <MudTextField @bind-Value="_marketMafiosoTargetCharacter"
                                          id="market-mafioso-target-character"
                                          Label="Claiming character"
                                          Placeholder="Eriana Ning"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />
                        </MudItem>
                        <MudItem xs="12" sm="5">
                            <MudTextField @bind-Value="_marketMafiosoTargetWorld"
                                          id="market-mafioso-target-world"
                                          Label="Home world"
                                          Placeholder="Siren"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Immediate="true" />
                        </MudItem>
                    </MudGrid>
                    <MudText Typo="Typo.caption" Style="opacity: 0.72;">
                        These identify the plugin instance allowed to claim CA requests. The recommended purchase world is sent separately with each item.
                    </MudText>

                    <MudSwitch T="bool"
                               @bind-Value="_marketMafiosoAutoSyncEvidence"
                               Label="Automatically import refreshed evidence"
                               Color="Color.Primary"
                               Class="mt-3" />
                    <MudText Typo="Typo.caption" Style="opacity: 0.72;">
                        While Procurement Plan is open, CA watches the active request and reroutes as soon as MarketMafioso publishes a board observation. Sync MM remains available as a manual retry.
                    </MudText>

                    <div class="mt-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.WifiTethering"
                                   OnClick="TestMarketMafiosoConnectionAsync"
                                   Disabled="_marketMafiosoConnectionIsBusy"
                                   Style="white-space: nowrap;">
                            @if (_marketMafiosoConnectionIsBusy)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                <span>Testing</span>
                            }
                            else
                            {
                                <span>Test connection</span>
                            }
                        </MudButton>
                        <MudText Typo="Typo.caption" Class="mt-2" Style="display: block; opacity: 0.72;">
                            Checks authentication and acquisition handoff capability. New hosts also advertise durable work orders.
                        </MudText>
                    </div>

                    @if (IsCurrentMarketMafiosoConnectionTest() && _marketMafiosoConnectionTest != null)
                    {
                        <MudAlert Severity="@(_marketMafiosoConnectionTest.AcquisitionQueueAvailable ? Severity.Success : Severity.Warning)"
                                  Dense="true"
                                  Class="mt-3">
                            @_marketMafiosoConnectionStatus
                        </MudAlert>
                    }
                    else if (IsCurrentMarketMafiosoConnectionTest() && !string.IsNullOrWhiteSpace(_marketMafiosoConnectionStatus))
                    {
                        <MudAlert Severity="Severity.Error" Dense="true" Class="mt-3">
                            @_marketMafiosoConnectionStatus
                        </MudAlert>
                    }
                    }
                </MudPaper>
            }

            else if (_activePanelIndex == 3)
            {
                @if (!string.IsNullOrWhiteSpace(_companyLoadError))
                {
                    <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4">
                        @_companyLoadError
                    </MudAlert>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               OnClick="LoadCompanyProfileAsync"
                               Disabled="_companyIsBusy">
                        Retry
                    </MudButton>
                }
                else if (_companyProfile == null)
                {
                    <MudProgressLinear Indeterminate="true" Class="my-4" />
                }
                else
                {
                    <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
                        Configure the active local Trade company profile and its default payment policy.
                    </MudText>

                    <MudTextField @bind-Value="_companyName"
                                  id="company-name"
                                  Label="Company name"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Immediate="true"
                                  Class="my-2" />
                    <MudTextField @bind-Value="_companyDescription"
                                  id="company-description"
                                  Label="Description"
                                  Variant="Variant.Outlined"
                                  Margin="Margin.Dense"
                                  Lines="2"
                                  Class="my-2" />

                    <MudDivider Class="my-4" />

                    <CompactSelectField Id="options-payment-contract"
                                        Label="Default payment contract"
                                        @bind-Value="CompanyPaymentContractValue"
                                        Options="PaymentContractOptions"
                                        Class="options-select my-2" />
                    <MudNumericField T="decimal"
                                     id="legacy-material-commission-percent"
                                     @bind-Value="_companyLegacyCommissionPercent"
                                     Label="Legacy material commission percent"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Min="0m"
                                     Max="100m"
                                     Class="my-2" />
                    <MudNumericField T="decimal"
                                     id="labor-material-value-bonus-percent"
                                     @bind-Value="_companyLaborMaterialBonusPercent"
                                     Label="Labor material value bonus percent"
                                     Variant="Variant.Outlined"
                                     Margin="Margin.Dense"
                                     HideSpinButtons="true"
                                     Min="0m"
                                     Max="100m"
                                     Class="my-2" />

                    <MudText Typo="Typo.subtitle2" Class="mt-4 mb-2">Labor Standard</MudText>
                    <MudSwitch T="bool"
                               Value="_useCustomLaborBenchmark"
                               ValueChanged="OnCustomLaborBenchmarkChanged"
                               Label="Use custom benchmark"
                               Color="Color.Primary"
                               Class="my-2" />
                    @if (!_useCustomLaborBenchmark)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
                            Managed Cobalt Rivets benchmark. Recalculate uses fresh market evidence when available and refreshes only when needed.
                        </MudText>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Calculate"
                                   OnClick="RecalculateLaborBenchmarkAsync"
                                   Disabled="_companyIsBusy || _laborBenchmarkIsRecalculating">
                            @if (_laborBenchmarkIsRecalculating)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            Recalculate Benchmark
                        </MudButton>
                        <MudButton Variant="Variant.Text"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.AccountTree"
                                   OnClick="ToggleLaborBenchmarkPlanPreviewAsync"
                                   Disabled="_companyIsBusy || _laborBenchmarkPlanPreviewIsLoading"
                                   Class="ml-2">
                            @if (_laborBenchmarkPlanPreviewIsLoading)
                            {
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                            }
                            @(_showLaborBenchmarkPlanPreview ? "Hide Plan" : "View Plan")
                        </MudButton>
                    }
                    @if (!string.IsNullOrWhiteSpace(_laborBenchmarkStatus))
                    {
                        <MudText Typo="Typo.caption" Color="@_laborBenchmarkStatusColor" Class="mt-2 mb-2 d-block">
                            @_laborBenchmarkStatus
                        </MudText>
                    }
                    @if (_useCustomLaborBenchmark)
                    {
                        <MudTextField @bind-Value="_laborStandardName"
                                      id="labor-standard-name"
                                      Label="Benchmark name"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="my-2" />
                        <div style="display: grid; grid-template-columns: minmax(0, 1fr) auto; gap: 12px; align-items: end;">
                            <MudTextField @bind-Value="_laborBenchmarkItemSearchQuery"
                                          id="labor-benchmark-item-search"
                                          Label="Find benchmark item"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense" />
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.Search"
                                       OnClick="SearchLaborBenchmarkItemsAsync"
                                       Disabled="_laborBenchmarkItemSearchIsSearching">
                                @if (_laborBenchmarkItemSearchIsSearching)
                                {
                                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                }
                                Search
                            </MudButton>
                        </div>
                        @if (_laborBenchmarkItemSearchResults.Count > 0)
                        {
                            <MudSimpleTable Dense="true" Hover="true" Class="mb-2">
                                <thead>
                                    <tr>
                                        <th>Item</th>
                                        <th class="text-right">Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var result in _laborBenchmarkItemSearchResults)
                                    {
                                        <tr>
                                            <td>@result.Object.Name</td>
                                            <td class="text-right">
                                                <MudButton Variant="Variant.Text"
                                                           Color="Color.Secondary"
                                                           Size="Size.Small"
                                                           OnClick="() => SelectLaborBenchmarkItem(result)">
                                                    Select
                                                </MudButton>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </MudSimpleTable>
                        }
                        <div style="display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px;">
                            <MudTextField @bind-Value="_laborBenchmarkItemName"
                                          id="labor-benchmark-item-name"
                                          Label="Selected benchmark item"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          ReadOnly="true" />
                            <MudNumericField T="int"
                                             id="labor-benchmark-quantity"
                                             @bind-Value="_laborBenchmarkQuantity"
                                             Label="Benchmark quantity"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             HideSpinButtons="true"
                                             Min="1" />
                            <MudNumericField T="int"
                                             id="labor-benchmark-synths"
                                             @bind-Value="_laborBenchmarkSynthCount"
                                             Label="Benchmark synths"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             HideSpinButtons="true"
                                             Min="1" />
                            <MudNumericField T="decimal"
                                             id="labor-benchmark-payout"
                                             @bind-Value="_laborBenchmarkPayout"
                                             Label="Benchmark payout"
                                             Variant="Variant.Outlined"
                                             Margin="Margin.Dense"
                                             HideSpinButtons="true"
                                             Min="0m" />
                            <MudTextField Value="@FormatGilPerSynth()"
                                          id="labor-benchmark-derived-rate"
                                          Label="Derived rate"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          ReadOnly="true" />
                        </div>
                        <MudSwitch @bind-Value="_laborBenchmarkRequiresHq"
                                   Label="Benchmark requires HQ"
                                   Color="Color.Primary"
                                   Class="my-2" />
                    }
                    else
                    {
                        <div class="d-flex flex-wrap gap-2 my-2">
                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined">@_laborBenchmarkItemName</MudChip>
                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined">x@_laborBenchmarkQuantity.ToString("N0")</MudChip>
                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined">@_laborBenchmarkSynthCount.ToString("N0") synths</MudChip>
                            <MudChip T="string" Color="Color.Secondary" Variant="Variant.Outlined">@FormatGilPerSynth()</MudChip>
                        </div>
                    }
                    @if (_showLaborBenchmarkPlanPreview)
                    {
                        <MudPaper Variant="Variant.Outlined" Class="pa-3 my-3">
                            @if (_laborBenchmarkPlanPreview == null)
                            {
                                <MudText Typo="Typo.caption" Color="Color.Secondary">
                                    @_laborBenchmarkPlanPreviewStatus
                                </MudText>
                            }
                            else
                            {
                                <MudText Typo="Typo.subtitle2">@_laborBenchmarkPlanPreview.Title</MudText>
                                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-2 d-block">
                                    Data center: @_laborBenchmarkPlanPreview.DataCenter
                                </MudText>
                                <MudSimpleTable Dense="true" Hover="true">
                                    <thead>
                                        <tr>
                                            <th>Item</th>
                                            <th class="text-right">Qty</th>
                                            <th>Source</th>
                                            <th>Role</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in _laborBenchmarkPlanPreview.Items)
                                        {
                                            <tr>
                                                <td style="@($"padding-left: {item.Depth * 18}px;")">@item.Name</td>
                                                <td class="text-right">@item.Quantity.ToString("N0")</td>
                                                <td>@RecipePlanDisplayHelpers.GetSourceDisplayName(item.Source)</td>
                                                <td>@(item.IsActiveProcurement ? "Procure" : "Craft tree")</td>
                                            </tr>
                                        }
                                    </tbody>
                                </MudSimpleTable>
                            }
                        </MudPaper>
                    }

                    <MudDivider Class="my-4" />

                    <MudText Typo="Typo.subtitle2" Class="mb-2">Profile Transfer</MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-3 d-block">
                        Exports the active company profile, payment policy, and crafter roster. Orders and payroll drafts are not included.
                    </MudText>
                    <div style="display: flex; gap: 12px; flex-wrap: wrap;">
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   StartIcon="@Icons.Material.Filled.Download"
                                   OnClick="ExportCompanyProfileAsync"
                                   Disabled="_companyIsBusy">
                            Export Profile
                        </MudButton>
                        <InputFile id="tradeCompanyPackageInput"
                                   OnChange="ImportCompanyProfileAsync"
                                   accept=".tradeprofile,.json"
                                   style="display: none;" />
                        <label for="tradeCompanyPackageInput" style="display: inline-block; cursor: pointer;">
                            <MudButton Variant="Variant.Outlined"
                                       Color="Color.Secondary"
                                       StartIcon="@Icons.Material.Filled.UploadFile"
                                       Disabled="_companyIsBusy"
                                       Style="pointer-events: none;">
                                Import Profile
                            </MudButton>
                        </label>
                    </div>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 d-block">
                        Active roster: @_companyCrafterCount.ToString("N0") crafters
                    </MudText>
                    @if (_companyIsBusy)
                    {
                        <MudProgressLinear Indeterminate="true" Class="mt-4" />
                    }
                }
            }

            else if (_activePanelIndex == 4)
            {
                <MudText Typo="Typo.body2" Class="mb-4" Color="Color.Secondary">
                    Connect this browser profile to a private Craft Architect profile host.
                </MudText>

                <MudGrid Spacing="2">
                    <MudItem xs="12" md="7">
                        <MudTextField @bind-Value="_profileHostUrl"
                                      id="profile-host-url"
                                      Label="Host URL"
                                      Placeholder="https://craft.example.com"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      Disabled="_profileHostIsBusy" />
                    </MudItem>
                    <MudItem xs="12" md="5">
                        <MudTextField @bind-Value="_profileHostAccessKey"
                                      id="profile-host-access-key"
                                      Label="Access key"
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Immediate="true"
                                      InputType="InputType.Password"
                                      Disabled="_profileHostIsBusy" />
                    </MudItem>
                </MudGrid>

                <MudRadioGroup T="FirstConnectMode" @bind-Value="_profileHostFirstConnectMode" Class="my-2">
                    <MudRadio T="FirstConnectMode" Value="@FirstConnectMode.UploadLocal" Color="Color.Primary">
                        Upload this browser first
                    </MudRadio>
                    <MudRadio T="FirstConnectMode" Value="@FirstConnectMode.DownloadRemote" Color="Color.Primary">
                        Download server profile first
                    </MudRadio>
                </MudRadioGroup>

                <div class="d-flex flex-wrap gap-2 my-3">
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.WifiTethering"
                               OnClick="TestProfileHostConnectionAsync"
                               Disabled="_profileHostIsBusy">
                        Test
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               StartIcon="@Icons.Material.Filled.CloudSync"
                               OnClick="ConnectProfileHostAsync"
                               Disabled="_profileHostIsBusy">
                        Connect
                    </MudButton>
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Secondary"
                               StartIcon="@Icons.Material.Filled.Sync"
                               OnClick="SyncProfileHostNowAsync"
                               Disabled="_profileHostIsBusy || !ProfileSync.CurrentStatus.IsConnected">
                        Sync Now
                    </MudButton>
                    <MudButton Variant="Variant.Text"
                               Color="Color.Error"
                               StartIcon="@Icons.Material.Filled.LinkOff"
                               OnClick="DisconnectProfileHostAsync"
                               Disabled="_profileHostIsBusy || !ProfileSync.CurrentStatus.IsConnected">
                        Disconnect
                    </MudButton>
                </div>

                @if (_profileHostIsBusy)
                {
                    <MudProgressLinear Indeterminate="true" Class="my-3" />
                }

                <MudPaper Variant="Variant.Outlined" Class="pa-3 my-3">
                    <div style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 12px;">
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Connection</MudText>
                            <MudText Typo="Typo.body2">@GetProfileHostConnectionLabel()</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Host</MudText>
                            <MudText Typo="Typo.body2">@GetProfileHostReachabilityLabel()</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Revision</MudText>
                            <MudText Typo="Typo.body2">@ProfileSync.CurrentStatus.LastSyncRevision.ToString("N0")</MudText>
                        </div>
                        <div>
                            <MudText Typo="Typo.caption" Color="Color.Secondary">Queued / conflicts</MudText>
                            <MudText Typo="Typo.body2">@ProfileSync.CurrentStatus.PendingCount.ToString("N0") / @ProfileSync.CurrentStatus.ConflictCount.ToString("N0")</MudText>
                        </div>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_profileHostStatus))
                    {
                        <MudText Typo="Typo.caption" Color="@_profileHostStatusColor" Class="mt-2 d-block">
                            @_profileHostStatus
                        </MudText>
                    }
                    else if (!string.IsNullOrWhiteSpace(ProfileSync.CurrentStatus.Message))
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 d-block">
                            @ProfileSync.CurrentStatus.Message
                        </MudText>
                    }
                </MudPaper>

                @if (ProfileSync.Conflicts.Count > 0)
                {
                    <MudText Typo="Typo.subtitle2" Class="mb-2">Conflicts</MudText>
                    <MudSimpleTable Dense="true" Hover="true">
                        <thead>
                            <tr>
                                <th>Collection</th>
                                <th>Object</th>
                                <th class="text-right">Local rev.</th>
                                <th class="text-right">Remote rev.</th>
                                <th class="text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var conflict in ProfileSync.Conflicts)
                            {
                                <tr>
                                    <td>@conflict.Collection</td>
                                    <td>@conflict.ObjectId</td>
                                    <td class="text-right">@conflict.LocalRevision.ToString("N0")</td>
                                    <td class="text-right">@conflict.RemoteRevision.ToString("N0")</td>
                                    <td class="text-right">
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Secondary"
                                                   Size="Size.Small"
                                                   OnClick="() => AcceptRemoteConflictAsync(conflict)">
                                            Apply Remote
                                        </MudButton>
                                        <MudButton Variant="Variant.Text"
                                                   Color="Color.Primary"
                                                   Size="Size.Small"
                                                   OnClick="() => KeepLocalConflictAsync(conflict)">
                                            Keep Local
                                        </MudButton>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </MudSimpleTable>
                }
            }

            else if (_activePanelIndex == 5)
            {
                <MudText Typo="Typo.body2" Class="mb-4">
                    Manage the named plans stored in this browser.
                </MudText>
                
                <MudButton Color="Color.Error" 
                           Variant="Variant.Outlined"
                           StartIcon="@Icons.Material.Filled.DeleteSweep"
                           OnClick="ClearAllPlans"
                           Disabled="_isClearing">
                    @if (_isClearing)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                    }
                    Delete All Saved Plans
                </MudButton>
                
                <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2 d-block">
                    This will permanently delete all your saved plans. This action cannot be undone.
                </MudText>
            }

            else if (_activePanelIndex == 6)
            {
                <div class="diagnostics-heading">
                    <div>
                        <MudText Typo="Typo.h6">Diagnostics</MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Inspect the active session and export the evidence needed to reproduce a problem.
                        </MudText>
                    </div>
                    <span class="diagnostics-build">@WebBuildInfo.BuildVersion · @WebBuildInfo.CommitSha</span>
                </div>

                <div class="diagnostics-grid">
                    <section class="diagnostics-card">
                        <div class="diagnostics-card-title">Current session</div>
                        <div class="diagnostics-row">
                            <span>Plan</span>
                            <strong>@(AppState.CurrentPlanName ?? AppState.CurrentPlan?.Name ?? "No plan loaded")</strong>
                        </div>
                        <div class="diagnostics-row">
                            <span>Market evidence</span>
                            <strong>@AppState.ShoppingPlans.Count.ToString("N0") plans · @AppState.MarketItemAnalyses.Count.ToString("N0") analyses</strong>
                        </div>
                        <div class="diagnostics-row">
                            <span>Published</span>
                            <strong>@FormatPublishedEvidenceAge()</strong>
                        </div>
                        <div class="diagnostics-row">
                            <span>Scope</span>
                            <strong>@(AppState.SearchEntireRegion ? AppState.SelectedRegion : AppState.SelectedDataCenter)</strong>
                        </div>
                    </section>

                    <section class="diagnostics-card">
                        <div class="diagnostics-card-heading">
                            <div class="diagnostics-card-title">Automatic market refresh</div>
                            <span class="diagnostics-status @GetHydrationStatusClass()">@GetHydrationStatusLabel()</span>
                        </div>
                        <div class="diagnostics-message">@MarketEvidenceHydration.LastRun.Message</div>
                        <div class="diagnostics-row">
                            <span>Attempts</span>
                            <strong>@MarketEvidenceHydration.LastRun.AttemptCount.ToString("N0")</strong>
                        </div>
                        <div class="diagnostics-row">
                            <span>Result</span>
                            <strong>@FormatHydrationResult()</strong>
                        </div>
                        <div class="diagnostics-row">
                            <span>Timing</span>
                            <strong>@FormatHydrationTiming()</strong>
                        </div>
                    </section>
                </div>

                <section class="diagnostics-card diagnostics-card-wide">
                    <div class="diagnostics-card-title">Diagnostic exports</div>
                    <div class="diagnostics-action-row">
                        <div>
                            <strong>Application snapshot</strong>
                            <span>Active plan, acquisition decisions, market evidence, procurement routes, refresh outcome, and cache decision.</span>
                        </div>
                        <button type="button"
                                class="mud-button-root mud-button mud-button-filled mud-button-filled-primary mud-button-filled-size-small mud-ripple"
                                disabled="@(!_diagnosticSnapshotReady || _diagnosticsBusy)"
                                onclick="window.CraftArchitectFileExport?.downloadPreparedFile('@DiagnosticSnapshotSaveKey')">
                            <span class="mud-button-label">
                                <MudIcon Icon="@Icons.Material.Filled.Download"
                                         Class="mud-button-icon-start mud-button-icon-size-small" />
                                @(_diagnosticSnapshotReady ? "Download snapshot" : "Preparing snapshot...")
                            </span>
                        </button>
                    </div>
                    <div class="diagnostics-hint">
                        Acquisition Evaluation also exposes an Item dump beside the selected item, containing only that item's demand, actionability calculation, and market evidence.
                    </div>
                    <div class="diagnostics-action-row diagnostics-report-row">
                        <div>
                            <strong>Report a problem</strong>
                            <span>Open a prefilled GitHub issue for review. Diagnostic files stay local unless you prepare one below.</span>
                            <MudSwitch @bind-Value="_prepareDiagnosticAttachment"
                                       Label="Prepare diagnostic attachment"
                                       Color="Color.Primary"
                                       Dense="true"
                                       Disabled="@(!_diagnosticSnapshotReady)"
                                       Class="diagnostics-attachment-toggle" />
                            <span class="diagnostics-attachment-note">
                                @(_prepareDiagnosticAttachment
                                    ? "The snapshot downloads with the draft; drag it into GitHub before submitting."
                                    : "Off by default. The issue draft contains context only.")
                            </span>
                        </div>
                        <a class="mud-button-root mud-button mud-button-outlined mud-button-outlined-secondary mud-button-outlined-size-small mud-ripple"
                           href="@CreateGitHubIssueUrl()"
                           onclick="@GetGitHubIssueClickScript()"
                           target="_blank"
                           rel="noopener noreferrer">
                            <span class="mud-button-label">
                                <MudIcon Icon="@Icons.Material.Filled.BugReport"
                                         Class="mud-button-icon-start mud-button-icon-size-small" />
                                Draft GitHub issue
                            </span>
                        </a>
                    </div>
                </section>

                <section class="diagnostics-card diagnostics-card-wide">
                    <div class="diagnostics-action-row">
                        <div>
                            <strong>Browser storage</strong>
                            <span>Check the IndexedDB schema and market-cache inventory without deleting or changing anything.</span>
                        </div>
                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Secondary"
                                   Size="Size.Small"
                                   StartIcon="@Icons.Material.Filled.HealthAndSafety"
                                   Disabled="_diagnosticsBusy"
                                   OnClick="RunBrowserStorageChecksAsync">
                            @(_diagnosticsBusy ? "Checking..." : "Run checks")
                        </MudButton>
                    </div>
                    @if (_tradeStorageDiagnostics != null && _marketCacheStats != null)
                    {
                        <div class="diagnostics-storage-results">
                            <div class="diagnostics-row">
                                <span>Trade stores</span>
                                <strong class="@(_tradeStorageDiagnostics.IsReady ? "is-good" : "is-bad")">
                                    @(_tradeStorageDiagnostics.IsReady ? "Ready" : "Needs attention")
                                </strong>
                            </div>
                            <div class="diagnostics-row">
                                <span>Market cache</span>
                                <strong>@_marketCacheStats.ValidEntries.ToString("N0") valid · @_marketCacheStats.StaleEntries.ToString("N0") stale</strong>
                            </div>
                            <div class="diagnostics-row">
                                <span>Cache size</span>
                                <strong>@FormatBytes(_marketCacheStats.ApproximateSizeBytes)</strong>
                            </div>
                        </div>
                    }
                    else if (!string.IsNullOrWhiteSpace(_diagnosticStorageError))
                    {
                        <div class="diagnostics-error">@_diagnosticStorageError</div>
                    }
                </section>
            }

            else
            {
                <div class="d-flex flex-column align-center py-4" style="position: relative; min-height: 180px;">
                    <MudText Typo="Typo.h5" Class="mb-2">FFXIV Craft Architect</MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
                        Browser-based crafting and market planner
                    </MudText>

                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Build @WebBuildInfo.BuildVersion
                    </MudText>
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                        Branch @WebBuildInfo.BranchName
                    </MudText>

                    @if (AppState.SecretDebugToolsEnabled)
                    {
                        <MudText Typo="Typo.caption" Color="Color.Secondary">
                            Commit @WebBuildInfo.CommitSha
                        </MudText>
                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mb-4">
                            Dirty @WebBuildInfo.IsDirty
                        </MudText>
                    }
                    
                    <MudText Typo="Typo.body2" Align="Align.Center">
                        A crafting calculator for Final Fantasy XIV with market integration.
                    </MudText>
                    
                    <MudDivider Class="my-4" Style="width: 100%" />
                    
                    <MudText Typo="Typo.caption" Color="Color.Secondary">
                        Data sources: Garland Tools, Universalis, XIVAPI
                    </MudText>

                    <MudIconButton Icon="@Icons.Material.Filled.BugReport"
                                   OnClick="ToggleSecretDebugToolsAsync"
                                   Size="Size.Small"
                                   Color="@(AppState.SecretDebugToolsEnabled ? Color.Warning : Color.Default)"
                                   title="Developer Mode enables experimental work-in-progress features. These tools may change, break, or lose draft data."
                                   aria-label="Toggle Developer Mode"
                                   Style="position: absolute; bottom: 8px; left: 8px; opacity: 0.35;" />
                </div>
            }
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" OnClick="Save">Save</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public int InitialPanelIndex { get; set; }

    private static readonly string[] OptionsTabs =
        ["General", "Market", "Integrations", "Company", "Hosting", "Storage", "Diagnostics", "About"];
    private static readonly IReadOnlyList<CompactSelectOption> RegionOptions =
    [
        new("North America", "North America"),
        new("Europe", "Europe"),
        new("Japan", "Japan"),
        new("Oceania", "Oceania")
    ];
    private static readonly IReadOnlyList<CompactSelectOption> MarketFetchScopeOptions =
    [
        new(nameof(MarketFetchScope.SelectedDataCenter), "Selected data center"),
        new(nameof(MarketFetchScope.EntireRegion), "Entire region")
    ];
    private static readonly IReadOnlyList<CompactSelectOption> TravelPriorityOptions =
    [
        new(nameof(MarketTravelPriority.DataCenterTransfersFirst), "Avoid data-center transfers first"),
        new(nameof(MarketTravelPriority.WorldVisitsFirst), "Avoid total world visits first")
    ];
    private static readonly IReadOnlyList<CompactSelectOption> PaymentContractOptions =
    [
        new(nameof(TradePaymentContractMode.LegacyCommission), "Legacy commission"),
        new(nameof(TradePaymentContractMode.LaborStandard), "Labor standard")
    ];
    private readonly ElementReference[] _tabElements = new ElementReference[OptionsTabs.Length];
    private int _activePanelIndex;

    private static string GetTabId(int index) => $"options-tab-{index}";
    private static string GetPanelId(int index) => $"options-panel-{index}";

    private async Task SelectTab(int index)
    {
        _activePanelIndex = Math.Clamp(index, 0, OptionsTabs.Length - 1);
        if (_activePanelIndex == 6)
        {
            await PrepareDiagnosticSnapshotAsync();
        }
    }

    private async Task HandleTabKeyDown(KeyboardEventArgs args, int currentIndex)
    {
        var nextIndex = args.Key switch
        {
            "ArrowRight" => (currentIndex + 1) % OptionsTabs.Length,
            "ArrowLeft" => (currentIndex - 1 + OptionsTabs.Length) % OptionsTabs.Length,
            "Home" => 0,
            "End" => OptionsTabs.Length - 1,
            _ => currentIndex
        };

        if (nextIndex == currentIndex)
        {
            return;
        }

        await SelectTab(nextIndex);
        await InvokeAsync(StateHasChanged);
        await _tabElements[nextIndex].FocusAsync();
    }
    
    private bool _autoSaveEnabled = true;
    private string _defaultDataCenter = "Aether";
    private string _selectedRegion = "North America";
    private MarketFetchScope _defaultMarketFetchScope = MarketFetchScope.EntireRegion;
    private bool _procurementEnableSplitWorldPurchases = true;
    private bool _procurementStartFromHomeDataCenter;
    private MarketTravelPriority _procurementTravelPriority = MarketTravelPriority.DataCenterTransfersFirst;

    private string DefaultMarketFetchScopeValue
    {
        get => _defaultMarketFetchScope.ToString();
        set
        {
            if (Enum.TryParse<MarketFetchScope>(value, out var parsed))
            {
                _defaultMarketFetchScope = parsed;
            }
        }
    }

    private string ProcurementTravelPriorityValue
    {
        get => _procurementTravelPriority.ToString();
        set
        {
            if (Enum.TryParse<MarketTravelPriority>(value, out var parsed))
            {
                _procurementTravelPriority = parsed;
            }
        }
    }

    private string CompanyPaymentContractValue
    {
        get => _companyPaymentContract.ToString();
        set
        {
            if (Enum.TryParse<TradePaymentContractMode>(value, out var parsed))
            {
                _companyPaymentContract = parsed;
            }
        }
    }

    private static CompactSelectOption ToSelectOption(string value) => new(value, value);
    private string _marketMafiosoApiUrl = string.Empty;
    private string _marketMafiosoApiKey = string.Empty;
    private string _marketMafiosoTargetCharacter = string.Empty;
    private string _marketMafiosoTargetWorld = string.Empty;
    private bool _marketMafiosoEnabled;
    private bool _marketMafiosoAutoSyncEvidence = true;
    private bool _marketMafiosoConnectionIsBusy;
    private int? _marketMafiosoTestedConfigurationHash;
    private MarketMafiosoConnectionTestResult? _marketMafiosoConnectionTest;
    private string? _marketMafiosoConnectionStatus;
    private bool _isClearing = false;
    private TradeCompanyProfile? _companyProfile;
    private string _companyName = string.Empty;
    private string? _companyDescription;
    private int _companyCrafterCount;
    private string? _companyLoadError;
    private bool _companyIsBusy;
    private TradePaymentContractMode _companyPaymentContract = TradePaymentContractMode.LegacyCommission;
    private decimal _companyLegacyCommissionPercent = CommissionPayoutPolicy.Default.CommissionPercent;
    private decimal _companyLaborMaterialBonusPercent = TradePaymentPolicy.DefaultLaborStandardMaterialBonusPercent;
    private string _laborStandardName = "Cobalt Rivets benchmark";
    private int _laborBenchmarkItemId = TradeLaborStandardCalibrationService.CobaltRivetsItemId;
    private string _laborBenchmarkItemName = TradeLaborStandardCalibrationService.CobaltRivetsItemName;
    private int _laborBenchmarkQuantity = TradeLaborStandardCalibrationService.CobaltRivetsBenchmarkQuantity;
    private bool _laborBenchmarkRequiresHq = TradeLaborStandardCalibrationService.CobaltRivetsBenchmarkRequiresHq;
    private decimal _laborBenchmarkPayout = 120_000m;
    private int _laborBenchmarkSynthCount = 200;
    private bool _useCustomLaborBenchmark;
    private bool _laborBenchmarkIsRecalculating;
    private bool _showLaborBenchmarkPlanPreview;
    private bool _laborBenchmarkPlanPreviewIsLoading;
    private string? _laborBenchmarkStatus;
    private Color _laborBenchmarkStatusColor = Color.Secondary;
    private DateTime? _laborBenchmarkCalibratedAtUtc;
    private string? _laborBenchmarkCalibrationEvidence;
    private TradeLaborBenchmarkPlanPreview? _laborBenchmarkPlanPreview;
    private string? _laborBenchmarkPlanPreviewStatus;
    private string _laborBenchmarkItemSearchQuery = string.Empty;
    private bool _laborBenchmarkItemSearchIsSearching;
    private readonly List<GarlandSearchResult> _laborBenchmarkItemSearchResults = [];
    private string _profileHostUrl = string.Empty;
    private string _profileHostAccessKey = string.Empty;
    private string? _profileHostProfileName;
    private bool _profileHostIsBusy;
    private FirstConnectMode _profileHostFirstConnectMode = FirstConnectMode.UploadLocal;
    private string? _profileHostStatus;
    private Color _profileHostStatusColor = Color.Secondary;
    private bool _diagnosticsBusy;
    private bool _diagnosticSnapshotReady;
    private bool _prepareDiagnosticAttachment;
    private string? _diagnosticSnapshotFileName;
    private TradeIndexedDbDiagnostics? _tradeStorageDiagnostics;
    private CacheStats? _marketCacheStats;
    private string? _diagnosticStorageError;
    private const string DiagnosticSnapshotSaveKey = "options-diagnostic-snapshot";

    private static readonly JsonSerializerOptions CompanyPackageJsonOptions = new(JsonSerializerDefaults.Web)
    {
        WriteIndented = true,
        PropertyNameCaseInsensitive = true
    };
    
    // Region to Data Centers mapping
    private static readonly Dictionary<string, List<string>> RegionToDataCenters = new()
    {
        ["North America"] = new() { "Aether", "Primal", "Crystal", "Dynamis" },
        ["Europe"] = new() { "Chaos", "Light" },
        ["Japan"] = new() { "Elemental", "Gaia", "Mana", "Meteor" },
        ["Oceania"] = new() { "Materia" }
    };
    
    protected override async Task OnInitializedAsync()
    {
        _activePanelIndex = InitialPanelIndex;
        _autoSaveEnabled = await Settings.GetAsync("ui.auto_save_enabled", true);
        _defaultDataCenter = await Settings.GetAsync("market.default_datacenter", "Aether") ?? "Aether";
        _selectedRegion = await Settings.GetAsync("market.region", "North America") ?? "North America";
        _defaultMarketFetchScope = ParseMarketFetchScope(
            await Settings.GetAsync("market.default_search_scope", nameof(MarketFetchScope.EntireRegion)));
        _procurementEnableSplitWorldPurchases = await Settings.GetAsync("procurement.enable_split_world_purchases", true);
        _procurementStartFromHomeDataCenter = await Settings.GetAsync("procurement.start_from_home_data_center", false);
        _procurementTravelPriority = ParseTravelPriority(
            await Settings.GetAsync(
                "procurement.travel_priority",
                nameof(MarketTravelPriority.DataCenterTransfersFirst)));
        _marketMafiosoEnabled = await Settings.GetAsync("marketmafioso.enabled", false);
        _marketMafiosoApiUrl = await Settings.GetAsync(
            "marketmafioso.workshop_host_url",
            string.Empty) ?? string.Empty;
        _marketMafiosoApiKey = await Settings.GetAsync("marketmafioso.api_key", string.Empty) ?? string.Empty;
        _marketMafiosoTargetCharacter = await Settings.GetAsync("marketmafioso.target_character", string.Empty) ?? string.Empty;
        _marketMafiosoTargetWorld = await Settings.GetAsync("marketmafioso.target_world", string.Empty) ?? string.Empty;
        _marketMafiosoAutoSyncEvidence = await Settings.GetAsync("marketmafioso.auto_sync_evidence", true);

        await LoadCompanyProfileAsync();
        await LoadProfileHostSettingsAsync();
        if (_activePanelIndex == 6)
        {
            await PrepareDiagnosticSnapshotAsync();
        }
    }

    private async Task TestMarketMafiosoConnectionAsync()
    {
        _marketMafiosoConnectionIsBusy = true;
        _marketMafiosoConnectionTest = null;
        _marketMafiosoConnectionStatus = null;
        _marketMafiosoTestedConfigurationHash = GetMarketMafiosoConfigurationHash();
        try
        {
            _marketMafiosoConnectionTest = await MarketMafiosoAcquisitionWorkflow.TestConnectionAsync(
                _marketMafiosoApiUrl,
                _marketMafiosoApiKey);
            var service = string.IsNullOrWhiteSpace(_marketMafiosoConnectionTest.Service)
                ? "Workshop Host"
                : _marketMafiosoConnectionTest.Service;
            _marketMafiosoConnectionStatus = _marketMafiosoConnectionTest.AcquisitionQueueAvailable
                ? $"Connected to {service}. Market acquisition handoff is ready."
                : $"Connected to {service}, but this instance does not support market acquisition handoff.";
        }
        catch (Exception ex)
        {
            _marketMafiosoConnectionStatus = DescribeMarketMafiosoConnectionFailure(ex);
        }
        finally
        {
            _marketMafiosoConnectionIsBusy = false;
        }
    }

    private bool IsCurrentMarketMafiosoConnectionTest() =>
        _marketMafiosoTestedConfigurationHash == GetMarketMafiosoConfigurationHash();

    private int GetMarketMafiosoConfigurationHash() => HashCode.Combine(
        _marketMafiosoApiUrl.Trim().ToUpperInvariant(),
        _marketMafiosoApiKey.Trim());

    private async Task ForgetMarketMafiosoKey()
    {
        _marketMafiosoApiKey = string.Empty;
        _marketMafiosoConnectionTest = null;
        _marketMafiosoConnectionStatus = string.Empty;
        _marketMafiosoTestedConfigurationHash = null;
        await Settings.SetAsync("marketmafioso.api_key", string.Empty);
        Snackbar.Add("Craft Architect access key forgotten", Severity.Info);
    }

    private async Task OpenMarketMafiosoKeyManagerAsync()
    {
        if (!Uri.TryCreate(_marketMafiosoApiUrl.Trim(), UriKind.Absolute, out var apiUri))
        {
            Snackbar.Add("Enter a valid Workshop Host API URL first", Severity.Warning);
            return;
        }

        var apiSegment = apiUri.AbsolutePath.IndexOf("/api", StringComparison.OrdinalIgnoreCase);
        var dashboardPath = apiSegment < 0
            ? "/settings"
            : $"{apiUri.AbsolutePath[..apiSegment].TrimEnd('/')}/settings";
        var dashboardUri = new UriBuilder(apiUri)
        {
            Path = dashboardPath,
            Query = "tab=authentication",
            Fragment = string.Empty,
        }.Uri;

        await JSRuntime.InvokeVoidAsync("open", dashboardUri.ToString(), "_blank", "noopener,noreferrer");
    }

    private string GetMarketMafiosoConnectionLabel()
    {
        if (!_marketMafiosoEnabled)
            return "Disabled";
        if (!IsCurrentMarketMafiosoConnectionTest())
            return "Not tested";
        if (_marketMafiosoConnectionTest?.AcquisitionQueueAvailable == true)
            return "Ready";
        return _marketMafiosoConnectionTest == null ? "Failed" : "Limited";
    }

    private Color GetMarketMafiosoConnectionColor()
    {
        if (!_marketMafiosoEnabled)
            return Color.Default;
        if (!IsCurrentMarketMafiosoConnectionTest())
            return Color.Secondary;
        if (_marketMafiosoConnectionTest?.AcquisitionQueueAvailable == true)
            return Color.Success;
        return _marketMafiosoConnectionTest == null ? Color.Error : Color.Warning;
    }

    private static string DescribeMarketMafiosoConnectionFailure(Exception exception)
    {
        if (exception is HttpRequestException { StatusCode: System.Net.HttpStatusCode.Unauthorized })
            return "Connection failed: the Workshop Host rejected this client API key.";
        if (exception is HttpRequestException { StatusCode: null })
            return "Connection failed: CA could not reach the Workshop Host. Check the API URL and MarketMafioso__AllowedOrigins__0 when the hosts differ.";
        return $"Connection failed: {exception.Message}";
    }
    
    private List<string> GetAvailableDataCenters()
    {
        return RegionToDataCenters.GetValueOrDefault(_selectedRegion, new List<string> { "Aether" });
    }
    
    private string GetRegionForDataCenter(string dataCenter)
    {
        foreach (var (region, dataCenters) in RegionToDataCenters)
        {
            if (dataCenters.Contains(dataCenter))
                return region;
        }
        return "North America";
    }

    private async Task LoadCompanyProfileAsync()
    {
        _companyIsBusy = true;
        _companyLoadError = null;
        try
        {
            _companyProfile = await TradeOperationsPersistence.GetOrCreateActiveCompanyProfileAsync();
            var crafters = await TradeOperationsPersistence.LoadCraftersAsync(_companyProfile.Id);
            _companyCrafterCount = crafters.Count;
            ApplyCompanyProfileFields(_companyProfile);
        }
        catch (Exception ex)
        {
            _companyProfile = null;
            _companyCrafterCount = 0;
            _companyLoadError = ex.Message;
        }
        finally
        {
            _companyIsBusy = false;
        }
    }

    private void ApplyCompanyProfileFields(TradeCompanyProfile profile)
    {
        _companyName = profile.Name;
        _companyDescription = profile.Description;
        var policy = TradeLaborStandardCalibrationService.NormalizeManagedCobaltRivetsBenchmark(
            profile.PaymentPolicy ?? TradePaymentPolicy.LegacyDefault);
        _companyPaymentContract = policy.ActiveContract;
        _companyLegacyCommissionPercent = policy.LegacyCommissionPercent;
        _companyLaborMaterialBonusPercent = policy.LaborStandardMaterialBonusPercent;

        if (policy.LaborStandard != null)
        {
            _laborStandardName = policy.LaborStandard.Name;
            _laborBenchmarkItemId = policy.LaborStandard.BenchmarkItemId;
            _laborBenchmarkItemName = policy.LaborStandard.BenchmarkItemName;
            _laborBenchmarkQuantity = policy.LaborStandard.BenchmarkQuantity;
            _laborBenchmarkRequiresHq = policy.LaborStandard.BenchmarkRequiresHq;
            _laborBenchmarkPayout = policy.LaborStandard.BenchmarkLaborPayout;
            _laborBenchmarkSynthCount = policy.LaborStandard.BenchmarkSynthCount;
            _useCustomLaborBenchmark = policy.LaborStandard.IsCustomBenchmark;
            _laborBenchmarkCalibratedAtUtc = policy.LaborStandard.CalibratedAtUtc;
            _laborBenchmarkCalibrationEvidence = policy.LaborStandard.CalibrationEvidence;
        }
        else
        {
            RestoreManagedLaborBenchmarkFields(keepCurrentRate: true);
            _laborBenchmarkCalibratedAtUtc = null;
            _laborBenchmarkCalibrationEvidence = null;
            _useCustomLaborBenchmark = false;
        }
    }

    private TradePaymentPolicy? BuildCompanyPaymentPolicy()
    {
        if (_companyLegacyCommissionPercent < 0 || _companyLegacyCommissionPercent > 100)
        {
            Snackbar.Add("Legacy material commission percent must be between 0 and 100.", Severity.Error);
            return null;
        }

        if (_companyLaborMaterialBonusPercent < 0 || _companyLaborMaterialBonusPercent > 100)
        {
            Snackbar.Add("Labor material value bonus percent must be between 0 and 100.", Severity.Error);
            return null;
        }

        var laborStandard = BuildLaborStandard();
        if (_companyPaymentContract == TradePaymentContractMode.LaborStandard && laborStandard == null)
        {
            Snackbar.Add("Labor standard requires a benchmark name, item, payout, and synth count.", Severity.Error);
            return null;
        }

        return new TradePaymentPolicy(
            _companyPaymentContract,
            _companyLegacyCommissionPercent,
            laborStandard)
        {
            LaborStandardMaterialBonusPercent = _companyLaborMaterialBonusPercent
        };
    }

    private TradeLaborStandard? BuildLaborStandard()
    {
        if (string.IsNullOrWhiteSpace(_laborStandardName) ||
            string.IsNullOrWhiteSpace(_laborBenchmarkItemName) ||
            _laborBenchmarkItemId <= 0 ||
            _laborBenchmarkQuantity <= 0 ||
            _laborBenchmarkPayout <= 0 ||
            _laborBenchmarkSynthCount <= 0)
        {
            return null;
        }

        return new TradeLaborStandard(
            _laborStandardName.Trim(),
            _laborBenchmarkItemId,
            _laborBenchmarkItemName.Trim(),
            _laborBenchmarkQuantity,
            _laborBenchmarkRequiresHq,
            _laborBenchmarkPayout,
            _laborBenchmarkSynthCount,
            _laborBenchmarkCalibratedAtUtc ?? DateTime.UtcNow,
            _useCustomLaborBenchmark
                ? TradeLaborBenchmarkMode.Custom
                : TradeLaborBenchmarkMode.CobaltRivets,
            _laborBenchmarkCalibratedAtUtc,
            _laborBenchmarkCalibrationEvidence);
    }

    private string FormatGilPerSynth()
    {
        return _laborBenchmarkSynthCount <= 0
            ? "Unavailable"
            : $"{_laborBenchmarkPayout / _laborBenchmarkSynthCount:N2} gil/synth";
    }

    private void OnCustomLaborBenchmarkChanged(bool useCustomBenchmark)
    {
        _useCustomLaborBenchmark = useCustomBenchmark;
        _laborBenchmarkStatus = null;
        _showLaborBenchmarkPlanPreview = false;
        _laborBenchmarkPlanPreview = null;
        _laborBenchmarkPlanPreviewStatus = null;
        _laborBenchmarkItemSearchResults.Clear();
        if (!useCustomBenchmark)
        {
            RestoreManagedLaborBenchmarkFields(keepCurrentRate: true);
        }
        else
        {
            _laborBenchmarkCalibratedAtUtc = DateTime.UtcNow;
            _laborBenchmarkCalibrationEvidence = "Custom company benchmark.";
            _laborBenchmarkItemSearchQuery = _laborBenchmarkItemName;
        }
    }

    private void RestoreManagedLaborBenchmarkFields(bool keepCurrentRate)
    {
        _laborStandardName = "Cobalt Rivets benchmark";
        _laborBenchmarkItemId = TradeLaborStandardCalibrationService.CobaltRivetsItemId;
        _laborBenchmarkItemName = TradeLaborStandardCalibrationService.CobaltRivetsItemName;
        _laborBenchmarkQuantity = TradeLaborStandardCalibrationService.CobaltRivetsBenchmarkQuantity;
        _laborBenchmarkRequiresHq = TradeLaborStandardCalibrationService.CobaltRivetsBenchmarkRequiresHq;
        if (!keepCurrentRate)
        {
            _laborBenchmarkPayout = 120_000m;
            _laborBenchmarkSynthCount = 200;
        }

        _laborBenchmarkCalibrationEvidence ??= "Managed Cobalt Rivets benchmark.";
    }

