    private HostedProfileConnectionSettings? BuildProfileHostConnectionSettings()
    {
        if (string.IsNullOrWhiteSpace(_profileHostUrl))
        {
            SetProfileHostStatus("Host URL is required.", Color.Error);
            return null;
        }

        if (string.IsNullOrWhiteSpace(_profileHostAccessKey))
        {
            SetProfileHostStatus("Access key is required.", Color.Error);
            return null;
        }

        return new HostedProfileConnectionSettings
        {
            HostUrl = _profileHostUrl.Trim(),
            AccessKey = _profileHostAccessKey.Trim(),
            RememberAccessKey = true,
            ConnectedProfileName = _profileHostProfileName
        };
    }

    private string GetProfileHostConnectionLabel()
    {
        return ProfileSync.CurrentStatus.IsConnected
            ? string.IsNullOrWhiteSpace(_profileHostProfileName) ? "Connected" : _profileHostProfileName
            : "Local only";
    }

    private string GetProfileHostReachabilityLabel()
    {
        if (!ProfileSync.CurrentStatus.IsConnected)
        {
            return "Not connected";
        }

        return ProfileSync.CurrentStatus.HostReachable ? "Reachable" : "Offline";
    }

    private void SetProfileHostStatus(string message, Color color)
    {
        _profileHostStatus = message;
        _profileHostStatusColor = color;
        Snackbar.Add(message, color == Color.Error ? Severity.Error : color == Color.Success ? Severity.Success : Severity.Info);
    }
    
