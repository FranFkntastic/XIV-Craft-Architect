    private string FormatPublishedEvidenceAge()
    {
        var publishedAtUtc = AppState.PublishedMarketAnalysisScope?.PublishedAtUtc;
        if (!publishedAtUtc.HasValue)
        {
            return "Not published";
        }

        var age = DateTime.UtcNow - publishedAtUtc.Value;
        return age.TotalMinutes < 1
            ? "Just now"
            : age.TotalHours < 1
                ? $"{Math.Floor(age.TotalMinutes):N0}m ago"
                : $"{age.TotalHours:F1}h ago";
    }

    private string GetHydrationStatusLabel() => MarketEvidenceHydration.LastRun.Status switch
    {
        MarketEvidenceHydrationStatus.NotNeeded => "Reusable",
        MarketEvidenceHydrationStatus.Running => "Running",
        MarketEvidenceHydrationStatus.Published => "Published",
        MarketEvidenceHydrationStatus.NotPublished => "No publication",
        MarketEvidenceHydrationStatus.Failed => "Failed",
        MarketEvidenceHydrationStatus.Canceled => "Canceled",
        MarketEvidenceHydrationStatus.Superseded => "Superseded",
        _ => "Not run"
    };

    private string GetHydrationStatusClass() => MarketEvidenceHydration.LastRun.Status switch
    {
        MarketEvidenceHydrationStatus.NotNeeded or MarketEvidenceHydrationStatus.Published => "is-good",
        MarketEvidenceHydrationStatus.Running => "is-running",
        MarketEvidenceHydrationStatus.NotPublished or MarketEvidenceHydrationStatus.Failed => "is-bad",
        _ => "is-neutral"
    };

    private string FormatHydrationResult()
    {
        var result = MarketEvidenceHydration.LastRun.Result;
        return result == null
            ? "No result"
            : $"{result.AnalyzedCount:N0} analyzed · {result.FetchedCount:N0} fetched";
    }

    private string FormatHydrationTiming()
    {
        var run = MarketEvidenceHydration.LastRun;
        if (run.Status == MarketEvidenceHydrationStatus.Running && run.StartedAtUtc.HasValue)
        {
            return $"Running {(DateTime.UtcNow - run.StartedAtUtc.Value).TotalSeconds:F1}s";
        }

        return run.Duration.HasValue ? $"{run.Duration.Value.TotalSeconds:F1}s" : "—";
    }

