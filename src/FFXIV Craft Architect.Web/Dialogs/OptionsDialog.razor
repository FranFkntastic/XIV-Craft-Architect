    private string CreateGitHubIssueUrl()
    {
        return GitHubIssueReportService.CreateIssueUrl(new GitHubIssueReportContext(
            WebBuildInfo.BuildVersion,
            WebBuildInfo.BranchName,
            WebBuildInfo.CommitSha,
            AppState.SearchEntireRegion ? AppState.SelectedRegion : AppState.SelectedDataCenter,
