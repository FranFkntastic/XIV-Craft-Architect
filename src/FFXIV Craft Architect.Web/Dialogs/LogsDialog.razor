@using FFXIV_Craft_Architect.Web.Services
@inject AppState AppState
@inject WorkerProjectionStore WorkerProjections

<MudDialog Style="min-width: 600px; max-width: 800px;">
    <DialogContent>
        <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">
            A quick check of the plan and browser storage currently in use.
        </MudText>

        <MudSimpleTable Dense="true" Striped="true">
            <tbody>
                <tr><td>Saved plans</td><td>@AppState.SavedPlans.Count.ToString("N0")</td></tr>
                <tr><td>Data center</td><td>@WorkerProjections.Shell.SelectedDataCenter</td></tr>
                <tr><td>Automatic saving</td><td>@(AppState.IsAutoSaveEnabled ? "Enabled" : "Disabled")</td></tr>
                @if (WorkerProjections.Shell.HasSession)
                {
                    <tr><td>Active plan</td><td>@(WorkerProjections.Shell.PlanName ?? "Unsaved plan")</td></tr>
                    <tr><td>Target items</td><td>@FormatItemCount(WorkerProjections.Shell.ProjectItemCount)</td></tr>
                    <tr><td>Session revision</td><td>@WorkerProjections.Shell.Revision.ToString("N0")</td></tr>
                }
                @if (AppState.LastAutoSave.HasValue)
                {
                    <tr><td>Last automatic save</td><td>@AppState.LastAutoSave.Value.ToString("g")</td></tr>
                }
            </tbody>
        </MudSimpleTable>

        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-4 d-block">
            Technical logs remain available in the browser developer console when troubleshooting is needed.
        </MudText>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Close">Close</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] MudDialogInstance MudDialog { get; set; } = null!;

    private static string FormatItemCount(int count)
    {
        return count == 1 ? "1 item" : $"{count:N0} items";
    }
    
    private void Close()
    {
        MudDialog.Close();
    }
}
