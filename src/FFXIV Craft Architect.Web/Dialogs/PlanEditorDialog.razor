@using System.Globalization
@using FFXIV_Craft_Architect.Core.Helpers
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services

<MudDialog Class="pe-dialog">
    <DialogContent>
        <div class="pe-shell">
            <div class="pe-header">
                <div>
                    <MudText Typo="Typo.caption" Class="pe-muted">
                        Edit a working set of recipe nodes, then apply the changes together.
                    </MudText>
                </div>
                <div class="pe-counts">
                    @_selectedNodeIds.Count selected of @VisibleRows.Count visible
                </div>
            </div>

            <section class="pe-toolbar">
                <label class="pe-field">
                    <span>Show</span>
                    <select class="pe-select" @bind="_filter">
                        <option value="@PlanNodeFilter.All">All nodes</option>
                        <option value="@PlanNodeFilter.LeavesOnly">Leaves only</option>
                        <option value="@PlanNodeFilter.CraftableOnly">Crafts only</option>
                        <option value="@PlanNodeFilter.MarketBuyableOnly">Market-buyable</option>
                        <option value="@PlanNodeFilter.HqCapableOnly">HQ-capable</option>
                    </select>
                </label>

                <div class="pe-selection-actions">
                    <button type="button" class="pe-text-btn" @onclick="SelectVisible">Select visible</button>
                    <button type="button" class="pe-text-btn" @onclick="SelectCurrentSubtree" disabled="@(SelectedNode == null)">
                        Select subtree
                    </button>
                    <button type="button" class="pe-text-btn" @onclick="ClearSelection">Clear</button>
                </div>
            </section>

            <section class="pe-edit-bar">
                <label class="pe-field">
                    <span>Quality</span>
                    <select class="pe-select" @bind="_quality">
                        <option value="@BulkQualitySetting.NoChange">No change</option>
                        <option value="@BulkQualitySetting.RequireHq">Require HQ</option>
                        <option value="@BulkQualitySetting.RequireNq">Require NQ</option>
                    </select>
                </label>

                <label class="pe-field">
                    <span>Acquisition</span>
                    <select class="pe-select" @bind="_sourceValue">
                        <option value="">No change</option>
                        <option value="@AcquisitionSource.Craft">Craft</option>
                        <option value="@AcquisitionSource.MarketBuyNq">Buy NQ</option>
                        <option value="@AcquisitionSource.MarketBuyHq">Buy HQ</option>
                        <option value="@AcquisitionSource.VendorBuy">Vendor</option>
                    </select>
                </label>

                <label class="pe-check-row">
                    <input type="checkbox" @bind="_requireHqMaterials" />
                    <span>Require HQ materials under selected crafts</span>
                </label>
            </section>

            <WebGridTable TItem="PlanNodeEditRow"
                          TColumnId="PlanEditorNodeColumn"
                          CssClass="pe-node-table"
                          Items="@VisibleRows"
                          Columns="@GetNodeColumns()"
                          GetRowKey="row => row.Node.NodeId"
                          GetRowClass="GetNodeRowClass"
                          RowActionLabel="@(row => $"Toggle {row.Node.Name}")"
                          RowActivated="ToggleNodeFromRow" />

            <div class="pe-summary">
                @SummaryText
            </div>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary"
                   Variant="Variant.Filled"
                   Disabled="@(!CanApply)"
                   OnClick="Apply">
            Apply
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public CraftingPlan? CurrentPlan { get; set; }
    [Parameter] public PlanNode? SelectedNode { get; set; }

    private readonly HashSet<string> _selectedNodeIds = new();
    private List<PlanNodeEditRow> _rows = new();
    private PlanNodeFilter _filter = PlanNodeFilter.All;
    private BulkQualitySetting _quality = BulkQualitySetting.NoChange;
    private string _sourceValue = string.Empty;
    private bool _requireHqMaterials;

    private List<PlanNodeEditRow> VisibleRows => PlanBulkEditService.FilterNodes(_rows, _filter).ToList();

    private enum PlanEditorNodeColumn
    {
        Select,
        Item,
        Quantity,
        Quality,
        Source,
        Flags
    }

    private IReadOnlyList<WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>> GetNodeColumns()
    {
        return
        [
            new WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>
            {
                Id = PlanEditorNodeColumn.Select,
                Header = string.Empty,
                Size = new WebTableColumnSize(34, 34),
                Sortable = false,
                SuppressRowActivation = true,
                CellTemplate = row => builder =>
                {
                    builder.OpenElement(0, "input");
                    builder.AddAttribute(1, "type", "checkbox");
                    builder.AddAttribute(2, "checked", _selectedNodeIds.Contains(row.Node.NodeId));
                    builder.AddAttribute(3, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ToggleNode(row.Node.NodeId, args)));
                    builder.CloseElement();
                }
            },
            new WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>
            {
                Id = PlanEditorNodeColumn.Item,
                Header = "Item",
                Size = new WebTableColumnSize(320, 260),
                Sortable = false,
                CellTemplate = row => builder =>
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "pe-node-name");
                    builder.AddAttribute(2, "style", $"padding-left: {(row.Depth * 14).ToString(CultureInfo.InvariantCulture)}px");
                    builder.AddContent(3, row.Node.Name);
                    builder.CloseElement();
                }
            },
            WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>.Text(
                PlanEditorNodeColumn.Quantity,
                "Qty",
                row => $"x{row.Node.Quantity.ToString(CultureInfo.InvariantCulture)}",
                widthPx: 70,
                minWidthPx: 58,
                sortable: false),
            new WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>
            {
                Id = PlanEditorNodeColumn.Quality,
                Header = "HQ",
                Size = new WebTableColumnSize(60, 54),
                Sortable = false,
                CellCssClassSelector = row => row.Node.MustBeHq ? "pe-hq" : "pe-muted-cell",
                CellTemplate = row => builder => builder.AddContent(0, row.Node.MustBeHq ? "HQ" : "NQ")
            },
            new WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>
            {
                Id = PlanEditorNodeColumn.Source,
                Header = "Source",
                Size = new WebTableColumnSize(90, 82),
                Sortable = false,
                CellTemplate = row => builder =>
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "style", $"color: {RecipePlanDisplayHelpers.GetSourceHexColor(row.Node.Source)}");
                    builder.AddContent(2, RecipePlanDisplayHelpers.GetSourceShortName(row.Node.Source));
                    builder.CloseElement();
                }
            },
            new WebTableColumn<PlanNodeEditRow, PlanEditorNodeColumn>
            {
                Id = PlanEditorNodeColumn.Flags,
                Header = "Flags",
                Size = new WebTableColumnSize(210, 150),
                Sortable = false,
                CellTemplate = row => builder =>
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "pe-flags");
                    builder.AddContent(2, GetFlags(row.Node));
                    builder.CloseElement();
                }
            }
        ];
    }

    private static string GetNodeRowClass(PlanNodeEditRow row)
    {
        return "pe-table-row";
    }

    private void ToggleNodeFromRow(PlanNodeEditRow row)
    {
        if (!_selectedNodeIds.Add(row.Node.NodeId))
        {
            _selectedNodeIds.Remove(row.Node.NodeId);
        }
    }

    private bool CanApply =>
        _selectedNodeIds.Any() &&
        (_quality != BulkQualitySetting.NoChange ||
         !string.IsNullOrWhiteSpace(_sourceValue) ||
         _requireHqMaterials);

    private string SummaryText
    {
        get
        {
            if (!_selectedNodeIds.Any())
            {
                return "Select one or more nodes to prepare a bulk edit.";
            }

            var actions = new List<string>();
            if (_quality != BulkQualitySetting.NoChange)
            {
                actions.Add(_quality == BulkQualitySetting.RequireHq ? "quality: HQ" : "quality: NQ");
            }

            if (!string.IsNullOrWhiteSpace(_sourceValue))
            {
                actions.Add($"source: {GetSourceLabel(ParseSource())}");
            }

            if (_requireHqMaterials)
            {
                actions.Add("HQ materials under selected crafts");
            }

            return actions.Any()
                ? $"{_selectedNodeIds.Count} nodes selected. Pending: {string.Join(", ", actions)}."
                : $"{_selectedNodeIds.Count} nodes selected. Choose a bulk edit to apply.";
        }
    }

    protected override void OnInitialized()
    {
        _rows = CurrentPlan != null
            ? PlanBulkEditService.FlattenPlanNodes(CurrentPlan)
            : new List<PlanNodeEditRow>();

        SelectCurrentSubtree();
    }

    private void ToggleNode(string nodeId, ChangeEventArgs args)
    {
        if (args.Value is bool isSelected && isSelected)
        {
            _selectedNodeIds.Add(nodeId);
        }
        else
        {
            _selectedNodeIds.Remove(nodeId);
        }
    }

    private void SelectVisible()
    {
        foreach (var row in VisibleRows)
        {
            _selectedNodeIds.Add(row.Node.NodeId);
        }
    }

    private void SelectCurrentSubtree()
    {
        if (SelectedNode == null)
        {
            return;
        }

        foreach (var node in GetSubtreeNodes(SelectedNode))
        {
            _selectedNodeIds.Add(node.NodeId);
        }
    }

    private void ClearSelection()
    {
        _selectedNodeIds.Clear();
    }

    private void Apply()
    {
        MudDialog.Close(DialogResult.Ok(new PlanEditorResult(
            _selectedNodeIds.ToList(),
            new PlanBulkEditOptions
            {
                Quality = _quality,
                Source = ParseSource()
            },
            _requireHqMaterials)));
    }

    private AcquisitionSource? ParseSource()
    {
        return Enum.TryParse<AcquisitionSource>(_sourceValue, out var source)
            ? source
            : null;
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static IEnumerable<PlanNode> GetSubtreeNodes(PlanNode node)
    {
        yield return node;

        foreach (var child in node.Children)
        {
            foreach (var descendant in GetSubtreeNodes(child))
            {
                yield return descendant;
            }
        }
    }

    private static string GetFlags(PlanNode node)
    {
        var flags = new List<string>();
        if (node.Children.Any())
        {
            flags.Add("craft");
        }

        if (node.CanBuyFromMarket)
        {
            flags.Add("market");
        }

        if (node.CanBuyFromVendor)
        {
            flags.Add("vendor");
        }

        if (node.CanBeHq)
        {
            flags.Add("HQ");
        }

        return flags.Any() ? string.Join(", ", flags) : "-";
    }

    private static string GetSourceLabel(AcquisitionSource? source)
    {
        return source.HasValue
            ? RecipePlanDisplayHelpers.GetSourceDisplayName(source.Value)
            : "No change";
    }

    public sealed record PlanEditorResult(
        List<string> NodeIds,
        PlanBulkEditOptions Options,
        bool RequireHqMaterials);
}
