@using System.Globalization
@using FFXIV_Craft_Architect.Core.Models
@using FFXIV_Craft_Architect.Core.Services
@using Microsoft.AspNetCore.Components.Web
@inject GarlandService GarlandService
@inject ISnackbar Snackbar

<MudDialog Class="pb-dialog">
    <DialogContent>
        <div class="pb-shell">
            <section class="pb-search-panel">
                <div class="pb-panel-header">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="pb-title">Search Items</MudText>
                        <MudText Typo="Typo.caption" Class="pb-muted">Select multiple results and add them at once.</MudText>
                    </div>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="@(!_selectedSearchIds.Any())"
                               OnClick="AddSelectedSearchResults">
                        Add Selected
                    </MudButton>
                </div>

                <div class="pb-search-row">
                    <input class="pb-input"
                           placeholder="Search item name..."
                           value="@_searchQuery"
                           @oninput="OnSearchInput"
                           @onkeyup="OnSearchKeyUp" />
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Primary"
                               Size="Size.Small"
                               Disabled="@(_isSearching || string.IsNullOrWhiteSpace(_searchQuery))"
                               OnClick="SearchAsync">
                        @(_isSearching ? "Searching..." : "Search")
                    </MudButton>
                </div>

                <WebGridTable TItem="GarlandSearchResult"
                              TColumnId="PlanBuilderSearchColumn"
                              CssClass="pb-result-table"
                              Items="@_searchResults"
                              Columns="@GetSearchResultColumns()"
                              GetRowKey="result => result.Id.ToString(CultureInfo.InvariantCulture)"
                              GetRowClass="GetSearchResultRowClass"
                              EmptyContent="RenderSearchEmptyContent" />
            </section>

            <section class="pb-target-panel">
                <div class="pb-panel-header">
                    <div>
                        <MudText Typo="Typo.subtitle1" Class="pb-title">Target Items</MudText>
                        <MudText Typo="Typo.caption" Class="pb-muted">@_draftItems.Count items in this plan draft.</MudText>
                    </div>
                    <div class="pb-action-row">
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(!_selectedTargetIds.Any())" OnClick="() => SetSelectedQuality(true)">HQ</MudButton>
                        <MudButton Variant="Variant.Outlined" Size="Size.Small" Disabled="@(!_selectedTargetIds.Any())" OnClick="() => SetSelectedQuality(false)">NQ</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Disabled="@(!_draftItems.Any())" OnClick="() => SetAllQuality(true)">All HQ</MudButton>
                        <MudButton Variant="Variant.Text" Size="Size.Small" Disabled="@(!_draftItems.Any())" OnClick="() => SetAllQuality(false)">All NQ</MudButton>
                    </div>
                </div>

                <WebGridTable TItem="ProjectItem"
                              TColumnId="PlanBuilderTargetColumn"
                              CssClass="pb-target-table"
                              Items="@_draftItems.OrderBy(item => item.Name).ToList()"
                              Columns="@GetTargetItemColumns()"
                              GetRowKey="item => item.Id.ToString(CultureInfo.InvariantCulture)"
                              GetRowClass="GetTargetItemRowClass"
                              EmptyContent="RenderTargetEmptyContent" />
            </section>
        </div>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Color="Color.Primary" Variant="Variant.Filled" Disabled="@(!_draftItems.Any())" OnClick="Apply">Apply</MudButton>
        <MudButton Color="Color.Success" Variant="Variant.Filled" Disabled="@(!_draftItems.Any())" OnClick="ApplyAndBuild">Apply & Build</MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] public MudDialogInstance MudDialog { get; set; } = null!;
    [Parameter] public IReadOnlyList<ProjectItem> InitialItems { get; set; } = Array.Empty<ProjectItem>();

    private readonly HashSet<int> _selectedSearchIds = new();
    private readonly HashSet<int> _selectedTargetIds = new();
    private readonly Dictionary<int, int> _searchQuantities = new();
    private readonly List<ProjectItem> _draftItems = new();
    private readonly List<GarlandSearchResult> _searchResults = new();
    private string _searchQuery = string.Empty;
    private bool _isSearching;

    private enum PlanBuilderSearchColumn
    {
        Select,
        Item,
        Quantity,
        Type,
        Level,
        Id
    }

    private enum PlanBuilderTargetColumn
    {
        Select,
        Item,
        Quantity,
        Quality,
        Remove
    }

    private IReadOnlyList<WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>> GetSearchResultColumns()
    {
        return
        [
            new WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>
            {
                Id = PlanBuilderSearchColumn.Select,
                Header = string.Empty,
                Size = new WebTableColumnSize(28, 28),
                Sortable = false,
                CellTemplate = result => builder =>
                {
                    var alreadyAdded = IsSearchResultAdded(result.Id);
                    builder.OpenElement(0, "input");
                    builder.AddAttribute(1, "type", "checkbox");
                    builder.AddAttribute(2, "checked", _selectedSearchIds.Contains(result.Id));
                    builder.AddAttribute(3, "disabled", alreadyAdded);
                    builder.AddAttribute(4, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ToggleSearchSelection(result.Id, args)));
                    builder.CloseElement();
                }
            },
            new WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>
            {
                Id = PlanBuilderSearchColumn.Item,
                Header = "Item",
                Size = new WebTableColumnSize(260, 190),
                Sortable = false,
                CellTemplate = result => builder =>
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "pb-primary");
                    builder.AddContent(2, result.Object.Name);
                    builder.CloseElement();
                }
            },
            new WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>
            {
                Id = PlanBuilderSearchColumn.Quantity,
                Header = "Qty",
                Size = new WebTableColumnSize(72, 72),
                Sortable = false,
                CellTemplate = result => builder =>
                {
                    var alreadyAdded = IsSearchResultAdded(result.Id);
                    builder.OpenElement(0, "input");
                    builder.AddAttribute(1, "class", "pb-qty-input");
                    builder.AddAttribute(2, "type", "number");
                    builder.AddAttribute(3, "min", "1");
                    builder.AddAttribute(4, "max", "9999");
                    builder.AddAttribute(5, "value", GetSearchQuantity(result.Id));
                    builder.AddAttribute(6, "disabled", alreadyAdded);
                    builder.AddAttribute(7, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => SetSearchQuantity(result.Id, args)));
                    builder.CloseElement();
                }
            },
            WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>.Text(
                PlanBuilderSearchColumn.Type,
                "Type",
                result => result.Type,
                widthPx: 86,
                minWidthPx: 70,
                sortable: false),
            WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>.Text(
                PlanBuilderSearchColumn.Level,
                "Lvl",
                result => result.Object.Level?.ToString(CultureInfo.InvariantCulture) ?? "-",
                widthPx: 50,
                minWidthPx: 44,
                sortable: false),
            WebTableColumn<GarlandSearchResult, PlanBuilderSearchColumn>.Text(
                PlanBuilderSearchColumn.Id,
                "ID",
                result => result.Id.ToString(CultureInfo.InvariantCulture),
                widthPx: 72,
                minWidthPx: 60,
                sortable: false)
        ];
    }

    private IReadOnlyList<WebTableColumn<ProjectItem, PlanBuilderTargetColumn>> GetTargetItemColumns()
    {
        return
        [
            new WebTableColumn<ProjectItem, PlanBuilderTargetColumn>
            {
                Id = PlanBuilderTargetColumn.Select,
                Header = string.Empty,
                Size = new WebTableColumnSize(28, 28),
                Sortable = false,
                CellTemplate = item => builder =>
                {
                    builder.OpenElement(0, "input");
                    builder.AddAttribute(1, "type", "checkbox");
                    builder.AddAttribute(2, "checked", _selectedTargetIds.Contains(item.Id));
                    builder.AddAttribute(3, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => ToggleTargetSelection(item.Id, args)));
                    builder.CloseElement();
                }
            },
            new WebTableColumn<ProjectItem, PlanBuilderTargetColumn>
            {
                Id = PlanBuilderTargetColumn.Item,
                Header = "Item",
                Size = new WebTableColumnSize(260, 190),
                Sortable = false,
                CellTemplate = item => builder =>
                {
                    builder.OpenElement(0, "span");
                    builder.AddAttribute(1, "class", "pb-primary");
                    builder.AddContent(2, item.Name);
                    builder.CloseElement();
                }
            },
            new WebTableColumn<ProjectItem, PlanBuilderTargetColumn>
            {
                Id = PlanBuilderTargetColumn.Quantity,
                Header = "Qty",
                Size = new WebTableColumnSize(82, 72),
                Sortable = false,
                CellTemplate = item => builder =>
                {
                    builder.OpenElement(0, "input");
                    builder.AddAttribute(1, "class", "pb-qty-input");
                    builder.AddAttribute(2, "type", "number");
                    builder.AddAttribute(3, "min", "1");
                    builder.AddAttribute(4, "max", "9999");
                    builder.AddAttribute(5, "value", item.Quantity);
                    builder.AddAttribute(6, "onchange", EventCallback.Factory.Create<ChangeEventArgs>(this, args => SetQuantity(item, args)));
                    builder.CloseElement();
                }
            },
            new WebTableColumn<ProjectItem, PlanBuilderTargetColumn>
            {
                Id = PlanBuilderTargetColumn.Quality,
                Header = "HQ",
                Size = new WebTableColumnSize(64, 56),
                Sortable = false,
                CellTemplate = item => builder =>
                {
                    builder.OpenElement(0, "button");
                    builder.AddAttribute(1, "class", $"pb-hq-toggle{(item.MustBeHq ? " is-active" : string.Empty)}");
                    builder.AddAttribute(2, "type", "button");
                    builder.AddAttribute(3, "onclick", EventCallback.Factory.Create<MouseEventArgs>(this, () => ToggleQuality(item)));
                    builder.AddContent(4, "HQ");
                    builder.CloseElement();
                }
            },
            new WebTableColumn<ProjectItem, PlanBuilderTargetColumn>
            {
                Id = PlanBuilderTargetColumn.Remove,
                Header = string.Empty,
                Size = new WebTableColumnSize(36, 36),
                Sortable = false,
                CellTemplate = item => builder =>
                {
                    builder.OpenComponent<MudIconButton>(0);
                    builder.AddAttribute(1, "Icon", Icons.Material.Filled.Delete);
                    builder.AddAttribute(2, "Size", Size.Small);
                    builder.AddAttribute(3, "Color", Color.Error);
                    builder.AddAttribute(4, "Title", "Remove item");
                    builder.AddAttribute(5, "OnClick", EventCallback.Factory.Create<MouseEventArgs>(this, () => RemoveItem(item)));
                    builder.CloseComponent();
                }
            }
        ];
    }

    private RenderFragment RenderSearchEmptyContent => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "pb-empty");
        builder.AddContent(2, "Search for items to populate this list.");
        builder.CloseElement();
    };

    private RenderFragment RenderTargetEmptyContent => builder =>
    {
        builder.OpenElement(0, "div");
        builder.AddAttribute(1, "class", "pb-empty");
        builder.AddContent(2, "Add one or more items from search results.");
        builder.CloseElement();
    };

    private bool IsSearchResultAdded(int itemId)
    {
        return _draftItems.Any(item => item.Id == itemId);
    }

    private string GetSearchResultRowClass(GarlandSearchResult result)
    {
        return IsSearchResultAdded(result.Id)
            ? "pb-table-row is-disabled"
            : "pb-table-row";
    }

    private static string GetTargetItemRowClass(ProjectItem item)
    {
        return "pb-table-row";
    }

    protected override void OnInitialized()
    {
        _draftItems.Clear();
        _draftItems.AddRange(InitialItems.Select(CloneProjectItem));
    }

    private async Task SearchAsync()
    {
        if (string.IsNullOrWhiteSpace(_searchQuery) || _isSearching)
        {
            return;
        }

        _isSearching = true;
        _searchResults.Clear();

        try
        {
            var results = await GarlandService.SearchAsync(_searchQuery);
            _searchResults.AddRange(results.Take(75));
            _selectedSearchIds.Clear();
            SyncSearchQuantities();
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Search failed: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isSearching = false;
        }
    }

    private Task OnSearchInput(ChangeEventArgs args)
    {
        _searchQuery = args.Value?.ToString() ?? string.Empty;
        return Task.CompletedTask;
    }

    private async Task OnSearchKeyUp(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            await SearchAsync();
        }
    }

    private void ToggleSearchSelection(int itemId, ChangeEventArgs args)
    {
        SetSelection(_selectedSearchIds, itemId, args);
    }

    private void ToggleTargetSelection(int itemId, ChangeEventArgs args)
    {
        SetSelection(_selectedTargetIds, itemId, args);
    }

    private static void SetSelection(HashSet<int> selections, int itemId, ChangeEventArgs args)
    {
        if (args.Value is bool selected && selected)
        {
            selections.Add(itemId);
            return;
        }

        selections.Remove(itemId);
    }

    private void AddSelectedSearchResults()
    {
        foreach (var result in _searchResults.Where(result => _selectedSearchIds.Contains(result.Id)))
        {
            if (_draftItems.Any(item => item.Id == result.Id))
            {
                continue;
            }

            _draftItems.Add(new ProjectItem
            {
                Id = result.Id,
                Name = result.Object.Name,
                IconId = result.Object.IconId,
                Quantity = GetSearchQuantity(result.Id),
                MustBeHq = false
            });
        }

        _selectedSearchIds.Clear();
    }

    private void SyncSearchQuantities()
    {
        var resultIds = _searchResults.Select(result => result.Id).ToHashSet();
        foreach (var itemId in _searchQuantities.Keys.Where(itemId => !resultIds.Contains(itemId)).ToList())
        {
            _searchQuantities.Remove(itemId);
        }

        foreach (var result in _searchResults)
        {
            _searchQuantities.TryAdd(result.Id, 1);
        }
    }

    private int GetSearchQuantity(int itemId)
    {
        return _searchQuantities.TryGetValue(itemId, out var quantity)
            ? Math.Clamp(quantity, 1, 9999)
            : 1;
    }

    private void SetSearchQuantity(int itemId, ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var quantity))
        {
            _searchQuantities[itemId] = Math.Clamp(quantity, 1, 9999);
        }
    }

    private static void SetQuantity(ProjectItem item, ChangeEventArgs args)
    {
        if (int.TryParse(args.Value?.ToString(), out var quantity))
        {
            item.Quantity = Math.Clamp(quantity, 1, 9999);
        }
    }

    private static void ToggleQuality(ProjectItem item)
    {
        item.MustBeHq = !item.MustBeHq;
    }

    private void SetSelectedQuality(bool mustBeHq)
    {
        foreach (var item in _draftItems.Where(item => _selectedTargetIds.Contains(item.Id)))
        {
            item.MustBeHq = mustBeHq;
        }
    }

    private void SetAllQuality(bool mustBeHq)
    {
        foreach (var item in _draftItems)
        {
            item.MustBeHq = mustBeHq;
        }
    }

    private void RemoveItem(ProjectItem item)
    {
        _draftItems.Remove(item);
        _selectedTargetIds.Remove(item.Id);
    }

    private void Apply()
    {
        MudDialog.Close(DialogResult.Ok(new PlanBuilderResult(
            _draftItems.Select(CloneProjectItem).ToList(),
            BuildAfterApply: false)));
    }

    private void ApplyAndBuild()
    {
        MudDialog.Close(DialogResult.Ok(new PlanBuilderResult(
            _draftItems.Select(CloneProjectItem).ToList(),
            BuildAfterApply: true)));
    }

    private void Cancel()
    {
        MudDialog.Cancel();
    }

    private static ProjectItem CloneProjectItem(ProjectItem item)
    {
        return new ProjectItem
        {
            Id = item.Id,
            Name = item.Name,
            IconId = item.IconId,
            Quantity = item.Quantity,
            MustBeHq = item.MustBeHq
        };
    }

    public sealed record PlanBuilderResult(List<ProjectItem> Items, bool BuildAfterApply);
}
